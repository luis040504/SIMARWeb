### Variables Globales
@hostname = localhost
@port = 5188
@host = http://{{hostname}}:{{port}}

### 1. Registro de Chofer (Caso Exitoso)
# Prueba que el flujo funciona con todos los campos de licencia
POST {{host}}/api/Usuarios/registro-completo
Content-Type: application/json

{
  "email": "chofer_exito@simar.com",
  "username": "chofer_pro",
  "password": "Password123!",
  "nombreCompleto": "Juan Pérez Chofer",
  "curp": "PERJ880101HDFRRN01",
  "rfc": "PERJ880101ABC",
  "direccion": "Calle de las Pruebas 123",
  "rolSeleccionado": "Chofer",
  "salario": 15000,
  "licenseNumber": "LIC-998877",
  "licenseType": "Federal Clase B"
}

