@page
@model ClienteWeb.Pages.WasteCatalog.IndexModel
@{
    ViewData["Title"] = "Catálogo de Residuos";
    int totalPages = Model.Result.TotalCount > 0
        ? (int)Math.Ceiling((double)Model.Result.TotalCount / Model.Result.PageSize)
        : 1;
}

<style>
    :root {
        --simar-green: #5aad31;
        --simar-green-dark: #4a9228;
        --simar-green-light: #e8f5e1;
    }

    .page-header-simar {
        background: linear-gradient(135deg, var(--simar-green) 0%, var(--simar-green-dark) 100%);
        color: white;
        padding: 1.5rem 2rem;
        border-radius: 0 0 1rem 1rem;
        margin-bottom: 1.5rem;
    }

    .btn-simar {
        background-color: var(--simar-green);
        border-color: var(--simar-green);
        color: white;
    }

    .btn-simar:hover {
        background-color: var(--simar-green-dark);
        border-color: var(--simar-green-dark);
        color: white;
    }

    .table-simar thead {
        background-color: var(--simar-green);
        color: white;
    }

    .table-simar tbody tr:hover {
        background-color: var(--simar-green-light);
    }

    .badge-peligroso { background-color: #dc3545; }
    .badge-especial   { background-color: #fd7e14; }

    .cretib-badge {
        font-size: 0.7rem;
        font-weight: 700;
        padding: 2px 5px;
        border-radius: 3px;
        background-color: #dc3545;
        color: white;
        margin: 1px;
        display: inline-block;
    }

    .modal-header-simar {
        background: linear-gradient(135deg, var(--simar-green), var(--simar-green-dark));
        color: white;
    }

    .modal-header-simar .btn-close { filter: invert(1); }

    .filter-bar {
        background: white;
        border-radius: 0.75rem;
        padding: 1rem 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        margin-bottom: 1.25rem;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: #6c757d;
    }

    .empty-state i { font-size: 3.5rem; color: #dee2e6; margin-bottom: 1rem; }
</style>

<!-- Header -->
<div class="page-header-simar">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-0 fw-bold"><i class="bi bi-recycle me-2"></i>Catálogo de Residuos</h2>
            <small class="opacity-75">Residuos peligrosos (RP) y de manejo especial (RME)</small>
        </div>
        <button class="btn btn-light fw-semibold" data-bs-toggle="modal" data-bs-target="#modalCrear">
            <i class="bi bi-plus-circle me-1"></i> Nuevo Residuo
        </button>
    </div>
</div>

<div class="container-fluid px-4">

    <!-- Mensajes -->
    @if (TempData["SuccessMessage"] is string ok)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@ok
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] is string err)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@err
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (Model.ApiError is not null)
    {
        <div class="alert alert-danger alert-dismissible fade show py-2 mb-3" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i> @Model.ApiError
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filtros -->
    <div class="filter-bar">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold mb-1"><i class="bi bi-search me-1"></i>Buscar</label>
                <input type="text" name="Search" value="@Model.Search" class="form-control"
                       placeholder="Nombre o clave del residuo..." />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold mb-1">Tipo</label>
                <select name="TypeFilter" class="form-select">
                    <option value="">Todos</option>
                    <option value="peligroso" selected="@(Model.TypeFilter == "peligroso")">Peligroso (RP)</option>
                    <option value="especial"  selected="@(Model.TypeFilter == "especial")">Manejo Especial (RME)</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-simar">
                    <i class="bi bi-funnel me-1"></i>Filtrar
                </button>
                @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.TypeFilter))
                {
                    <a href="/WasteCatalog" class="btn btn-outline-secondary ms-2">
                        <i class="bi bi-x me-1"></i>Limpiar
                    </a>
                }
            </div>
            @if (Model.HasSearched)
            {
                <div class="col-md-2 text-end text-muted small align-self-center">
                    @Model.Result.TotalCount registro(s)
                </div>
            }
        </form>
    </div>

    <!-- Tabla -->
    @if (!Model.HasSearched)
    {
        <div class="empty-state">
            <i class="bi bi-search d-block"></i>
            <h5>Realiza una búsqueda</h5>
            <p>Escribe una clave o nombre de residuo, o filtra por tipo para ver resultados.</p>
        </div>
    }
    else if (Model.Result.Items.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-inbox-fill d-block"></i>
            <h5>No se encontraron residuos</h5>
            <p>Prueba con otros filtros o agrega un nuevo residuo al catálogo.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-simar mb-0">
                        <thead>
                            <tr>
                                <th>Clave</th>
                                <th>Nombre</th>
                                <th>Tipo</th>
                                <th>Estado Físico</th>
                                <th>Forma de Almacenado</th>
                                <th>CRETIB</th>
                                <th>Unidades</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Result.Items)
                            {
                                <tr>
                                    <td><code class="fw-bold">@item.Code</code></td>
                                    <td>@item.Name</td>
                                    <td>
                                        <span class="badge badge-@item.TypeBadgeCss">@item.TypeLabel</span>
                                    </td>
                                    <td>@(item.PhysicalState ?? "—")</td>
                                    <td>@(item.StorageForm ?? "—")</td>
                                    <td>
                                        @if (item.Type == "peligroso")
                                        {
                                            @if (item.IsCorrosive == true)  { <span class="cretib-badge">C</span> }
                                            @if (item.IsReactive  == true)  { <span class="cretib-badge">R</span> }
                                            @if (item.IsExplosive == true)  { <span class="cretib-badge">E</span> }
                                            @if (item.IsToxic     == true)  { <span class="cretib-badge" style="background:#e67e00">T</span> }
                                            @if (item.IsFlammable == true)  { <span class="cretib-badge" style="background:#e67e00">I</span> }
                                            @if (item.IsBiological== true)  { <span class="cretib-badge" style="background:#6f42c1">B</span> }
                                            @if (item.IsMutagenic == true)  { <span class="cretib-badge" style="background:#6f42c1">M</span> }
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td><small class="text-muted">@item.ValidUnits</small></td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary btn-editar me-1"
                                                data-id="@item.Id"
                                                data-code="@item.Code"
                                                data-name="@item.Name"
                                                data-type="@item.Type"
                                                data-description="@item.Description"
                                                data-corrosive="@item.IsCorrosive"
                                                data-reactive="@item.IsReactive"
                                                data-explosive="@item.IsExplosive"
                                                data-toxic="@item.IsToxic"
                                                data-flammable="@item.IsFlammable"
                                                data-biological="@item.IsBiological"
                                                data-mutagenic="@item.IsMutagenic"
                                                data-physicalstate="@item.PhysicalState"
                                                data-storageform="@item.StorageForm"
                                                data-lgpgir="@item.LgpgirCategory"
                                                data-units="@item.ValidUnits"
                                                title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger btn-eliminar"
                                                data-id="@item.Id"
                                                data-name="@item.Name"
                                                title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Paginación -->
        @if (totalPages > 1)
        {
            <nav>
                <ul class="pagination justify-content-center">
                    @for (int p = 1; p <= totalPages; p++)
                    {
                        <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                            <a class="page-link" asp-page="/WasteCatalog/Index"
                               asp-route-Search="@Model.Search"
                               asp-route-TypeFilter="@Model.TypeFilter"
                               asp-route-PageNumber="@p">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>

<!-- ═══════════════════════════════════ MODAL CREAR ═══════════════════════════════════ -->
<div class="modal fade" id="modalCrear" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header modal-header-simar">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Nuevo Residuo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Search" />
                <input type="hidden" asp-for="TypeFilter" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Clave Regulatoria *</label>
                            <input class="form-control" name="CreateForm.Code" required maxlength="50" placeholder="Ej. RP-SL-01" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Nombre del Residuo *</label>
                            <input class="form-control" name="CreateForm.Name" required maxlength="200" placeholder="Nombre descriptivo del residuo" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Tipo *</label>
                            <select class="form-select" id="createType" name="CreateForm.Type">
                                <option value="peligroso">Peligroso (RP)</option>
                                <option value="especial">Manejo Especial (RME)</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Estado Físico</label>
                            <select class="form-select" name="CreateForm.PhysicalState">
                                <option value="">— Seleccionar —</option>
                                <option value="solido">Sólido</option>
                                <option value="liquido">Líquido</option>
                                <option value="gaseoso">Gaseoso</option>
                                <option value="pastoso">Pastoso</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Forma de Almacenado</label>
                            <input class="form-control" name="CreateForm.StorageForm" maxlength="100" placeholder="Ej. A granel bajo techo" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Descripción</label>
                            <textarea class="form-control" name="CreateForm.Description" rows="2" maxlength="500"></textarea>
                        </div>
                        <!-- CRETIB -->
                        <div class="col-12" id="createCretibSection">
                            <label class="form-label fw-semibold">Características CRETIB</label>
                            <div class="d-flex flex-wrap gap-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="createCorrosive" name="CreateForm.IsCorrosive" value="true" />
                                    <label class="form-check-label" for="createCorrosive"><span class="cretib-badge">C</span> Corrosivo</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="createReactive" name="CreateForm.IsReactive" value="true" />
                                    <label class="form-check-label" for="createReactive"><span class="cretib-badge">R</span> Reactivo</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="createExplosive" name="CreateForm.IsExplosive" value="true" />
                                    <label class="form-check-label" for="createExplosive"><span class="cretib-badge">E</span> Explosivo</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="createToxic" name="CreateForm.IsToxic" value="true" />
                                    <label class="form-check-label" for="createToxic"><span class="cretib-badge" style="background:#e67e00">T</span> Tóxico</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="createFlammable" name="CreateForm.IsFlammable" value="true" />
                                    <label class="form-check-label" for="createFlammable"><span class="cretib-badge" style="background:#e67e00">I</span> Inflamable</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="createBiological" name="CreateForm.IsBiological" value="true" />
                                    <label class="form-check-label" for="createBiological"><span class="cretib-badge" style="background:#6f42c1">B</span> Biológico</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="createMutagenic" name="CreateForm.IsMutagenic" value="true" />
                                    <label class="form-check-label" for="createMutagenic"><span class="cretib-badge" style="background:#6f42c1">M</span> Mutagénico</label>
                                </div>
                            </div>
                        </div>
                        <!-- LGPGIR (solo RME) -->
                        <div class="col-md-6" id="createLgpgirSection" style="display:none">
                            <label class="form-label fw-semibold">Categoría LGPGIR</label>
                            <input class="form-control" name="CreateForm.LgpgirCategory" maxlength="100" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Unidades Válidas *</label>
                            <input class="form-control" name="CreateForm.ValidUnits" required maxlength="50" value="kg" placeholder="kg,ton,lt" />
                            <div class="form-text">Separadas por coma. Ej: kg,ton,lt</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-simar"><i class="bi bi-save me-1"></i>Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════ MODAL EDITAR ══════════════════════════════════ -->
<div class="modal fade" id="modalEditar" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header modal-header-simar">
                <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Editar Residuo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Edit">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="EditId" id="editId" />
                <input type="hidden" asp-for="Search" />
                <input type="hidden" asp-for="TypeFilter" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Clave Regulatoria *</label>
                            <input class="form-control" id="editCode" name="EditForm.Code" required maxlength="50" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Nombre del Residuo *</label>
                            <input class="form-control" id="editName" name="EditForm.Name" required maxlength="200" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Tipo *</label>
                            <select class="form-select" id="editType" name="EditForm.Type" onchange="toggleCretibEdit(this.value)">
                                <option value="peligroso">Peligroso (RP)</option>
                                <option value="especial">Manejo Especial (RME)</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Estado Físico</label>
                            <select class="form-select" id="editPhysicalState" name="EditForm.PhysicalState">
                                <option value="">— Seleccionar —</option>
                                <option value="solido">Sólido</option>
                                <option value="liquido">Líquido</option>
                                <option value="gaseoso">Gaseoso</option>
                                <option value="pastoso">Pastoso</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Forma de Almacenado</label>
                            <input class="form-control" id="editStorageForm" name="EditForm.StorageForm" maxlength="100" placeholder="Ej. A granel bajo techo" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Descripción</label>
                            <textarea class="form-control" id="editDescription" name="EditForm.Description" rows="2" maxlength="500"></textarea>
                        </div>
                        <!-- CRETIB -->
                        <div class="col-12" id="editCretibSection">
                            <label class="form-label fw-semibold">Características CRETIB</label>
                            <div class="d-flex flex-wrap gap-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="editCorrosive" name="EditForm.IsCorrosive" value="true" />
                                    <label class="form-check-label" for="editCorrosive"><span class="cretib-badge">C</span> Corrosivo</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="editReactive" name="EditForm.IsReactive" value="true" />
                                    <label class="form-check-label" for="editReactive"><span class="cretib-badge">R</span> Reactivo</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="editExplosive" name="EditForm.IsExplosive" value="true" />
                                    <label class="form-check-label" for="editExplosive"><span class="cretib-badge">E</span> Explosivo</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="editToxic" name="EditForm.IsToxic" value="true" />
                                    <label class="form-check-label" for="editToxic"><span class="cretib-badge" style="background:#e67e00">T</span> Tóxico</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="editFlammable" name="EditForm.IsFlammable" value="true" />
                                    <label class="form-check-label" for="editFlammable"><span class="cretib-badge" style="background:#e67e00">I</span> Inflamable</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="editBiological" name="EditForm.IsBiological" value="true" />
                                    <label class="form-check-label" for="editBiological"><span class="cretib-badge" style="background:#6f42c1">B</span> Biológico</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="editMutagenic" name="EditForm.IsMutagenic" value="true" />
                                    <label class="form-check-label" for="editMutagenic"><span class="cretib-badge" style="background:#6f42c1">M</span> Mutagénico</label>
                                </div>
                            </div>
                        </div>
                        <!-- LGPGIR (solo RME) -->
                        <div class="col-md-6" id="editLgpgirSection" style="display:none">
                            <label class="form-label fw-semibold">Categoría LGPGIR</label>
                            <input class="form-control" id="editLgpgir" name="EditForm.LgpgirCategory" maxlength="100" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Unidades Válidas *</label>
                            <input class="form-control" id="editUnits" name="EditForm.ValidUnits" required maxlength="50" placeholder="kg,ton,lt" />
                            <div class="form-text">Separadas por coma. Ej: kg,ton,lt</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-simar"><i class="bi bi-save me-1"></i>Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════ MODAL ELIMINAR ════════════════════════════════ -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-trash me-2"></i>Eliminar Residuo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro de que deseas eliminar el residuo <strong id="deleteNombre"></strong>?</p>
                <p class="text-muted small">Esta acción lo desactiva del catálogo (soft delete). No afecta registros históricos.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" asp-page-handler="Delete">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteId" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Editar: poblar modal ──────────────────────────────────────────────────
    document.querySelectorAll('.btn-editar').forEach(btn => {
        btn.addEventListener('click', function () {
            const d = this.dataset;
            document.getElementById('editId').value            = d.id;
            document.getElementById('editCode').value          = d.code;
            document.getElementById('editName').value          = d.name;
            document.getElementById('editType').value          = d.type;
            document.getElementById('editDescription').value   = d.description || '';
            document.getElementById('editPhysicalState').value = d.physicalstate || '';
            document.getElementById('editStorageForm').value   = d.storageform || '';
            document.getElementById('editLgpgir').value        = d.lgpgir || '';
            document.getElementById('editUnits').value         = d.units || 'kg';

            setCheckbox('editCorrosive',  d.corrosive);
            setCheckbox('editReactive',   d.reactive);
            setCheckbox('editExplosive',  d.explosive);
            setCheckbox('editToxic',      d.toxic);
            setCheckbox('editFlammable',  d.flammable);
            setCheckbox('editBiological', d.biological);
            setCheckbox('editMutagenic',  d.mutagenic);

            toggleCretibEdit(d.type);
            new bootstrap.Modal(document.getElementById('modalEditar')).show();
        });
    });

    function setCheckbox(id, val) {
        document.getElementById(id).checked = (val === 'True' || val === 'true');
    }

    function toggleCretibEdit(type) {
        const cretib = document.getElementById('editCretibSection');
        const lgpgir = document.getElementById('editLgpgirSection');
        cretib.style.display = type === 'peligroso' ? '' : 'none';
        lgpgir.style.display = type === 'especial'  ? '' : 'none';
    }

    // ── Eliminar: poblar modal ────────────────────────────────────────────────
    document.querySelectorAll('.btn-eliminar').forEach(btn => {
        btn.addEventListener('click', function () {
            document.getElementById('deleteId').value    = this.dataset.id;
            document.getElementById('deleteNombre').textContent = this.dataset.name;
            new bootstrap.Modal(document.getElementById('modalEliminar')).show();
        });
    });

    // ── Crear: toggle CRETIB / LGPGIR ────────────────────────────────────────
    const createType = document.getElementById('createType');
    if (createType) {
        createType.addEventListener('change', function () {
            const v = this.value;
            document.getElementById('createCretibSection').style.display = v === 'peligroso' ? '' : 'none';
            document.getElementById('createLgpgirSection').style.display = v === 'especial'  ? '' : 'none';
        });
    }
</script>
}
