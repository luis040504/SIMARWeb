@page
@model ClienteWeb.Pages.Recolecciones.IndexModel
@{
    ViewData["Title"] = "Programación de Recolecciones - SIMAR";
}

<style>
    :root {
        --simar-green: #5aad31;
        --simar-dark: #4a4a4a;
        --simar-gray-light: #f8f9fa;
        --simar-border: #e9ecef;
    }
    * { font-family: 'Inter', sans-serif; }
    
    select, select option, .form-select, .form-select option {
        color: #000000 !important;
        background-color: #ffffff !important;
    }
    
    .filter-section {
        background: white; border-radius: 20px; padding: 1.5rem; margin-bottom: 1.5rem;
        border: 1px solid var(--simar-border); box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }
    .table-custom {
        background: white; border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }
    .table-custom thead th {
        background: var(--simar-gray-light); color: var(--simar-dark); font-weight: 600;
        font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px;
        border-bottom: 2px solid var(--simar-green); padding: 0.75rem;
    }
    .table-custom tbody td {
        padding: 0.75rem; vertical-align: middle; border-bottom: 1px solid var(--simar-border);
        font-size: 0.85rem; color: var(--simar-dark);
    }
    .table-custom tbody tr:hover { background: rgba(90,173,49,0.03); }
    
    .badge-estado {
        padding: 0.3rem 0.7rem; border-radius: 30px; font-size: 0.7rem; font-weight: 600;
        display: inline-block;
    }
    .badge-programada { background: rgba(108,117,125,0.15); color: #6c757d; }
    .badge-completada { background: rgba(40,167,69,0.15); color: #28a745; }
    .badge-cancelada { background: rgba(220,53,69,0.15); color: #dc3545; }
    .badge-enruta { background: rgba(255,193,7,0.15); color: #e6a700; }
    
    .btn-simar-outline {
        background: transparent; border: 1px solid var(--simar-green); color: var(--simar-green);
        border-radius: 10px; padding: 0.5rem 1.2rem; transition: all 0.2s; font-weight: 500;
    }
    .btn-simar-outline:hover { background: var(--simar-green); color: white; }
    .btn-simar-primary {
        background: var(--simar-green); border: none; color: white;
        border-radius: 10px; padding: 0.5rem 1.2rem; transition: all 0.2s; font-weight: 500;
    }
    .btn-simar-primary:hover { background: #3d7a1f; }
    .btn-simar-danger {
        background: #dc3545; border: none; color: white;
        border-radius: 10px; padding: 0.3rem 0.8rem; font-size: 0.8rem;
    }
    .form-label { font-weight: 500; font-size: 0.8rem; color: var(--simar-dark); margin-bottom: 0.2rem; }
    .form-control, .form-select {
        border-radius: 10px; border: 1px solid var(--simar-border);
        padding: 0.45rem 0.7rem; font-size: 0.85rem;
        color: #000000 !important;
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--simar-green); box-shadow: 0 0 0 2px rgba(90,173,49,0.2);
    }
    .modal-content { border-radius: 20px; border: none; }
    .modal-header { border-bottom: 2px solid var(--simar-green); padding: 1rem 1.5rem; }
    .modal-footer { border-top: 1px solid var(--simar-border); padding: 1rem 1.5rem; }
    .modal-scrollable { max-height: 60vh; overflow-y: auto; }
    
    .vehiculo-asignado-card {
        background: var(--simar-gray-light); border-radius: 12px; padding: 1rem;
        margin-bottom: 0.75rem; border: 1px solid var(--simar-border);
    }
    .vehiculo-asignado-card select,
    .vehiculo-asignado-card option {
        color: #000000 !important;
    }
    .empty-state {
        text-align: center; padding: 4rem 2rem; background: white;
        border-radius: 20px; border: 1px solid var(--simar-border);
    }
    .container-fluid-custom { width: 100%; padding-right: 1rem; padding-left: 1rem; }
    .table-responsive-custom { 
        overflow-x: auto; 
        border-radius: 16px; 
    }
    
    /* ✅ Checkboxes de técnicos */
    .tecnicos-checkboxes {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
    }
    .tecnico-check-label {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.75rem;
        cursor: pointer;
        padding: 0.2rem 0.5rem;
        border-radius: 15px;
        border: 1px solid var(--simar-border);
        background: white;
        transition: all 0.15s;
        white-space: nowrap;
    }
    .tecnico-check-label:hover {
        border-color: var(--simar-green);
        background: rgba(90,173,49,0.05);
    }
    .tecnico-check-label input:checked + span {
        color: var(--simar-green);
        font-weight: 600;
    }
    .tecnico-check-label:has(input:checked) {
        border-color: var(--simar-green);
        background: rgba(90,173,49,0.1);
    }
</style>

<div class="container-fluid-custom">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-semibold" style="color: var(--simar-dark);">
                <i class="bi bi-truck me-2" style="color: var(--simar-green);"></i>
                Programación de Recolecciones
            </h2>
            <p class="text-muted small mb-0">Gestión de servicios por contrato</p>
        </div>
        <button class="btn-simar-primary" data-bs-toggle="modal" data-bs-target="#modalCreate" onclick="prepararModalCreate()">
            <i class="bi bi-plus-lg me-2"></i>Nueva Recolección
        </button>
    </div>

    <!-- Filtros -->
    <div class="filter-section">
        <h6 class="mb-3"><i class="bi bi-funnel me-2" style="color: var(--simar-green);"></i>Filtros</h6>
        <form method="get" class="row g-2">
            <div class="col-md-2">
                <label class="form-label">Contrato #</label>
                <input type="number" name="FiltroIdContrato" class="form-control" placeholder="ID Contrato" value="@Model.FiltroIdContrato">
            </div>
            <div class="col-md-2">
                <label class="form-label">Cliente</label>
                <input type="text" name="FiltroCliente" class="form-control" placeholder="Buscar cliente" value="@Model.FiltroCliente">
            </div>
            <div class="col-md-2">
                <label class="form-label">Desde</label>
                <input type="date" name="FiltroFechaInicio" class="form-control" value="@(Model.FiltroFechaInicio?.ToString("yyyy-MM-dd"))">
            </div>
            <div class="col-md-2">
                <label class="form-label">Hasta</label>
                <input type="date" name="FiltroFechaFin" class="form-control" value="@(Model.FiltroFechaFin?.ToString("yyyy-MM-dd"))">
            </div>
            <div class="col-md-2">
                <label class="form-label">Estado</label>
                <select name="FiltroEstado" class="form-select">
                    <option value="">Todos</option>
                    <option value="Programada" selected="@(Model.FiltroEstado == "Programada")">Programada</option>
                    <option value="En ruta" selected="@(Model.FiltroEstado == "En ruta")">En ruta</option>
                    <option value="Completada" selected="@(Model.FiltroEstado == "Completada")">Completada</option>
                    <option value="Cancelada" selected="@(Model.FiltroEstado == "Cancelada")">Cancelada</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn-simar-outline w-100"><i class="bi bi-search"></i></button>
                <a asp-page="Index" class="btn-simar-outline w-100"><i class="bi bi-x-circle"></i></a>
            </div>
        </form>
    </div>

    <!-- Tabla -->
    @if (!Model.Recolecciones.Any())
    {
        <div class="empty-state">
            <i class="bi bi-calendar-x" style="font-size:4rem;color:var(--simar-green);opacity:0.5;"></i>
            <h4>No hay recolecciones</h4>
            <p class="text-muted">Programa una nueva recolección</p>
        </div>
    }
    else
    {
        <div class="table-responsive-custom">
            <table class="table-custom w-100">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Contrato</th>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th>Dirección</th>
                        <th>Vehículo(s)</th>
                        <th>Chofer</th>
                        <th>Estado</th>
                        <th style="width:70px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Recolecciones)
                    {
                        <tr>
                            <td class="text-muted small">@item.Id.Substring(0, 8)...</td>
                            <td><span class="badge bg-dark">#@item.IdContrato</span></td>
                            <td>
                                <strong>@item.Cliente</strong>
                                <br><small class="text-muted">#@item.ManifestNumber</small>
                                @if (!string.IsNullOrEmpty(item.TipoResiduo))
                                {
                                    <br><small class="text-success">@item.TipoResiduo</small>
                                }
                            </td>
                            <td>
                                @item.Fecha.ToString("dd/MM/yyyy")
                                <br><small class="text-muted">@item.Fecha.ToString("HH:mm")</small>
                            </td>
                            <td>
                                <span class="text-truncate d-inline-block" style="max-width:150px;" title="@item.Direccion">
                                    @item.Direccion
                                </span>
                            </td>
                            <td>
                                @foreach (var v in item.Vehiculos)
                                {
                                    <span class="badge bg-light text-dark me-1">@v.Vehiculo</span>
                                }
                            </td>
                            <td>@item.ChoferPrincipal</td>
                            <td>
                                @{
                                    string badgeClass = "badge-estado";
                                    if (item.Estado == "Completada") badgeClass += " badge-completada";
                                    else if (item.Estado == "Cancelada") badgeClass += " badge-cancelada";
                                    else if (item.Estado == "En ruta") badgeClass += " badge-enruta";
                                    else badgeClass += " badge-programada";
                                }
                                <span class="@badgeClass">@item.Estado</span>
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm rounded-circle" style="border:1px solid var(--simar-border);width:32px;height:32px;background:white;" 
                                            type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport" aria-expanded="false">
                                        <i class="bi bi-three-dots-vertical" style="color:#4a4a4a;"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-lg" style="min-width:160px;">
                                        <li>
                                            <button class="dropdown-item btn-details" type="button"
                                                    data-id="@item.Id" data-idcontrato="@item.IdContrato"
                                                    data-cliente="@item.Cliente" data-fecha="@item.Fecha.ToString("yyyy-MM-ddTHH:mm")"
                                                    data-direccion="@item.Direccion" data-estado="@item.Estado"
                                                    data-tiporesiduo="@item.TipoResiduo" data-cantidad="@item.CantidadEstimada"
                                                    data-observaciones="@item.Observaciones">
                                                <i class="bi bi-eye me-2"></i>Ver detalles
                                            </button>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <button class="dropdown-item text-danger btn-delete" type="button"
                                                    data-id="@item.Id" data-cliente="@item.Cliente"
                                                    data-fecha="@item.Fecha.ToString("dd/MM/yyyy")">
                                                <i class="bi bi-trash me-2"></i>Eliminar
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Modal Create -->
<div class="modal fade" id="modalCreate" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Nueva Recolección</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="formCreate" method="post" asp-page-handler="Create">
                @Html.AntiForgeryToken()
                <div class="modal-body modal-scrollable">
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-file-earmark-text me-1"></i>Contrato *</label>
                            <select name="idContrato" class="form-select" id="createIdContrato" required>
                                <option value="">Seleccionar contrato</option>
                                @foreach (var c in Model.Contratos)
                                {
                                    <option value="@c.Id">#@c.Id - @c.Folio - @c.Cliente</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-person me-1"></i>Cliente *</label>
                            <input type="text" name="cliente" class="form-control" id="createCliente" placeholder="Seleccione un contrato" required readonly>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label"><i class="bi bi-calendar me-1"></i>Fecha y hora *</label>
                            <input type="datetime-local" name="fecha" class="form-control" id="createFecha" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><i class="bi bi-trash me-1"></i>Tipo de residuo</label>
                            <select name="tipoResiduo" class="form-select" id="createTipoResiduo">
                                <option value="">Seleccionar</option>
                                <option value="Residuos Peligrosos">Peligrosos</option>
                                <option value="Residuos Biológicos">Biológicos</option>
                                <option value="Residuos Reciclables">Reciclables</option>
                                <option value="Residuos de Construcción">Construcción</option>
                                <option value="Residuos Orgánicos">Orgánicos</option>
                                <option value="Residuos Electrónicos">Electrónicos</option>
                                <option value="Residuos Industriales">Industriales</option>
                                <option value="Residuos Varios">Varios</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><i class="bi bi-speedometer2 me-1"></i>Cantidad (ton)</label>
                            <input type="number" step="0.1" name="cantidadEstimada" class="form-control" id="createCantidad" placeholder="Ej: 5.5">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><i class="bi bi-geo-alt me-1"></i>Dirección *</label>
                        <input type="text" name="direccion" class="form-control" id="createDireccion" placeholder="Calle, número, colonia, ciudad" required>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label fw-bold mb-0"><i class="bi bi-truck-front me-1"></i>Vehículos asignados *</label>
                            <button type="button" class="btn btn-sm btn-simar-outline" onclick="agregarVehiculoCreate()">
                                <i class="bi bi-plus"></i> Agregar vehículo
                            </button>
                        </div>
                        <div id="listaVehiculosCreate"></div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label"><i class="bi bi-chat-text me-1"></i>Observaciones</label>
                            <textarea name="observaciones" class="form-control" id="createObservaciones" rows="2" placeholder="Instrucciones especiales..."></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><i class="bi bi-tag me-1"></i>Estado</label>
                            <select name="estado" class="form-select" id="createEstado">
                                <option value="Programada">Programada</option>
                                <option value="En ruta">En ruta</option>
                                <option value="Completada">Completada</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-simar-outline" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-simar-primary"><i class="bi bi-check-lg"></i> Programar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Details -->
<div class="modal fade" id="modalDetails" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-info-circle me-2"></i>Detalles de Recolección</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3"><label class="text-muted small">ID</label><p class="fw-semibold" id="detailsId"></p></div>
                        <div class="mb-3"><label class="text-muted small">Contrato</label><p class="fw-semibold">#<span id="detailsIdContrato"></span></p></div>
                        <div class="mb-3"><label class="text-muted small">Cliente</label><p class="fw-semibold" id="detailsCliente"></p></div>
                        <div class="mb-3"><label class="text-muted small">Fecha y hora</label><p id="detailsFecha"></p></div>
                        <div class="mb-3"><label class="text-muted small">Dirección</label><p id="detailsDireccion"></p></div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3"><label class="text-muted small">Estado</label><p id="detailsEstado"></p></div>
                        <div class="mb-3"><label class="text-muted small">Tipo de residuo</label><p id="detailsTipoResiduo"></p></div>
                        <div class="mb-3"><label class="text-muted small">Cantidad estimada</label><p id="detailsCantidad"></p></div>
                        <div class="mb-3"><label class="text-muted small">Observaciones</label><p id="detailsObservaciones" class="fst-italic"></p></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-simar-outline" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Delete -->
<div class="modal fade" id="modalDelete" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirmar eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning mb-3" style="background: rgba(255,193,7,0.1); border: 1px solid #ffc107;">
                    <i class="bi bi-exclamation-circle me-2"></i>Esta acción no se puede deshacer.
                </div>
                <p>¿Estás seguro de eliminar esta recolección?</p>
                <div class="card bg-light">
                    <div class="card-body">
                        <p class="mb-1"><strong>Cliente:</strong> <span id="deleteCliente"></span></p>
                        <p class="mb-0"><strong>Fecha:</strong> <span id="deleteFecha"></span></p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-simar-outline" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn-simar-danger" id="confirmDelete"><i class="bi bi-trash"></i> Eliminar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ============ DATOS DESDE SERVIDOR ============
        const vehiculosDisponibles = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Vehiculos.Select(v => new { 
                valor = $"{v.Marca} {v.Modelo} - {v.Placas}", 
                texto = $"{v.Marca} {v.Modelo} ({v.Placas})" 
            })
        ));
        const choferesDisponibles = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Choferes.Select(c => c.FullName)
        ));
        const tecnicosDisponibles = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Tecnicos.Select(t => t.FullName)
        ));

        // ============ TOAST ============
        @if (Model.SuccessMessage != null) { <text>showToast('@Model.SuccessMessage', 'success');</text> }
        @if (Model.ErrorMessage != null) { <text>showToast('@Model.ErrorMessage', 'error');</text> }
        function showToast(msg, type) {
            const d = document.createElement('div');
            d.style.cssText = `position:fixed;top:20px;right:20px;z-index:9999;background:${type==='success'?'#5aad31':'#dc3545'};color:white;padding:15px 20px;border-radius:10px;box-shadow:0 5px 15px rgba(0,0,0,0.2);`;
            d.innerHTML = msg; document.body.appendChild(d);
            setTimeout(() => d.remove(), 3500);
        }

        // ============ VEHÍCULOS DINÁMICOS ============
        let contadorVehiculosCreate = 0;

        function prepararModalCreate() {
            contadorVehiculosCreate = 0;
            document.getElementById('listaVehiculosCreate').innerHTML = '';
            agregarVehiculoCreate();
        }

        function agregarVehiculoCreate() {
            const idx = contadorVehiculosCreate++;
            const div = document.createElement('div');
            div.className = 'vehiculo-asignado-card';
            
            const vehiculosOptions = vehiculosDisponibles.map(v => 
                `<option value="${v.valor}">${v.texto}</option>`
            ).join('');
            
            const choferesOptions = choferesDisponibles.map(c => 
                `<option value="${c}">${c}</option>`
            ).join('');

            // ✅ Checkboxes para técnicos
            const tecnicosCheckboxes = tecnicosDisponibles.length > 0 
                ? tecnicosDisponibles.map((t, i) => `
                    <label class="tecnico-check-label">
                        <input type="checkbox" name="vehiculos[${idx}].tecnicos" value="${t}" class="form-check-input" style="width:14px;height:14px;margin:0;">
                        <span>${t}</span>
                    </label>
                `).join('')
                : '<small class="text-muted">No hay técnicos disponibles</small>';

            div.innerHTML = `
                <div class="d-flex justify-content-end mb-2">
                    <button type="button" class="btn btn-sm btn-danger" onclick="this.closest('.vehiculo-asignado-card').remove()" title="Quitar vehículo">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label class="form-label small">Vehículo *</label>
                        <select name="vehiculos[${idx}].vehiculo" class="form-select form-select-sm" required>
                            <option value="">Seleccionar vehículo</option>
                            ${vehiculosOptions}
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Chofer *</label>
                        <select name="vehiculos[${idx}].chofer" class="form-select form-select-sm" required>
                            <option value="">Seleccionar chofer</option>
                            ${choferesOptions}
                        </select>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label small">Técnicos (selecciona los que apliquen)</label>
                        <div class="tecnicos-checkboxes" id="tecnicos-${idx}">
                            ${tecnicosCheckboxes}
                        </div>
                        <small class="text-muted mt-1">Máx. 3 técnicos por vehículo</small>
                    </div>
                </div>`;
            
            // Validar máximo 3 técnicos
            const checkboxes = div.querySelectorAll('input[type="checkbox"]');
            checkboxes.forEach(cb => {
                cb.addEventListener('change', function() {
                    const checked = div.querySelectorAll('input[type="checkbox"]:checked');
                    if (checked.length > 3) {
                        this.checked = false;
                        showToast('Máximo 3 técnicos por vehículo', 'error');
                    }
                });
            });

            document.getElementById('listaVehiculosCreate').appendChild(div);
        }

        // Auto-completar cliente
        document.getElementById('createIdContrato')?.addEventListener('change', function() {
            const selected = this.options[this.selectedIndex];
            const text = selected.text;
            const match = text.match(/- (.+)$/);
            document.getElementById('createCliente').value = match ? match[1] : '';
        });

        // ============ DETALLES ============
        document.querySelectorAll('.btn-details').forEach(btn => {
            btn.addEventListener('click', function() {
                document.getElementById('detailsId').textContent = this.dataset.id?.substring(0, 12) + '...';
                document.getElementById('detailsIdContrato').textContent = this.dataset.idcontrato || 'N/A';
                document.getElementById('detailsCliente').textContent = this.dataset.cliente || 'No especificado';
                document.getElementById('detailsFecha').textContent = this.dataset.fecha ? new Date(this.dataset.fecha).toLocaleString('es-MX', { dateStyle: 'long', timeStyle: 'short' }) : 'N/A';
                document.getElementById('detailsDireccion').textContent = this.dataset.direccion || 'No especificada';
                document.getElementById('detailsEstado').textContent = this.dataset.estado || 'N/A';
                document.getElementById('detailsTipoResiduo').textContent = this.dataset.tiporesiduo || 'No especificado';
                document.getElementById('detailsCantidad').textContent = this.dataset.cantidad ? parseFloat(this.dataset.cantidad).toFixed(1) + ' ton' : 'N/A';
                document.getElementById('detailsObservaciones').textContent = this.dataset.observaciones || 'Sin observaciones';
                new bootstrap.Modal(document.getElementById('modalDetails')).show();
            });
        });

        // ============ ELIMINAR ============
        let recoleccionAEliminar = null;
        document.querySelectorAll('.btn-delete').forEach(btn => {
            btn.addEventListener('click', function() {
                recoleccionAEliminar = { id: this.dataset.id };
                document.getElementById('deleteCliente').textContent = this.dataset.cliente || 'No especificado';
                document.getElementById('deleteFecha').textContent = this.dataset.fecha || 'N/A';
                new bootstrap.Modal(document.getElementById('modalDelete')).show();
            });
        });
        document.getElementById('confirmDelete')?.addEventListener('click', function() {
            if (recoleccionAEliminar) {
                const form = document.createElement('form');
                form.method = 'post';
                form.action = `?handler=Delete&id=${recoleccionAEliminar.id}`;
                const token = document.querySelector('input[name="__RequestVerificationToken"]');
                if (token) form.innerHTML += `<input type="hidden" name="__RequestVerificationToken" value="${token.value}">`;
                document.body.appendChild(form);
                form.submit();
            }
        });

        document.getElementById('modalCreate')?.addEventListener('hidden.bs.modal', function() {
            document.getElementById('formCreate').reset();
            document.getElementById('listaVehiculosCreate').innerHTML = '';
            document.getElementById('createCliente').value = '';
        });
    </script>
}