@page
@model ClienteWeb.Pages.Recolecciones.IndexModel
@{
    ViewData["Title"] = "Programación de Recolecciones - SIMAR";
}

<style>
    /* Unificación de estilos con el layout */
    :root {
        --simar-green: #5aad31;
        --simar-dark: #4a4a4a;
        --simar-gray-light: #f8f9fa;
        --simar-border: #e9ecef;
    }
    
    * {
        font-family: 'Inter', sans-serif;
    }
    
    /* Sección de filtros */
    .filter-section {
        background: white;
        border-radius: 20px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        border: 1px solid var(--simar-border);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
    }
    
    .filter-section h6 {
        color: var(--simar-dark);
        font-weight: 600;
    }
    
    /* Tabla mejorada */
    .table-custom {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
    }
    
    .table-custom thead th {
        background: var(--simar-gray-light);
        color: var(--simar-dark);
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 2px solid var(--simar-green);
        padding: 1rem;
    }
    
    .table-custom tbody td {
        padding: 1rem;
        vertical-align: middle;
        border-bottom: 1px solid var(--simar-border);
    }
    
    .table-custom tbody tr:hover {
        background: rgba(90, 173, 49, 0.03);
    }
    
    /* Badges de estado */
    .badge-estado {
        padding: 0.35rem 0.85rem;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-block;
    }
    
    .badge-programada {
        background: rgba(108, 117, 125, 0.15);
        color: #6c757d;
        border-left: 3px solid #6c757d;
    }
    
    .badge-completada {
        background: rgba(40, 167, 69, 0.15);
        color: #28a745;
        border-left: 3px solid #28a745;
    }
    
    .badge-cancelada {
        background: rgba(220, 53, 69, 0.15);
        color: #dc3545;
        border-left: 3px solid #dc3545;
    }
    
    .badge-enruta {
        background: rgba(255, 193, 7, 0.15);
        color: #e6a700;
        border-left: 3px solid #ffc107;
    }
    
    /* Botones */
    .btn-simar-outline {
        background: transparent;
        border: 1px solid var(--simar-green);
        color: var(--simar-green);
        border-radius: 10px;
        padding: 0.5rem 1.2rem;
        transition: all 0.2s;
        font-weight: 500;
        font-size: 0.9rem;
    }
    
    .btn-simar-outline:hover {
        background: var(--simar-green);
        color: white;
        transform: translateY(-2px);
    }
    
    .btn-simar-primary {
        background: var(--simar-green);
        border: none;
        color: white;
        border-radius: 10px;
        padding: 0.5rem 1.2rem;
        transition: all 0.2s;
        font-weight: 500;
    }
    
    .btn-simar-primary:hover {
        background: #3d7a1f;
        transform: translateY(-2px);
    }
    
    .btn-simar-secondary {
        background: var(--simar-dark);
        border: none;
        color: white;
        border-radius: 10px;
        padding: 0.5rem 1.2rem;
        transition: all 0.2s;
        font-weight: 500;
    }
    
    .btn-simar-secondary:hover {
        background: #3a3a3a;
        transform: translateY(-2px);
    }
    
    /* Campos de formulario */
    .form-label {
        font-weight: 500;
        font-size: 0.85rem;
        color: var(--simar-dark);
        margin-bottom: 0.3rem;
    }
    
    .form-control, .form-select {
        border-radius: 10px;
        border: 1px solid var(--simar-border);
        padding: 0.5rem 0.8rem;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    
    .form-control:focus, .form-select:focus {
        border-color: var(--simar-green);
        box-shadow: 0 0 0 2px rgba(90, 173, 49, 0.2);
    }
    
    /* Modales */
    .modal-content {
        border-radius: 20px;
        border: none;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }
    
    .modal-header {
        border-bottom: 2px solid var(--simar-green);
        background: white;
        border-radius: 20px 20px 0 0;
        padding: 1.2rem 1.5rem;
    }
    
    .modal-header .modal-title {
        color: var(--simar-dark);
        font-weight: 600;
    }
    
    .modal-header .modal-title i {
        color: var(--simar-green);
    }
    
    .modal-footer {
        border-top: 1px solid var(--simar-border);
        padding: 1rem 1.5rem;
    }
    
    .modal-scrollable {
        max-height: 65vh;
        overflow-y: auto;
        padding-right: 0.5rem;
    }
    
    .modal-scrollable::-webkit-scrollbar {
        width: 4px;
    }
    
    .modal-scrollable::-webkit-scrollbar-track {
        background: var(--simar-border);
        border-radius: 4px;
    }
    
    .modal-scrollable::-webkit-scrollbar-thumb {
        background: var(--simar-green);
        border-radius: 4px;
    }
    
    /* Dropdown */
    .dropdown-menu {
        border-radius: 12px;
        border: 1px solid var(--simar-border);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    }
    
    .dropdown-item:hover {
        background: rgba(90, 173, 49, 0.1);
        color: var(--simar-green);
    }
    
    .dropdown-item.text-danger:hover {
        background: rgba(220, 53, 69, 0.1);
        color: #dc3545;
    }
    
    /* Estado vacío */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 20px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
        border: 1px solid var(--simar-border);
    }
    
    .empty-state i {
        font-size: 4rem;
        color: var(--simar-green);
        opacity: 0.5;
        margin-bottom: 1rem;
    }
    
    /* Ajuste de contenedor */
    .container-fluid-custom {
        width: 100%;
        padding-right: 1rem;
        padding-left: 1rem;
    }
    
    /* Tabla responsiva */
    .table-responsive-custom {
        overflow-x: auto;
        border-radius: 16px;
    }
</style>

<div class="container-fluid-custom">
    <!-- Header de la página -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-semibold" style="color: var(--simar-dark);">
                <i class="bi bi-truck me-2" style="color: var(--simar-green);"></i>
                Programación de Recolecciones
            </h2>
            <p class="text-muted small mb-0">Gestión de rutas y servicios programados</p>
        </div>
        
        <button class="btn-simar-primary" data-bs-toggle="modal" data-bs-target="#modalCreate">
            <i class="bi bi-plus-lg me-2"></i>Nueva Recolección
        </button>
    </div>
    
    <!-- Sección de Filtros -->
    <div class="filter-section">
        <h6 class="mb-3">
            <i class="bi bi-funnel me-2" style="color: var(--simar-green);"></i>Filtros de búsqueda
        </h6>
        
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label"><i class="bi bi-person me-1"></i>Cliente</label>
                <input type="text" name="FiltroCliente" class="form-control" placeholder="Buscar por cliente" value="@Model.FiltroCliente">
            </div>
            
            <div class="col-md-2">
                <label class="form-label"><i class="bi bi-calendar me-1"></i>Fecha inicio</label>
                <input type="date" name="FiltroFechaInicio" class="form-control" value="@(Model.FiltroFechaInicio?.ToString("yyyy-MM-dd"))">
            </div>
            
            <div class="col-md-2">
                <label class="form-label"><i class="bi bi-calendar me-1"></i>Fecha fin</label>
                <input type="date" name="FiltroFechaFin" class="form-control" value="@(Model.FiltroFechaFin?.ToString("yyyy-MM-dd"))">
            </div>
            
            <div class="col-md-2">
                <label class="form-label"><i class="bi bi-truck-front me-1"></i>Vehículo</label>
                <input type="text" name="FiltroVehiculo" class="form-control" placeholder="Ej: Kenworth" value="@Model.FiltroVehiculo">
            </div>
            
            <div class="col-md-2">
                <label class="form-label"><i class="bi bi-person-badge me-1"></i>Técnico</label>
                <input type="text" name="FiltroTecnico" class="form-control" placeholder="Nombre técnico" value="@Model.FiltroTecnico">
            </div>
            
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn-simar-outline w-100">
                    <i class="bi bi-search"></i>
                </button>
            </div>
            
            @if (!string.IsNullOrEmpty(Model.FiltroCliente) || Model.FiltroFechaInicio.HasValue || 
                 Model.FiltroFechaFin.HasValue || !string.IsNullOrEmpty(Model.FiltroVehiculo) || 
                 !string.IsNullOrEmpty(Model.FiltroTecnico))
            {
                <div class="col-12 text-end">
                    <a asp-page="Index" class="btn-simar-outline btn-sm">
                        <i class="bi bi-x-circle me-1"></i> Limpiar filtros
                    </a>
                </div>
            }
        </form>
    </div>
    
    <!-- Tabla de Recolecciones -->
    @if (!Model.Recolecciones.Any())
    {
        <div class="empty-state">
            <i class="bi bi-calendar-x"></i>
            <h4 class="text-secondary">No hay recolecciones programadas</h4>
            <p class="text-muted">Comienza programando una nueva recolección</p>
            <button class="btn-simar-primary mt-3" data-bs-toggle="modal" data-bs-target="#modalCreate">
                <i class="bi bi-plus-lg"></i> Programar Recolección
            </button>
        </div>
    }
    else
    {
        <div class="table-responsive-custom">
            <table class="table-custom w-100">
                <thead>
                    <tr>
                        <th>#</th>
                        <th><i class="bi bi-person me-1"></i>Cliente</th>
                        <th><i class="bi bi-calendar me-1"></i>Fecha</th>
                        <th><i class="bi bi-geo-alt me-1"></i>Dirección</th>
                        <th><i class="bi bi-truck-front me-1"></i>Vehículo</th>
                        <th><i class="bi bi-person-badge me-1"></i>Técnico</th>
                        <th><i class="bi bi-tag me-1"></i>Estado</th>
                        <th><i class="bi bi-three-dots me-1"></i>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Recolecciones)
                    {
                        <tr>
                            <td class="fw-light">@item.Id</td>
                            <td>
                                <strong>@item.Cliente</strong>
                                @if (!string.IsNullOrEmpty(item.TipoResiduo))
                                {
                                    <br><small class="text-muted">@item.TipoResiduo</small>
                                }
                            </td>
                            <td>
                                <span class="fw-semibold">@item.Fecha.ToString("dd/MM/yyyy")</span>
                                <br><small class="text-muted">@item.Fecha.ToString("HH:mm") hrs</small>
                            </td>
                            <td>
                                <span class="text-truncate d-inline-block" style="max-width: 200px;" title="@item.Direccion">
                                    @item.Direccion
                                </span>
                            </td>
                            <td>
                                <span class="fw-light">@item.Vehiculo</span>
                                @if (item.CantidadEstimada.HasValue)
                                {
                                    <br><small class="text-muted">@item.CantidadEstimada.Value.ToString("N1") ton</small>
                                }
                            </td>
                            <td>@item.Tecnico</td>
                            <td>
                                @{
                                    string badgeClass = "badge-estado";
                                    if (item.Estado == "Completada") badgeClass += " badge-completada";
                                    else if (item.Estado == "Cancelada") badgeClass += " badge-cancelada";
                                    else if (item.Estado == "En ruta") badgeClass += " badge-enruta";
                                    else badgeClass += " badge-programada";
                                }
                                <span class="@badgeClass">
                                    @item.Estado
                                </span>
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm rounded-circle" style="background: transparent; border: 1px solid var(--simar-border); width: 32px; height: 32px;" type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <button class="dropdown-item btn-edit" 
                                                    data-id="@item.Id"
                                                    data-cliente="@item.Cliente"
                                                    data-fecha="@item.Fecha.ToString("yyyy-MM-ddTHH:mm")"
                                                    data-direccion="@item.Direccion"
                                                    data-vehiculo="@item.Vehiculo"
                                                    data-tecnico="@item.Tecnico"
                                                    data-observaciones="@item.Observaciones"
                                                    data-tiporesiduo="@item.TipoResiduo"
                                                    data-cantidad="@item.CantidadEstimada"
                                                    data-estado="@item.Estado">
                                                <i class="bi bi-pencil me-2"></i>Editar
                                            </button>
                                        </li>
                                        <li>
                                            <button class="dropdown-item btn-details"
                                                    data-id="@item.Id"
                                                    data-cliente="@item.Cliente"
                                                    data-fecha="@item.Fecha.ToString("yyyy-MM-ddTHH:mm")"
                                                    data-direccion="@item.Direccion"
                                                    data-vehiculo="@item.Vehiculo"
                                                    data-tecnico="@item.Tecnico"
                                                    data-observaciones="@item.Observaciones"
                                                    data-tiporesiduo="@item.TipoResiduo"
                                                    data-cantidad="@item.CantidadEstimada"
                                                    data-estado="@item.Estado">
                                                <i class="bi bi-eye me-2"></i>Ver detalles
                                            </button>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <button class="dropdown-item text-danger btn-delete"
                                                    data-id="@item.Id"
                                                    data-cliente="@item.Cliente"
                                                    data-fecha="@item.Fecha.ToString("dd/MM/yyyy")">
                                                <i class="bi bi-trash me-2"></i>Eliminar
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="d-flex justify-content-between align-items-center mt-3">
            <small class="text-muted">
                <i class="bi bi-info-circle me-1"></i>Mostrando @Model.Recolecciones.Count recolecciones
            </small>
        </div>
    }
</div>

<!-- ==================== MODALES ==================== -->

<!-- Modal Create -->
<div class="modal fade" id="modalCreate" tabindex="-1" aria-labelledby="modalCreateLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalCreateLabel">
                    <i class="bi bi-plus-circle me-2"></i>Programar Nueva Recolección
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form id="formCreate" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body modal-scrollable">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-person me-1"></i> Cliente *</label>
                            <select name="Cliente" class="form-select" id="createCliente" required>
                                <option value="">Seleccionar cliente</option>
                                @foreach (var cliente in Model.Clientes)
                                {
                                    <option value="@cliente.Nombre">@cliente.Nombre</option>
                                }
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-calendar me-1"></i> Fecha y hora *</label>
                            <input type="datetime-local" name="Fecha" class="form-control" id="createFecha" required>
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-geo-alt me-1"></i> Dirección *</label>
                            <input type="text" name="Direccion" class="form-control" id="createDireccion" placeholder="Calle, número, colonia, ciudad" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-truck-front me-1"></i> Vehículo *</label>
                            <select name="Vehiculo" class="form-select" id="createVehiculo" required>
                                <option value="">Seleccionar vehículo</option>
                                @foreach (var vehiculo in Model.Vehiculos)
                                {
                                    <option value="@vehiculo.Nombre - @vehiculo.Placas">@vehiculo.Nombre (@vehiculo.Placas)</option>
                                }
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-person-badge me-1"></i> Técnico *</label>
                            <select name="Tecnico" class="form-select" id="createTecnico" required>
                                <option value="">Seleccionar técnico</option>
                                @foreach (var tecnico in Model.Tecnicos)
                                {
                                    <option value="@tecnico.Nombre">@tecnico.Nombre</option>
                                }
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-trash me-1"></i> Tipo de residuo</label>
                            <select name="TipoResiduo" class="form-select" id="createTipoResiduo">
                                <option value="">Seleccionar tipo</option>
                                <option value="Peligrosos">Peligrosos</option>
                                <option value="Biológicos">Biológicos</option>
                                <option value="Reciclables">Reciclables (papel, cartón)</option>
                                <option value="Orgánicos">Orgánicos</option>
                                <option value="Construcción">Construcción</option>
                                <option value="Electrónicos">Electrónicos</option>
                                <option value="Industriales">Industriales</option>
                                <option value="Varios">Varios</option>
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-speedometer2 me-1"></i> Cantidad estimada (ton)</label>
                            <input type="number" step="0.1" name="CantidadEstimada" class="form-control" id="createCantidad" placeholder="Ej: 5.5">
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-chat-text me-1"></i> Observaciones</label>
                            <textarea name="Observaciones" class="form-control" id="createObservaciones" rows="2" placeholder="Instrucciones especiales, tipo de contenedor, etc."></textarea>
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-tag me-1"></i> Estado</label>
                            <select name="Estado" class="form-select" id="createEstado">
                                <option value="Programada">Programada</option>
                                <option value="En ruta">En ruta</option>
                                <option value="Completada">Completada</option>
                                <option value="Cancelada">Cancelada</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-simar-outline" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-simar-primary">
                        <i class="bi bi-check-lg"></i> Programar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Edit -->
<div class="modal fade" id="modalEdit" tabindex="-1" aria-labelledby="modalEditLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalEditLabel">
                    <i class="bi bi-pencil-square me-2"></i>Editar Recolección
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form id="formEdit" method="post">
                <input type="hidden" name="Id" id="editId">
                @Html.AntiForgeryToken()
                <div class="modal-body modal-scrollable">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-person me-1"></i> Cliente *</label>
                            <select name="Cliente" class="form-select" id="editCliente" required>
                                <option value="">Seleccionar cliente</option>
                                @foreach (var cliente in Model.Clientes)
                                {
                                    <option value="@cliente.Nombre">@cliente.Nombre</option>
                                }
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-calendar me-1"></i> Fecha y hora *</label>
                            <input type="datetime-local" name="Fecha" class="form-control" id="editFecha" required>
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-geo-alt me-1"></i> Dirección *</label>
                            <input type="text" name="Direccion" class="form-control" id="editDireccion" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-truck-front me-1"></i> Vehículo *</label>
                            <select name="Vehiculo" class="form-select" id="editVehiculo" required>
                                <option value="">Seleccionar vehículo</option>
                                @foreach (var vehiculo in Model.Vehiculos)
                                {
                                    <option value="@vehiculo.Nombre - @vehiculo.Placas">@vehiculo.Nombre (@vehiculo.Placas)</option>
                                }
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-person-badge me-1"></i> Técnico *</label>
                            <select name="Tecnico" class="form-select" id="editTecnico" required>
                                <option value="">Seleccionar técnico</option>
                                @foreach (var tecnico in Model.Tecnicos)
                                {
                                    <option value="@tecnico.Nombre">@tecnico.Nombre</option>
                                }
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-trash me-1"></i> Tipo de residuo</label>
                            <select name="TipoResiduo" class="form-select" id="editTipoResiduo">
                                <option value="">Seleccionar tipo</option>
                                <option value="Peligrosos">Peligrosos</option>
                                <option value="Biológicos">Biológicos</option>
                                <option value="Reciclables">Reciclables (papel, cartón)</option>
                                <option value="Orgánicos">Orgánicos</option>
                                <option value="Construcción">Construcción</option>
                                <option value="Electrónicos">Electrónicos</option>
                                <option value="Industriales">Industriales</option>
                                <option value="Varios">Varios</option>
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-speedometer2 me-1"></i> Cantidad estimada (ton)</label>
                            <input type="number" step="0.1" name="CantidadEstimada" class="form-control" id="editCantidad" placeholder="Ej: 5.5">
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-chat-text me-1"></i> Observaciones</label>
                            <textarea name="Observaciones" class="form-control" id="editObservaciones" rows="2"></textarea>
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-tag me-1"></i> Estado</label>
                            <select name="Estado" class="form-select" id="editEstado">
                                <option value="Programada">Programada</option>
                                <option value="En ruta">En ruta</option>
                                <option value="Completada">Completada</option>
                                <option value="Cancelada">Cancelada</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-simar-outline" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-simar-primary">
                        <i class="bi bi-check-lg"></i> Guardar cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Details -->
<div class="modal fade" id="modalDetails" tabindex="-1" aria-labelledby="modalDetailsLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalDetailsLabel">
                    <i class="bi bi-info-circle me-2"></i>Detalles de la Recolección
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="fw-semibold mb-3">Información general</h6>
                        
                        <div class="mb-3">
                            <label class="text-muted small mb-1">ID de recolección</label>
                            <p class="fw-semibold" id="detailsId"></p>
                        </div>
                        
                        <div class="mb-3">
                            <label class="text-muted small mb-1"><i class="bi bi-person me-1"></i>Cliente</label>
                            <p class="fw-semibold" id="detailsCliente"></p>
                        </div>
                        
                        <div class="mb-3">
                            <label class="text-muted small mb-1"><i class="bi bi-calendar me-1"></i>Fecha y hora</label>
                            <p class="fw-semibold" id="detailsFecha"></p>
                        </div>
                        
                        <div class="mb-3">
                            <label class="text-muted small mb-1"><i class="bi bi-geo-alt me-1"></i>Dirección</label>
                            <p id="detailsDireccion"></p>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <h6 class="fw-semibold mb-3">Asignación</h6>
                        
                        <div class="mb-3">
                            <label class="text-muted small mb-1"><i class="bi bi-truck-front me-1"></i>Vehículo</label>
                            <p class="fw-semibold" id="detailsVehiculo"></p>
                        </div>
                        
                        <div class="mb-3">
                            <label class="text-muted small mb-1"><i class="bi bi-person-badge me-1"></i>Técnico</label>
                            <p class="fw-semibold" id="detailsTecnico"></p>
                        </div>
                        
                        <h6 class="fw-semibold mb-3 mt-4">Detalles de la carga</h6>
                        
                        <div class="mb-3">
                            <label class="text-muted small mb-1"><i class="bi bi-trash me-1"></i>Tipo de residuo</label>
                            <p id="detailsTipoResiduo"></p>
                        </div>
                        
                        <div class="mb-3">
                            <label class="text-muted small mb-1"><i class="bi bi-speedometer2 me-1"></i>Cantidad estimada</label>
                            <p id="detailsCantidad"></p>
                        </div>
                        
                        <div class="mb-3">
                            <label class="text-muted small mb-1"><i class="bi bi-tag me-1"></i>Estado</label>
                            <p id="detailsEstado"></p>
                        </div>
                    </div>
                    
                    <div class="col-12">
                        <div class="mb-3">
                            <label class="text-muted small mb-1"><i class="bi bi-chat-text me-1"></i>Observaciones</label>
                            <p id="detailsObservaciones" class="fst-italic"></p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-simar-outline" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn-simar-primary" id="btnEditFromDetails">
                    <i class="bi bi-pencil"></i> Editar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Delete -->
<div class="modal fade" id="modalDelete" tabindex="-1" aria-labelledby="modalDeleteLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalDeleteLabel">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirmar eliminación
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning mb-3" style="background: rgba(90, 173, 49, 0.1); border: 1px solid var(--simar-green); color: var(--simar-dark);">
                    <i class="bi bi-exclamation-circle me-2"></i> Esta acción no se puede deshacer.
                </div>
                <p>¿Estás seguro de que quieres eliminar esta recolección?</p>
                <div class="card mb-3 bg-light">
                    <div class="card-body">
                        <h6 id="deleteRecoleccionInfo"></h6>
                        <p class="mb-1"><strong>Cliente:</strong> <span id="deleteCliente"></span></p>
                        <p class="mb-0"><strong>Fecha:</strong> <span id="deleteFecha"></span></p>
                        <p class="mb-0"><strong>ID:</strong> <span id="deleteId"></span></p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-simar-outline" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cancelar
                </button>
                <button type="button" class="btn-simar-primary" id="confirmDelete">
                    <i class="bi bi-trash"></i> Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Variables globales
        let recoleccionAEliminar = null;

        // ========== MANEJO DE EDIT ==========
        document.querySelectorAll('.btn-edit').forEach(btn => {
            btn.addEventListener('click', function () {
                document.getElementById('editId').value = this.dataset.id;
                document.getElementById('editCliente').value = this.dataset.cliente || '';
                document.getElementById('editFecha').value = this.dataset.fecha || '';
                document.getElementById('editDireccion').value = this.dataset.direccion || '';
                document.getElementById('editVehiculo').value = this.dataset.vehiculo || '';
                document.getElementById('editTecnico').value = this.dataset.tecnico || '';
                document.getElementById('editTipoResiduo').value = this.dataset.tiporesiduo || '';
                document.getElementById('editCantidad').value = this.dataset.cantidad || '';
                document.getElementById('editObservaciones').value = this.dataset.observaciones || '';
                document.getElementById('editEstado').value = this.dataset.estado || 'Programada';
                
                const modal = new bootstrap.Modal(document.getElementById('modalEdit'));
                modal.show();
            });
        });

        // ========== MANEJO DE DETAILS ==========
        document.querySelectorAll('.btn-details').forEach(btn => {
            btn.addEventListener('click', function () {
                document.getElementById('detailsId').textContent = this.dataset.id;
                document.getElementById('detailsCliente').textContent = this.dataset.cliente || 'No especificado';
                
                const fechaRaw = this.dataset.fecha;
                if (fechaRaw) {
                    const fecha = new Date(fechaRaw);
                    const opciones = { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
                    document.getElementById('detailsFecha').textContent = fecha.toLocaleDateString('es-MX', opciones);
                } else {
                    document.getElementById('detailsFecha').textContent = 'No especificada';
                }
                
                document.getElementById('detailsDireccion').textContent = this.dataset.direccion || 'No especificada';
                document.getElementById('detailsVehiculo').textContent = this.dataset.vehiculo || 'No asignado';
                document.getElementById('detailsTecnico').textContent = this.dataset.tecnico || 'No asignado';
                document.getElementById('detailsTipoResiduo').textContent = this.dataset.tiporesiduo || 'No especificado';
                
                const cantidad = this.dataset.cantidad;
                document.getElementById('detailsCantidad').textContent = cantidad ? `${parseFloat(cantidad).toFixed(1)} toneladas` : 'No especificada';
                
                document.getElementById('detailsEstado').textContent = this.dataset.estado || 'Programada';
                document.getElementById('detailsObservaciones').textContent = this.dataset.observaciones || 'Sin observaciones';
                
                const modal = new bootstrap.Modal(document.getElementById('modalDetails'));
                modal.show();
            });
        });

        // Botón para editar desde detalles
        document.getElementById('btnEditFromDetails')?.addEventListener('click', function() {
            const id = document.getElementById('detailsId').textContent;
            if (id && id !== 'No especificado') {
                const btnEdit = document.querySelector(`.btn-edit[data-id="${id}"]`);
                if (btnEdit) btnEdit.click();
                bootstrap.Modal.getInstance(document.getElementById('modalDetails')).hide();
            }
        });

        // ========== MANEJO DE DELETE ==========
        document.querySelectorAll('.btn-delete').forEach(btn => {
            btn.addEventListener('click', function () {
                recoleccionAEliminar = {
                    id: this.dataset.id,
                    cliente: this.dataset.cliente || 'No especificado',
                    fecha: this.dataset.fecha || 'No especificada'
                };
                
                document.getElementById('deleteId').textContent = recoleccionAEliminar.id;
                document.getElementById('deleteCliente').textContent = recoleccionAEliminar.cliente;
                document.getElementById('deleteFecha').textContent = recoleccionAEliminar.fecha;
                document.getElementById('deleteRecoleccionInfo').textContent = `Recolección #${recoleccionAEliminar.id} - ${recoleccionAEliminar.cliente}`;
                
                const modal = new bootstrap.Modal(document.getElementById('modalDelete'));
                modal.show();
            });
        });

        // Confirmar eliminación
        document.getElementById('confirmDelete')?.addEventListener('click', function() {
            if (recoleccionAEliminar) {
                alert(`Recolección #${recoleccionAEliminar.id} eliminada (simulado)`);
                bootstrap.Modal.getInstance(document.getElementById('modalDelete')).hide();
            }
        });

        // Validar fechas en filtros
        const fechaInicio = document.querySelector('input[name="FiltroFechaInicio"]');
        const fechaFin = document.querySelector('input[name="FiltroFechaFin"]');
        
        if (fechaInicio && fechaFin) {
            fechaInicio.addEventListener('change', function() {
                fechaFin.min = this.value;
            });
        }

        // Limpiar formularios al cerrar modales
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('hidden.bs.modal', function () {
                const forms = this.querySelectorAll('form');
                forms.forEach(form => form.reset());
            });
        });

        // Prevenir envío de formularios (simulación)
        document.querySelectorAll('form').forEach(form => {
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                alert('Funcionalidad simulada - Los datos no se guardarán realmente');
                const modal = this.closest('.modal');
                if (modal) bootstrap.Modal.getInstance(modal).hide();
            });
        });
    </script>
}