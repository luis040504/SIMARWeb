@page "/Manifest/Generate/SpecialWaste"
@model ClienteWeb.Pages.Manifest.Generate.SpecialWasteModel
@{
    ViewData["Title"] = "Generate Manifest - Special Waste";
}

<style>
    .manifest-container {
        max-width: 960px;
        margin: 0 auto;
        padding: 1.5rem 1rem;
    }

    .manifest-header {
        border-bottom: 2px solid #1a3a5c;
        padding-bottom: 0.75rem;
    }

    .brand-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a3a5c;
        margin: 0;
    }

    .brand-logo { height: 48px; }

    .manifest-title {
        font-size: 0.85rem;
        font-weight: 700;
        color: #1a3a5c;
        text-transform: uppercase;
        line-height: 1.4;
    }

    .manifest-number-box {
        border: 2px solid #1a3a5c;
        padding: 4px 12px;
        font-size: 1rem;
        font-weight: 700;
        color: #1a3a5c;
        border-radius: 4px;
        margin-top: 4px;
    }

    .section-card {
        border: 1px solid #c8d6e3;
        border-radius: 6px;
        padding: 1rem 1.25rem;
        position: relative;
        padding-left: 3.5rem;
        background: #fafcff;
    }

    .section-label {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 2.5rem;
        background: #1a3a5c;
        color: #fff;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        writing-mode: vertical-rl;
        text-orientation: mixed;
        transform: rotate(180deg);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px 0 0 6px;
    }

    .subsection-title {
        font-size: 0.8rem;
        font-weight: 700;
        color: #1a3a5c;
        text-transform: uppercase;
        border-bottom: 1px solid #c8d6e3;
        padding-bottom: 4px;
        margin-bottom: 8px;
    }

    .form-label-sm {
        font-size: 0.75rem;
        font-weight: 600;
        color: #4a5568;
        margin-bottom: 2px;
        display: block;
    }

    .manifest-table th {
        font-size: 0.72rem;
        white-space: nowrap;
        background-color: #e8f0f8;
        color: #1a3a5c;
    }

    .manifest-table td {
        vertical-align: middle;
        padding: 3px 4px;
    }
</style>


<div class="manifest-container">

    <!-- Header -->
    <div class="manifest-header d-flex justify-content-between align-items-start mb-3">
        <div class="brand-block">
            <img src="~/images/simar-logo.png" alt="SIMAR" class="brand-logo" onerror="this.style.display='none'" />
            <h2 class="brand-title">SIMAR</h2>
        </div>
        <div class="manifest-title-block text-center flex-grow-1 px-4">
            <h5 class="manifest-title">
                MANIFIESTO DE GENERADOR, TRANSPORTE Y DISPOSICIÓN FINAL,<br />
                TRATAMIENTO O REUTILIZACIÓN DE RESIDUOS DE MANEJO ESPECIAL
            </h5>
        </div>
        <div class="manifest-num-block text-end">
            <small class="text-muted">No. de Manifiesto</small>
            <div class="manifest-number-box">
                <span asp-for="ManifestNumber" class="fw-bold">@Model.ManifestNumber</span>
            </div>
        </div>
    </div>

    <form method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="section-card">
            <div class="section-label">GENERADOR</div>

            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label class="form-label-sm">No. de Registro SEDEMA</label>
                    <input asp-for="EnvironmentalRegistrationNumber"
                           class="form-control form-control-sm"
                           placeholder="Ej. SEDEMA/DRME-CH0990/20EX8-17/182" />
                    <span asp-validation-for="EnvironmentalRegistrationNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label class="form-label-sm">Razón Social</label>
                    <input asp-for="SocialReason"
                           class="form-control form-control-sm"
                           placeholder="Nombre o razón social del generador" />
                    <span asp-validation-for="SocialReason" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-md-6">
                    <label class="form-label-sm">Domicilio</label>
                    <input asp-for="Address"
                           class="form-control form-control-sm"
                           placeholder="Calle, número, colonia" />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label class="form-label-sm">C.P.</label>
                    <input asp-for="PostalCode"
                           class="form-control form-control-sm"
                           placeholder="00000" />
                </div>
                <div class="col-md-4">
                    <label class="form-label-sm">Municipio</label>
                    <input asp-for="Municipality"
                           class="form-control form-control-sm"
                           placeholder="Municipio" />
                </div>
            </div>

            <div class="row g-2 mb-3">
                <div class="col-md-4">
                    <label class="form-label-sm">Teléfono</label>
                    <input asp-for="PhoneNumber"
                           class="form-control form-control-sm"
                           placeholder="Ej. 2288326510" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label-sm">Fecha</label>
                    <input asp-for="ManifestDate" type="date"
                           class="form-control form-control-sm" />
                </div>
                <div class="col-md-4">
                    <label class="form-label-sm">Hora</label>
                    <input asp-for="ManifestTime" type="time"
                           class="form-control form-control-sm" />
                </div>
            </div>

            <!-- Tabla de residuos -->
            <h6 class="subsection-title">Identificación de los Residuos</h6>
            <div class="table-responsive mb-2">
                <table class="table table-bordered table-sm manifest-table">
                    <thead class="table-light">
                        <tr>
                            <th>Clave del Residuo</th>
                            <th>Tipo / Nombre del Residuo</th>
                            <th colspan="2" class="text-center">Envase</th>
                            <th colspan="2" class="text-center">Peso y Unidad</th>
                        </tr>
                        <tr>
                            <th></th>
                            <th></th>
                            <th>Tipo</th>
                            <th>Capacidad</th>
                            <th>Cantidad</th>
                            <th>Unidad</th>
                        </tr>
                    </thead>
                    <tbody id="residues-body">
                        @for (int i = 0; i < Model.Residues.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input asp-for="Residues[i].ResidueKey"
                                           class="form-control form-control-sm"
                                           placeholder="RS-001" />
                                </td>
                                <td>
                                    <input asp-for="Residues[i].ResidueName"
                                           class="form-control form-control-sm"
                                           placeholder="Nombre del residuo" />
                                </td>
                                <td>
                                    <input asp-for="Residues[i].Container"
                                           class="form-control form-control-sm"
                                           placeholder="OF / DF" />
                                </td>
                                <td>
                                    <input asp-for="Residues[i].ContainerCapacity"
                                           class="form-control form-control-sm"
                                           placeholder="N/A" />
                                </td>
                                <td>
                                    <input asp-for="Residues[i].Amount" type="number" step="0.01"
                                           class="form-control form-control-sm"
                                           placeholder="0.00" />
                                </td>
                                <td>
                                    <select asp-for="Residues[i].Unit" class="form-select form-select-sm">
                                        <option value="kg">kg</option>
                                        <option value="ton">ton</option>
                                        <option value="lt">lt</option>
                                        <option value="m3">m³</option>
                                        <option value="pza">pza</option>
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm mb-3" onclick="addResidueRow()">
                + Agregar residuo
            </button>

            <!-- Observaciones -->
            <div class="mb-2">
                <label class="form-label-sm">Observaciones</label>
                <textarea asp-for="GeneratorObservations" class="form-control form-control-sm" rows="2"
                          placeholder="Observaciones del generador..."></textarea>
            </div>

            <!-- Marco regulatorio -->
            <div class="mb-2">
                <label class="form-label-sm">Marco Regulatorio / Descripción</label>
                <textarea asp-for="RegulatoryFramework" class="form-control form-control-sm" rows="2"
                          placeholder="Marco regulatorio aplicable..."></textarea>
            </div>

            <!-- Firma generador -->
            <div class="row g-2 mt-1">
                <div class="col-md-6">
                    <label class="form-label-sm">Nombre del Responsable</label>
                    <input asp-for="GeneratorResponsibleName"
                           class="form-control form-control-sm"
                           placeholder="Nombre completo" />
                </div>
                <div class="col-md-3">
                    <label class="form-label-sm">Firma (imagen)</label>
                    <input type="file" name="SignedManifestFile" accept="image/*,.pdf"
                           class="form-control form-control-sm" />
                </div>
                <div class="col-md-3">
                    <label class="form-label-sm">Correo electrónico</label>
                    <input asp-for="Email"
                           class="form-control form-control-sm"
                           placeholder="correo@empresa.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <!-- ===================== SECCIÓN: TRANSPORTISTA ===================== -->
        <div class="section-card mt-3">
            <div class="section-label">TRANSPORTISTA</div>

            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label class="form-label-sm">No. de Autorización SEDEMA</label>
                    <input asp-for="TransporterAuthorizationNumber"
                           class="form-control form-control-sm"
                           placeholder="Autorización" />
                </div>
                <div class="col-md-8">
                    <label class="form-label-sm">Razón Social del Transportista</label>
                    <input asp-for="TransporterSocialReason"
                           class="form-control form-control-sm"
                           placeholder="Nombre o razón social" />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-md-6">
                    <label class="form-label-sm">Domicilio</label>
                    <input asp-for="TransporterAddress"
                           class="form-control form-control-sm"
                           placeholder="Calle, número, colonia" />
                </div>
                <div class="col-md-2">
                    <label class="form-label-sm">C.P.</label>
                    <input asp-for="TransporterPostalCode"
                           class="form-control form-control-sm"
                           placeholder="00000" />
                </div>
                <div class="col-md-4">
                    <label class="form-label-sm">Municipio</label>
                    <input asp-for="TransporterMunicipality"
                           class="form-control form-control-sm"
                           placeholder="Municipio" />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label class="form-label-sm">Teléfono</label>
                    <input asp-for="TransporterPhone"
                           class="form-control form-control-sm"
                           placeholder="Teléfono" />
                </div>
                <div class="col-md-4">
                    <label class="form-label-sm">Tipo de Vehículo</label>
                    <input asp-for="VehicleType"
                           class="form-control form-control-sm"
                           placeholder="Ej. Camión Caja Seca" />
                </div>
                <div class="col-md-4">
                    <label class="form-label-sm">No. de Placa</label>
                    <input asp-for="VehiclePlate"
                           class="form-control form-control-sm"
                           placeholder="Placa del vehículo" />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-md-6">
                    <label class="form-label-sm">Nombre del Conductor</label>
                    <input asp-for="DriverName"
                           class="form-control form-control-sm"
                           placeholder="Nombre del conductor" />
                </div>
                <div class="col-md-6">
                    <label class="form-label-sm">No. de Licencia de Conducción</label>
                    <input asp-for="DriverLicense"
                           class="form-control form-control-sm"
                           placeholder="Número de licencia" />
                </div>
            </div>

            <div class="mb-2">
                <label class="form-label-sm">Ruta de Transporte</label>
                <input asp-for="TransportRoute"
                       class="form-control form-control-sm"
                       placeholder="Ej. De Apazapan, Ver. a Xalapa, Ver." />
            </div>

            <div class="mb-2">
                <label class="form-label-sm">Observaciones del Transportista</label>
                <textarea asp-for="TransporterObservations" class="form-control form-control-sm" rows="2"
                          placeholder="Observaciones..."></textarea>
            </div>

            <div class="row g-2 mt-1">
                <div class="col-md-6">
                    <label class="form-label-sm">Nombre del Responsable (Transportista)</label>
                    <input asp-for="TransporterResponsibleName"
                           class="form-control form-control-sm"
                           placeholder="Nombre completo" />
                </div>
                <div class="col-md-3">
                    <label class="form-label-sm">Fecha de recepción</label>
                    <input asp-for="TransporterReceptionDate" type="date"
                           class="form-control form-control-sm" />
                </div>
            </div>
        </div>

        <!-- ===================== SECCIÓN: DESTINATARIO / DISPOSICIÓN FINAL ===================== -->
        <div class="section-card mt-3">
            <div class="section-label">DESTINATARIO / DISPOSICIÓN FINAL</div>

            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label class="form-label-sm">No. de Autorización SEDEMA</label>
                    <input asp-for="ReceiverAuthorizationNumber"
                           class="form-control form-control-sm"
                           placeholder="Autorización" />
                </div>
                <div class="col-md-8">
                    <label class="form-label-sm">Razón Social del Destinatario</label>
                    <input asp-for="ReceiverSocialReason"
                           class="form-control form-control-sm"
                           placeholder="Nombre o razón social" />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-md-6">
                    <label class="form-label-sm">Domicilio</label>
                    <input asp-for="ReceiverAddress"
                           class="form-control form-control-sm"
                           placeholder="Calle, número, colonia" />
                </div>
                <div class="col-md-2">
                    <label class="form-label-sm">C.P.</label>
                    <input asp-for="ReceiverPostalCode"
                           class="form-control form-control-sm"
                           placeholder="00000" />
                </div>
                <div class="col-md-4">
                    <label class="form-label-sm">Municipio</label>
                    <input asp-for="ReceiverMunicipality"
                           class="form-control form-control-sm"
                           placeholder="Municipio" />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label class="form-label-sm">Teléfono</label>
                    <input asp-for="ReceiverPhone"
                           class="form-control form-control-sm"
                           placeholder="Teléfono" />
                </div>
                <div class="col-md-4">
                    <label class="form-label-sm">Tipo de Disposición</label>
                    <input asp-for="DisposalType"
                           class="form-control form-control-sm"
                           placeholder="Ej. Almacén Temporal" />
                </div>
                <div class="col-md-4">
                    <label class="form-label-sm">Fecha</label>
                    <input asp-for="ReceiverDate" type="date"
                           class="form-control form-control-sm" />
                </div>
            </div>

            <div class="mb-2">
                <label class="form-label-sm">Observaciones del Destinatario</label>
                <textarea asp-for="ReceiverObservations" class="form-control form-control-sm" rows="2"
                          placeholder="Observaciones..."></textarea>
            </div>

            <div class="row g-2 mt-1">
                <div class="col-md-6">
                    <label class="form-label-sm">Nombre del Responsable (Destinatario)</label>
                    <input asp-for="ReceiverResponsibleName"
                           class="form-control form-control-sm"
                           placeholder="Nombre completo" />
                </div>
            </div>
        </div>

        <!-- Botones de acción -->
        <div class="d-flex justify-content-end gap-2 mt-4 mb-4">
            <a asp-page="/Index" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary">
                Generar Manifiesto
            </button>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Contador de filas de residuos
        let residueIndex = @Model.Residues.Count;

        function addResidueRow() {
            const tbody = document.getElementById('residues-body');
            const i = residueIndex++;
            const row = document.createElement('tr');
            row.innerHTML = `
                <td><input name="Residues[${i}].ResidueKey" class="form-control form-control-sm" placeholder="RS-001" /></td>
                <td><input name="Residues[${i}].ResidueName" class="form-control form-control-sm" placeholder="Nombre del residuo" /></td>
                <td><input name="Residues[${i}].Container" class="form-control form-control-sm" placeholder="OF / DF" /></td>
                <td><input name="Residues[${i}].ContainerCapacity" class="form-control form-control-sm" placeholder="N/A" /></td>
                <td><input name="Residues[${i}].Amount" type="number" step="0.01" class="form-control form-control-sm" placeholder="0.00" /></td>
                <td>
                    <select name="Residues[${i}].Unit" class="form-select form-select-sm">
                        <option value="kg">kg</option>
                        <option value="ton">ton</option>
                        <option value="lt">lt</option>
                        <option value="m3">m³</option>
                        <option value="pza">pza</option>
                    </select>
                </td>
            `;
            tbody.appendChild(row);
        }
    </script>
}
