@page "/Manifest/Generate/SpecialWaste"
@model ClienteWeb.Pages.Manifest.Generate.SpecialWasteModel
@{
    ViewData["Title"] = "Generate Manifest - Special Waste";
}

<div class="manifest-container">

    <div class="manifest-header d-flex justify-content-between align-items-start gap-3 mb-3 flex-wrap">
        <div class="brand-block">
            <img src="~/images/simar-logo.png" alt="SIMAR" class="brand-logo" onerror="this.style.display='none'" />
            <h2 class="brand-title">SIMAR</h2>
        </div>

        <div class="manifest-title-block text-center flex-grow-1 px-4">
            <h5 class="manifest-title">
                MANIFIESTO DE GENERADOR, TRANSPORTE Y DISPOSICIÓN FINAL,<br />
                TRATAMIENTO O REUTILIZACIÓN DE RESIDUOS DE MANEJO ESPECIAL
            </h5>
        </div>

        <div class="text-end">
            <small class="text-muted">No. de Manifiesto</small>
            <div class="manifest-number-box">Se asignará al guardar</div>
        </div>
    </div>

    <form method="post" id="manifestForm">
        @Html.AntiForgeryToken()

        <!-- GENERADOR -->
        <div class="section-card mb-3">
            <div class="section-label">GENERADOR</div>

            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label asp-for="EnvironmentalRegistrationNumber" class="form-label-sm">No. de Registro SEDEMA</label>
                    <input asp-for="EnvironmentalRegistrationNumber"
                           class="form-control form-control-sm"
                           placeholder="Ej. SEDEMA/DRME-CH09987205XB-17/182" />
                    <span asp-validation-for="EnvironmentalRegistrationNumber" class="text-danger small"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="SocialReason" class="form-label-sm">Razón social</label>
                    <input asp-for="SocialReason"
                           class="form-control form-control-sm"
                           placeholder="Ej. CEMENTOS MOCTEZUMA S.A. DE C.V." />
                    <span asp-validation-for="SocialReason" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-md-6">
                    <label asp-for="Address" class="form-label-sm">Domicilio</label>
                    <input asp-for="Address"
                           class="form-control form-control-sm"
                           placeholder="Ej. Camino vecinal, predio Los Gallineros, Cerro Colorado" />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="col-md-2">
                    <label asp-for="PostalCode" class="form-label-sm">C.P.</label>
                    <input asp-for="PostalCode"
                           class="form-control form-control-sm"
                           placeholder="Ej. 91645" />
                </div>

                <div class="col-md-4">
                    <label asp-for="Municipality" class="form-label-sm">Municipio</label>
                    <input asp-for="Municipality"
                           class="form-control form-control-sm"
                           placeholder="Ej. Apazapan" />
                </div>
            </div>

            <div class="row g-2 mb-3">
                <div class="col-md-3">
                    <label asp-for="PhoneNumber" class="form-label-sm">Teléfono</label>
                    <input asp-for="PhoneNumber"
                           class="form-control form-control-sm"
                           placeholder="Ej. 2288323510" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Email" class="form-label-sm">Correo electrónico</label>
                    <input asp-for="Email"
                           class="form-control form-control-sm"
                           placeholder="Ej. gerencia@empresa.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="ManifestDate" class="form-label-sm">Fecha</label>
                    <input asp-for="ManifestDate" type="date" class="form-control form-control-sm" />
                </div>

                <div class="col-md-3">
                    <label asp-for="ManifestTime" class="form-label-sm">Hora</label>
                    <input asp-for="ManifestTime" type="time" class="form-control form-control-sm" />
                </div>
            </div>

            <h6 class="subsection-title">Identificación de los residuos</h6>

            <div class="table-responsive mb-2">
                <table class="table table-bordered table-sm manifest-table align-middle">
                    <thead>
                        <tr>
                            <th style="width: 14%;">Clave de residuo</th>
                            <th style="width: 34%;">Tipo de residuo</th>
                            <th style="width: 12%;">Envase tipo</th>
                            <th style="width: 12%;">Capacidad</th>
                            <th style="width: 12%;">Peso</th>
                            <th style="width: 12%;">Unidad</th>
                            <th style="width: 36px;"></th>
                        </tr>
                    </thead>
                    <tbody id="residues-body">
                        @for (int i = 0; i < Model.Residues.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input asp-for="Residues[i].ResidueKey"
                                           class="form-control form-control-sm"
                                           placeholder="Ej. RI-001" />
                                </td>
                                <td>
                                    <input asp-for="Residues[i].ResidueName"
                                           class="form-control form-control-sm"
                                           placeholder="Ej. Otros residuos inorgánicos (RSU)" />
                                </td>
                                <td>
                                    <input asp-for="Residues[i].ContainerType"
                                           class="form-control form-control-sm"
                                           placeholder="Ej. OF" />
                                </td>
                                <td>
                                    <input asp-for="Residues[i].ContainerCapacity"
                                           class="form-control form-control-sm"
                                           placeholder="Ej. N/A" />
                                </td>
                                <td>
                                    <input asp-for="Residues[i].Weight"
                                           class="form-control form-control-sm"
                                           placeholder="Ej. 680" />
                                </td>
                                <td>
                                    <select asp-for="Residues[i].Unit" class="form-select form-select-sm">
                                        <option value="kg">kg</option>
                                        <option value="ton">ton</option>
                                        <option value="lt">lt</option>
                                        <option value="m3">m3</option>
                                        <option value="pza">pza</option>
                                    </select>
                                </td>
                                <td class="text-center">
                                    <button type="button" class="del-row-btn" onclick="deleteRow(this)" title="Eliminar fila">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <button type="button" class="btn-simar-outline add-row-btn mb-3" onclick="addResidueRow()">
                + Agregar residuo
            </button>

            <div class="mb-3">
                <label asp-for="GeneratorObservations" class="form-label-sm">Observaciones</label>
                <textarea asp-for="GeneratorObservations"
                          class="form-control form-control-sm"
                          rows="2"
                          placeholder="Ej. Sin observaciones."></textarea>
            </div>

            <div class="declaration-box mb-3">
                DECLARO BAJO PROTESTA DE DECIR VERDAD, que el contenido de este lote está total y correctamente descrito mediante el número de manifiesto, nombre del residuo, debidamente envasado y etiquetado y que se han previsto las condiciones de seguridad para su transporte por vía terrestre, de acuerdo con la legislación vigente.
            </div>

            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label asp-for="GeneratorResponsibleName" class="form-label-sm">Nombre del responsable</label>
                    <input asp-for="GeneratorResponsibleName"
                           class="form-control form-control-sm"
                           placeholder="Ej. Juan Pérez López" />
                </div>

                <div class="col-md-4">
                    <label class="form-label-sm">Firma</label>
                    <div class="signature-placeholder"></div>
                </div>

                <div class="col-md-4">
                    <label class="form-label-sm">Sello</label>
                    <div class="signature-placeholder"></div>
                </div>
            </div>
        </div>

        <!-- TRANSPORTISTA -->
        <div class="section-card mb-3">
            <div class="section-label">TRANSPORTISTA</div>

            @if (Model.Vehiculos.Count > 0)
            {
                <div class="row g-2 mb-3">
                    <div class="col-12">
                        <label class="form-label-sm">
                            <i class="bi bi-truck me-1"></i> Seleccionar vehículo del catálogo
                            <span class="text-muted">(opcional — pre-llena placa, tipo y licencia requerida)</span>
                        </label>
                        <select id="vehiculoSelector" class="form-select form-select-sm" onchange="onVehiculoChange(this)">
                            <option value="">— Seleccionar vehículo —</option>
                            @foreach (var v in Model.Vehiculos)
                            {
                                <option value="@v.Id"
                                        data-placas="@v.Placas"
                                        data-tipo="@($"{v.Marca} {v.Modelo}".Trim())"
                                        data-licencia="@(v.LicenciaRequerida ?? "")">
                                    @v.DisplayLabel
                                </option>
                            }
                        </select>
                    </div>
                    <div id="licenciaHint" class="col-12 d-none">
                        <div class="alert alert-info py-1 mb-0 small">
                            <i class="bi bi-info-circle me-1"></i>
                            Este vehículo requiere licencia tipo <strong id="licenciaTipo"></strong>.
                        </div>
                    </div>
                </div>
            }

            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label asp-for="TransporterAuthorizationNumber" class="form-label-sm">No. de Autorización SEDEMA</label>
                    <input asp-for="TransporterAuthorizationNumber"
                           class="form-control form-control-sm"
                           placeholder="Ej. SEDEMA/TRME-SMA0810239G-2025/073" />
                </div>

                <div class="col-md-8">
                    <label asp-for="TransporterSocialReason" class="form-label-sm">Razón social</label>
                    <input asp-for="TransporterSocialReason"
                           class="form-control form-control-sm"
                           placeholder="Ej. Sistemas en Manejo y Administración de Residuos S.A. de C.V." />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-md-6">
                    <label asp-for="TransporterAddress" class="form-label-sm">Domicilio</label>
                    <input asp-for="TransporterAddress"
                           class="form-control form-control-sm"
                           placeholder="Ej. Av. Pípila No. 126, Col. José Cardel" />
                </div>

                <div class="col-md-2">
                    <label asp-for="TransporterPostalCode" class="form-label-sm">C.P.</label>
                    <input asp-for="TransporterPostalCode"
                           class="form-control form-control-sm"
                           placeholder="Ej. 91030" />
                </div>

                <div class="col-md-4">
                    <label asp-for="TransporterMunicipality" class="form-label-sm">Municipio</label>
                    <input asp-for="TransporterMunicipality"
                           class="form-control form-control-sm"
                           placeholder="Ej. Xalapa" />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label asp-for="TransporterPhone" class="form-label-sm">Teléfono</label>
                    <input asp-for="TransporterPhone"
                           class="form-control form-control-sm"
                           placeholder="Ej. 2288343149" />
                </div>

                <div class="col-md-4">
                    <label asp-for="TransporterDate" class="form-label-sm">Fecha</label>
                    <input asp-for="TransporterDate" type="date" class="form-control form-control-sm" />
                </div>

                <div class="col-md-4">
                    <label asp-for="TransporterTime" class="form-label-sm">Hora</label>
                    <input asp-for="TransporterTime" type="time" class="form-control form-control-sm" />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-md-6">
                    <label asp-for="VehicleType" class="form-label-sm">Tipo de vehículo</label>
                    <input asp-for="VehicleType"
                           class="form-control form-control-sm"
                           placeholder="Ej. Camión caja seca 3.5 ton." />
                </div>

                <div class="col-md-6">
                    <label asp-for="VehiclePlate" class="form-label-sm">No. de placa</label>
                    <input asp-for="VehiclePlate"
                           class="form-control form-control-sm"
                           placeholder="Ej. YJ-9638-A" />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-12">
                    <label class="form-label-sm">Chofer</label>
                    <span class="text-muted">(opcional — pre-llena nombre y licencia)</span>
                    <select id="choferSelect" class="form-select form-select-sm"
                            onchange="aplicarChofer(this)">
                        <option value="">— Seleccionar chofer del catálogo —</option>
                        @foreach (var c in Model.Choferes)
                        {
                            <option value="@c.UserId"
                                    data-nombre="@c.FullName"
                                    data-licencia="@c.LicenseNumber">
                                @c.FullName @(string.IsNullOrEmpty(c.LicenseNumber) ? "" : $"— Lic. {c.LicenseNumber}")
                            </option>
                        }
                    </select>
                    @if (!Model.Choferes.Any())
                    {
                        <small class="text-muted">No hay choferes registrados en el sistema.</small>
                    }
                </div>
            </div>
            <div class="row g-2 mb-2">
                <div class="col-md-6">
                    <label asp-for="DriverName" class="form-label-sm">Nombre del conductor</label>
                    <input asp-for="DriverName"
                           id="driverNameInput"
                           class="form-control form-control-sm"
                           placeholder="Ej. Fernando López Sánchez" />
                </div>

                <div class="col-md-6">
                    <label asp-for="DriverLicense" class="form-label-sm">No. de licencia de conducir</label>
                    <input asp-for="DriverLicense"
                           id="driverLicenseInput"
                           class="form-control form-control-sm"
                           placeholder="Ej. UB0030UNC" />
                </div>
            </div>

            <div class="mb-2">
                <label asp-for="TransportRoute" class="form-label-sm">Ruta de transporte</label>
                <input asp-for="TransportRoute"
                       class="form-control form-control-sm"
                       placeholder="Ej. De Apazapan, Ver. a Xalapa, Ver." />
            </div>

            <div class="mb-3">
                <label asp-for="TransporterObservations" class="form-label-sm">Observaciones</label>
                <textarea asp-for="TransporterObservations"
                          class="form-control form-control-sm"
                          rows="2"
                          placeholder="Ej. Sin observaciones."></textarea>
            </div>

            <div class="declaration-box mb-3">
                DECLARO BAJO PROTESTA DE DECIR VERDAD, que recibí los residuos descritos en el manifiesto para su transporte al establecimiento destinado señalado por el generador.
            </div>

            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label asp-for="TransporterResponsibleName" class="form-label-sm">Nombre del responsable</label>
                    <input asp-for="TransporterResponsibleName"
                           class="form-control form-control-sm"
                           placeholder="Ej. Fernando López Sánchez" />
                </div>

                <div class="col-md-4">
                    <label class="form-label-sm">Firma</label>
                    <div class="signature-placeholder"></div>
                </div>

                <div class="col-md-4">
                    <label class="form-label-sm">Sello</label>
                    <div class="signature-placeholder"></div>
                </div>
            </div>
        </div>

        <!-- DESTINATARIO -->
        <div class="section-card mb-4">
            <div class="section-label">DESTINATARIO</div>

            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label asp-for="ReceiverAuthorizationNumber" class="form-label-sm">No. de autorización SEDEMA</label>
                    <input asp-for="ReceiverAuthorizationNumber"
                           class="form-control form-control-sm"
                           placeholder="Ej. SEDEMA/AATRME-SMA0810239L9-2024/36" />
                </div>

                <div class="col-md-8">
                    <label asp-for="ReceiverSocialReason" class="form-label-sm">Razón social</label>
                    <input asp-for="ReceiverSocialReason"
                           class="form-control form-control-sm"
                           placeholder="Ej. Sistemas en Manejo y Administración de Residuos S.A. de C.V." />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-md-6">
                    <label asp-for="ReceiverAddress" class="form-label-sm">Domicilio</label>
                    <input asp-for="ReceiverAddress"
                           class="form-control form-control-sm"
                           placeholder="Ej. Félix Licona #209, Col. Rafael Lucio" />
                </div>

                <div class="col-md-2">
                    <label asp-for="ReceiverPostalCode" class="form-label-sm">C.P.</label>
                    <input asp-for="ReceiverPostalCode"
                           class="form-control form-control-sm"
                           placeholder="Ej. 91110" />
                </div>

                <div class="col-md-4">
                    <label asp-for="ReceiverMunicipality" class="form-label-sm">Municipio</label>
                    <input asp-for="ReceiverMunicipality"
                           class="form-control form-control-sm"
                           placeholder="Ej. Xalapa" />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label asp-for="ReceiverPhone" class="form-label-sm">Teléfono</label>
                    <input asp-for="ReceiverPhone"
                           class="form-control form-control-sm"
                           placeholder="Ej. 2288190044" />
                </div>

                <div class="col-md-4">
                    <label asp-for="ReceiverDate" class="form-label-sm">Fecha</label>
                    <input asp-for="ReceiverDate" type="date" class="form-control form-control-sm" />
                </div>

                <div class="col-md-4">
                    <label asp-for="ReceiverTime" class="form-label-sm">Hora</label>
                    <input asp-for="ReceiverTime" type="time" class="form-control form-control-sm" />
                </div>
            </div>

            <div class="mb-2">
                <label asp-for="DisposalType" class="form-label-sm">Tipo de disposición</label>
                <input asp-for="DisposalType"
                       class="form-control form-control-sm"
                       placeholder="Ej. Almacén temporal" />
            </div>

            <div class="mb-3">
                <label asp-for="ReceiverObservations" class="form-label-sm">Observaciones</label>
                <textarea asp-for="ReceiverObservations"
                          class="form-control form-control-sm"
                          rows="2"
                          placeholder="Ej. Sin observaciones."></textarea>
            </div>

            <div class="declaration-box mb-3">
                DECLARO BAJO PROTESTA DE DECIR VERDAD, que recibí los residuos descritos en el manifiesto para su manejo adecuado conforme a la legislación vigente.
            </div>

            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label asp-for="ReceiverResponsibleName" class="form-label-sm">Nombre del responsable</label>
                    <input asp-for="ReceiverResponsibleName"
                           class="form-control form-control-sm"
                           placeholder="Ej. Gustavo Cruz Torres" />
                </div>

                <div class="col-md-4">
                    <label class="form-label-sm">Firma</label>
                    <div class="signature-placeholder"></div>
                </div>

                <div class="col-md-4">
                    <label class="form-label-sm">Sello</label>
                    <div class="signature-placeholder"></div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <a asp-page="/Manifest/Consult/Index" class="btn-simar-outline-gray">Cancelar</a>
            <button type="button" id="btnOpenConfirm" class="btn-simar-primary">
                <i class="bi bi-check2-circle"></i> Generar manifiesto
            </button>
        </div>
    </form>
</div>

<!-- Modal de confirmación -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-semibold">Confirmar generación de manifiesto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Desea guardar el manifiesto como borrador?</p>
                <p class="mb-0">Se guardará con estado <span class="badge bg-secondary">Borrador</span>. Podrá editarlo y enviarlo a tránsito desde el listado de manifiestos.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-simar-outline-gray" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnConfirm" class="btn-simar-primary">
                    <i class="bi bi-check2-circle"></i> Guardar como borrador
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function aplicarChofer(sel) {
            const opt = sel.selectedOptions[0];
            const nombre   = opt?.dataset.nombre   || '';
            const licencia = opt?.dataset.licencia || '';
            const fNombre   = document.getElementById('driverNameInput');
            const fLicencia = document.getElementById('driverLicenseInput');
            if (fNombre)   fNombre.value   = nombre;
            if (fLicencia) fLicencia.value = licencia;
        }

        function onVehiculoChange(sel) {
            const opt = sel.selectedOptions[0];
            if (!opt || !opt.value) {
                document.getElementById('licenciaHint')?.classList.add('d-none');
                return;
            }
            const placas   = opt.dataset.placas  || '';
            const tipo     = opt.dataset.tipo     || '';
            const licencia = opt.dataset.licencia || '';

            const fPlaca = document.getElementById('VehiclePlate');
            const fTipo  = document.getElementById('VehicleType');
            if (fPlaca) fPlaca.value = placas;
            if (fTipo)  fTipo.value  = tipo;

            const hint = document.getElementById('licenciaHint');
            if (hint) {
                if (licencia) {
                    document.getElementById('licenciaTipo').textContent = licencia;
                    hint.classList.remove('d-none');
                } else {
                    hint.classList.add('d-none');
                }
            }
        }

        $.validator.messages.required = "Este campo es obligatorio.";
        $.validator.messages.email = "Por favor ingrese un correo electrónico válido.";
        $.validator.messages.number = "Por favor ingrese un número válido.";
        $.validator.messages.range = $.validator.format("Por favor ingrese un valor entre {0} y {1}.");
        $.validator.messages.min = $.validator.format("El valor mínimo es {0}.");
        $.validator.messages.max = $.validator.format("El valor máximo es {0}.");

        document.getElementById('btnOpenConfirm').addEventListener('click', function () {
            const form = document.getElementById('manifestForm');
            if ($(form).valid()) {
                new bootstrap.Modal(document.getElementById('confirmModal')).show();
            }
        });

        document.getElementById('btnConfirm').addEventListener('click', function () {
            document.getElementById('manifestForm').submit();
        });

        let residueIndex = @Model.Residues.Count;

        function deleteRow(btn) {
            const tbody = btn.closest('tbody');
            if (tbody.rows.length > 1) {
                btn.closest('tr').remove();
            }
        }

        function addResidueRow() {
            const tbody = document.getElementById('residues-body');
            const i = residueIndex++;

            const row = document.createElement('tr');
            row.innerHTML = `
                <td>
                    <input name="Residues[${i}].ResidueKey" class="form-control form-control-sm" placeholder="Ej. RI-001" />
                </td>
                <td>
                    <input name="Residues[${i}].ResidueName" class="form-control form-control-sm" placeholder="Ej. Otros residuos inorgánicos (RSU)" />
                </td>
                <td>
                    <input name="Residues[${i}].ContainerType" class="form-control form-control-sm" placeholder="Ej. OF" />
                </td>
                <td>
                    <input name="Residues[${i}].ContainerCapacity" class="form-control form-control-sm" placeholder="Ej. N/A" />
                </td>
                <td>
                    <input name="Residues[${i}].Weight" class="form-control form-control-sm" placeholder="Ej. 680" />
                </td>
                <td>
                    <select name="Residues[${i}].Unit" class="form-select form-select-sm">
                        <option value="kg">kg</option>
                        <option value="ton">ton</option>
                        <option value="lt">lt</option>
                        <option value="m3">m3</option>
                        <option value="pza">pza</option>
                    </select>
                </td>
                <td class="text-center">
                    <button type="button" class="del-row-btn" onclick="deleteRow(this)" title="Eliminar fila">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </td>
            `;
            tbody.appendChild(row);
        }
    </script>
}