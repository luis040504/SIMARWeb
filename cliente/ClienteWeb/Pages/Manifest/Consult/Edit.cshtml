@page "/Manifest/Consult/Edit/{id}"
@model ClienteWeb.Pages.Manifest.Consult.EditModel
@{
    ViewData["Title"] = $"Editar – {Model.Manifest.ManifestNumber}";
    var m = Model.Manifest;
    bool esEspecial = m.Type == "especial";
    string hdrClass = esEspecial ? "consult-section-header especial" : "consult-section-header peligroso";
}

<form method="post">
    <input type="hidden" asp-for="Manifest.Id" />
    <input type="hidden" asp-for="Manifest.Type" />
    <input type="hidden" asp-for="Manifest.ManifestNumber" />

    <div class="consult-container">

        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
            <a asp-page="/Manifest/Consult/Detail"
               asp-route-id="@m.Id"
               class="btn-simar-outline-gray">← Volver</a>

            <h1 class="consult-heading @(esEspecial ? "especial" : "peligroso")">
                Editar: @m.ManifestNumber
            </h1>

            @if (esEspecial)
            {
                <span class="badge-simar badge-simar-especial">Residuos Especiales</span>
            }
            else
            {
                <span class="badge-simar badge-simar-peligroso">Residuos Peligrosos</span>
            }
        </div>

        <!-- GENERADOR -->
        <div class="consult-section-card @(esEspecial ? "" : "peligroso")">
            <div class="@hdrClass" onclick="toggleSection(this)">
                <span>👤 Datos del Generador</span><span class="chevron">▲</span>
            </div>

            <div class="consult-section-body">
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label-sm">No. Registro @(esEspecial ? "SEDEMA" : "SEMARNAT") <span class="text-danger">*</span></label>
                        <input asp-for="Manifest.EnvironmentalRegistrationNumber" class="form-control form-control-sm" />
                        <span asp-validation-for="Manifest.EnvironmentalRegistrationNumber" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label-sm">Razón Social <span class="text-danger">*</span></label>
                        <input asp-for="Manifest.SocialReason" class="form-control form-control-sm" />
                        <span asp-validation-for="Manifest.SocialReason" class="text-danger small"></span>
                    </div>

                    @if (esEspecial)
                    {
                        <div class="col-md-9">
                            <label class="form-label-sm">Domicilio</label>
                            <input asp-for="Manifest.Address" class="form-control form-control-sm" />
                        </div>
                    }
                    else
                    {
                        <div class="col-md-5">
                            <label class="form-label-sm">Calle</label>
                            <input asp-for="Manifest.Street" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label-sm">Núm. Ext.</label>
                            <input asp-for="Manifest.ExteriorNumber" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label-sm">Núm. Int.</label>
                            <input asp-for="Manifest.InteriorNumber" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-sm">Colonia</label>
                            <input asp-for="Manifest.Colony" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label-sm">Estado</label>
                            <input asp-for="Manifest.State" class="form-control form-control-sm" />
                        </div>
                    }

                    <div class="col-md-3">
                        <label class="form-label-sm">C.P.</label>
                        <input asp-for="Manifest.PostalCode" class="form-control form-control-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label-sm">Municipio</label>
                        <input asp-for="Manifest.Municipality" class="form-control form-control-sm" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-sm">Teléfono <span class="text-danger">*</span></label>
                        <input asp-for="Manifest.PhoneNumber" class="form-control form-control-sm" />
                        <span asp-validation-for="Manifest.PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label-sm">Correo electrónico</label>
                        <input asp-for="Manifest.Email" type="email" class="form-control form-control-sm" />
                        <span asp-validation-for="Manifest.Email" class="text-danger small"></span>
                    </div>

                    @if (esEspecial)
                    {
                        <div class="col-md-2">
                            <label class="form-label-sm">Fecha</label>
                            <input asp-for="Manifest.ManifestDate" type="date" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label-sm">Hora</label>
                            <input asp-for="Manifest.ManifestTime" type="time" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12">
                            <label class="form-label-sm">Observaciones del generador</label>
                            <textarea asp-for="Manifest.GeneratorObservations"
                                      class="form-control form-control-sm" rows="2"></textarea>
                        </div>
                    }
                    else
                    {
                        <div class="col-12">
                            <label class="form-label-sm">Instrucciones de manejo seguro</label>
                            <textarea asp-for="Manifest.SafeHandlingInstructions"
                                      class="form-control form-control-sm" rows="2"></textarea>
                        </div>
                    }

                    <div class="col-md-5">
                        <label class="form-label-sm">Nombre del responsable</label>
                        <input asp-for="Manifest.GeneratorResponsibleName" class="form-control form-control-sm" />
                    </div>

                    @if (!esEspecial)
                    {
                        <div class="col-md-3">
                            <label class="form-label-sm">Fecha</label>
                            <input asp-for="Manifest.GeneratorSignDate" type="date" class="form-control form-control-sm" />
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- RESIDUOS -->
        <div class="consult-section-card @(esEspecial ? "" : "peligroso")">
            <div class="@hdrClass" onclick="toggleSection(this)">
                <span>Residuos</span><span class="chevron">▲</span>
            </div>

            <div class="consult-section-body p-2">
                @if (esEspecial)
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered mb-1" id="tblSpecial">
                            <thead>
                                <tr style="background:#f0f4f8; font-size:.73rem;">
                                    <th>Clave</th>
                                    <th>Nombre del Residuo</th>
                                    <th>Envase</th>
                                    <th>Capacidad</th>
                                    <th>Peso</th>
                                    <th>Unidad</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="specialBody">
                                @for (int i = 0; i < m.SpecialResidues.Count; i++)
                                {
                                    <tr class="residue-row">
                                        <td><input name="Manifest.SpecialResidues[@i].ResidueKey" value="@m.SpecialResidues[i].ResidueKey" class="form-control form-control-sm" style="min-width:70px" /></td>
                                        <td><input name="Manifest.SpecialResidues[@i].ResidueName" value="@m.SpecialResidues[i].ResidueName" class="form-control form-control-sm" style="min-width:160px" /></td>
                                        <td><input name="Manifest.SpecialResidues[@i].ContainerType" value="@m.SpecialResidues[i].ContainerType" class="form-control form-control-sm" style="min-width:60px" /></td>
                                        <td><input name="Manifest.SpecialResidues[@i].ContainerCapacity" value="@m.SpecialResidues[i].ContainerCapacity" class="form-control form-control-sm" style="min-width:70px" /></td>
                                        <td><input name="Manifest.SpecialResidues[@i].Weight" value="@m.SpecialResidues[i].Weight" type="number" step="0.01" class="form-control form-control-sm" style="min-width:70px" /></td>
                                        <td>
                                            <select name="Manifest.SpecialResidues[@i].Unit" class="form-select form-select-sm" style="min-width:60px">
                                                @foreach (var u in new[] { "kg", "ton", "lt", "m3", "pza" })
                                                {
                                                    if (m.SpecialResidues[i].Unit == u)
                                                    {
                                                        <option value="@u" selected>@u</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@u">@u</option>
                                                    }
                                                }
                                            </select>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-outline-danger del-row-btn"
                                                    onclick="this.closest('tr').remove()">✕</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <button type="button" class="btn-simar-outline add-row-btn"
                            onclick="addSpecialRow()">+ Agregar residuo</button>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered mb-1" id="tblHazard">
                            <thead>
                                <tr style="background:#fdf0f0; font-size:.73rem;">
                                    <th>Nombre del Residuo</th>
                                    <th>CRETIBM</th>
                                    <th>Envase</th>
                                    <th>Capacidad</th>
                                    <th>Cant. (kg)</th>
                                    <th>Etiqueta</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="hazardBody">
                                @for (int i = 0; i < m.HazardousResidues.Count; i++)
                                {
                                    var r = m.HazardousResidues[i];
                                    <tr class="residue-row">
                                        <td><input name="Manifest.HazardousResidues[@i].ResidueName" value="@r.ResidueName" class="form-control form-control-sm" style="min-width:160px" /></td>
                                        <td style="min-width:260px">
                                            <div class="d-flex flex-nowrap gap-1">
                                                @foreach (var (lbl, prop, val) in new[] {
                                                    ("C","IsCorrosive", r.IsCorrosive),
                                                    ("R","IsReactive", r.IsReactive),
                                                    ("E","IsExplosive", r.IsExplosive),
                                                    ("T","IsToxic", r.IsToxic),
                                                    ("I","IsFlammable", r.IsFlammable),
                                                    ("B","IsBiological", r.IsBiological),
                                                    ("M","IsMutagenic", r.IsMutagenic)
                                                })
                                                {
                                                    <div class="form-check form-check-inline m-0">
                                                        <input class="form-check-input" type="checkbox"
                                                               name="Manifest.HazardousResidues[@i].@prop"
                                                               value="true"
                                                               @(val ? "checked" : null) />
                                                        <label class="form-check-label">@lbl</label>
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                        <td><input name="Manifest.HazardousResidues[@i].ContainerType" value="@r.ContainerType" class="form-control form-control-sm" style="min-width:60px" /></td>
                                        <td><input name="Manifest.HazardousResidues[@i].ContainerCapacity" value="@r.ContainerCapacity" class="form-control form-control-sm" style="min-width:60px" /></td>
                                        <td><input name="Manifest.HazardousResidues[@i].AmountKg" value="@r.AmountKg" type="number" step="0.01" class="form-control form-control-sm" style="min-width:70px" /></td>
                                        <td>
                                            <select name="Manifest.HazardousResidues[@i].HasLabel" class="form-select form-select-sm" style="min-width:60px">
                                                @if (r.HasLabel == null)
                                                {
                                                    <option value="" selected>–</option>
                                                }
                                                else
                                                {
                                                    <option value="">–</option>
                                                }

                                                @if (r.HasLabel == true)
                                                {
                                                    <option value="true" selected>Sí</option>
                                                }
                                                else
                                                {
                                                    <option value="true">Sí</option>
                                                }

                                                @if (r.HasLabel == false)
                                                {
                                                    <option value="false" selected>No</option>
                                                }
                                                else
                                                {
                                                    <option value="false">No</option>
                                                }
                                            </select>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-outline-danger del-row-btn"
                                                    onclick="this.closest('tr').remove()">✕</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <button type="button" class="btn-simar-outline add-row-btn"
                            onclick="addHazardRow()">+ Agregar residuo peligroso</button>
                }
            </div>
        </div>

        <!-- TRANSPORTISTA -->
        <div class="consult-section-card @(esEspecial ? "" : "peligroso")">
            <div class="@hdrClass" onclick="toggleSection(this)">
                <span>Transportista</span><span class="chevron">▲</span>
            </div>

            <div class="consult-section-body">
                <div class="row g-2">
                    <div class="col-md-5">
                        <label class="form-label-sm">No. Autorización</label>
                        <input asp-for="Manifest.TransporterAuthorizationNumber" class="form-control form-control-sm" />
                    </div>

                    @if (!esEspecial)
                    {
                        <div class="col-md-5">
                            <label class="form-label-sm">No. Permiso SCT</label>
                            <input asp-for="Manifest.TransporterSCTPermit" class="form-control form-control-sm" />
                        </div>
                    }

                    <div class="col-md-7">
                        <label class="form-label-sm">Razón Social <span class="text-danger">*</span></label>
                        <input asp-for="Manifest.TransporterSocialReason" class="form-control form-control-sm" />
                        <span asp-validation-for="Manifest.TransporterSocialReason" class="text-danger small"></span>
                    </div>

                    @if (esEspecial)
                    {
                        <div class="col-md-9">
                            <label class="form-label-sm">Domicilio</label>
                            <input asp-for="Manifest.TransporterAddress" class="form-control form-control-sm" />
                        </div>
                    }
                    else
                    {
                        <div class="col-md-5">
                            <label class="form-label-sm">Calle</label>
                            <input asp-for="Manifest.TransporterStreet" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label-sm">Núm. Ext.</label>
                            <input asp-for="Manifest.TransporterExteriorNumber" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label-sm">Núm. Int.</label>
                            <input asp-for="Manifest.TransporterInteriorNumber" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-sm">Colonia</label>
                            <input asp-for="Manifest.TransporterColony" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label-sm">Estado</label>
                            <input asp-for="Manifest.TransporterState" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-sm">Correo</label>
                            <input asp-for="Manifest.TransporterEmail" type="email" class="form-control form-control-sm" />
                        </div>
                    }

                    <div class="col-md-2">
                        <label class="form-label-sm">C.P.</label>
                        <input asp-for="Manifest.TransporterPostalCode" class="form-control form-control-sm" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-sm">Municipio</label>
                        <input asp-for="Manifest.TransporterMunicipality" class="form-control form-control-sm" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-sm">Teléfono</label>
                        <input asp-for="Manifest.TransporterPhone" class="form-control form-control-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label-sm">Tipo de vehículo</label>
                        <input asp-for="Manifest.VehicleType" class="form-control form-control-sm" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-sm">No. de placa</label>
                        <input asp-for="Manifest.VehiclePlate" class="form-control form-control-sm" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label-sm">Ruta de transporte</label>
                        <input asp-for="Manifest.TransportRoute" class="form-control form-control-sm" />
                    </div>

                    @if (esEspecial)
                    {
                        <div class="col-md-3">
                            <label class="form-label-sm">Fecha de recepción</label>
                            <input asp-for="Manifest.TransporterDate" type="date" class="form-control form-control-sm" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label-sm">Hora</label>
                            <input asp-for="Manifest.TransporterTime" type="time" class="form-control form-control-sm" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label-sm">No. Licencia</label>
                            <input asp-for="Manifest.DriverLicense" class="form-control form-control-sm" />
                        </div>

                        <div class="col-12">
                            <label class="form-label-sm">Observaciones</label>
                            <textarea asp-for="Manifest.TransporterObservations" class="form-control form-control-sm" rows="2"></textarea>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-3">
                            <label class="form-label-sm">Fecha</label>
                            <input asp-for="Manifest.TransporterSignDate" type="date" class="form-control form-control-sm" />
                        </div>
                    }

                    <div class="col-md-4">
                        <label class="form-label-sm">Nombre del responsable</label>
                        <input asp-for="Manifest.TransporterResponsibleName" class="form-control form-control-sm" />
                    </div>
                </div>
            </div>
        </div>

        <!-- DESTINATARIO -->
        <div class="consult-section-card @(esEspecial ? "" : "peligroso")">
            <div class="@hdrClass" onclick="toggleSection(this)">
                <span>Destinatario / Disposición Final</span><span class="chevron">▲</span>
            </div>

            <div class="consult-section-body">
                <div class="row g-2">
                    <div class="col-md-5">
                        <label class="form-label-sm">No. Autorización</label>
                        <input asp-for="Manifest.ReceiverAuthorizationNumber" class="form-control form-control-sm" />
                    </div>

                    <div class="col-md-7">
                        <label class="form-label-sm">Razón Social <span class="text-danger">*</span></label>
                        <input asp-for="Manifest.ReceiverSocialReason" class="form-control form-control-sm" />
                        <span asp-validation-for="Manifest.ReceiverSocialReason" class="text-danger small"></span>
                    </div>

                    @if (esEspecial)
                    {
                        <div class="col-md-9">
                            <label class="form-label-sm">Domicilio</label>
                            <input asp-for="Manifest.ReceiverAddress" class="form-control form-control-sm" />
                        </div>
                    }
                    else
                    {
                        <div class="col-md-5">
                            <label class="form-label-sm">Calle</label>
                            <input asp-for="Manifest.ReceiverStreet" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label-sm">Núm. Ext.</label>
                            <input asp-for="Manifest.ReceiverExteriorNumber" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label-sm">Núm. Int.</label>
                            <input asp-for="Manifest.ReceiverInteriorNumber" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-sm">Colonia</label>
                            <input asp-for="Manifest.ReceiverColony" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label-sm">Estado</label>
                            <input asp-for="Manifest.ReceiverState" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-sm">Correo</label>
                            <input asp-for="Manifest.ReceiverEmail" type="email" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-sm">Persona que recibe los residuos</label>
                            <input asp-for="Manifest.ReceiverPersonName" class="form-control form-control-sm" />
                        </div>
                    }

                    <div class="col-md-2">
                        <label class="form-label-sm">C.P.</label>
                        <input asp-for="Manifest.ReceiverPostalCode" class="form-control form-control-sm" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-sm">Municipio</label>
                        <input asp-for="Manifest.ReceiverMunicipality" class="form-control form-control-sm" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-sm">Teléfono</label>
                        <input asp-for="Manifest.ReceiverPhone" class="form-control form-control-sm" />
                    </div>

                    @if (esEspecial)
                    {
                        <div class="col-md-4">
                            <label class="form-label-sm">Tipo de disposición</label>
                            <input asp-for="Manifest.DisposalType" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label-sm">Fecha</label>
                            <input asp-for="Manifest.ReceiverDate" type="date" class="form-control form-control-sm" />
                        </div>
                    }
                    else
                    {
                        <div class="col-md-3">
                            <label class="form-label-sm">Fecha</label>
                            <input asp-for="Manifest.ReceiverSignDate" type="date" class="form-control form-control-sm" />
                        </div>
                    }

                    <div class="col-md-4">
                        <label class="form-label-sm">Nombre del responsable</label>
                        <input asp-for="Manifest.ReceiverResponsibleName" class="form-control form-control-sm" />
                    </div>

                    <div class="col-12">
                        <label class="form-label-sm">Observaciones</label>
                        <textarea asp-for="Manifest.ReceiverObservations" class="form-control form-control-sm" rows="2"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between mt-2 mb-4">
            <a asp-page="/Manifest/Consult/Detail"
               asp-route-id="@m.Id"
               class="btn-simar-outline-gray">Cancelar</a>

            <button type="button" class="btn-simar-primary" data-bs-toggle="modal" data-bs-target="#confirmSaveModal">
                <i class="bi bi-check2-circle"></i> Guardar cambios
            </button>
        </div>
    </div>
</form>

<!-- Modal de confirmación -->
<div class="modal fade" id="confirmSaveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-semibold">Confirmar cambios</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">¿Desea guardar los cambios del manifiesto <strong>@m.ManifestNumber</strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-simar-outline-gray" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnConfirmSave" class="btn-simar-primary">
                    <i class="bi bi-check2-circle"></i> Guardar cambios
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('btnConfirmSave').addEventListener('click', function () {
        document.querySelector('form').submit();
    });

    function toggleSection(header) {
        const body = header.nextElementSibling;
        const chevron = header.querySelector('.chevron');
        const isOpen = body.style.display !== 'none';
        body.style.display = isOpen ? 'none' : '';
        chevron.textContent = isOpen ? '▼' : '▲';
    }

    // Contadores que sólo suben — evitan colisión de índices al borrar y agregar filas
    let specialIdx = document.getElementById('specialBody')?.querySelectorAll('tr').length ?? 0;
    let hazardIdx  = document.getElementById('hazardBody')?.querySelectorAll('tr').length ?? 0;

    function addSpecialRow() {
        const body = document.getElementById('specialBody');
        const idx = specialIdx++;
        const units = ['kg','ton','lt','m3','pza'].map(u =>
            `<option value="${u}">${u}</option>`).join('');

        body.insertAdjacentHTML('beforeend', `
        <tr class="residue-row">
            <td><input name="Manifest.SpecialResidues[${idx}].ResidueKey" class="form-control form-control-sm" style="min-width:70px" /></td>
            <td><input name="Manifest.SpecialResidues[${idx}].ResidueName" class="form-control form-control-sm" style="min-width:160px" /></td>
            <td><input name="Manifest.SpecialResidues[${idx}].ContainerType" class="form-control form-control-sm" style="min-width:60px" /></td>
            <td><input name="Manifest.SpecialResidues[${idx}].ContainerCapacity" class="form-control form-control-sm" style="min-width:70px" /></td>
            <td><input name="Manifest.SpecialResidues[${idx}].Weight" type="number" step="0.01" class="form-control form-control-sm" style="min-width:70px" /></td>
            <td><select name="Manifest.SpecialResidues[${idx}].Unit" class="form-select form-select-sm" style="min-width:60px">${units}</select></td>
            <td class="text-center"><button type="button" class="btn btn-outline-danger del-row-btn" onclick="this.closest('tr').remove()">✕</button></td>
        </tr>`);
    }

    function addHazardRow() {
        const body = document.getElementById('hazardBody');
        const idx = hazardIdx++;
        const checks = [['C','IsCorrosive'],['R','IsReactive'],['E','IsExplosive'],
                        ['T','IsToxic'],['I','IsFlammable'],['B','IsBiological'],['M','IsMutagenic']]
            .map(([l,p]) => `
            <div class="form-check form-check-inline m-0" style="white-space:nowrap">
                <input class="form-check-input" type="checkbox"
                       name="Manifest.HazardousResidues[${idx}].${p}" value="true" />
                <label class="form-check-label">${l}</label>
            </div>`).join('');

        body.insertAdjacentHTML('beforeend', `
        <tr class="residue-row">
            <td><input name="Manifest.HazardousResidues[${idx}].ResidueName" class="form-control form-control-sm" style="min-width:160px" /></td>
            <td style="min-width:260px"><div class="d-flex flex-nowrap gap-1">${checks}</div></td>
            <td><input name="Manifest.HazardousResidues[${idx}].ContainerType" class="form-control form-control-sm" style="min-width:60px" /></td>
            <td><input name="Manifest.HazardousResidues[${idx}].ContainerCapacity" class="form-control form-control-sm" style="min-width:60px" /></td>
            <td><input name="Manifest.HazardousResidues[${idx}].AmountKg" type="number" step="0.01" class="form-control form-control-sm" style="min-width:70px" /></td>
            <td>
                <select name="Manifest.HazardousResidues[${idx}].HasLabel" class="form-select form-select-sm" style="min-width:60px">
                    <option value="">–</option>
                    <option value="true">Sí</option>
                    <option value="false">No</option>
                </select>
            </td>
            <td class="text-center"><button type="button" class="btn btn-outline-danger del-row-btn" onclick="this.closest('tr').remove()">✕</button></td>
        </tr>`);
    }
</script>
}
