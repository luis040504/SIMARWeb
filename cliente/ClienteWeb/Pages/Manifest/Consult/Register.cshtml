@page "/Manifest/Consult/Register/{id}"
@model ClienteWeb.Pages.Manifest.Consult.RegisterModel
@{
    ViewData["Title"] = $"Subir firma – {Model.ManifestInfo.ManifestNumber}";
    var m = Model.ManifestInfo;
    bool esEspecial = m.Type == "especial";

    var fechaEmision =
        esEspecial
            ? (m.ManifestDate?.ToString("dd/MM/yyyy") ?? "–")
            : (m.GeneratorSignDate?.ToString("dd/MM/yyyy") ?? "–");
}

<div class="register-container">
    <div class="mb-3">
        <a asp-page="/Manifest/Consult/Detail"
           asp-route-id="@m.Id"
           class="btn-simar-outline-gray">
            ← Volver al manifiesto
        </a>
    </div>

    <div class="register-card-simar">
        <div class="register-card-header @(esEspecial ? "especial" : "peligroso")">
            <h2>Subir manifiesto firmado</h2>
            <span class="badge-simar @(esEspecial ? "badge-simar-especial" : "badge-simar-peligroso")">
                @(esEspecial ? "Especial" : "Peligroso")
            </span>
        </div>

        <div class="register-card-body">
            <div class="info-summary @(esEspecial ? "especial" : "peligroso")">
                <div class="row">
                    <div class="col-sm-6 mb-2">
                        <strong>Folio:</strong><br />@m.ManifestNumber
                    </div>
                    <div class="col-sm-6 mb-2">
                        <strong>Fecha base:</strong><br />@fechaEmision
                    </div>
                    <div class="col-sm-12">
                        <strong>Generador:</strong><br />@m.SocialReason
                    </div>
                </div>
            </div>

            <form method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Input.Id" value="@m.Id" />

                <div class="mb-3">
                    <label asp-for="Input.SignedDate" class="form-label-sm">Fecha de firma / recepción final</label>
                    <input asp-for="Input.SignedDate" type="date" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.SignedFile" class="form-label-sm">Manifiesto firmado y sellado (PDF)</label>

                    <div class="file-drop-area" onclick="document.getElementById('file-upload').click()"
                         ondragover="event.preventDefault(); this.classList.add('dragover')"
                         ondragleave="this.classList.remove('dragover')"
                         ondrop="handleDrop(event)">
                        <div class="file-drop-icon">📄</div>
                        <div>Haz clic o arrastra aquí el PDF firmado</div>
                        <div class="form-hint mt-1">Solo PDF · máx. 10 MB</div>
                        <div id="file-name-display">
                            @if (!string.IsNullOrWhiteSpace(m.SignedManifestFileName))
                            {
                                <span>Archivo actual: <strong>@m.SignedManifestFileName</strong></span>
                            }
                        </div>
                    </div>

                    <input type="file"
                           asp-for="Input.SignedFile"
                           id="file-upload"
                           class="d-none"
                           accept=".pdf"
                           onchange="onFileSelected(this)" />
                </div>

                <div id="pdf-preview-new" style="display:none;" class="mb-3">
                    <span class="form-label-sm">Vista previa del archivo seleccionado</span>
                    <iframe id="pdf-preview-frame"
                            style="width:100%; height:480px; border:1px solid #c8d6e3; border-radius:8px; margin-top:0.4rem;"
                            title="Vista previa">
                    </iframe>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn-simar-primary justify-content-center py-2 fw-bold">
                        <i class="bi bi-check2-circle"></i> Guardar firma y marcar como completado
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function handleDrop(event) {
            event.preventDefault();
            event.currentTarget.classList.remove('dragover');
            const file = event.dataTransfer.files[0];
            if (!file) return;
            if (file.type !== 'application/pdf') {
                alert('Solo se permiten archivos PDF.');
                return;
            }
            const input = document.getElementById('file-upload');
            const dt = new DataTransfer();
            dt.items.add(file);
            input.files = dt.files;
            showPreview(file);
        }

        function onFileSelected(input) {
            const file = input.files[0];
            if (!file) return;
            showPreview(file);
        }

        function showPreview(file) {
            const display = document.getElementById('file-name-display');
            if (display) display.textContent = file.name;

            const preview = document.getElementById('pdf-preview-new');
            const frame = document.getElementById('pdf-preview-frame');
            if (preview && frame) {
                frame.src = URL.createObjectURL(file);
                preview.style.display = 'block';
            }
        }
    </script>
}
