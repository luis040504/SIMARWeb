@page "/Manifest/Consult/Register"
@model ClienteWeb.Pages.Manifest.Consult.RegisterModel
@{
    ViewData["Title"] = $"Registrar Firma – {Model.ManifestInfo.ManifestNumber}";
    var m = Model.ManifestInfo;
    bool esEspecial = m.Type == "especial";
}

<style>
    .register-container { max-width: 600px; margin: 2rem auto; }
    
    .register-card {
        background: #fff;
        border: 1px solid #c8d6e3;
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .register-header {
        background: @(esEspecial ? "#1a3a5c" : "#7b2d2d");
        color: #fff;
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .register-header h2 { margin: 0; font-size: 1.25rem; font-weight: 600; }
    .register-header .badge { font-size: 0.75rem; background: rgba(255,255,255,0.2); }

    .register-body { padding: 1.5rem; }

    .info-summary {
        background: #f8f9fa;
        padding: 1rem;
        border-radius: 6px;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        border-left: 4px solid @(esEspecial ? "#1a3a5c" : "#7b2d2d");
    }

    .info-summary strong { color: #4a5568; }

    .form-label { font-size: 0.85rem; font-weight: 600; color: #4a5568; margin-bottom: 0.25rem; }
    .form-text { font-size: 0.75rem; color: #6c757d; }

    .file-drop-area {
        border: 2px dashed #c8d6e3;
        border-radius: 8px;
        padding: 2rem;
        text-align: center;
        background: #f8f9fa;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .file-drop-area:hover, .file-drop-area.dragover {
        border-color: #0d6efd;
        background: #e9f2ff;
    }

    .file-drop-icon { font-size: 2.5rem; color: #6c757d; margin-bottom: 0.5rem; }
    
    #file-name-display {
        font-weight: 600;
        color: #0d6efd;
        margin-top: 0.5rem;
    }
</style>

<div class="register-container">
    <div class="mb-3">
        <a asp-page="/Manifest/Consult/Detail" asp-route-id="@m.Id" class="btn btn-outline-secondary btn-sm">← Volver al Manifiesto</a>
    </div>

    <div class="register-card">
        <div class="register-header">
            <h2>Registrar Avance / Firma</h2>
            <span class="badge">@(esEspecial ? "Especial" : "Peligroso")</span>
        </div>
        
        <div class="register-body">
            <div class="info-summary">
                <div class="row">
                    <div class="col-sm-6 mb-2">
                        <strong>Folio:</strong><br />@m.ManifestNumber
                    </div>
                    <div class="col-sm-6 mb-2">
                        <strong>Fecha Emisión:</strong><br />@m.ManifestDate.ToString("dd/MM/yyyy")
                    </div>
                    <div class="col-sm-12">
                        <strong>Generador:</strong><br />@m.SocialReason
                    </div>
                </div>
            </div>

            <form method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Input.Id" value="@m.Id" />
                
                <div class="mb-3">
                    <label class="form-label">Estado Actual</label>
                    <select asp-for="Input.Status" class="form-select status-select">
                        <option value="Borrador">Borrador (Generado)</option>
                        <option value="Impreso">Impreso (Listo para recolección)</option>
                        <option value="EnTransito">En Tránsito (Recolectado)</option>
                        <option value="Completado">Completado (Firmado y Recibido)</option>
                    </select>
                </div>
                
                <div id="firma-container" style="display: @(m.Status == ManifestStatus.Completado ? "block" : "none");">
                    <div class="mb-3">
                        <label class="form-label">Fecha de Firma (Recepción)</label>
                        <input asp-for="Input.SignedDate" type="date" class="form-control" />
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label">Manifiesto Firmado (PDF/Imagen)</label>
                        <div class="file-drop-area" onclick="document.getElementById('file-upload').click()">
                            <div class="file-drop-icon">📥</div>
                            <div>Haz clic para seleccionar el archivo escaneado</div>
                            <div class="form-text mt-1">Formatos soportados: PDF, JPG, PNG (Max. 5MB)</div>
                            <div id="file-name-display">
                                @if(!string.IsNullOrEmpty(m.SignedManifestFileName))
                                {
                                    <span>Ya subido: @m.SignedManifestFileName</span>
                                }
                            </div>
                        </div>
                        <input type="file" asp-for="Input.SignedFile" id="file-upload" class="d-none" accept=".pdf,.jpg,.jpeg,.png"
                               onchange="document.getElementById('file-name-display').innerText = this.files[0] ? this.files[0].name : ''" />
                    </div>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-success fw-bold py-2">
                        Guardar Registro
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const select = document.querySelector('.status-select');
            const firmaContainer = document.getElementById('firma-container');
            
            select.addEventListener('change', (e) => {
                if(e.target.value === 'Completado') {
                    firmaContainer.style.display = 'block';
                } else {
                    firmaContainer.style.display = 'none';
                }
            });
            
            if(select.value === 'Completado') {
                firmaContainer.style.display = 'block';
            }
        });
    </script>
}
