@page "/Manifest/Consult"
@model ClienteWeb.Pages.Manifest.Consult.IndexModel
@{
    ViewData["Title"] = "Consulta de Manifiestos";
}

<div class="consult-container">

    <!-- Encabezado -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-semibold mb-0" style="color: var(--simar-dark);">
                <i class="bi bi-file-earmark-text me-2" style="color: var(--simar-green);"></i>
                Consulta de Manifiestos
            </h2>
            <p class="text-muted small mb-0">Gestión y seguimiento de manifiestos de residuos</p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a asp-page="/Manifest/Generate/SpecialWaste" class="btn-simar-primary">
                <i class="bi bi-plus-lg"></i> Nuevo especial
            </a>
            <a asp-page="/Manifest/Generate/HazardousWaste" class="btn-simar-primary">
                <i class="bi bi-plus-lg"></i> Nuevo peligroso
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string msg)
    {
        <div class="alert alert-success alert-dismissible fade show py-2 mb-3" role="alert">
            ✅ @msg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filtros -->
    <div class="filter-section-simar">
        <h6><i class="bi bi-funnel me-1"></i> Filtros de búsqueda</h6>

        <form method="get">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label asp-for="FilterManifestNumber" class="form-label-sm">No. de manifiesto</label>
                    <input asp-for="FilterManifestNumber"
                           class="form-control form-control-sm"
                           placeholder="Ej. 002/2026" />
                </div>

                <div class="col-md-3">
                    <label asp-for="FilterSocialReason" class="form-label-sm">Razón social del generador</label>
                    <input asp-for="FilterSocialReason"
                           class="form-control form-control-sm"
                           placeholder="Nombre de empresa o institución" />
                </div>

                <div class="col-md-2">
                    <label asp-for="FilterType" class="form-label-sm">Tipo</label>
                    <select asp-for="FilterType" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        <option value="especial">Residuos especiales</option>
                        <option value="peligroso">Residuos peligrosos</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label asp-for="FilterStatus" class="form-label-sm">Estado</label>
                    <select asp-for="FilterStatus" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        <option value="borrador">Borrador</option>
                        <option value="en_transito">En tránsito</option>
                        <option value="completado">Completado</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label asp-for="FilterDateFrom" class="form-label-sm">Fecha desde</label>
                    <input asp-for="FilterDateFrom" type="date" class="form-control form-control-sm" />
                </div>

                <div class="col-md-2">
                    <label asp-for="FilterDateTo" class="form-label-sm">Fecha hasta</label>
                    <input asp-for="FilterDateTo" type="date" class="form-control form-control-sm" />
                </div>
            </div>

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn-simar-primary">
                    <i class="bi bi-search"></i> Buscar
                </button>
                <a asp-page="/Manifest/Consult/Index" class="btn-simar-outline-gray">
                    <i class="bi bi-x-circle"></i> Limpiar
                </a>
            </div>
        </form>
    </div>

    @if (Model.Results.Any())
    {
        <div class="results-summary">
            Se encontraron <strong>@Model.Results.Count</strong> manifiestos.
        </div>

        <div class="table-responsive-simar">
            <table class="table-simar">
                <thead>
                    <tr>
                        <th>No. manifiesto</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th>Razón social generador</th>
                        <th>Municipio</th>
                        <th>Fecha</th>
                        <th>Residuo(s)</th>
                        <th>Transportista</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Results)
                    {
                        <tr>
                            <td class="fw-bold">@m.ManifestNumber</td>
                            <td>
                                @if (m.Type == "peligroso")
                                {
                                    <span class="badge-simar badge-simar-peligroso">Peligrosos</span>
                                }
                                else
                                {
                                    <span class="badge-simar badge-simar-especial">Especiales</span>
                                }
                            </td>
                            <td>
                                @switch (m.Status)
                                {
                                    case "completado":
                                        <span class="badge-simar badge-simar-completada">Completado</span>
                                        break;
                                    case "en_transito":
                                        <span class="badge-simar badge-simar-enruta">En tránsito</span>
                                        break;
                                    default:
                                        <span class="badge-simar badge-simar-programada">Borrador</span>
                                        break;
                                }
                            </td>
                            <td>@m.SocialReason</td>
                            <td>@m.Municipality</td>
                            <td>@m.ManifestDate.ToString("dd/MM/yyyy")</td>
                            <td>@m.ResidueSummary</td>
                            <td>@m.TransporterName</td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center flex-wrap">
                                    <a asp-page="/Manifest/Consult/Detail"
                                       asp-route-id="@m.Id"
                                       class="action-btn ver">
                                        <i class="bi bi-eye"></i> Ver
                                    </a>

                                    @if (m.Type == "peligroso")
                                    {
                                        <a asp-page="/Manifest/Print/HazardousWaste"
                                           asp-route-id="@m.Id"
                                           class="action-btn ver">
                                            <i class="bi bi-printer"></i> Imprimir
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-page="/Manifest/Print/SpecialWaste"
                                           asp-route-id="@m.Id"
                                           class="action-btn ver">
                                            <i class="bi bi-printer"></i> Imprimir
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state-simar">
            <i class="bi bi-file-earmark-text"></i>
            <h4>No se encontraron manifiestos</h4>
            <p class="text-muted mb-3">Ajusta los filtros o genera un nuevo manifiesto.</p>
            <div class="d-flex gap-2 justify-content-center flex-wrap">
                <a asp-page="/Manifest/Generate/SpecialWaste" class="btn-simar-outline">
                    Nuevo especial
                </a>
                <a asp-page="/Manifest/Generate/HazardousWaste" class="btn-simar-outline">
                    Nuevo peligroso
                </a>
            </div>
        </div>
    }

</div>
