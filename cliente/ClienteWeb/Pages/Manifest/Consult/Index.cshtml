@page "/Manifest/Consult"
@model ClienteWeb.Pages.Manifest.Consult.IndexModel
@{
    ViewData["Title"] = "Consult Manifests";
}

<style>
    .consult-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 1.5rem 1rem;
    }

    .page-heading {
        font-size: 1.4rem;
        font-weight: 700;
        color: #1a3a5c;
        border-left: 4px solid #1a3a5c;
        padding-left: 0.75rem;
        margin-bottom: 1.25rem;
    }

    .filters-card {
        background: #f5f9ff;
        border: 1px solid #c8d6e3;
        border-radius: 8px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1.5rem;
    }

    .filters-title {
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #1a3a5c;
        letter-spacing: 0.08em;
        margin-bottom: 0.75rem;
    }

    .form-label-sm {
        font-size: 0.75rem;
        font-weight: 600;
        color: #4a5568;
        margin-bottom: 2px;
        display: block;
    }

    .badge-borrador   { background:#6c757d; color:#fff; font-size:.7rem; padding:3px 8px; border-radius:10px; }
    .badge-impreso    { background:#0d6efd; color:#fff; font-size:.7rem; padding:3px 8px; border-radius:10px; }
    .badge-transito   { background:#fd7e14; color:#fff; font-size:.7rem; padding:3px 8px; border-radius:10px; }
    .badge-completado { background:#198754; color:#fff; font-size:.7rem; padding:3px 8px; border-radius:10px; }

    .badge-especial  { background-color:#1a3a5c; color:#fff; font-size:.7rem; padding:3px 8px; border-radius:10px; }
    .badge-peligroso { background-color:#7b2d2d; color:#fff; font-size:.7rem; padding:3px 8px; border-radius:10px; }

    .results-table th {
        font-size: 0.75rem;
        white-space: nowrap;
        background-color: #1a3a5c;
        color: #fff;
        font-weight: 600;
        border-color: #1a3a5c;
    }

    .results-table td {
        font-size: 0.82rem;
        vertical-align: middle;
    }

    .results-table tbody tr:hover {
        background-color: #eef4fb;
    }

    .no-results {
        text-align: center;
        padding: 3rem 1rem;
        color: #8a9bb0;
    }

    .no-results-icon {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }

    .summary-bar {
        font-size: 0.8rem;
        color: #4a5568;
        margin-bottom: 0.75rem;
    }

    .action-btn {
        font-size: 0.75rem;
        padding: 3px 10px;
    }

    .quick-actions {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }
</style>

<div class="consult-container">

    <h1 class="page-heading">Consulta de Manifiestos</h1>

    @if (TempData["SuccessMessage"] is string msg)
    {
        <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
            ✅ @msg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="quick-actions">
        <a asp-page="/Manifest/Generate/SpecialWaste" class="btn btn-primary btn-sm">
            + Nuevo manifiesto especial
        </a>
        <a asp-page="/Manifest/Generate/HazardousWaste" class="btn btn-danger btn-sm">
            + Nuevo manifiesto peligroso
        </a>
    </div>

    <div class="filters-card">
        <div class="filters-title">🔍 Filtros de búsqueda</div>

        <form method="get">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label asp-for="FilterManifestNumber" class="form-label-sm">No. de manifiesto</label>
                    <input asp-for="FilterManifestNumber"
                           class="form-control form-control-sm"
                           placeholder="Ej. 002/2026" />
                </div>

                <div class="col-md-3">
                    <label asp-for="FilterSocialReason" class="form-label-sm">Razón social del generador</label>
                    <input asp-for="FilterSocialReason"
                           class="form-control form-control-sm"
                           placeholder="Nombre de empresa o institución" />
                </div>

                <div class="col-md-2">
                    <label asp-for="FilterType" class="form-label-sm">Tipo de manifiesto</label>
                    <select asp-for="FilterType" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        <option value="especial">Residuos especiales</option>
                        <option value="peligroso">Residuos peligrosos</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label asp-for="FilterStatus" class="form-label-sm">Estado</label>
                    <select asp-for="FilterStatus" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        <option value="borrador">Borrador</option>
                        <option value="impreso">Impreso</option>
                        <option value="en_transito">En tránsito</option>
                        <option value="completado">Completado</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label asp-for="FilterDateFrom" class="form-label-sm">Fecha desde</label>
                    <input asp-for="FilterDateFrom" type="date" class="form-control form-control-sm" />
                </div>

                <div class="col-md-2">
                    <label asp-for="FilterDateTo" class="form-label-sm">Fecha hasta</label>
                    <input asp-for="FilterDateTo" type="date" class="form-control form-control-sm" />
                </div>
            </div>

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn btn-primary btn-sm px-3">Buscar</button>
                <a asp-page="/Manifest/Consult/Index" class="btn btn-outline-secondary btn-sm">Limpiar</a>
            </div>
        </form>
    </div>

    @if (Model.Results.Any())
    {
        <div class="summary-bar">
            Se encontraron <strong>@Model.Results.Count</strong> manifiestos.
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-sm results-table">
                <thead>
                    <tr>
                        <th>No. manifiesto</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th>Razón social generador</th>
                        <th>Municipio</th>
                        <th>Fecha</th>
                        <th>Residuo(s)</th>
                        <th>Transportista</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Results)
                    {
                        <tr>
                            <td class="fw-bold">@m.ManifestNumber</td>
                            <td>
                                @if (m.Type == "peligroso")
                                {
                                    <span class="badge-peligroso">Peligrosos</span>
                                }
                                else
                                {
                                    <span class="badge-especial">Especiales</span>
                                }
                            </td>
                            <td>
                                @switch (m.Status)
                                {
                                    case "completado":
                                        <span class="badge-completado">Completado</span>
                                        break;
                                    case "en_transito":
                                        <span class="badge-transito">En tránsito</span>
                                        break;
                                    case "impreso":
                                        <span class="badge-impreso">Impreso</span>
                                        break;
                                    default:
                                        <span class="badge-borrador">Borrador</span>
                                        break;
                                }
                            </td>
                            <td>@m.SocialReason</td>
                            <td>@m.Municipality</td>
                            <td>@m.ManifestDate.ToString("dd/MM/yyyy")</td>
                            <td>@m.ResidueSummary</td>
                            <td>@m.TransporterName</td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center flex-wrap">
                                    <a asp-page="/Manifest/Consult/Detail"
                                       asp-route-id="@m.Id"
                                       class="btn btn-outline-primary action-btn">
                                        Ver
                                    </a>

                                    @if (m.Type == "peligroso")
                                    {
                                        <a asp-page="/Manifest/Print/HazardousWaste"
                                           asp-route-id="@m.Id"
                                           class="btn btn-outline-danger action-btn">
                                            Imprimir
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-page="/Manifest/Print/SpecialWaste"
                                           asp-route-id="@m.Id"
                                           class="btn btn-outline-secondary action-btn">
                                            Imprimir
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="no-results">
            <div class="no-results-icon">📋</div>
            <div class="fw-semibold">No se encontraron manifiestos</div>
            <div class="mt-1 small">
                Ajusta los filtros o genera un nuevo manifiesto:
            </div>
            <div class="mt-3 d-flex gap-2 justify-content-center flex-wrap">
                <a asp-page="/Manifest/Generate/SpecialWaste" class="btn btn-outline-primary btn-sm">
                    Nuevo especial
                </a>
                <a asp-page="/Manifest/Generate/HazardousWaste" class="btn btn-outline-danger btn-sm">
                    Nuevo peligroso
                </a>
            </div>
        </div>
    }

</div>