@page "/Manifest/Consult/Detail/{id}"
@model ClienteWeb.Pages.Manifest.Consult.DetailModel
@{
    ViewData["Title"] = $"Detalle – {Model.Manifest.ManifestNumber}";
    var m = Model.Manifest;
    bool esEspecial = m.Type == "especial";
    string sHdr = esEspecial ? "consult-section-header especial" : "consult-section-header peligroso";
    var fechaEmision = esEspecial
        ? (m.ManifestDate?.ToString("dd/MM/yyyy") ?? "–")
        : (m.GeneratorSignDate?.ToString("dd/MM/yyyy") ?? "–");
}

<div class="consult-container">

    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <a asp-page="/Manifest/Consult/Index" class="btn-simar-outline-gray">← Volver</a>
        <h1 class="detail-heading">@m.ManifestNumber</h1>

        @if (esEspecial)
        {
            <span class="badge-simar badge-simar-especial">Residuos Especiales</span>
        }
        else
        {
            <span class="badge-simar badge-simar-peligroso">Residuos Peligrosos</span>
        }

        @switch (m.Status)
        {
            case ManifestStatus.Completado:
                <span class="badge-simar badge-simar-completada">Completado</span>
                break;
            case ManifestStatus.EnTransito:
                <span class="badge-simar badge-simar-enruta">En tránsito</span>
                break;
            default:
                <span class="badge-simar badge-simar-programada">Borrador</span>
                break;
        }

        <div class="ms-auto d-flex gap-2">
            @if (m.Status == ManifestStatus.EnTransito)
            {
                <button type="button"
                        class="btn-simar-primary"
                        data-bs-toggle="modal"
                        data-bs-target="#modalRegistrarFirma">
                    <i class="bi bi-pen"></i> Registrar Firma
                </button>
            }
            @if (m.Status == ManifestStatus.Borrador)
            {
                <form method="post" asp-page-handler="Transitar" class="d-inline">
                    <input type="hidden" name="id" value="@m.Id" />
                    <button type="submit" class="btn-simar-primary">
                        <i class="bi bi-arrow-right-circle"></i> Enviar a tránsito
                    </button>
                </form>
                <a asp-page="/Manifest/Consult/Edit"
                   asp-route-id="@m.Id"
                   class="btn-simar-secondary">
                    <i class="bi bi-pencil"></i> Editar Manifiesto
                </a>
            }
        </div>
    </div>

    @if (m.Status == ManifestStatus.Completado && !string.IsNullOrEmpty(m.SignedManifestFileName))
    {
        <div class="consult-section-card">
            <div class="consult-section-header completado" style="background:#198754;" onclick="toggleSection(this)">
                <span>Manifiesto Firmado</span>
                <span class="chevron">▲</span>
            </div>
            <div class="consult-section-body">
                <div class="d-flex align-items-center gap-3">
                    <div>
                        <strong>Archivo:</strong> @m.SignedManifestFileName<br />
                        <strong>Fecha de firma:</strong> @m.SignedDate?.ToString("dd/MM/yyyy")
                    </div>
                    <div class="ms-auto">
                        <a href="/api/manifiestos/@m.Id/firma"
                           target="_blank"
                           class="btn-simar-outline">
                            <i class="bi bi-file-earmark-pdf"></i> Ver manifiesto firmado
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- GENERADOR -->
    <div class="consult-section-card">
        <div class="@sHdr" onclick="toggleSection(this)">
            <span>Datos del Generador</span>
            <span class="chevron">▲</span>
        </div>
        <div class="consult-section-body">
            <dl class="detail-dl">
                <dt>No. Registro @(esEspecial ? "SEDEMA" : "SEMARNAT")</dt>
                <dd>@D(m.EnvironmentalRegistrationNumber)</dd>

                <dt>No. Manifiesto</dt>
                <dd>@D(m.ManifestNumber)</dd>

                <dt>Razón Social</dt>
                <dd>@D(m.SocialReason)</dd>

                @if (esEspecial)
                {
                    <dt>Domicilio</dt>
                    <dd>@D(m.Address)</dd>
                }
                else
                {
                    <dt>Calle</dt>
                    <dd>@D(m.Street)</dd>

                    <dt>Núm. Ext / Int</dt>
                    <dd>@($"{D(m.ExteriorNumber)} / {D(m.InteriorNumber)}")</dd>

                    <dt>Colonia</dt>
                    <dd>@D(m.Colony)</dd>
                }

                <dt>C.P.</dt>
                <dd>@D(m.PostalCode)</dd>

                <dt>Municipio</dt>
                <dd>@D(m.Municipality)</dd>

                @if (!esEspecial)
                {
                    <dt>Estado</dt>
                    <dd>@D(m.State)</dd>
                }

                <dt>Teléfono</dt>
                <dd>@D(m.PhoneNumber)</dd>

                @if (!string.IsNullOrWhiteSpace(m.Email))
                {
                    <dt>Correo</dt>
                    <dd>@m.Email</dd>
                }

                @if (esEspecial && m.ManifestDate.HasValue)
                {
                    <dt>Fecha</dt>
                    <dd>@m.ManifestDate.Value.ToString("dd/MM/yyyy") @(m.ManifestTime.HasValue ? m.ManifestTime.Value.ToString("HH:mm") : "")</dd>
                }

                @if (!esEspecial && m.GeneratorSignDate.HasValue)
                {
                    <dt>Fecha</dt>
                    <dd>@m.GeneratorSignDate.Value.ToString("dd/MM/yyyy")</dd>
                }

                @if (!esEspecial && !string.IsNullOrWhiteSpace(m.SafeHandlingInstructions))
                {
                    <dt>Instrucciones de manejo seguro</dt>
                    <dd>@m.SafeHandlingInstructions</dd>
                }

                <dt>Nombre del responsable</dt>
                <dd>@D(m.GeneratorResponsibleName)</dd>

                @if (esEspecial && !string.IsNullOrWhiteSpace(m.GeneratorObservations))
                {
                    <dt>Observaciones</dt>
                    <dd>@m.GeneratorObservations</dd>
                }
            </dl>
        </div>
    </div>

    <!-- RESIDUOS -->
    <div class="consult-section-card">
        <div class="@sHdr" onclick="toggleSection(this)">
            <span>Residuos</span>
            <span class="chevron">▲</span>
        </div>
        <div class="consult-section-body p-0">
            @if (esEspecial)
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered residue-table mb-0">
                        <thead>
                            <tr>
                                <th>Clave</th>
                                <th>Nombre del Residuo</th>
                                <th>Envase</th>
                                <th>Capacidad</th>
                                <th>Peso</th>
                                <th>Unidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in m.SpecialResidues)
                            {
                                <tr>
                                    <td>@r.ResidueKey</td>
                                    <td>@r.ResidueName</td>
                                    <td>@r.ContainerType</td>
                                    <td>@r.ContainerCapacity</td>
                                    <td class="fw-bold">@r.Weight</td>
                                    <td>@r.Unit</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered residue-table peligroso mb-0">
                        <thead>
                            <tr>
                                <th>Nombre del Residuo</th>
                                <th>Clasificación CRETIBM</th>
                                <th>Envase</th>
                                <th>Capacidad</th>
                                <th>Cantidad (kg)</th>
                                <th>Etiqueta</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in m.HazardousResidues)
                            {
                                <tr>
                                    <td>@r.ResidueName</td>
                                    <td>
                                        @if (r.IsCorrosive)  { <span class="cretibm-tag">C</span> }
                                        @if (r.IsReactive)   { <span class="cretibm-tag">R</span> }
                                        @if (r.IsExplosive)  { <span class="cretibm-tag">E</span> }
                                        @if (r.IsToxic)      { <span class="cretibm-tag">T</span> }
                                        @if (r.IsFlammable)  { <span class="cretibm-tag">I</span> }
                                        @if (r.IsBiological) { <span class="cretibm-tag">B</span> }
                                        @if (r.IsMutagenic)  { <span class="cretibm-tag">M</span> }
                                    </td>
                                    <td>@r.ContainerType</td>
                                    <td>@r.ContainerCapacity</td>
                                    <td class="fw-bold">@r.AmountKg</td>
                                    <td>
                                        @if (r.HasLabel == true)
                                        {
                                            <span class="text-success fw-bold">Sí</span>
                                        }
                                        else if (r.HasLabel == false)
                                        {
                                            <span class="text-danger">No</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">–</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- TRANSPORTISTA -->
    <div class="consult-section-card">
        <div class="@sHdr" onclick="toggleSection(this)">
            <span>Transportista</span>
            <span class="chevron">▲</span>
        </div>
        <div class="consult-section-body">
            <dl class="detail-dl">
                <dt>No. Autorización</dt>
                <dd>@D(m.TransporterAuthorizationNumber)</dd>

                @if (!esEspecial && !string.IsNullOrWhiteSpace(m.TransporterSCTPermit))
                {
                    <dt>No. Permiso SCT</dt>
                    <dd>@m.TransporterSCTPermit</dd>
                }

                <dt>Razón Social</dt>
                <dd>@D(m.TransporterSocialReason)</dd>

                @if (esEspecial)
                {
                    <dt>Domicilio</dt>
                    <dd>@D(m.TransporterAddress)</dd>
                }
                else
                {
                    <dt>Calle</dt>
                    <dd>@($"{D(m.TransporterStreet)} {D(m.TransporterExteriorNumber)} {D(m.TransporterInteriorNumber)}")</dd>

                    <dt>Colonia</dt>
                    <dd>@D(m.TransporterColony)</dd>
                }

                <dt>C.P. / Municipio</dt>
                <dd>@($"{D(m.TransporterPostalCode)} – {D(m.TransporterMunicipality)}")</dd>

                @if (!string.IsNullOrWhiteSpace(m.TransporterState))
                {
                    <dt>Estado</dt>
                    <dd>@m.TransporterState</dd>
                }

                <dt>Teléfono</dt>
                <dd>@D(m.TransporterPhone)</dd>

                @if (!string.IsNullOrWhiteSpace(m.TransporterEmail))
                {
                    <dt>Correo</dt>
                    <dd>@m.TransporterEmail</dd>
                }

                <dt>Tipo de vehículo</dt>
                <dd>@D(m.VehicleType)</dd>

                <dt>No. de placa</dt>
                <dd>@D(m.VehiclePlate)</dd>

                @if (!string.IsNullOrWhiteSpace(m.DriverLicense))
                {
                    <dt>Licencia</dt>
                    <dd>@m.DriverLicense</dd>
                }

                <dt>Ruta</dt>
                <dd>@D(m.TransportRoute)</dd>

                @if (esEspecial && m.TransporterDate.HasValue)
                {
                    <dt>Fecha de recepción</dt>
                    <dd>@m.TransporterDate.Value.ToString("dd/MM/yyyy") @(m.TransporterTime.HasValue ? m.TransporterTime.Value.ToString("HH:mm") : "")</dd>
                }

                @if (!esEspecial && m.TransporterSignDate.HasValue)
                {
                    <dt>Fecha</dt>
                    <dd>@m.TransporterSignDate.Value.ToString("dd/MM/yyyy")</dd>
                }

                <dt>Nombre del responsable</dt>
                <dd>@D(m.TransporterResponsibleName)</dd>

                @if (!string.IsNullOrWhiteSpace(m.TransporterObservations))
                {
                    <dt>Observaciones</dt>
                    <dd>@m.TransporterObservations</dd>
                }
            </dl>
        </div>
    </div>

    <!-- DESTINATARIO -->
    <div class="consult-section-card">
        <div class="@sHdr" onclick="toggleSection(this)">
            <span>Destinatario / Disposición Final</span>
            <span class="chevron">▲</span>
        </div>
        <div class="consult-section-body">
            <dl class="detail-dl">
                @if (!string.IsNullOrWhiteSpace(m.ReceiverAuthorizationNumber))
                {
                    <dt>No. Autorización</dt>
                    <dd>@m.ReceiverAuthorizationNumber</dd>
                }

                <dt>Razón Social</dt>
                <dd>@D(m.ReceiverSocialReason)</dd>

                @if (esEspecial)
                {
                    <dt>Domicilio</dt>
                    <dd>@D(m.ReceiverAddress)</dd>
                }
                else
                {
                    <dt>Calle</dt>
                    <dd>@($"{D(m.ReceiverStreet)} {D(m.ReceiverExteriorNumber)} {D(m.ReceiverInteriorNumber)}")</dd>

                    <dt>Colonia</dt>
                    <dd>@D(m.ReceiverColony)</dd>
                }

                <dt>C.P. / Municipio</dt>
                <dd>@($"{D(m.ReceiverPostalCode)} – {D(m.ReceiverMunicipality)}")</dd>

                @if (!string.IsNullOrWhiteSpace(m.ReceiverState))
                {
                    <dt>Estado</dt>
                    <dd>@m.ReceiverState</dd>
                }

                @if (!string.IsNullOrWhiteSpace(m.ReceiverPhone))
                {
                    <dt>Teléfono</dt>
                    <dd>@m.ReceiverPhone</dd>
                }

                @if (!string.IsNullOrWhiteSpace(m.ReceiverEmail))
                {
                    <dt>Correo</dt>
                    <dd>@m.ReceiverEmail</dd>
                }

                @if (!string.IsNullOrWhiteSpace(m.DisposalType))
                {
                    <dt>Tipo de disposición</dt>
                    <dd>@m.DisposalType</dd>
                }

                @if (esEspecial && m.ReceiverDate.HasValue)
                {
                    <dt>Fecha</dt>
                    <dd>@m.ReceiverDate.Value.ToString("dd/MM/yyyy")</dd>
                }

                @if (!esEspecial && m.ReceiverSignDate.HasValue)
                {
                    <dt>Fecha</dt>
                    <dd>@m.ReceiverSignDate.Value.ToString("dd/MM/yyyy")</dd>
                }

                @if (!string.IsNullOrWhiteSpace(m.ReceiverPersonName))
                {
                    <dt>Persona que recibe</dt>
                    <dd>@m.ReceiverPersonName</dd>
                }

                <dt>Nombre del responsable</dt>
                <dd>@D(m.ReceiverResponsibleName)</dd>

                @if (!string.IsNullOrWhiteSpace(m.ReceiverObservations))
                {
                    <dt>Observaciones</dt>
                    <dd>@m.ReceiverObservations</dd>
                }
            </dl>
        </div>
    </div>

    <div class="d-flex justify-content-between mt-3">
        <a asp-page="/Manifest/Consult/Index" class="btn-simar-outline-gray">← Volver a la lista</a>
        @if (m.Status == ManifestStatus.Borrador)
        {
            <div class="d-flex gap-2">
                <a asp-page="/Manifest/Consult/Edit"
                   asp-route-id="@m.Id"
                   class="btn-simar-secondary">
                    <i class="bi bi-pencil"></i> Editar este manifiesto
                </a>
                <form method="post" asp-page-handler="Transitar">
                    <input type="hidden" name="id" value="@m.Id" />
                    <button type="submit" class="btn-simar-primary">
                        <i class="bi bi-arrow-right-circle"></i> Enviar a tránsito
                    </button>
                </form>
            </div>
        }
    </div>
</div>

@if (m.Status == ManifestStatus.EnTransito)
{
    <!-- MODAL: Registrar Firma -->
    <div class="modal fade" id="modalRegistrarFirma" tabindex="-1" aria-labelledby="modalRegistrarFirmaLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header @(esEspecial ? "especial" : "peligroso") register-card-header">
                    <h5 class="modal-title" id="modalRegistrarFirmaLabel">Subir manifiesto firmado</h5>
                    <span class="badge-simar @(esEspecial ? "badge-simar-especial" : "badge-simar-peligroso") ms-2">
                        @(esEspecial ? "Especial" : "Peligroso")
                    </span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <div class="modal-body">
                    <div class="info-summary @(esEspecial ? "especial" : "peligroso") mb-3">
                        <div class="row">
                            <div class="col-sm-6 mb-2">
                                <strong>Folio:</strong><br />@m.ManifestNumber
                            </div>
                            <div class="col-sm-6 mb-2">
                                <strong>Fecha base:</strong><br />@fechaEmision
                            </div>
                            <div class="col-sm-12">
                                <strong>Generador:</strong><br />@m.SocialReason
                            </div>
                        </div>
                    </div>

                    <form id="formRegistrarFirma" method="post" enctype="multipart/form-data" asp-page-handler="Register">
                        <input type="hidden" name="RegisterInput.Id" value="@m.Id" />

                        <div class="mb-3">
                            <label for="RegisterInput_SignedDate" class="form-label-sm">Fecha de firma / recepción final</label>
                            <input type="date"
                                   id="RegisterInput_SignedDate"
                                   name="RegisterInput.SignedDate"
                                   class="form-control"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label-sm">Manifiesto firmado y sellado (PDF)</label>
                            <div class="file-drop-area"
                                 id="dropAreaModal"
                                 onclick="document.getElementById('file-upload-modal').click()"
                                 ondragover="event.preventDefault(); this.classList.add('dragover')"
                                 ondragleave="this.classList.remove('dragover')"
                                 ondrop="handleDropModal(event)">
                                <div class="file-drop-icon">📄</div>
                                <div>Haz clic o arrastra aquí el PDF firmado</div>
                                <div class="form-hint mt-1">Solo PDF · máx. 10 MB</div>
                                <div id="file-name-display-modal"></div>
                            </div>
                            <input type="file"
                                   name="RegisterInput.SignedFile"
                                   id="file-upload-modal"
                                   class="d-none"
                                   accept=".pdf"
                                   onchange="onFileSelectedModal(this)" />
                        </div>

                        <div id="pdf-preview-modal" style="display:none;" class="mb-3">
                            <span class="form-label-sm">Vista previa del archivo seleccionado</span>
                            <iframe id="pdf-preview-frame-modal"
                                    style="width:100%; height:420px; border:1px solid #c8d6e3; border-radius:8px; margin-top:0.4rem;"
                                    title="Vista previa"></iframe>
                        </div>
                    </form>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-simar-outline-gray" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" form="formRegistrarFirma" class="btn-simar-primary">
                        <i class="bi bi-check2-circle"></i> Guardar firma y marcar como completado
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@functions {
    static string D(string? s) => string.IsNullOrWhiteSpace(s) ? "–" : s;
}

@section Scripts {
<script>
    function toggleSection(header) {
        const body = header.nextElementSibling;
        const chevron = header.querySelector('.chevron');
        const isOpen = body.style.display !== 'none';
        body.style.display = isOpen ? 'none' : '';
        chevron.textContent = isOpen ? '▼' : '▲';
    }

    function handleDropModal(event) {
        event.preventDefault();
        event.currentTarget.classList.remove('dragover');
        const file = event.dataTransfer.files[0];
        if (!file) return;
        if (file.type !== 'application/pdf') {
            alert('Solo se permiten archivos PDF.');
            return;
        }
        const input = document.getElementById('file-upload-modal');
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        showPreviewModal(file);
    }

    function onFileSelectedModal(input) {
        const file = input.files[0];
        if (!file) return;
        showPreviewModal(file);
    }

    function showPreviewModal(file) {
        const display = document.getElementById('file-name-display-modal');
        if (display) display.textContent = file.name;

        const preview = document.getElementById('pdf-preview-modal');
        const frame = document.getElementById('pdf-preview-frame-modal');
        if (preview && frame) {
            frame.src = URL.createObjectURL(file);
            preview.style.display = 'block';
        }
    }

    // Limpiar preview al cerrar el modal
    document.getElementById('modalRegistrarFirma')?.addEventListener('hidden.bs.modal', function () {
        const input = document.getElementById('file-upload-modal');
        if (input) input.value = '';
        const display = document.getElementById('file-name-display-modal');
        if (display) display.textContent = '';
        const preview = document.getElementById('pdf-preview-modal');
        if (preview) preview.style.display = 'none';
    });
</script>
}
