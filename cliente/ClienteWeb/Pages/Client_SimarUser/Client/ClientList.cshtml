                            <input type="text" id="editEmail" class="form-control" placeholder="Email" />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-lock-fill me-1" style="color: var(--simar-green);"></i>Contraseña:</strong>
                            <div class="input-group">
                                <input type="password" id="editPassword" class="form-control" placeholder="Contraseña" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('editPassword', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>

                        <!--pendiente de agregar para editar ^ ^-->

                        <div class="col-md-6">
                            <strong><i class="bi bi-person-badge-fill me-1" style="color: var(--simar-green);"></i> Nombre:</strong>
                            <input asp-for="EditInput.Name" type="text" id="editNombre" class="form-control" placeholder="Nombre" />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-card-text me-1" style="color: var(--simar-green);"></i>Razon social:</strong>
                            <input asp-for="EditInput.BusinessName" type="text" id="editRazonSocial" class="form-control" placeholder="Razon social" required />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-envelope-fill me-1" style="color: var(--simar-green);"></i>Email de contacto:</strong>
                            <input asp-for="EditInput.ContactEmail" type="text" id="editEmailContacto" class="form-control" placeholder="Email contacto" required />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-telephone-fill me-1" style="color: var(--simar-green);"></i> Teléfono:</strong>
                            <input asp-for="EditInput.Phone" type="text" id="editTelefono" class="form-control" placeholder="Teléfono" />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-geo-alt-fill me-1" style="color: var(--simar-green);"></i> Dirección:</strong>
                            <input asp-for="EditInput.Address" type="text" id="editDireccion" class="form-control" placeholder="Dirección" />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-file-text-fill me-1" style="color: var(--simar-green);"></i>RFC:</strong>
                            <input asp-for="EditInput.RFC" type="text" id="editRFC" class="form-control" placeholder="RFC" />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-tree-fill me-1" style="color: var(--simar-green);"></i> Número de Semarnat:</strong>
                            <input asp-for="EditInput.SemarnatNum" type="text" id="editSemarnat" class="form-control" placeholder="SEMARNAT" />
                        </div>

                        <div class="col-12">
                            <strong><i class="bi bi-file-pdf-fill me-1" style="color: var(--simar-green);"></i>Certificado SAT</strong>
                            <input asp-for="CertificadoFile" type="file" id="editCertificado" class="form-control" />
                        </div>

                    </div>

