<script>

    function validarArchivoPDF(inputId) {

        const archivo = document.getElementById(inputId).files[0];

        if (!archivo) {
            return true;
        }

        const maxSize = 5 * 1024 * 1024;

        if (archivo.size > maxSize) {
            alert("El archivo no puede exceder los 5 MB");
            return false;
        }

        const extension = archivo.name
            .split('.')
            .pop()
            .toLowerCase();

        if (extension !== "pdf") {
            alert("Solo se permiten archivos PDF");
            return false;
        }

        return true;
    }

</script>

<script>
    let filaActual = null;

    function abrirModalEditar(id) {

        filaActual = document.getElementById("cliente-" + id);

        document.getElementById("editId").value = id;

        document.getElementById("editNombre").value = filaActual.getAttribute("data-nombre");
        document.getElementById("editRazonSocial").value = filaActual.getAttribute("data-razonSocial");
        document.getElementById("editUsername").value = filaActual.getAttribute("data-username");
        document.getElementById("editEmail").value = filaActual.getAttribute("data-email");
        document.getElementById("editEmailContacto").value = filaActual.getAttribute("data-emailContacto");
        document.getElementById("editTelefono").value = filaActual.getAttribute("data-telefono");
        document.getElementById("editDireccion").value = filaActual.getAttribute("data-direccion");
        document.getElementById("editRFC").value = filaActual.getAttribute("data-rfc");
        document.getElementById("editSemarnat").value = filaActual.getAttribute("data-semarnat");

        let modal = new bootstrap.Modal(document.getElementById('modalEditar'));
        modal.show();
    }

    function cerrarModalEditar() {
        document.getElementById("modalEditar").style.display = "none";
    }

    function guardarEdicion(){
        const updatedData = {};

        updatedData.id = parseInt(document.getElementById("editId").value);

        const nombreNuevo = document.getElementById("editNombre").value;
        const nombreOriginal = filaActual.getAttribute("data-nombre");

        if (nombreNuevo !== nombreOriginal) {
            updatedData.name = nombreNuevo;
        }

        const telefonoNuevo = document.getElementById("editTelefono").value;
        const telefonoOriginal = filaActual.getAttribute("data-telefono");

        if (telefonoNuevo !== telefonoOriginal) {
            updatedData.phone = telefonoNuevo;
        }

        const direccionNueva = document.getElementById("editDireccion").value;
        const direccionOriginal = filaActual.getAttribute("data-direccion");

        if (direccionNueva !== direccionOriginal) {
            updatedData.address = direccionNueva;
        }

        const razonSocialNueva = document.getElementById("editRazonSocial").value;
        const razonSocialOriginal = filaActual.getAttribute("data-razonSocial");

        if (razonSocialNueva !== razonSocialOriginal) {
            updatedData.businessName = razonSocialNueva;
        }

        const emailContactoNueva = document.getElementById("editEmailContacto").value;
        const emailContactoOriginal = filaActual.getAttribute("data-emailContacto");

        if (emailContactoNueva !== emailContactoOriginal) {
            updatedData.contactEmail = emailContactoNueva;
        }

        const rfcNueva = document.getElementById("editRFC").value;
        const rfcOriginal = filaActual.getAttribute("data-rfc");

        if (rfcNueva !== rfcOriginal) {
            updatedData.RFC = rfcNueva;
        }

        const semarnatNumNueva = document.getElementById("editSemarnat").value;
        const semarnatNumOriginal = filaActual.getAttribute("data-semarnat");

        if (semarnatNumNueva !== semarnatNumOriginal) {
            updatedData.SemarnatNum = semarnatNumNueva;
        }
        


        const certificado = document.getElementById("editCertificado").files[0];

        if (certificado) {

            if (!validarArchivoPDF("editCertificado")) {
                return;
            }
        }


        // Si no hay cambios ni certificado
        if (Object.keys(updatedData).length === 1 && !certificado) {
            alert("No se realizaron cambios");
            return;
        }

        fetch('/Client_SimarUser/Client/ClientList?handler=Editar', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(updatedData)
        })
        .then(response => response.json())
        .then(data => {

            if (data.expired) {
                alert("Tu sesión expiró");
                window.location.href = "/inicio";
                return;
            }

            if (!data.success) {
                alert(data.message || "Error");
                return;
            }

            // Si NO hay certificado
            if (!certificado) {
                alert("Cliente actualizado");
                location.reload();
                return;
            }

            // Subir certificado
            const formData = new FormData();

            formData.append("file", certificado);

            fetch(`/Client_SimarUser/Client/ClientList?handler=ActualizarCertificado&id=${updatedData.id}`, {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(certData => {

                if (certData.expired) {
                    alert("Tu sesión expiró");
                    window.location.href = "/inicio";
                    return;
                }

                if (!certData.success) {
                    alert("Cliente actualizado, pero falló el certificado");
                    return;
                }

                alert("Cliente y certificado actualizados");
                location.reload();
            });
        });

    }
</script>

