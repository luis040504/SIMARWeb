@page
@model ClienteWeb.Pages.Client_SimarUser.Client.ClientListModel
@{
    ViewData["Title"] = "Listado de Clientes";
}

@if (TempData["Mensaje"] != null)
{
    <div class="card-simar-subtle text-simar-green" style="padding:10px; text-align:center;">
        @TempData["Mensaje"]
    </div>
}

<style>

    /* Tabla mejorada */
    .table-custom {
        background: white;
        border-radius: 16px;
        overflow: visible;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
    }

        .table-custom thead th {
            background: var(--simar-gray-light);
            color: var(--simar-dark);
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--simar-green);
            padding: 1rem;
        }

        .table-custom tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-bottom: 1px solid var(--simar-border);
        }

        .table-custom tbody tr:hover {
            background: rgba(90, 173, 49, 0.03);
        }

        .table-custom table {
            border-radius: 16px;
            overflow: hidden;
        }

    /* Barra de búsqueda */
    .search-box {
        border: 1px solid var(--simar-border);
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.2s;
    }

        .search-box:focus-within {
            border-color: var(--simar-green);
            box-shadow: 0 0 0 2px rgba(90, 173, 49, 0.2);
        }

        .search-box input {
            border: none;
            padding: 0.6rem 1rem;
            font-size: 0.9rem;
        }

            .search-box input:focus {
                box-shadow: none;
            }

        .search-box button {
            background: white;
            border: none;
            color: var(--simar-dark);
            padding: 0.6rem 1.2rem;
        }

            .search-box button:hover {
                background: var(--simar-green);
                color: white;
            }

    .top-bar {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
    }

    /* 🔎 Buscador (más grande) */
    .search-container {
        flex: 2;
        min-width: 250px;
    }

    /* 🔽 Combo (tamaño controlado) */
    .select-container {
        flex: 1;
        max-width: 220px;
    }

    /* ➕ Botón (compacto) */
    .btn-container {
        flex: 0;
    }

    /* Ajuste visual del select */
    .form-select-simar {
        width: 100%;
        padding: 0.55rem 0.9rem;
        border-radius: 10px;
    }

    /* Botón más consistente */
    .btn-simar-primary {
        white-space: nowrap;
        padding: 0.55rem 1rem;
    }

    .dropdown-item-simar-desactivar {
        background: var(--simar-white);
        color: green;
    }

    .status-activo {
        color: #2e7d32; /* verde */
        font-weight: 600;
    }

    .status-inactivo {
        color: #c62828; /* rojo */
        font-weight: 600;
    }

    .modal-simar {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .modal-content-registro {
        max-height: 90vh;
        overflow-y: auto;
    }

    .seccion-paso {
        display: none;
    }

        .seccion-paso.activa {
            display: block;
        }

    .modal-body {
        max-height: 70vh;
        overflow-y: auto;
    }

    .modal-scrollable {
        max-height: 70vh;
        overflow-y: auto;
    }
</style>

<h2 class="fw-semibold" style="color: var(--simar-dark);">
    <i class="bi bi-person-badge me-3" style="color: var(--simar-green);"></i>
    Clientes Registrados
</h2>


<div class="top-bar">

    <!-- 🔎 Buscador -->
    <div class="search-container">
        <div class="search-box flex-grow-1">
            <div class="d-flex">
                <input type="text" name="Search" class="form-control"
                       placeholder="Buscar por nombre, email, teléfono, dirección, RFC..."
                       value="@Model.Search"
                       oninput="filtrarClientes()">
                <button type="button" onclick="buscarConDebounce()">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </div>

        <button type="button" id="btnLimpiar" class="btn-simar-outline" onclick="limpiarFiltro()" style="display: none; white-space: nowrap;">
            <i class="bi bi-x-circle"></i> Limpiar
        </button>
    </div>

    <!-- 🔽 Combo -->
    <div class="select-container">
        <select class="form-select-simar">
            <option value="default">Ordenar por</option>
            <option value="nombre">Nombre</option>
            <option value="razonSocial">Razón Social</option>
            <option value="email">Email de contacto</option>
            <option value="telefono">Teléfono</option>
            <option value="fecha">Fecha de registro</option>
            <option value="estatus">Estatus</option>
        </select>
    </div>

    <!-- Select para dirección de ordenamiento -->
    <div class="select-container">
        <select id="orderDirectionSelect" class="form-select-simar">
            <option value="asc">Ascendente</option>
            <option value="desc">Descendente</option>
        </select>
    </div>

    <!-- ➕ Botón -->
    <div class="btn-container">
        <a class="btn-simar-primary" data-bs-toggle="modal" data-bs-target="#modalRegistro">
            <i class="bi bi-plus-lg"></i> Nuevo Cliente
        </a>
    </div>

</div>

<div class="table-responsive-custom">
    <table class="table-custom w-100">

        <thead>
            <th>ID</th>
            <th>Nombre</th>
            <th>Razon social</th>
            <th>Email de contacto</th>
            <th>Teléfono</th>
            <th>Fecha Registro</th>
            <th>Estatus</th>
            <th>Acciones</th>
        </thead>

        <tbody>
            @foreach (var cliente in Model.Clientes)
            {
                <tr id="cliente-@cliente.Id"
                    data-email="@cliente.Email"
                    data-emailContacto="@cliente.ContactEmail"
                    data-username="@cliente.UserName"
                    data-razonSocial="@cliente.BusinessName"
                    data-nombre="@cliente.Name"
                    data-telefono="@cliente.Phone"
                    data-direccion="@cliente.Address"
                    data-rfc="@cliente.RFC"
                    data-fecha="@cliente.RegisterDate.ToShortDateString()"
                    data-semarnat="@cliente.SemarnatNum"
                    data-status="@cliente.Status"
                    data-idUser="@cliente.IdUser"
                    data-certificado='@(string.IsNullOrEmpty(cliente.UrlSatCertificate)
                        ? ""
                        : $"http://localhost:8005{cliente.UrlSatCertificate}")'>

                    <td>@cliente.Id</td>
                    <td>@cliente.Name</td>
                    <td>@cliente.BusinessName</td>
                    <td>@cliente.ContactEmail</td>
                    <td>@cliente.Phone</td>
                    <td>@cliente.RegisterDate.ToShortDateString()</td>
                    <td class="status
                        @(cliente.Status == "activo" ? "status-activo" : "status-inactivo")">
                        @cliente.Status
                    </td>

                    <td>

                        <div class="dropdown">
                            <button class="btn btn-sm rounded-circle" style="background: transparent; border: 1px solid var(--simar-border); width: 32px; height: 32px;" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>

                            <ul class="dropdown-menu">

                                <!-- Editar -->
                                <li>
                                    <a class="dropdown-item btn-edit"
                                       onclick="abrirModalEditar(@cliente.Id)">
                                        <i class="bi bi-pencil me-2"></i> Editar
                                    </a>
                                </li>

                                <!-- Ver más -->
                                <li>
                                    <a class="dropdown-item btn-details"
                                       onclick="verDetalleCliente(@cliente.Id)">
                                        <i class="bi bi-eye me-2"></i> Ver más
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider"></li>

                                <!-- Activar / Desactivar -->
                                @if (cliente.Status == "activo")
                                {
                                    <li>
                                        <button class="dropdown-item text-danger btn-delete"
                                                onclick="cambiarEstado(@cliente.Id, 'desactivar')">
                                            <i class="bi bi-person-x me-2"></i> Desactivar
                                        </button>
                                    </li>
                                }
                                else
                                {
                                    <li>
                                        <button class="dropdown-item-simar-desactivar"
                                                onclick="cambiarEstado(@cliente.Id, 'activar')">
                                            <i class="bi bi-person-check me-2"></i> Activar
                                        </button>
                                    </li>
                                }

                            </ul>
                        </div>

                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="modalDesactivar" class="modal-simar" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); justify-content:center; align-items:center;">

    <div class="card-simar" style="padding:25px; text-align:center; width:300px;">
        <p id="mensajeModal"></p>

        <button onclick="ejecutarAccion()" class="btn-simar-primary">Confirmar</button>
        <button onclick="cerrarModal()" class="btn-simar-outline">Cancelar</button>
    </div>

</div>


<!-- Modal Registrar Cliente -->
<div class="modal fade" id="modalRegistro" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-person-plus me-2"></i>Registrar Cliente
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- FORM -->
            <form method="post" id="registroForm" enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <!-- BODY -->
                <div class="modal-body">

                    <div class="row g-3">

                        <div class="col-md-6">
                            <strong><i class="bi bi-envelope-fill me-1" style="color: var(--simar-green);"></i>Email: *</strong>
                            <input asp-for="Input.Email" type="email" class="form-control" name="Email" id="regEmail" placeholder="Email" required />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-person-fill me-1" style="color: var(--simar-green);"></i>Username: *</strong>
                            <input asp-for="Input.UserName" type="text" name="UserName" id="regUsername" class="form-control" placeholder="Username" required />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-lock-fill me-1" style="color: var(--simar-green);"></i>Contraseña *:</strong>
                            <div class="input-group">
                                <input asp-for="Input.Password" type="password" name="Password" id="regPassword" class="form-control" placeholder="Contraseña" required />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('regPassword', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-person-badge-fill me-1" style="color: var(--simar-green);"></i>Nombre Completo: *</strong>
                            <input asp-for="Input.Name" type="text" name="Name" id="regNombre" class="form-control" placeholder="Nombre completo" required />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-card-text me-1" style="color: var(--simar-green);"></i>Razon social: *</strong>
                            <input asp-for="Input.BusinessName" type="text" name="BusinessName" id="regRazonSocial" class="form-control" placeholder="Razon social" required />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-envelope-fill me-1" style="color: var(--simar-green);"></i>Email de contacto: *</strong>
                            <input asp-for="Input.ContactEmail" type="text" name="EmailContact" id="regEmailContacto" class="form-control" placeholder="Email contacto" required />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-telephone-fill me-1" style="color: var(--simar-green);"></i>Teléfono:</strong>
                            <input asp-for="Input.Phone" type="text" name="PhoneNumber" id="regTelefono" class="form-control" placeholder="Teléfono" />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-geo-alt-fill me-1" style="color: var(--simar-green);"></i>Dirección:</strong>
                            <input asp-for="Input.Address" type="text" name="Address" id="regDireccion" class="form-control" placeholder="Dirección" />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-file-text-fill me-1" style="color: var(--simar-green);"></i> RFC: *</strong>
                            <input asp-for="Input.RFC" type="text" name="RFC" id="regRFC" class="form-control" placeholder="RFC" required />
                        </div>

                        <div class="col-md-6">
                            <strong><i class="bi bi-tree-fill me-1" style="color: var(--simar-green);"></i>Número de Semarnat:</strong>
                            <input asp-for="Input.SemarnatNum" type="text" name="SemarnatNumber" id="regSemarnat" class="form-control" placeholder="Número de SEMARNAT" />
                        </div>

                        <div class="col-12">
                            <strong><i class="bi bi-file-pdf-fill me-1" style="color: var(--simar-green);"></i>Certificado SAT:</strong>
                            <input asp-for="CertificadoFile" type="file" name="CertificadoFile" id="regCertificado" class="form-control" />
                        </div>

                    </div>

                </div>

                <!-- FOOTER -->
                <div class="modal-footer">
                    <button type="button" class="btn-simar-outline" data-bs-dismiss="modal"><i class="bi bi-x-circle me-1"></i>Cancelar</button>
                    <button type="button" class="btn-simar-primary" onclick="registrarCliente()" ><i class="bi bi-check-circle me-1"></i>Registrar</button>
                </div>

            </form>

        </div>
    </div>
</div>


