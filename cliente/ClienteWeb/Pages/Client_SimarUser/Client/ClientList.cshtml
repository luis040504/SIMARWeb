@page
@model ClienteWeb.Pages.Client_SimarUser.Client.ClientListModel
@{
    ViewData["Title"] = "Listado de Clientes";
}

@if (TempData["Mensaje"] != null)
{
    <div class="alerta-exito">
        @TempData["Mensaje"]
    </div>
}

<h2>Clientes Registrados</h2>

<style>
    .btn-accion {
        padding: 6px 22px;
        border-radius: 5px;
        background-color: green;
        color: white;
        text-decoration: none;
        font-size: 12px;
    }

    .btn-desactivate {
        padding: 6px 12px;
        border-radius: 5px;
        background-color: red;
        color: white;
        text-decoration: wavy;
        font-size: 12px;
        margin-left: 35px;
    }

    .btn-activate {
        padding: 6px 12px;
        border-radius: 5px;
        background-color: greenyellow;
        color: black;
        text-decoration: wavy;
        font-size: 12px;
        margin-left: 35px;
    }

    .btn-edit {
        padding: 6px 12px;
        border-radius: 5px;
        background-color: yellow;
        color: black;
        text-decoration: wavy;
        font-size: 12px;
    }

    .btn-accion:hover {
        background-color: #757575;
    }

    .alerta-exito {
        background-color: #4CAF50;
        color: white;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 15px;
        text-align: center;
    }

    .buscador {
        flex: 1;
        min-width: 250px;
    }
</style>

<div style="margin-bottom:20px; display:flex; gap:10px;"> 
    
    <!-- Barra de búsqueda -->
    <input type="text" placeholder="Buscar cliente..." class="campo-entrada buscador" />

    <!-- Combo de orden -->
    <select class="campo-entrada">
        <option>Ordenar por</option>
        <option>Nombre</option>
        <option>Fecha de registro</option>
        <option>Status</option>
    </select>

    <!-- Boton registrar cliente -->
    <a class="btn-accion" asp-page="ClientRegister">+ Nuevo Registro</a> |

</div>

<table style="width:100%; border-collapse:collapse;">
    <thead>
        <tr style="background-color:#f0f0f0;">
            <th>ID</th>
            <th>Nombre</th>
            <th>Email</th>
            <th>Teléfono</th>
            <th>Fecha Registro</th>
            <th>Estatus</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var cliente in Model.Clientes)
        {
            <tr id="cliente-@cliente.Id">
                <td>@cliente.Id</td>
                <td>@cliente.Name</td>
                <td>@cliente.Email</td>
                <td>@cliente.PhoneNumber</td>
                <td>@cliente.RegisterDate.ToShortDateString()</td>
                <td class="status">@cliente.Status</td>

                <td>
                    <a class="btn-edit" asp-page="EditClient" asp-route-id="@cliente.Id">
                        <i class="bi bi-pencil"></i> Editar
                    </a> |

                    
                    <a class="btn-accion" asp-page="ConsultedClient" asp-route-id="@cliente.Id">
                        <i class="bi-eye"></i> Ver más
                    </a>

                    @if (cliente.Status == "Activo")
                    {
                        <button class="btn-desactivate" type="button" onclick="confirmarAccion(@cliente.Id, 'desactivar')">
                            <i class="bi bi-person-x"></i> Desactivar
                        </button>
                    }
                    else
                    {
                        <button class="btn-activate" type="button" onclick="confirmarAccion(@cliente.Id, 'activar')">
                            <i class="bi bi-person-check"></i> Activar
                        </button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<div id="modalDesactivar" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); justify-content:center; align-items:center;">

    <div style="background:white; padding:25px; border-radius:10px; text-align:center; width:300px;">
        <p id="mensajeModal"></p>

        <button onclick="ejecutarAccion()" class="btn">Confirmar</button>
        <button onclick="cerrarModal()" class="btn">Cancelar</button>
    </div>

</div>

<!-- simulacion desactivacion -->
<script>
    let clienteSeleccionado = null;
    let tipoAccion = null;

    function confirmarAccion(id, accion) {
        clienteSeleccionado = id;
        tipoAccion = accion;

        let mensaje = accion === "desactivar"
            ? "¿Está seguro de desactivar al cliente seleccionado?"
            : "¿Está seguro de activar al cliente seleccionado?";

        document.getElementById("mensajeModal").innerText = mensaje;
        document.getElementById("modalDesactivar").style.display = "flex";
    }

    function cerrarModal() {
        document.getElementById("modalDesactivar").style.display = "none";
    }

    function ejecutarAccion() {
        if (clienteSeleccionado != null) {

            let fila = document.getElementById("cliente-" + clienteSeleccionado);
            let statusCell = fila.querySelector(".status");
            let boton = fila.querySelector("button");

            if (tipoAccion === "desactivar") {
                statusCell.innerText = "Inactivo";

                boton.className = "btn-activate";
                boton.innerHTML = '<i class="bi bi-person-check"></i> Activar';
                boton.setAttribute("onclick", `confirmarAccion(${clienteSeleccionado}, 'activar')`);

                alert("El cliente ha sido dado de baja");
            } else {
                statusCell.innerText = "Activo";

                boton.className = "btn-desactivate";
                boton.innerHTML = '<i class="bi bi-person-x"></i> Desactivar';
                boton.setAttribute("onclick", `confirmarAccion(${clienteSeleccionado}, 'desactivar')`);

                alert("El cliente ha sido activado");
            }

            cerrarModal();
        }
    }
</script>