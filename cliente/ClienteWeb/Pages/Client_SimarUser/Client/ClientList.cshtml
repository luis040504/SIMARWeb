<script>

    let timeoutId;

    function buscarConDebounce() {
        clearTimeout(timeoutId);
        timeoutId = setTimeout(() => {
            filtrarClientes();
        }, 300);
    }

    // Función para filtrar clientes en tiempo real (sin recargar página)
    function filtrarClientes() {
        const searchTerm = document.querySelector('input[name="Search"]').value.toLowerCase().trim();
        const tbody = document.querySelector('.table-custom tbody');
        const filas = tbody.querySelectorAll('tr');
        const filtrarClientesOriginal = filtrarClientes;
        if (typeof filtrarClientesOriginal === 'function') {
            window.filtrarClientes = function() {
                filtrarClientesOriginal();
                // Después de filtrar, restaurar el orden actual
                if (currentSort !== 'default') {
                    ordenarTabla();
                }
            };
        }
        let resultadosEncontrados = 0;

        filas.forEach(fila => {
            // Obtener texto de todas las columnas importantes (excluyendo acciones)
            const nombre = fila.querySelector('td:nth-child(2)')?.innerText.toLowerCase() || '';
            const razonSocial = fila.querySelector('td:nth-child(3)')?.innerText.toLowerCase() || '';
            const emailContacto = fila.querySelector('td:nth-child(4)')?.innerText.toLowerCase() || '';
            const telefono = fila.querySelector('td:nth-child(5)')?.innerText.toLowerCase() || '';
            const status = fila.querySelector('td:nth-child(7)')?.innerText.toLowerCase() || '';

            // También buscar en atributos data-* (dirección, RFC, SEMARNAT, etc.)
            const direccion = fila.getAttribute('data-direccion')?.toLowerCase() || '';
            const rfc = fila.getAttribute('data-rfc')?.toLowerCase() || '';
            const semarnat = fila.getAttribute('data-semarnat')?.toLowerCase() || '';
            const username = fila.getAttribute('data-username')?.toLowerCase() || '';
            const email = fila.getAttribute('data-email')?.toLowerCase() || '';

            // Verificar si el término de búsqueda está en algún campo
            const coincide = searchTerm === '' ||
                nombre.includes(searchTerm) ||
                razonSocial.includes(searchTerm) ||
                emailContacto.includes(searchTerm) ||
                telefono.includes(searchTerm) ||
                status.includes(searchTerm) ||
                direccion.includes(searchTerm) ||
                rfc.includes(searchTerm) ||
                semarnat.includes(searchTerm) ||
                username.includes(searchTerm) ||
                email.includes(searchTerm);

            if (coincide) {
                fila.style.display = '';
                resultadosEncontrados++;
            } else {
                fila.style.display = 'none';
            }
        });

        // Mostrar mensaje si no hay resultados
        mostrarMensajeSinResultados(resultadosEncontrados, searchTerm);
    }

    function mostrarMensajeSinResultados(cantidad, searchTerm) {
        const tbody = document.querySelector('.table-custom tbody');
        let mensajeRow = document.getElementById('sinResultadosRow');

        if (cantidad === 0 && searchTerm !== '') {
            if (!mensajeRow) {
                mensajeRow = document.createElement('tr');
                mensajeRow.id = 'sinResultadosRow';
                mensajeRow.innerHTML = `
                    <td colspan="8" style="text-align: center; padding: 40px;">
                        <i class="bi bi-inbox" style="font-size: 48px; color: #ccc;"></i>
                        <p style="margin-top: 10px;">No se encontraron clientes que coincidan con "<strong>${searchTerm}</strong>"</p>
                    </td>
                `;
                tbody.appendChild(mensajeRow);
            } else {
                mensajeRow.querySelector('td p strong').innerText = searchTerm;
                mensajeRow.style.display = '';
            }
        } else if (mensajeRow) {
            mensajeRow.remove();
        }
    }

    // Limpiar filtro y mostrar todos los clientes
    function limpiarFiltro() {
        const searchInput = document.querySelector('input[name="Search"]');
        searchInput.value = '';
        filtrarClientes();

        // Ocultar botón de limpiar
        const limpiarBtn = document.querySelector('.btn-simar-outline');
        if (limpiarBtn) limpiarBtn.style.display = 'none';
    }

    // Eventos
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.querySelector('input[name="Search"]');
        const searchForm = document.querySelector('.search-container form');
        const limpiarBtn = document.querySelector('.btn-simar-outline');

        if (searchInput) {
            // Filtro en tiempo real mientras escribes
            searchInput.addEventListener('input', function() {
                filtrarClientes();

                // Mostrar/ocultar botón de limpiar
                if (limpiarBtn) {
                    limpiarBtn.style.display = this.value ? 'inline-block' : 'none';
                }
            });
        }

        if (searchForm) {
            // Prevenir envío del formulario (para no recargar la página)
            searchForm.addEventListener('submit', function(e) {
                e.preventDefault();
                filtrarClientes();
            });
        }

        if (limpiarBtn) {
            limpiarBtn.style.display = 'none';
        }
    });
</script>

<script>
        // Variables para el ordenamiento
    let currentSort = 'default';
    let currentDirection = 'asc';

    // Función principal para ordenar la tabla
    function ordenarTabla() {
        const sortBy = document.getElementById('sortSelect')?.value || 'default';
        const direction = document.getElementById('orderDirectionSelect')?.value || 'asc';

        if (sortBy === 'default') {
            restaurarOrdenOriginal();
            return;
        }

        currentSort = sortBy;
        currentDirection = direction;

        const tbody = document.querySelector('.table-custom tbody');
        const filas = Array.from(tbody.querySelectorAll('tr'));

        // Filtrar filas que no sean el mensaje de "sin resultados"
        const filasValidas = filas.filter(fila => fila.id !== 'sinResultadosRow');

        // Ordenar las filas
        filasValidas.sort((a, b) => {
            let valorA, valorB;

            switch(sortBy) {
                case 'nombre':
                    valorA = a.querySelector('td:nth-child(2)')?.innerText.toLowerCase() || '';
                    valorB = b.querySelector('td:nth-child(2)')?.innerText.toLowerCase() || '';
                    break;
                case 'razonSocial':
                    valorA = a.querySelector('td:nth-child(3)')?.innerText.toLowerCase() || '';
                    valorB = b.querySelector('td:nth-child(3)')?.innerText.toLowerCase() || '';
                    break;
                case 'email':
                    valorA = a.querySelector('td:nth-child(4)')?.innerText.toLowerCase() || '';
                    valorB = b.querySelector('td:nth-child(4)')?.innerText.toLowerCase() || '';
                    break;
                case 'telefono':
                    valorA = a.querySelector('td:nth-child(5)')?.innerText || '';
                    valorB = b.querySelector('td:nth-child(5)')?.innerText || '';
                    break;
                case 'fecha':
                    valorA = new Date(a.querySelector('td:nth-child(6)')?.innerText);
                    valorB = new Date(b.querySelector('td:nth-child(6)')?.innerText);
                    break;
                case 'estatus':
                    valorA = a.querySelector('td:nth-child(7)')?.innerText.toLowerCase() || '';
                    valorB = b.querySelector('td:nth-child(7)')?.innerText.toLowerCase() || '';
                    break;
                default:
                    return 0;
            }

            // Comparar según la dirección
            let comparacion = 0;
            if (valorA < valorB) comparacion = -1;
            if (valorA > valorB) comparacion = 1;

            return direction === 'asc' ? comparacion : -comparacion;
        });

        // Reordenar el DOM
        filasValidas.forEach(fila => tbody.appendChild(fila));

        // Actualizar iconos de ordenamiento
        actualizarIconosOrdenamiento(sortBy, direction);
    }

    // Función para restaurar el orden original (por ID)
    function restaurarOrdenOriginal() {
        const tbody = document.querySelector('.table-custom tbody');
        const filas = Array.from(tbody.querySelectorAll('tr'));
        const filasValidas = filas.filter(fila => fila.id !== 'sinResultadosRow');

        // Ordenar por ID (extraer el número del ID del atributo data-id o del texto)
        filasValidas.sort((a, b) => {
            const idA = parseInt(a.id?.split('-')[1] || 0);
            const idB = parseInt(b.id?.split('-')[1] || 0);
            return idA - idB;
        });

        filasValidas.forEach(fila => tbody.appendChild(fila));
        limpiarIconosOrdenamiento();
    }

    // Función para actualizar iconos en los encabezados
    function actualizarIconosOrdenamiento(sortBy, direction) {
        limpiarIconosOrdenamiento();

        const headers = document.querySelectorAll('.table-custom thead th');
        const indexMap = {
            'nombre': 1,
            'razonSocial': 2,
            'email': 3,
            'telefono': 4,
            'fecha': 5,
            'estatus': 6
        };

        const columnaIndex = indexMap[sortBy];
        if (columnaIndex !== undefined && headers[columnaIndex]) {
            const icono = document.createElement('i');
            icono.className = `bi bi-arrow-${direction === 'asc' ? 'up' : 'down'}-short ms-1`;
            icono.style.fontSize = '1.2rem';
            headers[columnaIndex].appendChild(icono);
        }
    }

    // Función para limpiar iconos de ordenamiento
    function limpiarIconosOrdenamiento() {
        const headers = document.querySelectorAll('.table-custom thead th');
        headers.forEach(th => {
            const iconos = th.querySelectorAll('i.bi-arrow-up-short, i.bi-arrow-down-short');
            iconos.forEach(icono => icono.remove());
        });
    }

    // Función para ordenar combinada con el filtro de búsqueda
    function ordenarYFiltrar() {
        // Aplicar filtro de búsqueda si existe
        if (typeof filtrarClientes === 'function') {
            filtrarClientes();
        }
        // Luego ordenar
        ordenarTabla();
    }
</script>