                <!-- FOOTER -->
                <div class="modal-footer">
                    <button class="btn-simar-outline" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" onclick="guardarEdicion()" class="btn-simar-primary">Guardar</button>
                </div>

            </div>
        </div>
    </div>
</div>




<script>

    async function registrarCliente() {

        const fileInput = document.getElementById("regCertificado");
        const file = fileInput.files[0];

        const data = {
            Email: document.getElementById("regEmail").value,
            UserName: document.getElementById("regUsername").value,
            Password: document.getElementById("regPassword").value,
            Role: "cliente",

            Name: document.getElementById("regNombre").value,
            BusinessName: document.getElementById("regRazonSocial").value,
            ContactEmail: document.getElementById("regEmailContacto").value,
            Phone: document.getElementById("regTelefono").value,
            Address: document.getElementById("regDireccion").value,
            RFC: document.getElementById("regRFC").value,
            SemarnatNum: document.getElementById("regSemarnat").value
        };

        try {

            // 🔥 DESACTIVA botón mientras carga (evita doble submit)
            const btn = document.querySelector("#registroForm button[type='submit']");
            if (btn) btn.disabled = true;

            // 🔥 1. REGISTRO COMPLETO EN RAZOR HANDLER
            const response = await fetch("?handler=RegistrarCliente", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            console.log("RESPUESTA:", result);

            if (result.expired) {
                alert("Sesión expirada");
                window.location.href = "/Inicio";
                return;
            }

            if (!result.success) {
                alert(result.message || "Error al registrar cliente");
                if (btn) btn.disabled = false;
                return;
            }

            const clientId = result.clientId;

            // 🔥 2. SUBIR CERTIFICADO SI EXISTE
            if (file) {

                const formData = new FormData();
                formData.append("file", file);

                const certResponse = await fetch(`?handler=SubirCertificado&id=${clientId}`, {
                    method: "POST",
                    body: formData
                });

                const certResult = await certResponse.json();

                console.log("CERT:", certResult);

                if (!certResult.success) {
                    alert("Cliente creado, pero falló el certificado");
                    location.reload();
                    return;
                }
            }

            // 🔥 3. ÉXITO
            alert("Cliente registrado correctamente");

            location.reload();

        } catch (error) {
            console.error("ERROR REGISTRO:", error);
            alert("Error inesperado al registrar cliente");

        } finally {
            const btn = document.querySelector("#registroForm button[type='submit']");
            if (btn) btn.disabled = false;
        }
    }

</script>

