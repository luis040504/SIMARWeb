@page "/inicio"
@model ClienteWeb.Pages.Client_SimarUser.Client.HomeClienteModel
@{
    ViewData["Title"] = "Bienvenido a SIMAR";
}

<style>
    /* Desactivar Sidebar del Layout para ancho completo */
    #sidebar, .sidebar, .sidebar-simar, .nav-lateral {
        display: none !important;
    }

    main, .content-wrapper, #main-content, .body-content {
        margin-left: 0 !important;
        padding-left: 0 !important;
        width: 100% !important;
        max-width: 100% !important;
    }

    body {
        background-color: #f8faf9;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .hero-simar {
        background: linear-gradient(135deg, #1a1a1a 0%, #2c3e50 100%);
        color: white;
        padding: 60px 0;
        border-bottom: 5px solid #00c02b;
        margin-bottom: 60px;
    }

    .card-portal {
        background: white;
        border: none;
        border-radius: 25px;
        padding: 50px 30px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        height: 100%;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    }

        .card-portal:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.12);
        }

    .icon-circle-portal {
        width: 90px;
        height: 90px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 25px;
        font-size: 3rem;
    }

    .bg-soft-green {
        background-color: #e6f9ed;
        color: #00c02b;
    }

    .bg-soft-blue {
        background-color: #eef2f7;
        color: #2c3e50;
    }

    /* Estilos de Modales */
    .modal-simar-custom .modal-content {
        border-radius: 25px;
        border: none;
        box-shadow: 0 25px 50px rgba(0,0,0,0.2);
    }

    /* Tarjetas de Selección en el Modal de Registro */
    .selection-card {
        border: 2px solid #f0f0f0;
        border-radius: 15px;
        padding: 20px;
        transition: all 0.3s;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        display: block;
    }

        .selection-card:hover {
            border-color: #00c02b;
            background-color: #f0fff4;
            transform: scale(1.02);
        }

        .selection-card i {
            font-size: 2.5rem;
            color: #00c02b;
            margin-bottom: 10px;
            display: block;
        }

    .form-control-simar {
        height: 50px;
        border-radius: 12px;
        border: 1px solid #dee2e6;
        padding-left: 45px;
    }

    .input-icon-group {
        position: relative;
    }

        .input-icon-group i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #adb5bd;
        }
</style>

<div class="container-fluid p-0">
    <header class="hero-simar shadow-sm">
        <div class="container text-center">
            <div class="mb-3"><i class="bi bi-recycle fs-1 text-white"></i></div>
            <h1 class="display-4 fw-bold">Sistema SIMAR</h1>
            <p class="lead opacity-75">Control de Residuos y Administración Operativa</p>
        </div>
    </header>

    <div class="container">
        <div class="row g-5 justify-content-center">
            <div class="col-lg-5 col-md-6">
                <div class="card-portal text-center border">
                    <div class="icon-circle-portal bg-soft-green">
                        <i class="bi bi-map-fill"></i>
                    </div>
                    <h2 class="fw-bold mb-3">Ruta del Residuo</h2>
                    <p class="text-muted mb-4">Consulte el estado actual de las rutas y puntos de recolección en tiempo real.</p>
                    <a href="#" class="btn border-dark w-100 py-3 fw-bold rounded-pill shadow-sm">Consultar Mapa</a>
                </div>
            </div>

            <div class="col-lg-5 col-md-6">
                <div class="card-portal text-center border">
                    <div class="icon-circle-portal bg-soft-blue">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h2 class="fw-bold mb-3">Portal de Acceso</h2>
                    <p class="text-muted mb-4">Ingrese a su cuenta o cree una nueva para comenzar a utilizar SIMAR.</p>
                    <div class="d-flex flex-column gap-3 mt-2">
                        <button type="button" class="btn btn-success w-100 py-3 fw-bold rounded-pill shadow-sm"
                                data-bs-toggle="modal" data-bs-target="#loginModal" style="background-color: #00c02b; border:none;">
                            <i class="bi bi-box-arrow-in-right me-2"></i> Iniciar Sesión
                        </button>
                        <button type="button" class="btn border-dark w-100 py-3 fw-bold rounded-pill shadow-sm bg-white"
                                data-bs-toggle="modal" data-bs-target="#registerTypeModal">
                            <i class="bi bi-person-plus-fill me-2"></i> Crear Cuenta Nueva
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade modal-simar-custom" id="loginModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-4">
            <div class="modal-header d-flex flex-column align-items-center border-0">
                <div class="icon-circle-portal bg-soft-green mb-3" style="width:70px; height:70px; font-size: 2rem;">
                    <i class="bi bi-person-badge"></i>
                </div>
                <h3 class="fw-bold">Ingresar a SIMAR</h3>
                <button type="button" class="btn-close position-absolute top-0 end-0 m-4" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="loginForm">
                    <div class="mb-4 input-icon-group">
                        <i class="bi bi-person"></i>
                        <input type="text" class="form-control form-control-simar" id="identifier" placeholder="Usuario o Correo" required>
                    </div>
                    <div class="mb-4 input-icon-group">
                        <i class="bi bi-lock"></i>
                        <input type="password" class="form-control form-control-simar" id="password" placeholder="Contraseña" required>
                    </div>
                    <button type="submit" class="btn btn-success w-100 py-3 fw-bold rounded-pill" style="background-color: #00c02b; border:none;">
                        Acceder
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade modal-simar-custom" id="registerTypeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-4 text-center">
            <div class="modal-header border-0 flex-column align-items-center">
                <h3 class="fw-bold">¿Cómo desea registrarse?</h3>
                <p class="text-muted">Seleccione su perfil para continuar</p>
                <button type="button" class="btn-close position-absolute top-0 end-0 m-4" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-6">
                        <a href="/registro-cliente" class="selection-card">
                            <i class="bi bi-house-door"></i>
                            <span class="fw-bold">Soy Cliente</span>
                            <small class="d-block text-muted mt-1">Solicitar recolección</small>
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/registro" class="selection-card">
                            <i class="bi bi-briefcase"></i>
                            <span class="fw-bold">Soy Personal</span>
                            <small class="d-block text-muted mt-1">Uso interno SIMAR</small>
                        </a>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 justify-content-center">
                <p class="small text-muted mb-0">Ya tengo cuenta. <a href="#" data-bs-dismiss="modal" data-bs-toggle="modal" data-bs-target="#loginModal" class="text-success fw-bold">Login</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Ocultar Sidebar
            const sidebars = document.querySelectorAll('#sidebar, .sidebar, .sidebar-simar');
            sidebars.forEach(s => s.style.setProperty('display', 'none', 'important'));
        });
    </script>
}