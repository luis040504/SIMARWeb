@page "/inicio"
@model ClienteWeb.Pages.Client_SimarUser.Client.HomeClienteModel
@{
    ViewData["Title"] = "Bienvenido a SIMAR";
}

<style>
    /* Efecto de elevación para las tarjetas */
    .tarjeta-funcionalidad {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        display: block;
    }

        .tarjeta-funcionalidad:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15) !important;
        }

    .btn-proximamente {
        background-color: #333;
        color: white;
        border-radius: 20px;
        font-size: 0.8rem;
        padding: 5px 15px;
        border: none;
        transition: background 0.3s;
    }

    .tarjeta-funcionalidad:hover .btn-proximamente {
        background-color: #007bff; /* Cambia a azul al pasar */
    }
</style>

@*TODO - Cambiar imagen*@
<header style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80'); background-size: cover; color: white; padding: 100px 0; text-align: center;">
    <div class="container">
        <h1 class="display-3 fw-bold">Sistema SIMAR</h1>
        <p class="lead mb-5">Sistema en Manejo y Administración de Residuos.</p>
        <a href="/login" class="btn btn-light btn-lg px-5" style="border-radius: 30px; font-weight: bold;">Comenzar Ahora</a>
    </div>
</header>

<section class="container my-5 py-5">
    <div class="row text-center">

        <div class="col-md-4 mb-4">
            <div class="p-4 shadow-sm h-100 tarjeta-funcionalidad" style="border-radius: 15px; background: #fff;">
                <div class="mb-3">
                    <i class="bi bi-graph-up-arrow" style="font-size: 2rem; color: #333;"></i>
                </div>
                <h3 class="h5 mb-3">Módulo 1...</h3>
                <p class="text-muted small">Agregar descripción del módulo.</p>
                <button class="btn-proximamente">Próximamente</button>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="p-4 shadow-sm h-100 tarjeta-funcionalidad" style="border-radius: 15px; background: #fff;">
                <div class="mb-3">
                    <i class="bi bi-truck" style="font-size: 2rem; color: #333;"></i>
                </div>
                <h3 class="h5 mb-3">Módulo 2...</h3>
                <p class="text-muted small">Agregar descripción del módulo.</p>
                <button class="btn-proximamente">Próximamente</button>
            </div>
        </div>
    </div>
</section>

<footer class="bg-dark text-white text-center py-4">
    <p class="mb-0">© 2026 SIMAR - Todos los derechos reservados.</p>
</footer>