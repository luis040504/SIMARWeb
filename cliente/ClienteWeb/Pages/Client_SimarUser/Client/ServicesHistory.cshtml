@page "{id:int}"
@model ClienteWeb.Pages.Client_SimarUser.Client.ServicesHistoryModel
@{
    ViewData["Title"] = "Historial de Servicios";
}

<style>
    .contenedor {
        max-width: 900px;
        margin: auto;
        padding: 20px;
    }

    .titulo {
        text-align: center;
        margin-bottom: 20px;
    }

    .barra-superior {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }

    .campo {
        padding: 8px;
        border-radius: 5px;
        border: 1px solid #ccc;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background-color: #f0f0f0;
        padding: 10px;
    }

    td {
        padding: 8px;
        text-align: center;
    }

    tr:nth-child(even) {
        background-color: #fafafa;
    }

    .btn {
        margin-top: 20px;
        padding: 10px 20px;
        border-radius: 20px;
        border: none;
        background-color: #9e9e9e;
        color: white;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn:hover {
        background-color: #757575;
    }
</style>

<div class="contenedor">

    <h2 class="titulo">Historial de Servicios</h2>

    <!-- Barra de búsqueda -->
    <div class="barra-superior">
        <input type="text" class="campo" placeholder="Buscar servicio..." />

        <select class="campo">
            <option>Ordenar por</option>
            <option>Fecha</option>
            <option>Estado</option>
            <option>Técnico</option>
        </select>
    </div>

    <!-- Tabla -->
    <table>
        <thead>
            <tr>
                <th>Fecha del Servicio</th>
                <th>Dirección</th>
                <th>Técnico</th>
                <th>Estado del Servicio</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var servicio in Model.Servicios)
            {
                <tr>
                    <td>@servicio.ServiceDate.ToShortDateString()</td>
                    <td>@servicio.Address</td>
                    <td>@servicio.Technical</td>
                    <td>@servicio.StateOfService</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Botón regresar -->
    <a asp-page="ClientList" asp-route-id="@Model.ClientId" class="btn">
        Regresar
    </a>

</div>