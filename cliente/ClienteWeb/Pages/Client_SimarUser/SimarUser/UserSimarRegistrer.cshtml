@page "/registro"
@model ClienteWeb.Pages.Client_SimarUser.SimarUser.UserSimarRegistrerModel
@{
    ViewData["Title"] = "Registro de Usuario SIMAR";
}

<div class="container-fluid-simar py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card-simar shadow-lg">
                <div class="card-simar-header d-flex align-items-center py-3">
                    <a href="/consultar" class="btn-simar-icon me-3 text-decoration-none" title="Volver a la consulta">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <div class="text-start">
                        <h4 class="text-simar-dark mb-0">REGISTRO DE PERSONAL</h4>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form method="post" id="registroForm">
                        @if (!ModelState.IsValid && ModelState.ErrorCount > 0)
                        {
                            <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
                                <strong><i class="bi bi-exclamation-triangle-fill me-2"></i>No se pudo completar el registro</strong>
                                <div asp-validation-summary="ModelOnly" class="mb-0 mt-1"></div>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <!-- Credenciales -->
                        <div id="paso1" class="seccion-paso activa">
                            <h5 class="text-simar-green mb-4 border-bottom-simar pb-2">1. Credenciales de Acceso</h5>
                            <div class="mb-3">
                                <label class="form-label-simar" asp-for="Input.Email">Correo</label>
                                <input asp-for="Input.Email" class="form-control-simar" placeholder="ejemplo@simar.com" />
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label-simar" asp-for="Input.UserName">Nombre de Usuario</label>
                                <input asp-for="Input.UserName" class="form-control-simar" placeholder="Username" />
                                <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                            </div>
                            <div class="mb-4">
                                <label class="form-label-simar" asp-for="Input.Password">Contraseña</label>
                                <input asp-for="Input.Password" type="password" class="form-control-simar" />
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <div class="puntos-progreso">
                                    <span class="badge-simar badge-simar-vehiculo">1</span>
                                    <span class="badge-simar badge-simar-programada">2</span>
                                    <span class="badge-simar badge-simar-programada">3</span>
                                </div>
                                <button type="button" class="btn-simar-primary" onclick="irAPaso(2)">Siguiente <i class="bi bi-arrow-right"></i></button>
                            </div>
                        </div>

                        <!-- Información Personal -->
                        <div id="paso2" class="seccion-paso d-none">
                            <h5 class="text-simar-green mb-4 border-bottom-simar pb-2">2. Información Personal</h5>
                            <div class="mb-3">
                                <label class="form-label-simar">Nombre Completo</label>
                                <input asp-for="Input.NombreCompleto" class="form-control-simar" />
                                <span asp-validation-for="Input.NombreCompleto" class="text-danger small"></span>
                            </div>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label-simar">CURP</label>
                                    <input asp-for="Input.Curp" class="form-control-simar" maxlength="18" oninput="this.value = this.value.toUpperCase()" />
                                    <span asp-validation-for="Input.Curp" class="text-danger small"></span>
                                </div>
                                <div class="col-6">
                                    <label class="form-label-simar">RFC</label>
                                    <input asp-for="Input.Rfc" class="form-control-simar" maxlength="13" oninput="this.value = this.value.toUpperCase()" />
                                    <span asp-validation-for="Input.Rfc" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label-simar">Domicilio Completo</label>
                                <input asp-for="Input.Direccion" class="form-control-simar" />
                            </div>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label-simar">Fecha de Nacimiento</label>
                                    <input asp-for="Input.Birthday" type="date" class="form-control-simar"
                                           max="@DateTime.Now.AddYears(-18).ToString("yyyy-MM-dd")" />
                                    <span asp-validation-for="Input.Birthday" class="text-danger small"></span>
                                </div>
                                <div class="col-6">
                                    <label class="form-label-simar">Teléfono</label>
                                    <input asp-for="Input.Phone" type="tel" class="form-control-simar" placeholder="10 dígitos" maxlength="10" />
                                    <span asp-validation-for="Input.Phone" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label-simar">Salario Mensual (MXN)</label>
                                    <input asp-for="Input.Salario" type="number" step="0.01" class="form-control-simar" />
                                    <span asp-validation-for="Input.Salario" class="text-danger small"></span>
                                </div>
                                <div class="col-6">
                                    <label class="form-label-simar">Género</label>
                                    <select asp-for="Input.Genre" class="form-select-simar">
                                        <option value="Masculino">Masculino</option>
                                        <option value="Femenino">Femenino</option>
                                        <option value="Otro">Otro</option>
                                    </select>
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label-simar">Rol en SIMAR</label>
                                <select asp-for="Input.RolSeleccionado" id="selectorRol" class="form-select-simar" onchange="mostrarCamposEspecificos()">
                                    <option value="">-- Seleccionar --</option>
                                    <option value="vendedor">Vendedor</option>
                                    <option value="tecnico">Técnico</option>
                                    <option value="chofer">Chofer</option>
                                    <option value="administrador">Administrador</option>
                                </select>
                                <span asp-validation-for="Input.RolSeleccionado" class="text-danger small"></span>
                            </div>

                            <div class="d-flex justify-content-between">
                                <button type="button" class="btn-simar-outline-gray" onclick="irAPaso(1)">Atrás</button>
                                <button type="button" class="btn-simar-primary" onclick="irAPaso(3)">Siguiente</button>
                            </div>
                        </div>

                        <!-- Detalles Específicos -->
                        <div id="paso3" class="seccion-paso d-none">
                            <h5 class="text-simar-green mb-4 border-bottom-simar pb-2">3. Validación Final</h5>

                            <div id="camposDriver" class="filter-section-simar d-none">
                                <h6 class="text-simar-dark mb-3"><i class="bi bi-card-checklist me-2"></i>Licencia de Conducir</h6>
                                <div class="mb-3">
                                    <label class="small text-muted">Número de licencia</label>
                                    <input asp-for="Input.LicenseNumber" class="form-control-simar" placeholder="Ej. A12345678" />
                                </div>
                                <div class="mb-3">
                                    <label class="small text-muted">Tipo de licencia</label>
                                    <select asp-for="Input.LicenseType" class="form-select-simar">
                                        <option value="A">Tipo A (Particular)</option>
                                        <option value="B">Tipo B (Carga)</option>
                                        <option value="E">Tipo E (Residuos Peligrosos)</option>
                                    </select>
                                </div>
                            </div>

                            <div class="empty-state-simar py-4" id="noSelection">
                                <i class="bi bi-person-check text-success" style="font-size: 2rem;"></i>
                                <h6 class="mt-2">Todo listo para registrar</h6>
                                <p class="small text-muted">Haga clic en Finalizar para completar el proceso.</p>
                            </div>

                            <div class="d-flex justify-content-between mt-5">
                                <button type="button" class="btn-simar-outline-gray" onclick="irAPaso(2)">Atrás</button>
                                <button type="submit" class="btn-simar-primary">Finalizar Registro <i class="bi bi-check-all"></i></button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function irAPaso(paso) {
            if (paso > 1) {
                const step1Valid = $('#Input_Email').valid() && $('#Input_UserName').valid() && $('#Input_Password').valid();
                if (paso === 2 && !step1Valid) return;

                if (paso === 3) {
                   const step2Valid = $('#Input_NombreCompleto').valid() &&
                                      $('#Input_Curp').valid() &&
                                      $('#Input_Rfc').valid() &&
                                      $('#Input_Birthday').valid() &&
                                      $('#Input_Phone').valid() &&
                                      $('#Input_Salario').valid() &&
                                      $('#selectorRol').valid();

                   if(!step2Valid) return;
                }
            }

            document.querySelectorAll('.seccion-paso').forEach(s => s.classList.add('d-none'));
            document.getElementById('paso' + paso).classList.remove('d-none');
            window.scrollTo(0,0);
        }

        function mostrarCamposEspecificos() {
            const rol = document.getElementById('selectorRol').value;
            const divDriver = document.getElementById('camposDriver');
            const noSelection = document.getElementById('noSelection');

            divDriver.classList.add('d-none');
            noSelection.classList.add('d-none');

            if (rol === "chofer") {
                divDriver.classList.remove('d-none');
            } else {
                noSelection.classList.remove('d-none');
            }
        }
    </script>
}