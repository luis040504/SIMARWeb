@page "/editar/{id}"
@model ClienteWeb.Pages.Client_SimarUser.SimarUser.EditSimarUserModel
@{
    ViewData["Title"] = "Expediente de Usuario";
}

<div class="container mt-4">
    <div class="card shadow-lg" style="border-radius: 15px; border: none;">

        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <h3 class="mb-0" style="font-weight: 300; color: #333;">
                Expediente: <span class="text-primary">@Model.DatosUsuario.UserName</span>
            </h3>
            <div>
                <button type="button" id="btnHabilitar" class="btn btn-outline-primary" onclick="activarEdicion()">
                    Modificar Datos
                </button>
                <a href="/consultar" class="btn btn-outline-secondary">Volver</a>
            </div>
        </div>

        <div class="card-body p-4">
            <form method="post">
                <fieldset id="formCampos" disabled>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            <h5 style="border-bottom: 2px solid #f4f4f4; padding-bottom: 10px;">Información de Usuario</h5>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small text-muted fw-bold">Nombre de usuario</label>
                            <input type="text" asp-for="DatosUsuario.UserName" class="form-control" readonly style="background-color: #f8f9fa;" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small text-muted fw-bold">Correo Electrónico</label>
                            <input type="email" asp-for="DatosUsuario.Email" class="form-control" />
                        </div>

                        <div class="col-md-12 mt-3 mb-4">
                            <h5 style="border-bottom: 2px solid #f4f4f4; padding-bottom: 10px;">Datos Personales y Fiscales</h5>
                        </div>
                        <div class="col-md-8 mb-3">
                            <label class="small text-muted fw-bold">Nombre Completo</label>
                            <input type="text" asp-for="DatosUsuario.NombreCompleto" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="small text-muted fw-bold">Género</label>
                            <select asp-for="DatosUsuario.Genero" class="form-select">
                                <option value="Masculino">Masculino</option>
                                <option value="Femenino">Femenino</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small text-muted fw-bold">CURP</label>
                            <input type="text" asp-for="DatosUsuario.Curp" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small text-muted fw-bold">RFC</label>
                            <input type="text" asp-for="DatosUsuario.Rfc" class="form-control" />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="small text-muted fw-bold">Domicilio</label>
                            <input type="text" asp-for="DatosUsuario.Direccion" class="form-control" />
                        </div>

                        <div class="col-md-12 mt-3 mb-4">
                            <h5 style="border-bottom: 2px solid #f4f4f4; padding-bottom: 10px;">Información Especifica</h5>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="small text-muted fw-bold">Rol en SIMAR</label>
                            <select asp-for="DatosUsuario.RolSeleccionado" id="rolSelect" class="form-select" onchange="actualizarCamposDinamicos()">
                                <option value="Seller">Seller</option>
                                <option value="Technical">Technical</option>
                                <option value="Manager">Manager</option>
                                <option value="Owner">Owner</option>
                                <option value="Accountant">Accountant</option>
                                <option value="Driver">Driver</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="small text-muted fw-bold">Salario Mensual ($ MXN)</label>
                            <input type="number" asp-for="DatosUsuario.Salario" class="form-control" />
                        </div>

                        <div class="col-md-4 mb-3" id="divProf" style="display:none;">
                            <label class="small text-muted fw-bold">ID Profesional (Cédula)</label>
                            <input type="text" asp-for="DatosUsuario.ProfessionalID" class="form-control" style="border: 1px solid #007bff;" />
                        </div>
                        <div class="col-md-4 mb-3" id="divDriver" style="display:none;">
                            <label class="small text-muted fw-bold">Licencia de Conducir</label>
                            <input type="text" asp-for="DatosUsuario.NumLicencia" class="form-control" style="border: 1px solid #ffc107;" />
                        </div>
                    </div>

                    <div id="zonaGuardar" class="text-end mt-4" style="display:none;">
                        <hr />
                        <button type="submit" class="btn btn-success btn-lg px-5 shadow">
                            Guardar Cambios en el Expediente
                        </button>
                    </div>

                </fieldset>
            </form>
        </div>
    </div>
</div>

<script>
    // Función para liberar el formulario
    function activarEdicion() {
        document.getElementById('formCampos').disabled = false;
        document.getElementById('btnHabilitar').style.display = 'none';
        document.getElementById('zonaGuardar').style.display = 'block';

        // Efecto visual: poner foco en el primer campo editable
        document.querySelector('input[type="email"]').focus();
    }

    // Función para mostrar campos según el Rol
    function actualizarCamposDinamicos() {
        const rol = document.getElementById('rolSelect').value;
        const listaProf = ["Seller", "Technical", "Manager", "Owner", "Accountant"];

        document.getElementById('divProf').style.display = listaProf.includes(rol) ? 'block' : 'none';
        document.getElementById('divDriver').style.display = (rol === "Driver") ? 'block' : 'none';
    }

    // Ejecutar al cargar la página
    window.onload = actualizarCamposDinamicos;
</script>
