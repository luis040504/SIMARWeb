@page "/consultar"
@model ClienteWeb.Pages.Client_SimarUser.SimarUser.ConsultSimarUserModel
@{
    ViewData["Title"] = "Consulta de Usuarios SIMAR";
}

<div class="container-fluid-simar mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-simar-dark fw-bold">Gestión de Usuarios</h2>
            <p class="text-muted">Administración de personal interno de la empresa SIMAR</p>
        </div>
        <a href="/registro" class="btn-simar-primary text-decoration-none">
            <i class="bi bi-person-plus-fill"></i> Nuevo Registro
        </a>
    </div>

    <div class="filter-section-simar shadow-sm">
        <h6 class="mb-3"><i class="bi bi-funnel text-simar-green"></i> Filtros de Búsqueda</h6>
        <div class="row g-3">
            <div class="col-lg-8">
                <label class="form-label-simar">Buscar por nombre o usuario</label>
                <div class="input-group" style="flex-wrap: nowrap;">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" id="busquedaInput" class="form-control-simar border-start-0"
                           placeholder="Ej. Luis López..." onkeyup="filtrarTabla()">
                </div>
            </div>
            <div class="col-lg-4">
                <label class="form-label-simar">Filtrar por Rol</label>
                <select id="rolFiltro" class="form-select-simar" onchange="filtrarTabla()">
                    <option value="">-- Todos los Roles --</option>
                    <option value="vendedor">Vendedor</option>
                    <option value="tecnico">Técnico</option>
                    <option value="chofer">Chofer</option>
                    <option value="administrador">Administrador</option>
                </select>
            </div>
        </div>
    </div>

    <div class="table-responsive-simar mt-4">
        <table class="table-simar" id="tablaUsuarios">
            <thead>
                <tr>
                    <th>Empleado y Correo</th>
                    <th>Rol / Puesto</th>
                    <th>CURP / RFC</th>
                    <th>Contacto</th>
                    <th>Salario (MXN)</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.EmpleadosCompletos != null && Model.EmpleadosCompletos.Any())
                {
                    @foreach (var emp in Model.EmpleadosCompletos)
                    {
                        string iconoRol = "bi-person-badge";
                        string rolBuscado = emp.RoleName?.ToLower() ?? "";

                        if (rolBuscado.Contains("chofer")) iconoRol = "bi-truck";
                        else if (rolBuscado.Contains("vend")) iconoRol = "bi-shop";
                        else if (rolBuscado.Contains("tec")) iconoRol = "bi-tools";
                        else if (rolBuscado.Contains("admin") || rolBuscado.Contains("dueño")) iconoRol = "bi-shield-lock-fill";
                        else if (rolBuscado.Contains("conta")) iconoRol = "bi-calculator";

                        <tr>
                            <td>
                                <div class="fw-bold text-simar-dark">@emp.FullName</div>
                                <div class="small text-muted"><i class="bi bi-envelope"></i> @emp.Email</div>
                                <span class="d-none">@emp.Username</span>
                            </td>

                            <td>
                                <span class="badge-simar badge-simar-vehiculo">
                                    <i class="bi @iconoRol me-1"></i> @emp.RoleName.ToUpper()
                                </span>
                            </td>

                            <td>
                                <div class="small fw-semibold text-secondary">C: @emp.Curp</div>
                                <div class="small text-muted">R: @emp.Rfc</div>
                            </td>

                            <td>
                                <div class="small text-muted"><i class="bi bi-telephone"></i> @(emp.Phone ?? "N/A")</div>
                                <div class="small text-muted"><i class="bi bi-geo-alt"></i> @(emp.Address ?? "N/A")</div>
                            </td>

                            <td class="fw-bold text-success">@emp.Salary.ToString("C")</td>

                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <button class="btn-simar-icon"
                                            onclick="prepararEdicion('@emp.UserId', '@emp.Username', '@emp.Email', '@emp.FullName', '@emp.Genre', '@emp.Curp', '@emp.Rfc', '@emp.Address', '@emp.Phone', '@(emp.Birthday?.ToString("yyyy-MM-dd"))', '@emp.RoleName', @emp.Salary, '', '')"
                                            title="Ver Expediente">
                                        <i class="bi bi-file-earmark-person"></i>
                                    </button>
                                    <button class="btn-simar-icon text-danger" onclick="confirmarBaja('@emp.UserId', '@emp.FullName')" title="Dar de baja">
                                        <i class="bi bi-person-x"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                            No hay empleados registrados en el sistema.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade modal-simar" id="modalBaja" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Confirmar Baja</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                ¿Estás seguro de desactivar a <strong id="nombreUsuarioBaja"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-simar-outline-gray" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn-simar-secondary" onclick="ejecutarBaja()">Desactivar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade modal-simar" id="modalEditarUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-file-earmark-person text-simar-green"></i>
                    Expediente: <span id="txtUsuarioTitulo" class="text-simar-green"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="text-end mb-3">
                    <button type="button" id="btnHabilitarEdicion" class="btn-simar-outline" onclick="activarCampos()">
                        <i class="bi bi-pencil"></i> Modificar Datos
                    </button>
                </div>

                <form id="formEditar" method="post">
                    <fieldset id="formCampos" disabled>

                        <h6 class="border-bottom-simar pb-2 mb-3">Información de Usuario</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-simar">Nombre de usuario</label>
                                <input type="text" id="editUsername" class="form-control-simar bg-light" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-simar">Correo Electrónico</label>
                                <input type="email" id="editEmail" class="form-control-simar bg-light" readonly />
                            </div>
                        </div>

                        <h6 class="border-bottom-simar pb-2 mt-4 mb-3">Datos Personales y Fiscales</h6>
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label-simar">Nombre Completo</label>
                                <input type="text" id="editNombre" class="form-control-simar" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label-simar">Género</label>
                                <select id="editGenero" class="form-select-simar">
                                    <option value="Masculino">Masculino</option>
                                    <option value="Femenino">Femenino</option>
                                    <option value="Otro">Otro</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-simar">CURP</label>
                                <input type="text" id="editCurp" class="form-control-simar bg-light" maxlength="18" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-simar">RFC</label>
                                <input type="text" id="editRfc" class="form-control-simar bg-light" maxlength="13" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-simar">Fecha de Nacimiento</label>
                                <input type="date" id="editBirthday" class="form-control-simar" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-simar">Teléfono</label>
                                <input type="tel" id="editPhone" class="form-control-simar" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label-simar">Domicilio</label>
                                <input type="text" id="editDireccion" class="form-control-simar" />
                            </div>
                        </div>

                        <h6 class="border-bottom-simar pb-2 mt-4 mb-3">Información Específica</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-simar">Rol en SIMAR</label>
                                <select id="editRol" class="form-select-simar bg-light" disabled>
                                    <option value="vendedor">Vendedor</option>
                                    <option value="tecnico">Técnico</option>
                                    <option value="chofer">Chofer</option>
                                    <option value="administrador">Administrador</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-simar">Salario Mensual ($ MXN)</label>
                                <input type="number" step="0.01" id="editSalario" class="form-control-simar" />
                            </div>

                            <div class="col-12 d-none" id="divEditDriver">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label-simar text-warning fw-bold">Número de Licencia</label>
                                        <input type="text" id="editNumLicencia" class="form-control-simar border-warning" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-simar text-warning fw-bold">Tipo de Licencia</label>
                                        <select id="editTipoLicencia" class="form-select-simar border-warning">
                                            <option value="A">Tipo A</option>
                                            <option value="B">Tipo B</option>
                                            <option value="E">Tipo E</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </fieldset>
                </form>
            </div>

            <div class="modal-footer d-none" id="footerGuardar">
                <button type="button" class="btn-simar-outline-gray" onclick="desactivarCampos()">Cancelar</button>
                <button type="submit" form="formEditar" class="btn-simar-primary">Guardar Cambios en Expediente</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // FILTRADO
        function filtrarTabla() {
            const busqueda = document.getElementById('busquedaInput').value.toLowerCase();
            const rolSeleccionado = document.getElementById('rolFiltro').value.toLowerCase();
            const filas = document.querySelector('#tablaUsuarios tbody').getElementsByTagName('tr');

            for (let fila of filas) {
                if(fila.cells.length < 2) continue;

                const informacionPrincipal = fila.cells[0].textContent.toLowerCase();
                const rol = fila.cells[1].textContent.toLowerCase();

                const coincideBusqueda = informacionPrincipal.includes(busqueda);
                const coincideRol = rolSeleccionado === "" || rol.includes(rolSeleccionado);

                fila.style.display = (coincideBusqueda && coincideRol) ? "" : "none";
            }
        }

        let idUsuarioParaEditar = ""; 

        function prepararEdicion(id, username, email, nombre, genero, curp, rfc, direccion, phone, birthday, rol, salario, numLic, tipoLic) 
        {
            idUsuarioParaEditar = id;

            document.getElementById('txtUsuarioTitulo').textContent = username;
            document.getElementById('editUsername').value = username;
            document.getElementById('editEmail').value = email;
            document.getElementById('editNombre').value = nombre;
            document.getElementById('editGenero').value = genero || "Otro";
            document.getElementById('editCurp').value = curp;
            document.getElementById('editRfc').value = rfc;
            document.getElementById('editDireccion').value = direccion || "";
            document.getElementById('editPhone').value = phone || "";
            document.getElementById('editBirthday').value = birthday || "";
            document.getElementById('editRol').value = rol.toLowerCase();
            document.getElementById('editSalario').value = salario;
            document.getElementById('editNumLicencia').value = numLic || "";
            document.getElementById('editTipoLicencia').value = tipoLic || "A";

            desactivarCampos();
            actualizarCamposDinamicosEdit();

            var modal = new bootstrap.Modal(document.getElementById('modalEditarUsuario'));
            modal.show();
        }

        document.getElementById('formEditar').addEventListener('submit', async function (e) {
            e.preventDefault(); 

            const datosActualizados = {
                fullName: document.getElementById('editNombre').value,
                address: document.getElementById('editDireccion').value,
                phone: document.getElementById('editPhone').value,
                genre: document.getElementById('editGenero').value,
                salary: parseFloat(document.getElementById('editSalario').value),
                licenseNumber: document.getElementById('editNumLicencia').value || null
            };

            try {
                const url = `http://localhost:8008/api/employees/${idUsuarioParaEditar}`;

                const response = await fetch(url, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(datosActualizados)
                });

                if (response.ok) {
                    Swal.fire('¡Éxito!', 'Los datos del empleado han sido actualizados.', 'success')
                        .then(() => location.reload());
                } else {
                    const errorData = await response.json();
                    Swal.fire('Error', errorData.mensaje || 'No se pudo actualizar la información.', 'error');
                }
            } catch (error) {
                console.error("Error en la petición:", error);
                Swal.fire('Error de Conexión', 'No se pudo contactar con el servidor.', 'error');
            }
        });

        function actualizarCamposDinamicosEdit() {
            const rol = document.getElementById('editRol').value;
            const divDriver = document.getElementById('divEditDriver');
            divDriver.classList.toggle('d-none', rol !== "chofer");
        }

        function activarCampos() {
            document.getElementById('formCampos').disabled = false;
            document.getElementById('btnHabilitarEdicion').classList.add('d-none');
            document.getElementById('footerGuardar').classList.remove('d-none');
        }

        function desactivarCampos() {
            document.getElementById('formCampos').disabled = true;
            document.getElementById('btnHabilitarEdicion').classList.remove('d-none');
            document.getElementById('footerGuardar').classList.add('d-none');
        }

        // --- Baja empleado ---
        let idUsuarioParaBaja = "";
        let nombreUsuarioParaBaja = "";

        function confirmarBaja(id, nombre) {
            idUsuarioParaBaja = id;
            nombreUsuarioParaBaja = nombre;
            document.getElementById('nombreUsuarioBaja').textContent = nombre;
            new bootstrap.Modal(document.getElementById('modalBaja')).show();
        }

        async function ejecutarBaja() {
            bootstrap.Modal.getInstance(document.getElementById('modalBaja')).hide();

            try {
                const url = `http://localhost:8008/api/employees/${idUsuarioParaBaja}/status?newState=0`;
                const response = await fetch(url, { method: 'PATCH' });

                if (response.ok) {
                    Swal.fire('¡Baja Exitosa!', `El empleado ${nombreUsuarioParaBaja} fue desactivado.`, 'success')
                        .then(() => location.reload());
                } else {
                    Swal.fire('Error', 'No se pudo desactivar al empleado. Verifica la consola.', 'error');
                }
            } catch (error) {
                console.error(error);
                Swal.fire('Error de Conexión', 'No se pudo contactar con el microservicio.', 'error');
            }
        }
    </script>
}

@section Styles {
    <style>
        .container-fluid-simar {
            width: 95%;
            max-width: 1400px;
            margin: 0 auto;
        }

        .input-group-text {
            height: 42px;
            border-radius: 10px 0 0 10px !important;
            background-color: white !important;
        }

        .form-control-simar {
            height: 42px;
        }
    </style>
}