<!-- Toasts -->
<div class="toast-container position-fixed bottom-0 end-0 p-4" style="z-index: 1060;">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="toast align-items-center text-white bg-success border-0 shadow-lg show" role="alert" aria-live="assertive" aria-atomic="true" style="border-radius:15px;">
            <div class="d-flex p-2">
                <div class="toast-body fs-5 d-flex align-items-center">
                    <i class="bi bi-check-circle-fill me-3 fs-4"></i>
                    <span>@Model.StatusMessage</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-danger border-0 shadow-lg show" role="alert" aria-live="assertive" aria-atomic="true" style="border-radius:15px;">
            <div class="d-flex p-2">
                <div class="toast-body fs-5 d-flex align-items-center">
                    <i class="bi bi-exclamation-triangle-fill me-3 fs-4"></i>
                    <span>@TempData["ErrorMessage"]</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var toastElList = [].slice.call(document.querySelectorAll('.toast'));
            toastElList.forEach(toastEl => {
                var toast = new bootstrap.Toast(toastEl, { delay: 6000 });
                toast.show();
            });

            var forms = document.querySelectorAll('.needs-validation');
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    // Checkbox group custom validation
                    var checkboxFeedback = form.querySelector('.checkbox-feedback');
                    var checkboxes = form.querySelectorAll('input[type="checkbox"][name="rejectReasons"]');
                    if (checkboxes.length > 0) {
                        var isChecked = Array.from(checkboxes).some(c => c.checked);
                        if (!isChecked) {
                            checkboxes.forEach(c => c.setCustomValidity("Debes seleccionar al menos un motivo."));
                            if(checkboxFeedback) checkboxFeedback.style.display = 'block';
                        } else {
                            checkboxes.forEach(c => c.setCustomValidity(""));
                            if(checkboxFeedback) checkboxFeedback.style.display = 'none';
                        }
                    }

                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    } else if (form.id === 'EditForm') {
                        if (!form.dataset.confirmed) {
                            event.preventDefault();
                            var confirmModal = new bootstrap.Modal(document.getElementById('confirmEditModal'));
                            confirmModal.show();
                            
                            document.getElementById('confirmEditBtn').onclick = function() {
                                form.dataset.confirmed = 'true';
                                confirmModal.hide();
                                form.submit();
                            };
                            return;
                        }
                    }
                    form.classList.add('was-validated');
                }, false);

                // Real-time validation and amount check
                var submitBtn = form.querySelector('button[type="submit"]');
                var validateForm = function() {
                    var isValid = form.checkValidity();
                    if (form.id === 'GenerateForm' || form.id === 'EditForm') {
                        var amount = parseFloat(submitBtn ? submitBtn.dataset.amount : 0);
                        if (amount <= 0) {
                            isValid = false;
                        }
                    }
                    if (submitBtn) {
                        submitBtn.disabled = !isValid;
                    }
                };

                // Listen to inputs
                var inputs = form.querySelectorAll('input, select, textarea');
                inputs.forEach(function(input) {
                    input.addEventListener('input', validateForm);
                    input.addEventListener('change', validateForm);
                });
                
                // Initial validation
                if (form.id === 'GenerateForm' || form.id === 'EditForm') {
                    validateForm();
                }
                
                // Add event listeners to checkboxes to hide error as soon as one is clicked
                var checkboxes = form.querySelectorAll('input[type="checkbox"][name="rejectReasons"]');
                checkboxes.forEach(function(chk) {
                    chk.addEventListener('change', function() {
                        var anyChecked = Array.from(checkboxes).some(c => c.checked);
                        if(anyChecked) {
                            checkboxes.forEach(c => c.setCustomValidity(""));
                            var feedback = form.querySelector('.checkbox-feedback');
                            if(feedback) feedback.style.display = 'none';
                        }
                        if (form.id === 'rejectModal-' + form.querySelector('input[name="id"]').value) {
                             validateForm();
                        }
                    });
                });
            });
        });
    </script>
}
