@if (Model.DisplayedRecords != null)
{
    foreach (var record in Model.DisplayedRecords.Where(r => r.Status == "Pending"))
    {
        <!-- Reject Modal for @record.Id -->
        <div class="modal fade modal-simar" id="rejectModal-@record.Id" tabindex="-1" aria-labelledby="rejectModalLabel-@record.Id" aria-hidden="true" style="z-index: 1060;">
          <div class="modal-dialog modal-dialog-centered">
            <form method="post" asp-page-handler="Reject" class="modal-content text-dark h-100 needs-validation" novalidate>
              <input type="hidden" name="id" value="@record.Id" />
              <input type="hidden" asp-for="Role" />
              <input type="hidden" asp-for="ActiveTab" />
              <div class="modal-header">
                <h5 class="modal-title" id="rejectModalLabel-@record.Id">Rechazar Factura @record.InvoiceNumber</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body text-start flex-grow-1 overflow-auto">
                <p class="mb-3">Por favor, marca las casillas de los campos incorrectos para informar al administrador:</p>
                <div class="row g-2">
                    @{
                        var reasonsList = new List<string> {
                            "RFC Incorrecto", "Razón Social Incorrecta", "Código Postal Incorrecto",
                            "Régimen Fiscal Incorrecto", "Uso de CFDI Incorrecto", "Forma de Pago Incorrecta",
                            "Método de Pago Incorrecto", "Concepto / Servicio Incorrecto", "Monto Total Incorrecto"
                        };
                    }
                    @for (int idx = 0; idx < reasonsList.Count; idx++)
                    {
                        var rText = reasonsList[idx];
                        var chkId = $"chk_{record.Id}_{idx}";
                        <div class="col-md-6">
                            <label class="form-check d-flex align-items-center p-2 border rounded-3 h-100 m-0 bg-light rounded" for="@chkId">
                                <input class="form-check-input my-0 ms-1 me-3 validate-checkbox" type="checkbox" name="rejectReasons" value="@rText" id="@chkId">
                                <span class="form-check-label text-simar-dark small">@rText</span>
                            </label>
                        </div>
                    }
                    <div class="col-12 mt-2 checkbox-feedback text-danger small text-center" style="display: none;">
                        <i class="bi bi-exclamation-circle me-1"></i> Debes seleccionar al menos un motivo de rechazo.
                    </div>
                </div>
              </div>
              <div class="modal-footer bg-light mt-auto">
                <button type="button" class="btn btn-simar-outline-gray" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-danger rounded-3 fw-medium px-3 py-2">Confirmar Rechazo</button>
              </div>
            </form>
          </div>
        </div>
    }
}

