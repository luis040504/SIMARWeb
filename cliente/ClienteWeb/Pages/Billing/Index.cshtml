@page
@model ClienteWeb.Pages.Billing.IndexModel
@{
    ViewData["Title"] = "Gestión de Facturación";
}

<div class="container-fluid-simar mt-4">
    <!-- User Role Selector Simulator -->
    <div class="card-simar mb-4 border-info">
        <div class="card-body bg-light d-flex align-items-center justify-content-between rounded-3">
            <div>
                <h5 class="mb-0 text-info fw-bold"><i class="bi bi-person-badge me-2"></i> Simulador de Rol de Usuario</h5>
                <small class="text-muted">Cambia el rol para ver las funcionalidades correspondientes.</small>
            </div>
            <form method="get" class="d-flex" id="roleForm">
                <select class="form-select-simar border-info" name="Role" asp-for="Role" onchange="document.getElementById('roleForm').submit()">
                    <option value="Admin">Administrador / Empleado</option>
                    <option value="Client">Cliente Final</option>
                </select>
                <input type="hidden" name="ActiveTab" value="" />
            </form>
        </div>
    </div>

    <!-- Main Content -->
    <div class="card-simar mb-4">
        <div class="card-simar-header pb-0 border-bottom-0">
            <ul class="nav nav-tabs border-bottom-0 pb-0">
                @if (Model.Role == "Admin")
                {
                    <li class="nav-item">
                        <a class="nav-link @(Model.ActiveTab == "RecentServices" ? "active fw-bold border-bottom-0 text-simar-green" : "text-secondary")" asp-page="./Index" asp-route-Role="@Model.Role" asp-route-ActiveTab="RecentServices">
                            <i class="bi bi-file-earmark-text me-1"></i> Servicios Recientes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Model.ActiveTab == "RejectedInvoices" ? "active fw-bold border-bottom-0 text-simar-green" : "text-secondary")" asp-page="./Index" asp-route-Role="@Model.Role" asp-route-ActiveTab="RejectedInvoices">
                            <i class="bi bi-exclamation-triangle me-1"></i> Facturas Rechazadas
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Model.ActiveTab == "GeneratedInvoices" ? "active fw-bold border-bottom-0 text-simar-green" : "text-secondary")" asp-page="./Index" asp-route-Role="@Model.Role" asp-route-ActiveTab="GeneratedInvoices">
                            <i class="bi bi-receipt me-1"></i> Facturas Generadas
                        </a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link @(Model.ActiveTab == "PendingInvoices" ? "active fw-bold border-bottom-0 text-simar-green" : "text-secondary")" asp-page="./Index" asp-route-Role="@Model.Role" asp-route-ActiveTab="PendingInvoices">
                            <i class="bi bi-clock-history me-1"></i> Facturas Pendientes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Model.ActiveTab == "AcceptedInvoices" ? "active fw-bold border-bottom-0 text-simar-green" : "text-secondary")" asp-page="./Index" asp-route-Role="@Model.Role" asp-route-ActiveTab="AcceptedInvoices">
                            <i class="bi bi-check-circle me-1"></i> Facturas Aceptadas
                        </a>
                    </li>
                }
            </ul>
        </div>
        <div class="card-body p-4 pt-4">

            <!-- Search Bar -->
            <form method="post" asp-page-handler="Search" class="mb-4">
                <input type="hidden" asp-for="Role" />
                <input type="hidden" asp-for="ActiveTab" />
                <div class="row align-items-end g-3">
                    <div class="col-md-@(Model.ActiveTab == "GeneratedInvoices" ? "3" : "5")">
                        <div class="position-relative h-100">
                            <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                            <input type="text" class="form-control-simar ps-5 h-100" asp-for="SearchQuery" placeholder="Buscar por RFC, Cliente o Factura...">
                        </div>
                    </div>
                    @if (Model.ActiveTab == "GeneratedInvoices")
                    {
                        <div class="col-md-2">
                            <label class="form-label form-label-simar mb-1 lh-1" style="font-size: 0.85rem;">Estado</label>
                            <select class="form-select form-control-simar px-3" style="height: 38px; border-radius: 8px;" asp-for="StatusFilter">
                                <option value="">Todos</option>
                                <option value="Pending">Pendiente</option>
                                <option value="Accepted">Aceptada</option>
                            </select>
                        </div>
                    }
                    <div class="col-md-2">
                        <label class="form-label form-label-simar mb-1 lh-1" style="font-size: 0.85rem;">Fecha Inicio</label>
                        <input type="date" class="form-control-simar" asp-for="StartDate">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label form-label-simar mb-1 lh-1" style="font-size: 0.85rem;">Fecha Fin</label>
                        <input type="date" class="form-control-simar" asp-for="EndDate">
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-simar-primary w-100 h-100 d-flex justify-content-center align-items-center" style="height: 38px;">
                            <i class="bi bi-search me-2"></i> Buscar
                        </button>
                    </div>
                </div>
            </form>

            @if (Model.IsSearchResult)
            {
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="text-simar-green fw-bold mb-0 fs-4">
                        <i class="bi bi-funnel me-2"></i> Resultados de la Búsqueda
                    </h5>
                    <a asp-page="./Index" asp-route-Role="@Model.Role" asp-route-ActiveTab="@Model.ActiveTab" class="btn btn-simar-outline-gray">Limpiar Búsqueda</a>
                </div>
            }

            <div class="row g-4">
                @if (Model.DisplayedRecords != null && Model.DisplayedRecords.Any())
                {
                    foreach (var record in Model.DisplayedRecords)
                    {
                        <div class="col-md-6 col-lg-4 col-xl-3">
                            <div class="card-simar-subtle h-100">
                                <div class="card-body p-4 position-relative d-flex flex-column h-100">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <h5 class="card-title text-dark fw-semibold text-truncate mb-0" title="@record.ClientName">@record.ClientName</h5>
                                        @if (record.RecordType == "Invoice")
                                        {
                                            <span class="badge badge-simar @(record.Status == "Accepted" ? "badge-simar-completada" : (record.Status == "Rejected" ? "badge-simar-cancelada" : "badge-simar-enruta"))">@record.InvoiceNumber</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-simar badge-simar-programada">ID: @record.Id</span>
                                        }
                                    </div>
                                    <p class="card-text mb-2"><small class="text-muted">RFC:</small> <strong class="text-simar-dark">@record.TaxId</strong></p>
                                    
                                    <p class="card-text mb-2"><small class="text-muted">Servicio:</small> <span class="badge bg-secondary badge-simar text-truncate d-inline-block align-bottom" title="@(record.ServiceType ?? record.Description)">@(record.ServiceType ?? record.Description)</span></p>
                                    @if(!string.IsNullOrEmpty(record.Reason))
                                    {
                                        <p class="card-text mb-2"><small class="text-muted">Motivo:</small> <span class="badge badge-simar badge-simar-cancelada text-wrap text-start lh-sm w-100 border-0">@record.Reason</span></p>
                                    }

                                    <p class="card-text mb-3"><small class="text-muted">Fecha:</small> @record.Date.ToString("dd/MM/yyyy")</p>
                                    <h4 class="card-text text-simar-green mt-2 mb-4">@record.Amount.ToString("C")</h4>
                                    
                                    <div class="mt-auto">
                                        @if (Model.Role == "Admin")
                                        {
                                            if (Model.ActiveTab == "RecentServices")
                                            {
                                                <form method="post" asp-page-handler="PrepareModal">
                                                    <input type="hidden" asp-for="SelectedRecordId" value="@record.Id" />
                                                    <input type="hidden" asp-for="Role" />
                                                    <input type="hidden" asp-for="ActiveTab" />
                                                    <input type="hidden" asp-for="SearchQuery" />
                                                    <input type="hidden" name="modalType" value="Generate" />
                                                    <button type="submit" class="btn btn-simar-primary justify-content-center w-100 mb-2">
                                                        <i class="bi bi-receipt"></i> Generar Factura
                                                    </button>
                                                </form>

                                                <form method="post" asp-page-handler="UploadPhysicalInvoice" enctype="multipart/form-data">
                                                    <input type="hidden" name="selectedRecordIdUpload" value="@record.Id" />
                                                    <input type="hidden" asp-for="Role" />
                                                    <input type="hidden" asp-for="ActiveTab" />
                                                    <div class="d-grid">
                                                        <label class="btn btn-simar-outline-gray justify-content-center w-100 mb-0" style="cursor: pointer;" for="upload_@record.Id">
                                                            <i class="bi bi-upload"></i> Subir Física
                                                        </label>
                                                        <input type="file" id="upload_@record.Id" name="PhysicalInvoice" accept=".pdf" class="d-none" onchange="this.form.submit()" />
                                                    </div>
                                                </form>
                                            }
                                            else if (Model.ActiveTab == "RejectedInvoices")
                                            {
                                                <form method="post" asp-page-handler="PrepareModal">
                                                    <input type="hidden" asp-for="SelectedRecordId" value="@record.Id" />
                                                    <input type="hidden" asp-for="Role" />
                                                    <input type="hidden" asp-for="ActiveTab" />
                                                    <input type="hidden" asp-for="SearchQuery" />
                                                    <input type="hidden" name="modalType" value="Edit" />
                                                    <button type="submit" class="btn btn-simar-outline justify-content-center w-100">
                                                        <i class="bi bi-pencil-fill"></i> Editar Factura
                                                    </button>
                                                </form>
                                            }
                                            else if (Model.ActiveTab == "GeneratedInvoices")
                                            {
                                                <div class="mb-2">
                                                    <form method="post" asp-page-handler="PrepareModal" class="w-100">
                                                        <input type="hidden" asp-for="SelectedRecordId" value="@record.Id" />
                                                        <input type="hidden" asp-for="Role" />
                                                        <input type="hidden" asp-for="ActiveTab" />
                                                        <input type="hidden" asp-for="SearchQuery" />
                                                        <input type="hidden" name="modalType" value="Details" />
                                                        <button type="submit" class="btn btn-simar-outline-gray justify-content-center w-100 d-inline-flex align-items-center gap-2">
                                                            <i class="bi bi-eye"></i> Ver Detalles
                                                        </button>
                                                    </form>
                                                </div>
                                                @if (record.Status == "Accepted") 
                                                {
                                                    <form method="post" asp-page-handler="Download" class="w-100">
                                                        <input type="hidden" name="id" value="@record.Id" />
                                                        <input type="hidden" asp-for="Role" />
                                                        <input type="hidden" asp-for="ActiveTab" />
                                                        <button type="submit" class="btn btn-simar-primary justify-content-center w-100">
                                                            <i class="bi bi-download"></i> Descargar
                                                        </button>
                                                    </form>
                                                }
                                            }
                                        }
                                        else 
                                        {
                                            <div class="mb-2">
                                                <form method="post" asp-page-handler="PrepareModal" class="w-100">
                                                    <input type="hidden" asp-for="SelectedRecordId" value="@record.Id" />
                                                    <input type="hidden" asp-for="Role" />
                                                    <input type="hidden" asp-for="ActiveTab" />
                                                    <input type="hidden" asp-for="SearchQuery" />
                                                    <input type="hidden" name="modalType" value="Details" />
                                                    <button type="submit" class="btn btn-simar-outline-gray justify-content-center w-100 mb-2 d-inline-flex align-items-center gap-2">
                                                        <i class="bi bi-eye"></i> Ver Detalles
                                                    </button>
                                                </form>
                                            </div>
                                            
                                            <div>
                                                <form method="post" class="w-100 d-flex justify-content-between gap-2">
                                                    <input type="hidden" name="id" value="@record.Id" />
                                                    <input type="hidden" asp-for="Role" />
                                                    <input type="hidden" asp-for="ActiveTab" />
                                                    @if (record.Status == "Pending")
                                                    {
                                                        <button type="submit" asp-page-handler="Accept" class="btn btn-simar-primary flex-fill justify-content-center flex-column px-1 py-2 text-center small">
                                                            <i class="bi bi-check-circle mb-1"></i> Aceptar
                                                        </button>
                                                        <button type="button" class="btn btn-outline-danger flex-fill d-inline-flex flex-column align-items-center justify-content-center px-1 py-2" data-bs-toggle="modal" data-bs-target="#rejectModal-@record.Id">
                                                            <i class="bi bi-x-circle mb-1"></i> Rechazar
                                                        </button>
                                                    }
                                                    else if (record.Status == "Accepted")
                                                    {
                                                        <button type="submit" asp-page-handler="Download" class="btn btn-simar-primary justify-content-center w-100">
                                                            <i class="bi bi-download"></i> Descargar
                                                        </button>
                                                    }
                                                </form>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="empty-state-simar">
                            <i class="bi bi-inboxes"></i>
                            <h4>No se encontraron registros</h4>
                            <p class="text-muted mb-0">Intenta cambiar los filtros de búsqueda o categoría.</p>
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
</div>

<!-- Modals Container -->
@if (Model.ActiveModal == "Generate" || Model.ActiveModal == "Edit")
{
    var modalTitle = Model.ActiveModal == "Generate" ? "Generar Factura" : "Editar Factura";
    var iconClass = Model.ActiveModal == "Generate" ? "bi-check-circle-fill" : "bi-save-fill";
    var handler = Model.ActiveModal == "Generate" ? "Generate" : "Edit";
    var bgClass = Model.ActiveModal == "Generate" ? "bg-simar-light" : "bg-warning bg-opacity-10";
    
    <div class="modal-backdrop fade show" style="z-index: 1040;"></div>
    <div class="modal modal-simar fade show d-block" tabindex="-1" role="dialog" style="z-index: 1050;">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <form method="post" asp-page-handler="@handler" id="@(handler)Form" class="modal-content h-100 needs-validation" novalidate>
                <div class="modal-header">
                    <h4 class="modal-title">
                        <i class="bi bi-clipboard-data me-2"></i> @modalTitle
                    </h4>
                    <a href="/Billing?Role=@Model.Role&ActiveTab=@Model.ActiveTab" class="btn-close"></a>
                </div>
                
                <div class="@bgClass px-5 py-4 border-bottom">
                    <div class="row align-items-end">
                        <div class="col-md-8">
                            <small class="text-uppercase fw-bold text-muted">@modalTitle para:</small>
                            <h3 class="mb-0 mt-2 text-simar-dark fw-bold">@Model.SelectedRecord?.ClientName <span class="fs-5 opacity-75 fw-normal">(@Model.SelectedRecord?.TaxId)</span></h3>
                        </div>
                        <div class="col-md-4 text-md-end mt-3 mt-md-0">
                            <h2 class="mb-0 fw-bold text-simar-green">@Model.SelectedRecord?.Amount.ToString("C")</h2>
                        </div>
                    </div>
                </div>

                @{
                    var reason = Model.SelectedRecord?.Reason ?? "";
                    var isRfcBad = Model.ActiveModal == "Edit" && reason.Contains("RFC");
                    var isNameBad = Model.ActiveModal == "Edit" && reason.Contains("Razón Social");
                    var isPostalBad = Model.ActiveModal == "Edit" && reason.Contains("Código Postal");
                    var isRegimeBad = Model.ActiveModal == "Edit" && reason.Contains("Régimen Fiscal");
                    var isCfdiBad = Model.ActiveModal == "Edit" && reason.Contains("CFDI");
                    var isPayFormBad = Model.ActiveModal == "Edit" && reason.Contains("Forma de Pago");
                    var isPayMethodBad = Model.ActiveModal == "Edit" && reason.Contains("Método de Pago");
                    var isConceptBad = Model.ActiveModal == "Edit" && (reason.Contains("Concepto") || reason.Contains("Servicio") || reason.Contains("Monto"));
                }

                <div class="modal-body modal-scrollable-simar p-5 pt-4 flex-grow-1 overflow-auto">
                    <input type="hidden" asp-for="SelectedRecordId" />
                    <input type="hidden" asp-for="Role" />
                    <input type="hidden" asp-for="ActiveTab" />
                    <input type="hidden" asp-for="SearchQuery" />
                    
                    <div class="row g-4">
                        <div class="col-12">
                            <div class="card-simar-subtle border-0">
                                <div class="card-body p-4">
                                    <h5 class="card-subtitle mb-4 text-simar-dark fw-bold text-uppercase border-bottom pb-3">
                                        <i class="bi bi-person-vcard text-simar-green me-3"></i>1. Información del Receptor
                                    </h5>
                                    <div class="row g-4">
                                            <div class="col-md-4">
                                                <label class="form-label form-label-simar text-danger @(isRfcBad ? "fw-bold" : "")">RFC *</label>
                                                <input type="text" class="form-control form-control-simar @(isRfcBad ? "is-invalid border-danger bg-danger bg-opacity-10" : "")" asp-for="TaxId" readonly="@(Model.ActiveModal == "Generate" ? "readonly" : null)" required pattern="^[A-Za-zÑñ&]{3,4}[0-9]{6}[A-Za-z0-9]{3}$" minlength="12" maxlength="13" oninput="this.value = this.value.toUpperCase()" title="Un RFC válido consta de 12 a 13 caracteres, formato letras y números (ej. ABC123456T12)">
                                                <div class="invalid-feedback">RFC inválido. Letras mayúsculas (3-4), AAMMdd y 3 caracteres finales.</div>
                                                @if(isRfcBad) { <div class="invalid-feedback d-block fw-bold"><i class="bi bi-exclamation-triangle"></i> Marcado para corrección</div> }
                                            </div>
                                            <div class="col-md-8">
                                                <label class="form-label form-label-simar text-danger @(isNameBad ? "fw-bold" : "")">Razón Social *</label>
                                                <input type="text" class="form-control form-control-simar @(isNameBad ? "is-invalid border-danger bg-danger bg-opacity-10" : "")" asp-for="BillingName" readonly="@(Model.ActiveModal == "Generate" ? "readonly" : null)" required minlength="3" maxlength="250" title="Ingresa la razón social">
                                                <div class="invalid-feedback">La razón social es requerida (mín. 3 caracteres).</div>
                                                @if(isNameBad) { <div class="invalid-feedback d-block fw-bold"><i class="bi bi-exclamation-triangle"></i> Marcado para corrección</div> }
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label form-label-simar text-danger @(isPostalBad ? "fw-bold" : "")">Código Postal *</label>
                                                <input type="text" class="form-control form-control-simar @(isPostalBad ? "is-invalid border-danger bg-danger bg-opacity-10" : "")" asp-for="PostalCode" required maxlength="5" minlength="5" pattern="\d{5}" title="Debe contener exactamente 5 dígitos numéricos">
                                                <div class="invalid-feedback">Debe contener 5 dígitos.</div>
                                                @if(isPostalBad) { <div class="invalid-feedback d-block fw-bold"><i class="bi bi-exclamation-triangle"></i> Marcado para corrección</div> }
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label form-label-simar text-danger @(isRegimeBad ? "fw-bold" : "")">Régimen Fiscal *</label>
                                                <select class="form-select form-select-simar @(isRegimeBad ? "is-invalid border-danger bg-danger bg-opacity-10" : "")" asp-for="FiscalRegime" required>
                                                    <option value="">-- Seleccione --</option>
                                                    <option value="601">601 - General Ley Personas Morales</option>
                                                    <option value="612">612 - Personas Físicas con Actividades</option>
                                                    <option value="626">626 - RESICO</option>
                                                </select>
                                                <div class="invalid-feedback">Selecciona un régimen fiscal.</div>
                                                @if(isRegimeBad) { <div class="invalid-feedback d-block fw-bold"><i class="bi bi-exclamation-triangle"></i> Marcado para corrección</div> }
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label form-label-simar text-danger @(isCfdiBad ? "fw-bold" : "")">Uso de CFDI *</label>
                                                <select class="form-select form-select-simar @(isCfdiBad ? "is-invalid border-danger bg-danger bg-opacity-10" : "")" asp-for="CfdiUsage" required>
                                                    <option value="">-- Seleccione --</option>
                                                    <option value="G01">G01 - Adquisición mercancías</option>
                                                    <option value="G03">G03 - Gastos en general</option>
                                                </select>
                                                <div class="invalid-feedback">Selecciona el uso de CFDI.</div>
                                                @if(isCfdiBad) { <div class="invalid-feedback d-block fw-bold"><i class="bi bi-exclamation-triangle"></i> Marcado para corrección</div> }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-12">
                                <div class="card-simar-subtle border-0">
                                    <div class="card-body p-4">
                                        <h5 class="card-subtitle mb-4 text-simar-dark fw-bold text-uppercase border-bottom pb-3">
                                            <i class="bi bi-wallet2 text-simar-green me-3"></i>2. Atributos de Pago
                                        </h5>
                                        <div class="row g-4">
                                            <div class="col-md-6">
                                                <label class="form-label form-label-simar text-danger @(isPayFormBad ? "fw-bold" : "")">Forma de Pago *</label>
                                                <select class="form-select form-select-simar @(isPayFormBad ? "is-invalid border-danger bg-danger bg-opacity-10" : "")" asp-for="PaymentForm" required>
                                                    <option value="">-- Seleccione --</option>
                                                    <option value="01">01 - Efectivo</option>
                                                    <option value="03">03 - Transferencia</option>
                                                    <option value="04">04 - Tarjeta Crédito</option>
                                                    <option value="99">99 - Por definir</option>
                                                </select>
                                                <div class="invalid-feedback">Selecciona una forma de pago.</div>
                                                @if(isPayFormBad) { <div class="invalid-feedback d-block fw-bold"><i class="bi bi-exclamation-triangle"></i> Marcado para corrección</div> }
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label form-label-simar text-danger @(isPayMethodBad ? "fw-bold" : "")">Método de Pago *</label>
                                                <select class="form-select form-select-simar @(isPayMethodBad ? "is-invalid border-danger bg-danger bg-opacity-10" : "")" asp-for="PaymentMethod" required>
                                                    <option value="">-- Seleccione --</option>
                                                    <option value="PUE">PUE - Pago una exhibición</option>
                                                    <option value="PPD">PPD - Pago diferido</option>
                                                </select>
                                                <div class="invalid-feedback">Selecciona un método de pago.</div>
                                                @if(isPayMethodBad) { <div class="invalid-feedback d-block fw-bold"><i class="bi bi-exclamation-triangle"></i> Marcado para corrección</div> }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="card-simar-subtle border-0">
                                    <div class="card-body p-4">
                                        <h5 class="card-subtitle mb-4 text-simar-dark fw-bold text-uppercase border-bottom pb-3">
                                            <i class="bi bi-list-check text-simar-green me-3"></i>3. Conceptos y Totales
                                        </h5>
                                        @if(isConceptBad) {
                                            <div class="alert alert-danger py-2 mb-3 fw-bold"><i class="bi bi-exclamation-triangle me-2"></i> Los importes o servicios están marcados para corrección.</div>
                                        }
                                        @if(Model.SelectedRecord?.Amount <= 0) {
                                            <div class="alert alert-danger py-2 mb-3 fw-bold"><i class="bi bi-exclamation-triangle me-2"></i> El monto total debe ser mayor a 0 para generar la factura.</div>
                                        }
                                        <div class="table-responsive table-responsive-simar">
                                            <table class="table table-simar mb-0 @(isConceptBad ? "border-danger bg-danger bg-opacity-10" : "")">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Concepto</th>
                                                        <th>Cantidad</th>
                                                        <th>Precio Unitario</th>
                                                        <th>Impuestos (IVA 16%)</th>
                                                        <th>Importe</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr>
                                                        <td>@(Model.SelectedRecord?.ServiceType ?? Model.SelectedRecord?.Description ?? "Servicio")</td>
                                                        <td>1</td>
                                                        <td>@(((Model.SelectedRecord?.Amount ?? 0) / 1.16m).ToString("C"))</td>
                                                        <td>@((((Model.SelectedRecord?.Amount ?? 0) / 1.16m) * 0.16m).ToString("C"))</td>
                                                        <td>@((Model.SelectedRecord?.Amount ?? 0).ToString("C"))</td>
                                                    </tr>
                                                </tbody>
                                                <tfoot>
                                                    <tr>
                                                        <th colspan="4" class="text-end border-0">Subtotal:</th>
                                                        <th>@(((Model.SelectedRecord?.Amount ?? 0) / 1.16m).ToString("C"))</th>
                                                    </tr>
                                                    <tr>
                                                        <th colspan="4" class="text-end border-0">IVA (16%):</th>
                                                        <th>@((((Model.SelectedRecord?.Amount ?? 0) / 1.16m) * 0.16m).ToString("C"))</th>
                                                    </tr>
                                                    <tr>
                                                        <th colspan="4" class="text-end fs-5 text-simar-green border-0">Total:</th>
                                                        <th class="fs-5 text-simar-green">@((Model.SelectedRecord?.Amount ?? 0).ToString("C"))</th>
                                                    </tr>
                                                </tfoot>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                </div>
                <div class="modal-footer bg-light mt-auto">
                    <a href="/Billing?Role=@Model.Role&ActiveTab=@Model.ActiveTab" class="btn btn-simar-outline-gray">Cancelar</a>
                    <button type="submit" class="btn btn-simar-primary" id="confirmSubmitBtn" data-amount="@(Model.SelectedRecord?.Amount ?? 0)">
                        <i class="bi @iconClass"></i> Confirmar
                    </button>
                </div>
            </form>
        </div>
    </div>
    <script> document.body.style.overflow = 'hidden'; </script>
}
