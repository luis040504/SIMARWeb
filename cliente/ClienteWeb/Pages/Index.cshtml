        </div>
        
        <div class="row g-4">
            <!-- Agencias Automotrices -->
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="giro-card">
                    <div class="giro-icon">
                        <i class="bi bi-car-front"></i>
                    </div>
                    <div class="giro-name">Agencias Automotrices</div>
                    <div class="giro-services">
                        <span>Aceites usados</span>
                        <span>Baterías</span>
                        <span>Llantas</span>
                        <span>Filtros</span>
                    </div>
                </div>
            </div>
            
            <!-- Constructoras -->
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="giro-card">
                    <div class="giro-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <div class="giro-name">Constructoras</div>
                    <div class="giro-services">
                        <span>Escombros</span>
                        <span>Tierra contaminada</span>
                        <span>Materiales de demolición</span>
                        <span>Residuos de construcción</span>
                    </div>
                </div>
            </div>
            
            <!-- Dentistas y consultorios -->
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="giro-card">
                    <div class="giro-icon">
                        <i class="bi bi-hospital"></i>
                    </div>
                    <div class="giro-name">Dentistas y consultorios</div>
                    <div class="giro-services">
                        <span>Residuos biológicos</span>
                        <span>Material punzocortante</span>
                        <span>Rayos X</span>
                        <span>Mercurio dental</span>
                    </div>
                </div>
            </div>
            
            <!-- Hospitales -->
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="giro-card">
                    <div class="giro-icon">
                        <i class="bi bi-heart-pulse"></i>
                    </div>
                    <div class="giro-name">Hospitales</div>
                    <div class="giro-services">
                        <span>Residuos peligrosos biológico-infecciosos</span>
                        <span>Desechos farmacéuticos</span>
                        <span>Material quirúrgico</span>
                    </div>
                </div>
            </div>
            
            <!-- Industrias -->
<div class="col-lg-3 col-md-4 col-sm-6">
    <div class="giro-card">
        <div class="giro-icon">
            <i class="bi bi-building-gear"></i>
        </div>
        <div class="giro-name">Industrias</div>
        <div class="giro-services">
            <span>Residuos peligrosos</span>
            <span>Líquidos industriales</span>
            <span>Lodos</span>
            <span>Envases contaminados</span>
        </div>
    </div>
</div>
            
            <!-- Gasolineras -->
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="giro-card">
                    <div class="giro-icon">
                        <i class="bi bi-fuel-pump"></i>
                    </div>
                    <div class="giro-name">Gasolineras</div>
                    <div class="giro-services">
                        <span>Hidrocarburos</span>
                        <span>Agua aceitosa</span>
                        <span>Trapos contaminados</span>
                        <span>Filtros usados</span>
                    </div>
                </div>
            </div>
            
            <!-- Laboratorios clínicos -->
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="giro-card">
                    <div class="giro-icon">
                        <i class="bi bi-motherboard"></i>
                    </div>
                    <div class="giro-name">Laboratorios clínicos</div>
                    <div class="giro-services">
                        <span>Residuos biológicos</span>
                        <span>Reactivos químicos</span>
                        <span>Muestras biológicas</span>
                        <span>Material de vidrio contaminado</span>
                    </div>
                </div>
            </div>
            
            <!-- Plazas comerciales -->
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="giro-card">
                    <div class="giro-icon">
                        <i class="bi bi-shop"></i>
                    </div>
                    <div class="giro-name">Plazas comerciales</div>
                    <div class="giro-services">
                        <span>Residuos sólidos urbanos</span>
                        <span>Residuos de comida</span>
