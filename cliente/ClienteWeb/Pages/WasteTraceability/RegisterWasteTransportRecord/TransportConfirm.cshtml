@page
@model ClienteWeb.Pages.WasteTraceability.RegisterWasteTransportRecord.TransportConfirmModel
@{
    ViewData["Title"] = "Confirmar Inicio de Transporte";
}

<style>
    /* Unificación de estilos con el layout */
    :root {
        --simar-green: #5aad31;
        --simar-dark: #4a4a4a;
        --simar-gray-light: #f8f9fa;
        --simar-border: #e9ecef;
    }
    
    * {
        font-family: 'Inter', sans-serif;
    }
    
    /* Contenedor principal */
    .container-fluid-custom {
        width: 100%;
        padding-right: 1rem;
        padding-left: 1rem;
    }
    
    .confirm-container {
        max-width: 900px;
        margin: 0 auto;
    }
    
    /* Header de página */
    .page-header {
        margin-bottom: 2rem;
    }
    
    .page-header h2 {
        font-size: 1.8rem;
        font-weight: 600;
        color: var(--simar-dark);
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .page-header h2 i {
        color: var(--simar-green);
    }
    
    .page-header p {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 0;
    }
    
    /* Botón regresar */
    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: transparent;
        border: 1px solid var(--simar-border);
        color: var(--simar-dark);
        border-radius: 10px;
        padding: 0.6rem 1.25rem;
        font-weight: 500;
        font-size: 0.9rem;
        transition: all 0.2s ease;
        cursor: pointer;
        text-decoration: none;
        margin-bottom: 1.5rem;
    }
    
    .btn-back:hover {
        background: var(--simar-gray-light);
        border-color: var(--simar-green);
        transform: translateX(-3px);
    }
    
    /* Mensaje de confirmación */
    .confirm-message {
        background: rgba(90, 173, 49, 0.08);
        border: 1px solid var(--simar-green);
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .confirm-message i {
        font-size: 2rem;
        color: var(--simar-green);
    }
    
    .confirm-message-content {
        flex: 1;
    }
    
    .confirm-message-content strong {
        font-size: 1.1rem;
        color: var(--simar-dark);
        display: block;
        margin-bottom: 0.25rem;
    }
    
    .confirm-message-content span {
        color: #3d7a1f;
        font-size: 0.9rem;
    }
    
    /* Tarjeta de detalles */
    .details-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        border: 1px solid var(--simar-border);
        margin-bottom: 2rem;
    }
    
    .details-header {
        padding: 1rem 1.5rem;
        background: var(--simar-gray-light);
        border-bottom: 2px solid var(--simar-green);
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .details-header i {
        color: var(--simar-green);
        font-size: 1.25rem;
    }
    
    .details-header h3 {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--simar-dark);
    }
    
    .detail-item {
        display: flex;
        border-bottom: 1px solid var(--simar-border);
    }
    
    .detail-item:last-child {
        border-bottom: none;
    }
    
    .detail-label {
        width: 220px;
        padding: 1rem 1.5rem;
        background: white;
        font-weight: 500;
        font-size: 0.85rem;
        color: var(--simar-dark);
        border-right: 1px solid var(--simar-border);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .detail-label i {
        color: var(--simar-green);
        font-size: 1rem;
        width: 18px;
    }
    
    .detail-value {
        flex: 1;
        padding: 1rem 1.5rem;
        color: #666;
        font-size: 0.9rem;
        background: white;
        word-break: break-word;
    }
    
    .detail-value strong {
        color: var(--simar-dark);
    }
    
    .detail-info {
        font-size: 0.75rem;
        color: #999;
        margin-top: 0.25rem;
    }
    
    /* Sección destacada del vehículo */
    .vehicle-highlight {
        background: rgba(90, 173, 49, 0.03);
    }
    
    .vehicle-highlight .detail-label {
        background: rgba(90, 173, 49, 0.05);
    }
    
    .vehicle-highlight .detail-value {
        background: rgba(90, 173, 49, 0.03);
    }
    
    .vehicle-info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem 1.5rem;
    }
    
    .vehicle-info-item {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
    }
    
    .vehicle-info-item i {
        color: var(--simar-green);
        font-size: 0.85rem;
        width: 18px;
    }
    
    .vehicle-info-item strong {
        min-width: 100px;
        color: var(--simar-dark);
    }
    
    /* Badge de estado */
    .status-badge {
        display: inline-block;
        padding: 0.3rem 0.75rem;
        font-size: 0.7rem;
        font-weight: 600;
        border-radius: 30px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        background: rgba(0, 102, 204, 0.1);
        color: #0066cc;
        border: 1px solid rgba(0, 102, 204, 0.3);
    }
    
    /* Botones de acción */
    .action-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        padding: 0.5rem 0;
    }
    
    .btn-simar-primary {
        background: var(--simar-green);
        border: none;
        color: white;
        border-radius: 12px;
        padding: 0.9rem 2.5rem;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.2s ease;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        min-width: 200px;
        justify-content: center;
        box-shadow: 0 4px 12px rgba(90, 173, 49, 0.2);
    }
    
    .btn-simar-primary:hover {
        background: #3d7a1f;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(90, 173, 49, 0.3);
    }
    
    .btn-simar-secondary {
        background: white;
        border: 1px solid var(--simar-border);
        color: var(--simar-dark);
        border-radius: 12px;
        padding: 0.9rem 2.5rem;
        font-weight: 500;
        font-size: 1rem;
        transition: all 0.2s ease;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        min-width: 200px;
        justify-content: center;
    }
    
    .btn-simar-secondary:hover {
        background: var(--simar-gray-light);
        border-color: var(--simar-green);
        transform: translateY(-2px);
    }
    
    /* Formularios inline */
    .inline-form {
        display: inline;
    }
    
    /* Nota informativa */
    .info-note {
        margin-top: 1.5rem;
        padding: 1rem 1.25rem;
        background: rgba(90, 173, 49, 0.05);
        border-radius: 12px;
        border-left: 4px solid var(--simar-green);
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
    }
    
    .info-note i {
        color: var(--simar-green);
        font-size: 1.1rem;
    }
    
    .info-note-content {
        flex: 1;
        color: #666;
        font-size: 0.85rem;
    }
    
    .info-note-content strong {
        color: var(--simar-dark);
        display: block;
        margin-bottom: 0.25rem;
    }
    
    /* Etiqueta de destino */
    .destination-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--simar-gray-light);
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.85rem;
        margin-top: 0.5rem;
    }
    
    .destination-badge i {
        color: var(--simar-green);
    }
    
    /* Responsive */
    @@media (max-width: 768px) {
        .detail-item {
            flex-direction: column;
        }
        
        .detail-label {
            width: 100%;
            border-right: none;
            border-bottom: 1px solid var(--simar-border);
        }
        
        .vehicle-info-grid {
            grid-template-columns: 1fr;
        }
        
        .action-buttons {
            flex-direction: column;
        }
        
        .btn-simar-primary,
        .btn-simar-secondary {
            width: 100%;
            min-width: auto;
        }
        
        .confirm-message {
            flex-direction: column;
            text-align: center;
        }
    }
</style>

<div class="container-fluid-custom">
    <div class="confirm-container">
        <!-- Botón regresar -->
        <button class="btn-back" onclick="window.location.href='/WasteTraceability/ConsultWasteHistory/ServiceHistory?cliente=@(Model.Servicio?.Cliente ?? "Industrias ABC")'">
            <i class="bi bi-arrow-left"></i>
            Regresar al historial
        </button>
        
        <!-- Header -->
        <div class="page-header">
            <h2>
                <i class="bi bi-truck"></i>
                Confirmar Inicio de Transporte
            </h2>
            <p>Verifique los detalles antes de iniciar el transporte de residuos</p>
        </div>
        
        <!-- Mensaje de confirmación -->
        <div class="confirm-message">
            <i class="bi bi-question-circle"></i>
            <div class="confirm-message-content">
                <strong>¿Está seguro de que desea iniciar el transporte?</strong>
                <span>Esta acción registrará el inicio del traslado de residuos hacia la planta de tratamiento</span>
            </div>
        </div>
        
        @if (Model.Servicio != null)
        {
            <!-- Tarjeta de detalles -->
            <div class="details-card">
                <div class="details-header">
                    <i class="bi bi-info-circle"></i>
                    <h3>Detalles del Servicio</h3>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="bi bi-hash"></i>
                        ID del Servicio
                    </div>
                    <div class="detail-value">
                        <strong>#@Model.Servicio.Id</strong>
                    </div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="bi bi-building"></i>
                        Cliente
                    </div>
                    <div class="detail-value">@Model.Servicio.Cliente</div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="bi bi-file-earmark-text"></i>
                        Contrato
                    </div>
                    <div class="detail-value">@Model.Servicio.Contrato</div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="bi bi-geo-alt"></i>
                        Dirección de Recolección
                    </div>
                    <div class="detail-value">
                        @Model.Servicio.Direccion
                        <div class="destination-badge">
                            <i class="bi bi-geo-alt-fill"></i>
                            <span>Destino: Planta de Tratamiento Central</span>
                        </div>
                    </div>
                </div>
                
                <!-- Sección destacada del vehículo -->
                <div class="detail-item vehicle-highlight">
                    <div class="detail-label">
                        <i class="bi bi-truck"></i>
                        Información del Vehículo
                    </div>
                    <div class="detail-value">
                        <div class="vehicle-info-grid">
                            <div class="vehicle-info-item">
                                <i class="bi bi-truck"></i>
                                <strong>Vehículo:</strong>
                                <span>@Model.Servicio.Vehiculo</span>
                            </div>
                            <div class="vehicle-info-item">
                                <i class="bi bi-upc-scan"></i>
                                <strong>Placa:</strong>
                                <span>@Model.Servicio.Placa</span>
                            </div>
                            <div class="vehicle-info-item">
                                <i class="bi bi-tags"></i>
                                <strong>Tipo:</strong>
                                <span>@Model.Servicio.TipoVehiculo</span>
                            </div>
                            <div class="vehicle-info-item">
                                <i class="bi bi-recycle"></i>
                                <strong>Residuo:</strong>
                                <span>@Model.Servicio.TipoResiduoTransporte</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="bi bi-person-badge"></i>
                        Conductor
                    </div>
                    <div class="detail-value">@Model.Servicio.Conductor</div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="bi bi-tools"></i>
                        Técnico
                    </div>
                    <div class="detail-value">@Model.Servicio.Tecnico</div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="bi bi-calendar"></i>
                        Fecha de Recolección
                    </div>
                    <div class="detail-value">
                        @Model.Servicio.FechaServicio.ToString("dd 'de' MMMM 'de' yyyy")
                        <div class="detail-info">
                            <i class="bi bi-clock"></i> 
                            @Model.Servicio.FechaServicio.ToString("HH:mm") hrs
                        </div>
                    </div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="bi bi-flag"></i>
                        Estado Actual
                    </div>
                    <div class="detail-value">
                        <span class="status-badge">
                            <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>
                            @Model.Servicio.Estado
                        </span>
                    </div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="bi bi-recycle"></i>
                        Tipo de Residuo
                    </div>
                    <div class="detail-value">@Model.Servicio.TipoResiduo</div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="bi bi-weight"></i>
                        Cantidad a Transportar
                    </div>
                    <div class="detail-value">
                        <strong>@Model.Servicio.CantidadEstimada.ToString("N2") kg</strong>
                    </div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="bi bi-chat-text"></i>
                        Observaciones
                    </div>
                    <div class="detail-value">
                        @(string.IsNullOrEmpty(Model.Servicio.Observaciones) ? "Sin observaciones" : Model.Servicio.Observaciones)
                    </div>
                </div>
            </div>
            
            <!-- Nota informativa -->
            <div class="info-note">
                <i class="bi bi-info-circle"></i>
                <div class="info-note-content">
                    <strong>Información importante</strong>
                    Al confirmar el inicio del transporte, el estado del servicio cambiará a "En curso" y se registrará la hora de salida. El vehículo deberá reportar su llegada al destino final.
                </div>
            </div>
        }
        
        <!-- Botones de acción -->
        <div class="action-buttons">
            <form method="post" asp-page-handler="ConfirmarTransporte" class="inline-form">
                <button type="submit" class="btn-simar-primary">
                    <i class="bi bi-play-fill"></i>
                    Iniciar Transporte
                </button>
            </form>
            
            <form method="post" asp-page-handler="Cancelar" class="inline-form">
                <button type="submit" class="btn-simar-secondary">
                    <i class="bi bi-x-lg"></i>
                    Cancelar
                </button>
            </form>
        </div>
    </div>
</div>