@page
@model ClienteWeb.Pages.WasteTraceability.RegisterWasteCollection.IndexModel
@{
    ViewData["Title"] = "Mis Servicios del Día";
}

<style>
    body {
        font-family: Arial, Helvetica, sans-serif;
        background-color: white;
        color: black;
        margin: 0;
        padding: 20px;
    }
    
    h1 {
        font-size: 24px;
        margin-bottom: 20px;
        border-bottom: 2px solid black;
        padding-bottom: 10px;
    }
    
    .container {
        max-width: 1200px;
        margin: 0 auto;
    }
    
    .filtros {
        margin-bottom: 20px;
        padding: 15px;
        border: 1px solid #ccc;
        background-color: #f9f9f9;
    }
    
    .filtros select, .filtros input {
        padding: 8px;
        margin-right: 10px;
        border: 1px solid #999;
        background-color: white;
    }
    
    .btn-filtrar {
        padding: 8px 15px;
        background-color: white;
        border: 1px solid black;
        cursor: pointer;
    }
    
    .btn-filtrar:hover {
        background-color: #f0f0f0;
    }
    
    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }
    
    th {
        text-align: left;
        padding: 12px;
        background-color: #333;
        color: white;
        font-weight: bold;
        border: 1px solid black;
    }
    
    td {
        padding: 12px;
        border: 1px solid #999;
        vertical-align: middle;
    }
    
    tr:hover {
        background-color: #f5f5f5;
    }
    
    .estado {
        font-weight: bold;
        padding: 4px 8px;
        display: inline-block;
    }
    
    .estado-asignado {
        background-color: #fff;
        border: 2px solid #0066cc;
        color: #0066cc;
    }
    
    .estado-proceso {
        background-color: #fff;
        border: 2px solid #ff9900;
        color: #ff9900;
    }
    
    .estado-completado {
        background-color: #fff;
        border: 2px solid #28a745;
        color: #28a745;
    }
    
    .btn-accion {
        padding: 8px 12px;
        background-color: white;
        border: 1px solid black;
        cursor: pointer;
        font-size: 14px;
        margin-right: 5px;
    }
    
    .btn-accion:hover {
        background-color: #e0e0e0;
    }
    
    .btn-accion:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    
    .menu-container {
        position: relative;
        display: inline-block;
    }
    
    .menu-button {
        background: none;
        border: 1px solid #999;
        font-size: 20px;
        cursor: pointer;
        padding: 5px 10px;
    }
    
    .menu-button:hover {
        background-color: #f0f0f0;
    }
    
    .menu-content {
        display: none;
        position: absolute;
        background-color: white;
        min-width: 200px;
        box-shadow: 0px 8px 16px rgba(0,0,0,0.2);
        z-index: 1;
        right: 0;
        border: 1px solid #999;
    }
    
    .menu-content a {
        color: black;
        padding: 12px 16px;
        text-decoration: none;
        display: block;
        border-bottom: 1px solid #eee;
    }
    
    .menu-content a:hover {
        background-color: #f1f1f1;
    }
    
    .menu-container:hover .menu-content {
        display: block;
    }
    
    .info-adicional {
        font-size: 12px;
        color: #666;
        margin-top: 5px;
    }
    
    .mensaje-info {
        padding: 15px;
        border: 1px solid #999;
        background-color: #f9f9f9;
        margin: 20px 0;
    }
</style>

<div class="container">
    <h1>Mis Servicios del Día</h1>
    @if (ViewData["MensajeExito"] != null)
    {
        <div style="padding: 15px; border: 2px solid #28a745; background-color: #d4edda; color: #155724; margin-bottom: 20px;">
            @ViewData["MensajeExito"]
        </div>
    }

    @if (ViewData["MensajeError"] != null)
    {
        <div style="padding: 15px; border: 2px solid #dc3545; background-color: #f8d7da; color: #721c24; margin-bottom: 20px;">
            @ViewData["MensajeError"]
            @if (ViewData["TipoError"] != null)
            {
                <div style="margin-top: 5px; font-size: 12px;">Código de error: @ViewData["TipoError"]</div>
            }
        </div>
    }
    
    <div class="filtros">
        <label>Filtrar por estado:</label>
        <select>
            <option>Todos</option>
            <option>Asignado</option>
            <option>En Proceso</option>
            <option>Completado</option>
        </select>
        
        <label>Buscar:</label>
        <input type="text" placeholder="Cliente, dirección o contrato" />
        
        <button class="btn-filtrar">Aplicar filtros</button>
    </div>
    
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Cliente</th>
                <th>Dirección</th>
                <th>Contrato</th>
                <th>Fecha</th>
                <th>Estado</th>
                <th>Conductor/Vehículo</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var servicio in Model.Servicios)
            {
                <tr>
                    <td>@servicio.Id</td>
                    <td>
                        @servicio.Cliente
                        <div class="info-adicional">Técnico: @servicio.Tecnico</div>
                    </td>
                    <td>@servicio.Direccion</td>
                    <td>@servicio.Contrato</td>
                    <td>@servicio.FechaServicio.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (servicio.Estado == "Asignado")
                        {
                            <span class="estado estado-asignado">@servicio.Estado</span>
                        }
                        else if (servicio.Estado == "En Proceso")
                        {
                            <span class="estado estado-proceso">@servicio.Estado</span>
                        }
                        else
                        {
                            <span class="estado estado-completado">@servicio.Estado</span>
                        }
                    </td>
                    <td>
                        @servicio.Conductor<br />
                        <span class="info-adicional">@servicio.Vehiculo</span>
                    </td>
                    <td>
                        @if (servicio.Estado == "Asignado" || servicio.Estado == "En Proceso")
                        {
                            <div class="menu-container">
                                <button class="menu-button">☰</button>
                                <div class="menu-content">
                                    <form method="post" asp-page-handler="IniciarRecoleccion" style="display: inline;">
                                        <input type="hidden" name="id" value="@servicio.Id" />
                                        <button type="submit" style="width:100%; text-align:left; background:none; border:none; padding:12px 16px; cursor:pointer;">
                                            Registrar recolección
                                        </button>
                                    </form>
                                    <a href="#">Registrar transporte</a>
                                    <a href="#">Registrar llegada a destino</a>
                                    <a href="#">Consultar seguimiento</a>
                                </div>
                            </div>
                        }
                        else
                        {
                            <button class="btn-accion" disabled>No disponible</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    <div class="mensaje-info">
        <strong>Nota:</strong> Solo los servicios con estado "Asignado" pueden ser iniciados.
        Total de servicios: @Model.Servicios.Count
    </div>
</div>