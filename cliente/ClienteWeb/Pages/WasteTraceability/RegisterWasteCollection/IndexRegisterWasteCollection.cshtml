@page
@model ClienteWeb.Pages.WasteTraceability.RegisterWasteCollection.IndexModel
@{
    ViewData["Title"] = "Seguimiento de Contratos y Servicios";
}

<style>
    :root {
        --simar-green: #5aad31;
        --simar-dark: #4a4a4a;
        --simar-gray-light: #f8f9fa;
        --simar-border: #e9ecef;
    }
    
    * {
        font-family: 'Inter', sans-serif;
    }
    
    .container-fluid-custom {
        width: 100%;
        padding-right: 1rem;
        padding-left: 1rem;
    }
    
    h1 {
        font-size: 1.8rem;
        font-weight: 600;
        color: var(--simar-dark);
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid var(--simar-green);
    }
    
    h1 i {
        color: var(--simar-green);
        margin-right: 0.5rem;
    }
    
    .table-container {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        border: 1px solid var(--simar-border);
        margin-top: 1rem;
    }
    
    .table-simar {
        width: 100%;
        border-collapse: collapse;
    }
    
    .table-simar thead tr {
        background: var(--simar-gray-light);
        border-bottom: 2px solid var(--simar-green);
    }
    
    .table-simar th {
        padding: 1rem 1.25rem;
        text-align: left;
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--simar-dark);
        text-transform: uppercase;
    }
    
    .table-simar td {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--simar-border);
        vertical-align: middle;
        font-size: 0.9rem;
    }
    
    .table-simar tbody tr:hover {
        background: rgba(90, 173, 49, 0.05);
        cursor: pointer;
    }
    
    .badge-status {
        padding: 0.35rem 0.85rem;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 600;
        color: white;
    }
    
    .modal-simar {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
    }
    
    .modal-content-simar {
        background: white;
        margin: 2% auto;
        width: 90%;
        max-width: 900px;
        max-height: 90vh;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    
    .modal-header-simar {
        padding: 1.25rem 1.5rem;
        border-bottom: 2px solid var(--simar-green);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .modal-body-simar {
        padding: 1.5rem;
        overflow-y: auto;
    }
    
    .close-simar {
        cursor: pointer;
        font-size: 1.5rem;
    }

    .historial-item {
        border-left: 3px solid var(--simar-green);
        background: var(--simar-gray-light);
        padding: 1rem;
        margin-bottom: 1rem;
        border-radius: 0 10px 10px 0;
    }
</style>

<div class="container-fluid-custom">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>
                <i class="bi bi-clipboard-pulse"></i>
                Seguimiento de Contratos y Servicios
            </h1>
            <p class="text-muted">Consulte el estado actual de sus servicios por contrato</p>
        </div>
    </div>

    <div class="table-container">
        <table class="table-simar">
            <thead>
                <tr>
                    <th>Folio Contrato</th>
                    <th>Cliente</th>
                    <th>Estado Contrato</th>
                    <th>Vencimiento</th>
                    <th>Último Servicio / En Curso</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contrato in Model.Contratos)
                {
                    <tr onclick="abrirHistorial(@contrato.Id)">
                        <td><strong>@contrato.Folio</strong></td>
                        <td>@contrato.Cliente</td>
                        <td>
                            <span class="badge @(contrato.EstadoContrato == "activo" ? "bg-success" : "bg-secondary")">
                                @contrato.EstadoContrato
                            </span>
                        </td>
                        <td>@(contrato.FechaExpiracion?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                        <td>
                            @if (contrato.UltimoServicio != null)
                            {
                                <div>
                                    <span class="badge @ClienteWeb.Pages.WasteTraceability.RegisterWasteCollection.IndexModel.GetStatusClass(contrato.UltimoServicio.Status)">
                                        @ClienteWeb.Pages.WasteTraceability.RegisterWasteCollection.IndexModel.MapStatus(contrato.UltimoServicio.Status)
                                    </span>
                                    <br />
                                    <small class="text-muted">#@contrato.UltimoServicio.ManifestNumber - @contrato.UltimoServicio.ManifestDate.ToString("dd/MM/yyyy")</small>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">Sin servicios registrados</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-success rounded-pill">
                                <i class="bi bi-eye"></i> Historial
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Historial -->
<div id="historialModal" class="modal-simar">
    <div class="modal-content-simar">
        <div class="modal-header-simar">
            <h2 id="modalTitle">Historial de Servicios</h2>
            <span class="close-simar" onclick="cerrarModal()">&times;</span>
        </div>
        <div class="modal-body-simar" id="modalBody">
            <!-- Cargado por JS -->
        </div>
    </div>
</div>

<script>
    const contratos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Contratos));

    function abrirHistorial(id) {
        const contrato = contratos.find(c => c.Id === id);
        if (!contrato) return;

        document.getElementById('modalTitle').innerText = `Historial de Servicios - ${contrato.Folio}`;
        const body = document.getElementById('modalBody');
        body.innerHTML = '';

        if (contrato.HistorialServicios.length === 0) {
            body.innerHTML = '<p class="text-center py-5 text-muted">No hay historial de servicios para este contrato.</p>';
        } else {
            contrato.HistorialServicios.forEach(m => {
                const item = document.createElement('div');
                item.className = 'historial-item';
                
                let statusName = mapStatus(m.Status);
                let statusClass = getStatusClass(m.Status);

                item.innerHTML = `
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1">Manifiesto #${m.ManifestNumber}</h5>
                            <p class="mb-0 small text-muted"><i class="bi bi-calendar"></i> ${formatDate(m.ManifestDate)}</p>
                            <p class="mb-0 small text-muted"><i class="bi bi-recycle"></i> ${m.ResidueSummary || 'Sin descripción'}</p>
                        </div>
                        <div>
                            <span class="badge ${statusClass}">${statusName}</span>
                        </div>
                    </div>
                `;
                body.appendChild(item);
            });
        }

        document.getElementById('historialModal').style.display = 'block';
    }

    function cerrarModal() {
        document.getElementById('historialModal').style.display = 'none';
    }

    function mapStatus(status) {
        switch(status) {
            case 'borrador': return 'Programado';
            case 'en_transito': return 'En ruta';
            case 'completado': return 'Concluido';
            case 'cancelado': return 'Cancelado';
            default: return status;
        }
    }

    function getStatusClass(status) {
        switch(status) {
            case 'borrador': return 'bg-info';
            case 'en_transito': return 'bg-warning';
            case 'completado': return 'bg-success';
            case 'cancelado': return 'bg-danger';
            default: return 'bg-secondary';
        }
    }

    function formatDate(dateStr) {
        if (!dateStr) return 'N/A';
        const d = new Date(dateStr);
        return d.toLocaleDateString('es-MX');
    }

    window.onclick = function(event) {
        if (event.target == document.getElementById('historialModal')) {
            cerrarModal();
        }
    }
</script>