@page
@model ClienteWeb.Pages.Contracts.Consult.ConsultModel

<style>
    .search-box {
        display: flex;
        border: 1px solid var(--simar-border);
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.2s;
    }
    
    .search-box:focus-within {
        border-color: var(--simar-green);
        box-shadow: 0 0 0 2px rgba(90, 173, 49, 0.2);
    }
    
    .search-box input {
        border: none;
        flex: 1;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
    }
    
    .search-box input:focus {
        box-shadow: none;
    }
    
    .search-box button {
        background: white;
        border: none;
        color: var(--simar-dark);
        padding: 0.6rem 1.2rem;
    }
    
    .search-box button:hover {
        background: var(--simar-green);
        color: white;
    }

    .document-preview {
        background: white;
        max-width: 800px;
        margin: 20px auto;
        padding: 60px 50px;
        box-shadow: 0 0 15px rgba(0,0,0,0.1);
        font-family: "Times New Roman", serif;
        font-size: 11pt;
        line-height: 1.5;
        color: #000;
    }

    .clause-title {
        display: block;
        font-weight: bold;
        text-transform: uppercase;
        margin-top: 15px;
    }

    .contract-header {
        text-align: center;
        font-weight: bold;
        margin-bottom: 30px;
        text-decoration: underline;
    }

    .firma-container {
        display: flex;
        justify-content: space-around;
        margin-top: 50px;
        text-align: center;
    }

    .modal-body {
        max-height: 70vh;
        overflow-y: auto;
    }
</style>

<div class="container-fluid-simar">

    @if (Model.ShowSuccessMessage)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert" style="border-radius: 12px; padding: 15px; margin-bottom: 20px; position: relative;">
            <strong>¡Éxito!</strong> El contrato ha sido actualizado correctamente.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar" style="position: absolute; right: 10px; top: 10px;"></button>
            <div class="mt-3 p-3 bg-simar-light" style="border: 1px solid var(--simar-border); border-radius: 10px;">
                <strong class="text-simar-dark">Registro de Auditoría (Trazabilidad):</strong>
                <ul class="mb-0 mt-2">
                    @foreach (var log in Model.AuditTrail)
                    {
                        <li>@log</li>
                    }
                </ul>
            </div>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-simar-dark fw-bold mb-0">Consultar Contratos</h2>
            <p class="text-muted small mb-0">Administración y seguimiento de vigencias</p>
        </div>
        <a class="btn-simar-primary" href="/Contracts/Generate">
            <i class="bi bi-plus-lg me-1"></i> Generar contrato
        </a>
    </div>

    <form method="get" class="mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label-simar">Búsqueda por Cliente</label>
                <div class="search-box">
                    <input type="text" name="Search" class="form-control" 
                        placeholder="Nombre del cliente o Folio..." value="@Model.Search">
                    <button type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>

            <div class="col-md-3">
                <label class="form-label-simar">Filtrar por Estatus</label>
                <select name="Status" class="form-select-simar w-100" onchange="this.form.submit()" @(string.IsNullOrEmpty(Model.Search) ? "disabled" : "")>
                    <option value="">Todos los estados</option>
                    <option value="Activo" selected="@(Model.Status == "Activo")">Activo</option>
                    <option value="Vencido" selected="@(Model.Status == "Vencido")">Vencido</option>
                    <option value="Pendiente de firma" selected="@(Model.Status == "Pendiente de firma")">Pendiente</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label-simar">Vigentes en la fecha:</label>
                <input type="date" name="DateFilter" class="form-control-simar w-100" 
                    value="@(Model.DateFilter?.ToString("yyyy-MM-dd"))" 
                    onchange="this.form.submit()" 
                    @(string.IsNullOrEmpty(Model.Search) ? "disabled" : "") />
            </div>

            <div class="col-md-1">
                @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Status) || Model.DateFilter.HasValue)
                {
                    <a href="/Contracts/Consult" class="btn-simar-outline-gray w-100 d-flex justify-content-center align-items-center" style="height: 42px;" title="Limpiar filtros">
                        <i class="bi bi-eraser-fill"></i>
                    </a>
                }
            </div>
        </div>
    </form>

    @if (Model.Contracts.Any())
    {
        <div class="table-responsive-simar">
            <table class="table-simar">
                <thead>
                    <tr>
                        <th>Folio</th>
                        <th>Cliente</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                        <th>Estatus</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var contract in Model.Contracts)
                    {
                        <tr>
                            <td class="fw-bold text-simar-green">#@contract.Id</td>
                            <td>@contract.Client</td>
                            <td>@contract.StartDate.ToShortDateString()</td>
                            <td>@contract.EndDate.ToShortDateString()</td>
                            <td>
                                <span class="badge-simar 
                                    @(contract.Status == "Activo" ? "badge-simar-completada" :
                                      contract.Status == "Vencido" ? "badge-simar-cancelada" : "badge-simar-programada")">
                                    @contract.Status
                                </span>
                            </td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <button type="button" class="btn-simar-icon"
                                            onclick="openDetailModal(@contract.DbId)"
                                            title="Ver Vista Previa">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    @if (contract.Status == "Activo" || contract.Status == "Pendiente de firma")
                                    {
                                        <button type="button" class="btn-simar-icon" 
                                                onclick="openUpdateModal('@contract.Id', '@contract.Client', '@contract.StartDate.ToString("yyyy-MM-dd")', '@contract.EndDate.ToString("yyyy-MM-dd")', '@contract.Status')"
                                                title="Actualizar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    }
                                    <button type="button" class="btn-simar-icon" onclick="downloadPdf(@contract.DbId)" title="Descargar PDF">
                                        <i class="bi bi-file-earmark-pdf"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state-simar">
            <i class="bi bi-file-earmark-x"></i>
            <h4>No se encontraron contratos</h4>
            <p class="text-muted">Intenta cambiar los términos de búsqueda o filtros.</p>
        </div>
    }
</div>

<div class="modal fade modal-simar" id="modalUpdate" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square me-2"></i>Actualizar Información del Contrato
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form id="formUpdate" asp-page-handler="Update" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <div id="modalUpdateError" class="alert alert-danger d-none mb-3" role="alert">
                        La nueva fecha de término debe ser posterior a la fecha de inicio.
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label-simar">Número de Contrato</label>
                            <input type="text" asp-for="UpdateId" class="form-control-simar" id="updateId" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-simar">Cliente</label>
                            <input type="text" asp-for="UpdateClient" class="form-control-simar" id="updateClient" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-simar">Estatus</label>
                            <input type="text" asp-for="UpdateStatus" class="form-control-simar" id="updateStatus" readonly>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label-simar">Fecha de Inicio</label>
                            <input type="date" asp-for="UpdateStartDate" class="form-control-simar" id="updateStartDate" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-simar">Nueva Fecha de Término</label>
                            <input type="date" asp-for="UpdateEndDate" class="form-control-simar" id="updateEndDate" required>
                        </div>

                        <div class="col-12">
                            <label class="form-label-simar">Condiciones del servicio</label>
                            <textarea asp-for="ServiceConditions" id="updateServiceConditions" class="form-control-simar" rows="3" required></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label-simar">Observaciones administrativas</label>
                            <textarea asp-for="AdminObservations" id="updateAdminObservations" class="form-control-simar" rows="2" required></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label-simar">Adjuntar nueva versión firmada (PDF)</label>
                            <input type="file" asp-for="PdfFile" accept=".pdf" class="form-control-simar" id="updatePdfFile">
                            <small class="text-muted">Solo archivos PDF. Opcional.</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-simar-outline-gray" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn-simar-primary" onclick="submitUpdateForm()">
                        <i class="bi bi-check-lg"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalViewContract" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" style="background-color: #f4f6f9;">
            <div class="modal-header bg-white border-bottom-0">
                <h5 class="modal-title fw-bold">Vista Previa del Contrato</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div id="contractContent" class="document-preview">
                    </div>
            </div>
            <div class="modal-footer bg-white border-top-0">
                <button type="button" class="btn-simar-outline-gray" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn-simar-primary" id="btnModalDownload" onclick="downloadPdfFromModal()">
                    <i class="bi bi-file-earmark-pdf"></i> Descargar PDF
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var currentModalDbId = null;
        var API_BASE = '@Model.ApiBaseUrl';

        function openUpdateModal(id, client, startDate, endDate, status) {
            document.getElementById('modalUpdateError').classList.add('d-none');

            document.getElementById('updateId').value = id;
            document.getElementById('updateClient').value = client;
            document.getElementById('updateStartDate').value = startDate;
            document.getElementById('updateEndDate').value = endDate;
            document.getElementById('updateStatus').value = status;
            
            var startDateObj = new Date(startDate);
            startDateObj.setDate(startDateObj.getDate() + 1); 
            var minIso = startDateObj.toISOString().split('T')[0];
            document.getElementById('updateEndDate').setAttribute('min', minIso);
            
            document.getElementById('updateServiceConditions').value = "Condiciones originales del servicio...";
            document.getElementById('updateAdminObservations').value = "Ninguna observación inicial.";

            var updateModal = new bootstrap.Modal(document.getElementById('modalUpdate'));
            updateModal.show();
        }

        function submitUpdateForm() {
            const startDateStr = document.getElementById('updateStartDate').value;
            const endDateStr = document.getElementById('updateEndDate').value;

            if (startDateStr && endDateStr) {
                if (endDateStr <= startDateStr) {
                    document.getElementById('modalUpdateError').classList.remove('d-none');
                    return; 
                }
            }
            document.getElementById('formUpdate').submit();
        }

        async function openDetailModal(dbId) {
            currentModalDbId = dbId;
            var contentDiv = document.getElementById('contractContent');
            contentDiv.innerHTML = '<div class="text-center p-5"><div class="spinner-border text-success" role="status"></div><p class="mt-3 text-muted">Cargando contrato...</p></div>';

            var modal = new bootstrap.Modal(document.getElementById('modalViewContract'));
            modal.show();

            try {
                var controller = new AbortController();
                var timeoutId = setTimeout(function() { controller.abort(); }, 15000);
                var response = await fetch(API_BASE + '/api/contracts/' + dbId + '/detail', { signal: controller.signal });
                clearTimeout(timeoutId);
                if (!response.ok) throw new Error('No se pudo cargar el contrato');
                var c = await response.json();

                var fechaCreacion = new Date(c.createdAt).toLocaleDateString('es-MX');
                var fechaPrimerServicio = c.firstServiceDate ? new Date(c.firstServiceDate).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' }) : 'Pendiente';

                // Tabla de servicios
                var servicesRows = '';
                if (c.services && c.services.length > 0) {
                    c.services.forEach(function(s) {
                        servicesRows += '<tr><td>' + esc(s.wasteType) + '</td><td>' + esc(s.wasteUnit) + '</td><td>' + esc(s.frequency) + '</td><td class="text-center">' + s.vehicles + ' / ' + s.technicians + '</td><td>' + esc(s.serviceAddress) + '</td><td>' + esc(s.warehouseAddress) + '</td></tr>';
                    });
                } else {
                    servicesRows = '<tr><td colspan="6" class="text-center text-muted">Sin servicios registrados</td></tr>';
                }

                // Tabla de pagos
                var paymentsRows = '';
                if (c.payments && c.payments.length > 0) {
                    c.payments.forEach(function(p) {
                        paymentsRows += '<tr><td>' + esc(p.description) + '</td><td class="text-center">$' + p.amount.toFixed(2) + '</td><td class="text-center">' + new Date(p.paymentDate).toLocaleDateString('es-MX') + '</td></tr>';
                    });
                } else {
                    paymentsRows = '<tr><td colspan="3" class="text-center text-muted">Sin pagos registrados</td></tr>';
                }

                // Tabla de extras
                var extrasHtml = '';
                if (c.extras && c.extras.length > 0) {
                    var totalExtras = 0;
                    var extrasRows = '';
                    c.extras.forEach(function(x) {
                        var sub = x.unitCost * x.quantity;
                        totalExtras += sub;
                        extrasRows += '<tr><td>' + esc(x.description) + '</td><td class="text-center">$' + x.unitCost.toFixed(2) + '</td><td class="text-center">' + x.quantity + '</td><td class="text-center">$' + sub.toFixed(2) + '</td></tr>';
                    });
                    extrasHtml = '<div style="page-break-before:always; margin-top:30px;"><div style="background:#000;color:#fff;padding:7px;text-align:center;font-weight:bold;">ANEXO ÚNICO: CATÁLOGO DE SERVICIOS EXTRAORDINARIOS</div><p style="margin-top:10px;">De conformidad con la Cláusula Cuarta, en caso de requerir servicios adicionales a los descritos en las cláusulas operativas, se aplicarán los siguientes costos autorizados:</p><table class="table table-bordered" style="font-size:10pt;"><thead style="background:#e6e6e6;"><tr><th>Descripción</th><th>Costo Unit.</th><th>Cant.</th><th>Subtotal</th></tr></thead><tbody>' + extrasRows + '</tbody><tfoot><tr style="background:#e6e6e6;"><td colspan="3" class="text-end fw-bold">TOTAL:</td><td class="text-center fw-bold">$' + totalExtras.toFixed(2) + '</td></tr></tfoot></table></div>';
                }

                var html = `
                    <div style="text-align:right; font-weight:bold; font-size:10pt; margin-bottom:8px;">CONTRATO DE PRESTACIÓN DE SERVICIOS</div>

                    <table class="table table-bordered" style="font-size:9pt;">
                        <tr style="background:#e6e6e6;"><td colspan="8" class="text-center fw-bold">CONTRATO DE PRESTACIÓN DE SERVICIOS</td></tr>
                        <tr><td style="background:#e6e6e6;" class="fw-bold">FECHA</td><td colspan="7">[${fechaCreacion}]</td></tr>
                        <tr style="background:#e6e6e6;"><td colspan="8" class="text-center fw-bold">EL PRESTADOR</td></tr>
                        <tr><td style="background:#e6e6e6;" class="fw-bold">RAZÓN SOCIAL</td><td colspan="7" class="fw-bold">SISTEMAS EN MANEJO Y ADMINISTRACION DE RESIDUOS S.A. DE C.V.</td></tr>
                        <tr>
                            <td style="background:#e6e6e6;" class="fw-bold">CONSTITUTIVA N°</td><td>556</td>
                            <td style="background:#e6e6e6;" class="fw-bold">FECHA</td><td>23 oct 2008</td>
                            <td style="background:#e6e6e6;" class="fw-bold">CORREDOR</td><td>N° 08, Veracruz</td>
                            <td style="background:#e6e6e6;" class="fw-bold">FOLIO</td><td>19779*11</td>
                        </tr>
                        <tr><td style="background:#e6e6e6;" class="fw-bold">APODERADO</td><td colspan="3" class="fw-bold text-center">GUSTAVO CRUZ TORRES</td><td style="background:#e6e6e6;" colspan="2" class="fw-bold">IDENTIFICACIÓN</td><td colspan="2">Credencial INE</td></tr>
                        <tr><td style="background:#e6e6e6;" class="fw-bold">OBJETO SOCIAL</td><td colspan="7">Realizar la recolección de residuos peligrosos y no peligrosos...</td></tr>
                        <tr><td style="background:#e6e6e6;" class="fw-bold">DOMICILIO</td><td colspan="5">Calle Pípila, N.E. 126, José Cardel, Xalapa, Ver. C.P.:91030</td><td style="background:#e6e6e6;" class="fw-bold">R.F.C.</td><td class="fw-bold">SMA0810239L9</td></tr>
                        <tr style="background:#e6e6e6;"><td colspan="8" class="text-center fw-bold">"EL CLIENTE"</td></tr>
                        <tr><td style="background:#e6e6e6;" class="fw-bold">RAZÓN SOCIAL</td><td colspan="7" class="fw-bold">${esc(c.clientName)}</td></tr>
                        <tr><td style="background:#e6e6e6;" class="fw-bold">APODERADO LEGAL</td><td colspan="7" class="fw-bold">${esc(c.representative)}</td></tr>
                        <tr><td style="background:#e6e6e6;" class="fw-bold">OBJETO SOCIAL</td><td colspan="7">${esc(c.clientObjetoSocial)}</td></tr>
                        <tr><td style="background:#e6e6e6;" class="fw-bold">DOMICILIO</td><td colspan="5">${esc(c.clientAddress || 'Pendiente de captura')}</td><td style="background:#e6e6e6;" class="fw-bold">R.F.C.</td><td class="fw-bold">${esc(c.clientRfc)}</td></tr>
                        <tr><td style="background:#e6e6e6;" class="fw-bold">DECLARACIONES</td><td colspan="7">${esc(c.clientDeclaraciones)}</td></tr>
                    </table>

                    <div style="background:#000; color:#fff; padding:7px; text-align:center; font-weight:bold; margin-top:15px;">CLÁUSULAS</div>

                    <div style="margin-top:10px;">
                        <p><strong>PRIMERA. - OBJETO Y ALCANCES OPERATIVOS.</strong></p>
                        <p>En virtud del presente instrumento, <strong>EL PRESTADOR</strong> se obliga a prestar a <strong>EL CLIENTE</strong> el servicio de recolección, transporte y disposición final de residuos, de conformidad con las especificaciones técnicas y operativas detalladas en la siguiente tabla de servicios:</p>
                        <table class="table table-bordered" style="font-size:9pt;">
                            <thead style="background:#e6e6e6;"><tr><th>Tipo de Residuo</th><th>Unidad</th><th>Periodicidad</th><th>Veh./Téc.</th><th>Dirección</th><th>Almacén</th></tr></thead>
                            <tbody>${servicesRows}</tbody>
                        </table>
                        <p>Las partes acuerdan que el primer servicio operativo de recolección se llevará a cabo el día <strong>${fechaPrimerServicio}</strong>.</p>

                        <p style="margin-top:15px;"><strong>SEGUNDA. - CONTRAPRESTACIÓN Y CONDICIONES DE PAGO.</strong></p>
                        <p>Como contraprestación, <strong>EL CLIENTE</strong> pagará a <strong>EL PRESTADOR</strong> la cantidad total de <strong>$${c.totalBasePrice.toFixed(2)} MXN</strong> (más IVA).</p>
                        <table class="table table-bordered" style="font-size:9pt; max-width:500px; margin:0 auto;">
                            <thead style="background:#e6e6e6;"><tr><th>Concepto</th><th>Monto (MXN)</th><th>Fecha de Pago</th></tr></thead>
                            <tbody>${paymentsRows}</tbody>
                        </table>

                        <p style="margin-top:15px;"><strong>TERCERA. - VIGENCIA.</strong></p>
                        <p>La vigencia del presente instrumento será de <strong>${esc(c.contractDuration)}</strong>.</p>

                        <p style="margin-top:15px;"><strong>CUARTA. - SERVICIOS EXTRAORDINARIOS.</strong></p>
                        <p>En caso de servicios adicionales, se aplicarán los costos del <strong>ANEXO ÚNICO</strong>.</p>

                        <p style="margin-top:15px;"><strong>QUINTA. - RESPONSABILIDAD LABORAL Y CONFIDENCIALIDAD.</strong></p>
                        <p><strong>EL PRESTADOR</strong> será el único responsable de sus empleados. Ambas partes mantendrán confidencialidad por 10 años.</p>

                        <p style="margin-top:15px;"><strong>SEXTA. - JURISDICCIÓN.</strong></p>
                        <p>Las partes se someten a la jurisdicción de los Tribunales Federales aplicables en los Estados Unidos Mexicanos.</p>
                    </div>

                    <div style="margin-top:50px; text-align:center;"><strong>LAS PARTES</strong></div>
                    <div style="display:flex; justify-content:space-around; margin-top:10px; text-align:center;">
                        <div>
                            <div style="font-weight:bold; margin-bottom:45px;">EL PRESTADOR</div>
                            <div style="border-top:1px solid #000; padding-top:5px; width:200px; margin:0 auto;">
                                <strong>GUSTAVO CRUZ TORRES</strong><br/>
                                <small>Apoderado Legal SIMAR S.A. de C.V.</small>
                            </div>
                        </div>
                        <div>
                            <div style="font-weight:bold; margin-bottom:45px;">EL CLIENTE</div>
                            <div style="border-top:1px solid #000; padding-top:5px; width:200px; margin:0 auto;">
                                <strong>${esc(c.representative)}</strong><br/>
                                <small>Apoderado Legal</small>
                            </div>
                        </div>
                    </div>

                    ${extrasHtml}
                `;

                contentDiv.innerHTML = html;
            } catch (err) {
                contentDiv.innerHTML = '<div class="text-center p-5 text-danger"><i class="bi bi-exclamation-triangle" style="font-size:2rem;"></i><p class="mt-3">' + err.message + '</p></div>';
            }
        }

        function esc(str) {
            if (!str) return '';
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(str));
            return div.innerHTML;
        }

        async function downloadPdf(dbId) {
            try {
                var controller = new AbortController();
                var timeoutId = setTimeout(function() { controller.abort(); }, 30000);
                var response = await fetch(API_BASE + '/api/contracts/' + dbId + '/download', { signal: controller.signal });
                clearTimeout(timeoutId);
                if (!response.ok) throw new Error('Error al descargar');
                var blob = await response.blob();
                var disposition = response.headers.get('Content-Disposition');
                var fileName = 'Contrato.pdf';
                if (disposition) {
                    var match = disposition.match(/filename[^;=\n]*=(['"]?)([^'"\n;]*)/i);
                    if (match && match[2]) fileName = match[2];
                }
                var link = document.createElement('a');
                link.href = URL.createObjectURL(blob);
                link.download = fileName;
                link.dataset.loading = 'false';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                setTimeout(function() { URL.revokeObjectURL(link.href); }, 1000);
            } catch (err) {
                alert('No se pudo descargar el PDF: ' + err.message);
            }
        }

        function downloadPdfFromModal() {
            if (currentModalDbId) downloadPdf(currentModalDbId);
        }
    </script>
}