@page
@model ClienteWeb.Pages.Contracts.Consult.ConsultModel

<style>
    body {
        background-color: #f4f6f9;
        font-family: Arial, Helvetica, sans-serif;
    }

    .container {
        max-width: 1100px;
        margin: 30px auto;
    }

    h2 {
        margin-bottom: 20px;
        border-bottom: 3px solid #333;
        padding-bottom: 10px;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .filters {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        padding: 15px;
        border: 1px solid #ddd;
        background-color: white;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    .filters input, 
    .filters select {
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 6px;
    }

    .btn {
        padding: 8px 14px;
        border-radius: 6px;
        border: 1px solid #333;
        background: white;
        cursor: pointer;
        text-decoration: none;
        color: black;
        font-size: 14px;
        transition: 0.2s;
    }

    .btn:hover {
        background: #333;
        color: white;
    }

    .btn-primary {
        background-color: #333;
        color: white;
    }

    .btn-primary:hover {
        background-color: black;
    }

    .card {
        background-color: white;
        border-radius: 10px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background-color: #333;
        color: white;
        padding: 12px;
        text-align: left;
    }

    td {
        padding: 12px;
        border-bottom: 1px solid #eee;
    }

    tr:hover {
        background-color: #f9f9f9;
    }

    .status {
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
    }

    .activo {
        background-color: #e6f4ea;
        color: #2e7d32;
    }

    .pendiente {
        background-color: #fff3e0;
        color: #ef6c00;
    }

    .vencido {
        background-color: #fdecea;
        color: #c62828;
    }

    .actions a {
        margin-right: 5px;
    }

    .no-data {
        padding: 20px;
        text-align: center;
        background-color: white;
        border-radius: 8px;
        border: 1px solid #ddd;
    }
</style>

<div class="container">

    <div class="top-bar">
        <h2>Consultar Contratos</h2>
        <a class="btn btn-primary" href="/Contracts/Generate">
            + Generar contrato
        </a>
    </div>

    <form method="get" class="filters">
        <input type="text" name="Search" placeholder="Buscar cliente o número..."
               value="@Model.Search" />

        <select name="Status">
            <option value="">Todos</option>
            <option value="Activo" selected="@(Model.Status == "Activo")">Activo</option>
            <option value="Vencido" selected="@(Model.Status == "Vencido")">Vencido</option>
            <option value="Pendiente de firma" selected="@(Model.Status == "Pendiente de firma")">
                Pendiente
            </option>
        </select>

        <button class="btn">Buscar</button>
    </form>

    @if (Model.Contracts.Any())
    {
        <div class="card">
            <table>
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Cliente</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                        <th>Estatus</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var contract in Model.Contracts)
                    {
                        <tr>
                            <td>@contract.Id</td>
                            <td>@contract.Client</td>
                            <td>@contract.StartDate.ToShortDateString()</td>
                            <td>@contract.EndDate.ToShortDateString()</td>
                            <td>
                                <span class="status 
                                    @(contract.Status == "Activo" ? "activo" :
                                      contract.Status == "Vencido" ? "vencido" : "pendiente")">
                                    @contract.Status
                                </span>
                            </td>
                            <td class="actions">
                                <a class="btn" href="/Contracts/Consult/Detail/@contract.Id">Ver</a>
                                <a class="btn" href="#">PDF</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="no-data">
            No se encontraron contratos con los filtros aplicados.
        </div>
    }

</div>