@page
@model ClienteWeb.Pages.Contracts.Consult.ConsultModel

<style>
    .container {
        max-width: 1000px;
        margin: 0 auto;
        font-family: Arial;
    }

    h2 {
        border-bottom: 2px solid black;
        padding-bottom: 10px;
    }

    .filters {
        border: 1px solid #ccc;
        padding: 15px;
        margin-bottom: 20px;
        background-color: #f9f9f9;
    }

    .filters input, .filters select {
        padding: 6px;
        margin-right: 10px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background-color: #333;
        color: white;
        padding: 10px;
    }

    td {
        padding: 10px;
        border: 1px solid #ccc;
    }

    tr:hover {
        background-color: #f5f5f5;
    }

    .btn {
        padding: 5px 10px;
        border: 1px solid black;
        background: white;
        cursor: pointer;
        text-decoration: none;
        color: black;
    }

    .btn:hover {
        background: #eee;
    }

    .no-data {
        padding: 15px;
        border: 1px solid #999;
        background-color: #f9f9f9;
        margin-top: 20px;
    }
</style>

<div class="container">

<h2>Consultar Contratos</h2>

<div class="filters">
    <form method="get">
        <label>Buscar:</label>
        <input type="text" name="Search" value="@Model.Search" />

        <label>Estatus:</label>
        <select name="Status">
            <option value="">Todos</option>
            <option value="Activo" selected="@(Model.Status == "Activo")">Activo</option>
            <option value="Vencido" selected="@(Model.Status == "Vencido")">Vencido</option>
            <option value="Pendiente de firma" selected="@(Model.Status == "Pendiente de firma")">Pendiente</option>
        </select>

        <button class="btn">Buscar</button>
    </form>
</div>

@if (Model.Contracts.Any())
{
    <table>
        <thead>
            <tr>
                <th>Número</th>
                <th>Cliente</th>
                <th>Inicio</th>
                <th>Fin</th>
                <th>Estatus</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var contract in Model.Contracts)
            {
                <tr>
                    <td>@contract.Id</td>
                    <td>@contract.Client</td>
                    <td>@contract.StartDate.ToShortDateString()</td>
                    <td>@contract.EndDate.ToShortDateString()</td>
                    <td>@contract.Status</td>
                    <td>
                        <a class="btn" href="/Contracts/Consult/Detail?id=@contract.Id">Ver</a>
                        <a class="btn" href="#">PDF</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="no-data">
        No se encontraron contratos con los filtros aplicados.
    </div>
}

</div>