@page
@model ClienteWeb.Pages.Contracts.Consult.ConsultModel

<style>
    .search-box {
        display: flex;
        border: 1px solid var(--simar-border);
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.2s;
    }
    
    .search-box:focus-within {
        border-color: var(--simar-green);
        box-shadow: 0 0 0 2px rgba(90, 173, 49, 0.2);
    }
    
    .search-box input {
        border: none;
        flex: 1;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
    }
    
    .search-box input:focus {
        box-shadow: none;
    }
    
    .search-box button {
        background: white;
        border: none;
        color: var(--simar-dark);
        padding: 0.6rem 1.2rem;
    }
    
    .search-box button:hover {
        background: var(--simar-green);
        color: white;
    }

    .document-preview {
        background: white;
        max-width: 800px;
        margin: 20px auto;
        padding: 60px 50px;
        box-shadow: 0 0 15px rgba(0,0,0,0.1);
        font-family: "Times New Roman", serif;
        font-size: 11pt;
        line-height: 1.5;
        color: #000;
    }

    .clause-title {
        display: block;
        font-weight: bold;
        text-transform: uppercase;
        margin-top: 15px;
    }

    .contract-header {
        text-align: center;
        font-weight: bold;
        margin-bottom: 30px;
        text-decoration: underline;
    }

    .firma-container {
        display: flex;
        justify-content: space-around;
        margin-top: 50px;
        text-align: center;
    }

    .modal-body {
        max-height: 70vh;
        overflow-y: auto;
    }
</style>

<div class="container-fluid-simar">

    @if (Model.ShowSuccessMessage)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert" style="border-radius: 12px; padding: 15px; margin-bottom: 20px; position: relative;">
            <strong>¡Éxito!</strong> El contrato ha sido actualizado correctamente.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar" style="position: absolute; right: 10px; top: 10px;"></button>
            <div class="mt-3 p-3 bg-simar-light" style="border: 1px solid var(--simar-border); border-radius: 10px;">
                <strong class="text-simar-dark">Registro de Auditoría (Trazabilidad):</strong>
                <ul class="mb-0 mt-2">
                    @foreach (var log in Model.AuditTrail)
                    {
                        <li>@log</li>
                    }
                </ul>
            </div>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-simar-dark fw-bold mb-0">Consultar Contratos</h2>
            <p class="text-muted small mb-0">Administración y seguimiento de vigencias</p>
        </div>
        <a class="btn-simar-primary" href="/Contracts/Generate">
            <i class="bi bi-plus-lg me-1"></i> Generar contrato
        </a>
    </div>

    <form method="get" class="mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label-simar">Búsqueda por Cliente</label>
                <div class="search-box">
                    <input type="text" name="Search" class="form-control" 
                        placeholder="Nombre del cliente o Folio..." value="@Model.Search">
                    <button type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>

            <div class="col-md-3">
                <label class="form-label-simar">Filtrar por Estatus</label>
                <select name="Status" class="form-select-simar w-100" onchange="this.form.submit()" @(string.IsNullOrEmpty(Model.Search) ? "disabled" : "")>
                    <option value="">Todos los estados</option>
                    <option value="Activo" selected="@(Model.Status == "Activo")">Activo</option>
                    <option value="Vencido" selected="@(Model.Status == "Vencido")">Vencido</option>
                    <option value="Pendiente de firma" selected="@(Model.Status == "Pendiente de firma")">Pendiente</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label-simar">Vigentes en la fecha:</label>
                <input type="date" name="DateFilter" class="form-control-simar w-100" 
                    value="@(Model.DateFilter?.ToString("yyyy-MM-dd"))" 
                    onchange="this.form.submit()" 
                    @(string.IsNullOrEmpty(Model.Search) ? "disabled" : "") />
            </div>

            <div class="col-md-1">
                @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Status) || Model.DateFilter.HasValue)
                {
                    <a href="/Contracts/Consult" class="btn-simar-outline-gray w-100 d-flex justify-content-center align-items-center" style="height: 42px;" title="Limpiar filtros">
                        <i class="bi bi-eraser-fill"></i>
                    </a>
                }
            </div>
        </div>
    </form>

    @if (Model.Contracts.Any())
    {
        <div class="table-responsive-simar">
            <table class="table-simar">
                <thead>
                    <tr>
                        <th>Folio</th>
                        <th>Cliente</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                        <th>Estatus</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var contract in Model.Contracts)
                    {
                        <tr>
                            <td class="fw-bold text-simar-green">#@contract.Id</td>
                            <td>@contract.Client</td>
                            <td>@contract.StartDate.ToShortDateString()</td>
                            <td>@contract.EndDate.ToShortDateString()</td>
                            <td>
                                <span class="badge-simar 
                                    @(contract.Status == "Activo" ? "badge-simar-completada" :
                                      contract.Status == "Vencido" ? "badge-simar-cancelada" : "badge-simar-programada")">
                                    @contract.Status
                                </span>
                            </td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    @if (contract.Status == "Pendiente de firma")
                                    {
                                        <button type="button" class="btn-simar-icon" 
                                                onclick="openUpdateModal(@contract.DbId, '@contract.Id', '@contract.Client', '@contract.StartDate.ToString("yyyy-MM-dd")', '@(contract.EndDate.ToString("yyyy-MM-dd"))', '@contract.Status')"
                                                title="Actualizar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    }
                                    <button type="button" class="btn-simar-icon" 
                                            onclick="openDetailModal(@contract.DbId, '@contract.SignedContractPath')" 
                                            title="Ver Vista Previa">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button type="button" class="btn-simar-icon" onclick="downloadPdf(@contract.DbId)" title="Descargar PDF">
                                        <i class="bi bi-file-earmark-pdf"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state-simar">
            <i class="bi bi-file-earmark-x"></i>
            <h4>No se encontraron contratos</h4>
            <p class="text-muted">Intenta cambiar los términos de búsqueda o filtros.</p>
        </div>
    }
</div>

<div class="modal fade modal-simar" id="modalUpdate" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square me-2"></i>Actualizar Información del Contrato
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form id="formUpdate" asp-page-handler="Update" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <div id="modalUpdateError" class="alert alert-danger d-none mb-3" role="alert">
                    </div>
                    <input type="hidden" asp-for="UpdateDbId" id="updateDbId" />
                    <input type="hidden" asp-for="ServicesJson" id="updateServicesJson" />
                    <input type="hidden" asp-for="PaymentsJson" id="updatePaymentsJson" />
                    <input type="hidden" asp-for="ExtrasJson" id="updateExtrasJson" />

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label-simar">Número de Contrato</label>
                            <input type="text" asp-for="UpdateId" class="form-control-simar" id="updateId" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-simar">Cliente</label>
                            <input type="text" asp-for="UpdateClient" class="form-control-simar" id="updateClient" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-simar">Fecha de Inicio</label>
                            <input type="date" asp-for="UpdateStartDate" class="form-control-simar" id="updateStartDate" readonly>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label-simar">Nueva Fecha de Término</label>
                            <input type="date" asp-for="UpdateEndDate" class="form-control-simar" id="updateEndDate" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-simar">Adjuntar nueva versión firmada (PDF)</label>
                            <input type="file" asp-for="PdfFile" accept=".pdf" class="form-control-simar" id="updatePdfFile">
                        </div>

                        <div class="col-12 mt-4">
                            <ul class="nav nav-tabs" id="updateTabs" role="tablist">
                                <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-services" type="button">Servicios</button></li>
                                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-payments" type="button">Pagos</button></li>
                                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-extras" type="button">Extras</button></li>
                            </ul>
                            <div class="tab-content p-3 border border-top-0 rounded-bottom">
                                <div class="tab-pane fade show active" id="tab-services">
                                    <div class="d-flex justify-content-end mb-2">
                                        <button type="button" class="btn btn-sm btn-success" onclick="addUpdateItem('services')">
                                            <i class="bi bi-plus-lg"></i> Añadir Servicio
                                        </button>
                                    </div>
                                    <div class="table-responsive">
                                        <table class="table table-sm table-bordered" id="tableUpdateServices">
                                            <thead class="bg-light">
                                                <tr>
                                                    <th style="width: 20%;">Residuo</th>
                                                    <th style="width: 10%;">Unidad</th>
                                                    <th style="width: 15%;">Frecuencia</th>
                                                    <th style="width: 8%;">Veh.</th>
                                                    <th style="width: 8%;">Téc.</th>
                                                    <th>Dirección</th>
                                                    <th style="width: 12%;">Subtotal</th>
                                                    <th style="width: 5%;"></th>
                                                </tr>
                                            </thead>
                                            <tbody></tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="tab-pane fade" id="tab-payments">
                                    <div class="d-flex justify-content-end mb-2">
                                        <button type="button" class="btn btn-sm btn-success" onclick="addUpdateItem('payments')">
                                            <i class="bi bi-plus-lg"></i> Añadir Pago
                                        </button>
                                    </div>
                                    <table class="table table-sm table-bordered" id="tableUpdatePayments">
                                        <thead class="bg-light">
                                            <tr>
                                                <th>Concepto del Pago</th>
                                                <th style="width: 20%;">Monto ($)</th>
                                                <th style="width: 20%;">Fecha de Pago</th>
                                                <th style="width: 5%;"></th>
                                            </tr>
                                        </thead>
                                        <tbody></tbody>
                                    </table>
                                </div>
                                <div class="tab-pane fade" id="tab-extras">
                                    <div class="d-flex justify-content-end mb-2">
                                        <button type="button" class="btn btn-sm btn-success" onclick="addUpdateItem('extras')">
                                            <i class="bi bi-plus-lg"></i> Añadir Extra
                                        </button>
                                    </div>
                                    <table class="table table-sm table-bordered" id="tableUpdateExtras">
                                        <thead class="bg-light">
                                            <tr>
                                                <th>Descripción</th>
                                                <th style="width: 20%;">Costo Unit.</th>
                                                <th style="width: 15%;">Cant.</th>
                                                <th style="width: 5%;"></th>
                                            </tr>
                                        </thead>
                                        <tbody></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-simar-outline-gray" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn-simar-primary" onclick="submitUpdateForm()">
                        <i class="bi bi-check-lg"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalViewContract" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" style="background-color: #f4f6f9;">
            <div class="modal-header bg-white border-bottom-0">
                <h5 class="modal-title fw-bold">Vista Previa del Contrato</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div id="contractContent" class="document-preview">
                    </div>
            </div>
            <div class="modal-footer bg-white border-top-0">
                <button type="button" class="btn-simar-outline-gray" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn-simar-primary" id="btnModalDownload" onclick="downloadPdfFromModal()">
                    <i class="bi bi-file-earmark-pdf"></i> Descargar PDF
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var currentModalDbId = null;
        var API_BASE = '@Model.ApiBaseUrl';

        var currentUpdateData = { services: [], payments: [], extras: [] };

        async function openUpdateModal(dbId, folio, client, startDate, endDate, status) {
            document.getElementById('modalUpdateError').classList.add('d-none');
            document.getElementById('updateDbId').value = dbId;
            document.getElementById('updateId').value = folio;
            document.getElementById('updateClient').value = client;
            document.getElementById('updateStartDate').value = startDate;
            document.getElementById('updateEndDate').value = endDate;
            
            var startDateObj = new Date(startDate);
            startDateObj.setDate(startDateObj.getDate() + 1); 
            var minIso = startDateObj.toISOString().split('T')[0];
            document.getElementById('updateEndDate').setAttribute('min', minIso);

            try {
                var response = await fetch(API_BASE + '/api/contracts/' + dbId + '/detail');
                if (response.ok) {
                    var c = await response.json();
                    currentUpdateData.services = c.services || [];
                    currentUpdateData.payments = c.payments || [];
                    currentUpdateData.extras = c.extras || [];
                    renderUpdateTables();
                }
            } catch (e) { console.error("Error al cargar detalle para edición", e); }

            var updateModal = new bootstrap.Modal(document.getElementById('modalUpdate'));
            updateModal.show();
        }

        function renderUpdateTables() {
            const sBody = document.querySelector('#tableUpdateServices tbody');
            sBody.innerHTML = currentUpdateData.services.map((s, i) => `
                <tr>
                    <td><input type="text" class="form-control form-control-sm" value="${esc(s.wasteType)}" onchange="updateDataValue('services', ${i}, 'wasteType', this.value)"></td>
                    <td><input type="text" class="form-control form-control-sm" value="${esc(s.wasteUnit)}" onchange="updateDataValue('services', ${i}, 'wasteUnit', this.value)"></td>
                    <td><input type="text" class="form-control form-control-sm" value="${esc(s.frequency)}" onchange="updateDataValue('services', ${i}, 'frequency', this.value)"></td>
                    <td><input type="number" class="form-control form-control-sm" value="${s.vehicles}" onchange="updateDataValue('services', ${i}, 'vehicles', this.value)"></td>
                    <td><input type="number" class="form-control form-control-sm" value="${s.technicians}" onchange="updateDataValue('services', ${i}, 'technicians', this.value)"></td>
                    <td><input type="text" class="form-control form-control-sm" value="${esc(s.serviceAddress)}" onchange="updateDataValue('services', ${i}, 'serviceAddress', this.value)"></td>
                    <td><input type="number" step="0.01" class="form-control form-control-sm" value="${s.subtotal}" onchange="updateDataValue('services', ${i}, 'subtotal', this.value)"></td>
                    <td class="text-center"><button type="button" class="btn btn-sm text-danger" onclick="removeUpdateItem('services', ${i})"><i class="bi bi-trash"></i></button></td>
                </tr>`).join('');
            
            const pBody = document.querySelector('#tableUpdatePayments tbody');
            pBody.innerHTML = currentUpdateData.payments.map((p, i) => `
                <tr>
                    <td><input type="text" class="form-control form-control-sm" value="${esc(p.description)}" onchange="updateDataValue('payments', ${i}, 'description', this.value)"></td>
                    <td><input type="number" step="0.01" class="form-control form-control-sm" value="${p.amount}" onchange="updateDataValue('payments', ${i}, 'amount', this.value)"></td>
                    <td><input type="date" class="form-control form-control-sm" value="${p.paymentDate.split('T')[0]}" onchange="updateDataValue('payments', ${i}, 'paymentDate', this.value)"></td>
                    <td class="text-center"><button type="button" class="btn btn-sm text-danger" onclick="removeUpdateItem('payments', ${i})"><i class="bi bi-trash"></i></button></td>
                </tr>`).join('');
            
            const eBody = document.querySelector('#tableUpdateExtras tbody');
            eBody.innerHTML = currentUpdateData.extras.map((x, i) => `
                <tr>
                    <td><input type="text" class="form-control form-control-sm" value="${esc(x.description)}" onchange="updateDataValue('extras', ${i}, 'description', this.value)"></td>
                    <td><input type="number" step="0.01" class="form-control form-control-sm" value="${x.unitCost}" onchange="updateDataValue('extras', ${i}, 'unitCost', this.value)"></td>
                    <td><input type="number" class="form-control form-control-sm" value="${x.quantity}" onchange="updateDataValue('extras', ${i}, 'quantity', this.value)"></td>
                    <td class="text-center"><button type="button" class="btn btn-sm text-danger" onclick="removeUpdateItem('extras', ${i})"><i class="bi bi-trash"></i></button></td>
                </tr>`).join('');
        }

        function updateDataValue(type, index, field, value) {
            if (field === 'vehicles' || field === 'technicians' || field === 'quantity') {
                currentUpdateData[type][index][field] = parseInt(value) || 0;
            } else if (field === 'subtotal' || field === 'amount' || field === 'unitCost') {
                currentUpdateData[type][index][field] = parseFloat(value) || 0;
            } else {
                currentUpdateData[type][index][field] = value;
            }
        }

        function addUpdateItem(type) {
            if (type === 'services') {
                currentUpdateData.services.push({ wasteType: '', wasteUnit: 'kg', frequency: 'Mensual', vehicles: 1, technicians: 2, serviceAddress: '', warehouseAddress: 'Planta', subtotal: 0 });
            } else if (type === 'payments') {
                currentUpdateData.payments.push({ description: '', amount: 0, paymentDate: new Date().toISOString().split('T')[0] });
            } else if (type === 'extras') {
                currentUpdateData.extras.push({ description: '', unitCost: 0, quantity: 1 });
            }
            renderUpdateTables();
        }

        function removeUpdateItem(type, index) {
            currentUpdateData[type].splice(index, 1);
            renderUpdateTables();
        }

        function submitUpdateForm() {
            const startDateStr = document.getElementById('updateStartDate').value;
            const endDateStr = document.getElementById('updateEndDate').value;

            if (startDateStr && endDateStr && endDateStr <= startDateStr) {
                const errorDiv = document.getElementById('modalUpdateError');
                errorDiv.textContent = "La nueva fecha de término debe ser posterior a la fecha de inicio.";
                errorDiv.classList.remove('d-none');
                return; 
            }

            document.getElementById('updateServicesJson').value = JSON.stringify(currentUpdateData.services);
            document.getElementById('updatePaymentsJson').value = JSON.stringify(currentUpdateData.payments);
            document.getElementById('updateExtrasJson').value = JSON.stringify(currentUpdateData.extras);
            
            document.getElementById('formUpdate').submit();
        }

        async function openDetailModal(id, signedPath) {
            if (signedPath && signedPath !== '') {
                window.open('@Model.ApiBaseUrl/api/contracts/' + id + '/download', '_blank');
                return;
            }

            currentModalDbId = id;
            var modal = new bootstrap.Modal(document.getElementById('modalViewContract'));
            modal.show();

            var contentDiv = document.getElementById('contractContent');
            contentDiv.innerHTML = '<div class="text-center p-5"><div class="spinner-border text-success" role="status"></div><p class="mt-3 text-muted">Cargando contrato...</p></div>';

            try {
                var controller = new AbortController();
                var timeoutId = setTimeout(function() { controller.abort(); }, 15000);
                var response = await fetch('@Model.ApiBaseUrl/api/contracts/' + id + '/detail', { signal: controller.signal });
                clearTimeout(timeoutId);
                if (!response.ok) throw new Error('No se pudo cargar el contrato');
                var c = await response.json();

                var fechaCreacion = new Date(c.createdAt).toLocaleDateString('es-MX');
                var fechaPrimerServicio = c.firstServiceDate ? new Date(c.firstServiceDate).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' }) : 'Pendiente';

                // Tabla de servicios
                var servicesRows = '';
                if (c.services && c.services.length > 0) {
                    c.services.forEach(function(s) {
                        servicesRows += '<tr><td>' + esc(s.wasteType) + '</td><td>' + esc(s.wasteUnit) + '</td><td>' + esc(s.frequency) + '</td><td class="text-center">' + s.vehicles + ' / ' + s.technicians + '</td><td>' + esc(s.serviceAddress) + '</td><td>' + esc(s.warehouseAddress) + '</td><td class="text-end">$' + (s.subtotal || 0).toLocaleString('en-US', {minimumFractionDigits: 2}) + '</td></tr>';
                    });
                } else {
                    servicesRows = '<tr><td colspan="7" class="text-center text-muted">Sin servicios registrados</td></tr>';
                }

                // Tabla de pagos
                var paymentsRows = '';
                var subtotalPagos = 0;
                if (c.payments && c.payments.length > 0) {
                    c.payments.forEach(function(p) {
                        paymentsRows += '<tr><td>' + esc(p.description) + '</td><td class="text-center">$' + p.amount.toLocaleString('en-US', {minimumFractionDigits: 2}) + '</td><td class="text-center">' + new Date(p.paymentDate).toLocaleDateString('es-MX') + '</td></tr>';
                        subtotalPagos += p.amount;
                    });

                    var iva = subtotalPagos * 0.16;
                    var total = subtotalPagos + iva;

                    paymentsRows += '<tr style="background:#f8f9fa;"><td class="text-end fw-bold">SUBTOTAL:</td><td class="text-center fw-bold">$' + subtotalPagos.toLocaleString('en-US', {minimumFractionDigits: 2}) + '</td><td></td></tr>';
                    paymentsRows += '<tr style="background:#f8f9fa;"><td class="text-end fw-bold">IVA (16%):</td><td class="text-center fw-bold">$' + iva.toLocaleString('en-US', {minimumFractionDigits: 2}) + '</td><td></td></tr>';
                    paymentsRows += '<tr style="background:#e6e6e6;"><td class="text-end fw-bold">TOTAL:</td><td class="text-center fw-bold text-success">$' + total.toLocaleString('en-US', {minimumFractionDigits: 2}) + '</td><td></td></tr>';
                } else {
                    paymentsRows = '<tr><td colspan="3" class="text-center text-muted">Sin pagos registrados</td></tr>';
                }

                // Tabla de extras
                var extrasHtml = '';
                if (c.extras && c.extras.length > 0) {
                    var totalExtras = 0;
                    var extrasRows = '';
                    c.extras.forEach(function(x) {
                        var sub = x.unitCost * x.quantity;
                        totalExtras += sub;
