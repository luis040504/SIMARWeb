        function esc(str) {
            if (!str) return '';
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(str));
            return div.innerHTML;
        }

        async function downloadPdf(dbId) {
            try {
                var controller = new AbortController();
                var timeoutId = setTimeout(function() { controller.abort(); }, 30000);
                var response = await fetch(API_BASE + '/api/contracts/' + dbId + '/download', { signal: controller.signal });
                clearTimeout(timeoutId);
                if (!response.ok) throw new Error('Error al descargar');
                var blob = await response.blob();
                var disposition = response.headers.get('Content-Disposition');
                var fileName = 'Contrato.pdf';
                if (disposition) {
                    var match = disposition.match(/filename[^;=\n]*=(['"]?)([^'"\n;]*)/i);
                    if (match && match[2]) fileName = match[2];
                }
                var link = document.createElement('a');
                link.href = URL.createObjectURL(blob);
                link.download = fileName;
                link.dataset.loading = 'false';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                setTimeout(function() { URL.revokeObjectURL(link.href); }, 1000);
            } catch (err) {
                alert('No se pudo descargar el PDF: ' + err.message);
            }
        }

        function downloadPdfFromModal() {
            if (currentModalDbId) downloadPdf(currentModalDbId);
        }
    </script>
