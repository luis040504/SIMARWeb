@page
@model GenerateModel

<style>
    body {
        background-color: #f4f6f9;
        font-family: "Times New Roman", serif;
    }

    .container {
        max-width: 900px;
        margin: 30px auto;
    }

    h2 {
        margin-bottom: 20px;
        border-bottom: 3px solid #333;
        padding-bottom: 10px;
        font-family: Arial, sans-serif;
    }

    select {
        padding: 8px;
        margin-top: 10px;
        border-radius: 6px;
        border: 1px solid #ccc;
    }

    .btn {
        padding: 8px 14px;
        border-radius: 6px;
        border: 1px solid #333;
        background: white;
        cursor: pointer;
        margin-right: 10px;
    }

    .btn:hover {
        background: #333;
        color: white;
    }

    .document {
        background: white;
        padding: 50px;
        border: 1px solid #ccc;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        margin-top: 20px;
        line-height: 1.8;
        text-align: justify;
    }

    .title {
        text-align: center;
        font-weight: bold;
        font-size: 20px;
        margin-bottom: 30px;
        text-transform: uppercase;
    }

    .actions {
        margin-top: 30px;
        text-align: right;
    }

    .firma {
        margin-top: 60px;
        display: flex;
        justify-content: space-between;
    }
</style>

<div class="container">

<h2>Generar Contrato</h2>

<form method="post">

    <label>Seleccionar Cotización Aprobada:</label><br />
    <select name="QuotationId" @(Model.ShowPreview ? "disabled" : "")>
        <option value="">-- Selecciona una cotización --</option>
    </select>

    @if (Model.ShowPreview)
    {
        <input type="hidden" name="QuotationId" value="@Model.QuotationId" />

        <div class="document">

            <div class="title">
                CONTRATO DE PRESTACIÓN DE SERVICIOS
            </div>

            <p>
                En la ciudad de <strong>Xalapa, Veracruz</strong>, a la fecha de generación del presente documento,
                se celebra el contrato de prestación de servicios entre la empresa 
                <strong>SIMAR S.A. de C.V.</strong>, en lo sucesivo “EL PRESTADOR”, 
                y <strong>@Model.BusinessName</strong>, en lo sucesivo “EL CLIENTE”, 
                al tenor de las siguientes cláusulas:
            </p>

            <p>
                <strong>PRIMERA. OBJETO DEL CONTRATO.</strong><br />
                EL PRESTADOR se obliga a proporcionar a EL CLIENTE el servicio consistente en 
                <strong>@Model.ServiceDetails</strong>, conforme a las especificaciones establecidas en la cotización aprobada.
            </p>

            <p>
                <strong>SEGUNDA. PRECIO Y FORMA DE PAGO.</strong><br />
                EL CLIENTE se obliga a pagar la cantidad de <strong>$@Model.Price</strong> 
                por concepto del servicio, mediante la modalidad de pago 
                <strong>@Model.PaymentMethod</strong>.
            </p>

            <p>
                <strong>TERCERA. VIGENCIA.</strong><br />
                El presente contrato tendrá una vigencia de <strong>@Model.Validity</strong>, 
                contados a partir de la fecha de firma del mismo.
            </p>

            <p>
                <strong>CUARTA. OBLIGACIONES DE LAS PARTES.</strong><br />
                Ambas partes se comprometen a cumplir con las obligaciones establecidas en el presente contrato,
                así como con las disposiciones legales aplicables.
            </p>

            <p>
                <strong>QUINTA. DISPOSICIONES GENERALES.</strong><br />
                El presente contrato constituye el acuerdo total entre las partes, sustituyendo cualquier acuerdo previo,
                verbal o escrito, relacionado con el objeto del mismo.
            </p>

            <div class="firma">
                <div>
                    ___________________________<br />
                    EL CLIENTE<br />
                    @Model.BusinessName
                </div>

                <div>
                    ___________________________<br />
                    EL PRESTADOR<br />
                    SIMAR S.A. de C.V.
                </div>
            </div>

            <div class="actions">
                <button class="btn" type="submit" name="action" value="confirm">
                    Confirmar
                </button>

                <button class="btn" type="submit" name="action" value="cancel">
                    Cancelar
                </button>
            </div>

        </div>
    }
    else
    {
        <br /><br />
        <button class="btn" type="submit" name="action" value="preview">
            Generar Vista Previa
        </button>
    }

</form>

</div>