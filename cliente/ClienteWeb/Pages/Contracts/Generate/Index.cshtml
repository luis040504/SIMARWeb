@page
@model ClienteWeb.Pages.Contracts.Generate.GenerateModel

<style>
    @@page { margin: 0; }
    .contract-container { background-color: #f8f9fa; padding: 40px 0; min-height: 100vh; }
    .pdf-page {
        background: white; width: 21.59cm; min-height: 27.94cm;
        padding: 1.8cm 2.2cm; margin: 0 auto 20px auto; 
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12); box-sizing: border-box;
        border: 1px solid #ddd; page-break-after: always;
    }
    
    /* Estilos Legales */
    .table-legal { width: 100%; border-collapse: collapse; margin-bottom: 15px; font-size: 8.5pt; }
    .table-legal td { border: 1px solid #000; padding: 4px 6px; vertical-align: top; }
    .bg-gray-simar { background-color: #E6E6E6; font-weight: bold; text-align: center; }
    .section-header { background: #000; color: #fff; padding: 7px 10px; font-weight: bold; font-size: 10.5pt; text-align: center; margin: 20px 0 12px 0; }
    .legal-body { font-size: 9.5pt; text-align: justify; line-height: 1.45; color: #222; }
    .sig-line { border-top: 1px solid #000; width: 80%; margin: 45px auto 8px auto; text-align: center; font-weight: bold; }
    
    /* Buscador y Modal */
    .table-editable input, .table-editable textarea { width: 100%; border: 1px solid #ccc; padding: 4px; border-radius: 4px; font-size: 0.85rem; }
    .search-box-local { display: flex; border: 1px solid var(--simar-border); border-radius: 8px; overflow: hidden; background: white; max-width: 400px; }
    .search-box-local input { border: none; padding: 10px 15px; width: 100%; outline: none; }
    .search-box-local i { padding: 10px 15px; color: gray; background: #f8f9fa; }

    @@media print {
        body * { visibility: hidden; }
        #contract-wrapper, #contract-wrapper * { visibility: visible; }
        #contract-wrapper { position: absolute; left: 0; top: 0; width: 100%; }
        .contract-container { background-color: transparent !important; padding: 0; }
        .pdf-page { box-shadow: none; border: none; margin: 0; width: 100%; min-height: 100%; border-radius: 0; }
    }
</style>

<form method="post" id="mainForm">
    <input type="hidden" name="QuotationId" id="selectedQuotationId" value="@Model.QuotationId" />
    <input type="hidden" id="hidServicesJson" name="ServicesJsonHidden" value="@Model.ServicesJsonHidden" />
    <input type="hidden" id="hidPaymentsJson" name="PaymentsJsonHidden" value="@Model.PaymentsJsonHidden" />
    <input type="hidden" id="hidExtrasJson" name="ExtrasJsonHidden" value="@Model.ExtrasJsonHidden" />
    
    <input type="hidden" id="hidObjetoSocial" name="ClientObjetoSocial" value="@Model.ClientObjetoSocial" />
    <input type="hidden" id="hidDeclaraciones" name="ClientDeclaraciones" value="@Model.ClientDeclaraciones" />
    <input type="hidden" id="hidDuration" name="ContractDuration" value="@Model.ContractDuration" />
    <input type="hidden" id="hidFirstService" name="FirstServiceDate" value="@Model.FirstServiceDate" />
    <input type="hidden" id="hidTotalPrice" name="TotalPrice" value="@Model.TotalPrice" />

    <div class="container-fluid-simar d-print-none">
        <div class="mb-3">
            <a href="/Contracts/Consult" class="btn-simar-outline-gray" style="text-decoration: none;"><i class="bi bi-arrow-left"></i> Regresar a Consulta</a>
        </div>

        @if (!Model.ShowPreview)
        {
            <div class="card-simar p-4 mb-4">
                <h4 class="text-simar-dark fw-bold mb-4">Cotizaciones Aprobadas Pendientes</h4>
                <div class="search-box-local mb-4">
                    <i class="bi bi-search"></i>
                    <input type="text" id="tableSearchInput" placeholder="Buscar por cliente..." onkeyup="filterQuotations()">
                </div>
                <div class="table-responsive-simar">
                    <table class="table-simar" id="quotationsTable">
                        <thead><tr><th>Folio Cot.</th><th>Cliente</th><th>Servicio Solicitado</th><th>Aprobación</th><th class="text-center">Acción</th></tr></thead>
                        <tbody>
                            @foreach (var q in Model.Quotations) {
                                <tr>
                                    <td class="fw-bold">#@q.Id</td><td>@q.ClientName</td><td>@q.ServiceType</td><td>@q.DateApproved</td>
                                    <td class="text-center"><button type="button" class="btn-simar-primary btn-sm" onclick="selectQuotationAndPreview(@q.Id)"><i class="bi bi-file-earmark-plus me-1"></i> Formular</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="card-simar p-4 mb-4">
                <div class="row align-items-center">
                    <div class="col-lg-7">
                        <h4 class="text-simar-dark fw-bold mb-1"><i class="bi bi-file-earmark-check text-success me-2"></i>Contrato Pre-cargado: @Model.BusinessName</h4>
                        <p class="text-muted small mb-0">Utiliza el botón de configuración para modificar el objeto social, declaraciones y tablas antes de descargar el documento legal.</p>
                    </div>
                    <div class="col-lg-5 text-end d-flex gap-2">
                        <button type="submit" name="action" value="cancel" class="btn-simar-outline-gray w-100"><i class="bi bi-arrow-repeat me-1"></i> Cancelar</button>
                        <button type="button" class="btn btn-outline-primary w-100 fw-bold" onclick="openConfigModal()"><i class="bi bi-sliders me-1"></i> Configurar Contrato</button>
                        <button type="submit" asp-page-handler="DownloadPdf" class="btn-simar-primary w-100"><i class="bi bi-download me-1"></i> Descargar PDF</button>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.ShowPreview)
    {
        <div id="contract-wrapper" class="contract-container">
            <div class="pdf-page">
                <div style="text-align: right; font-weight: bold; font-size: 10pt; margin-bottom: 5px;">DOCUMENTO NO AUTORIZADO PARA SU FIRMA</div>

                <table class="table-legal">
                    <tr><td colspan="8" class="bg-gray-simar">CONTRATO DE PRESTACIÓN DE SERVICIOS</td></tr>
                    <tr><td class="bg-gray-simar" style="width: 15%; text-align: left;">FECHA</td><td colspan="7" style="padding-left: 5px;">[@DateTime.Now.ToString("dd/MM/yyyy")]</td></tr>
                    
                    <tr><td colspan="8" class="bg-gray-simar">EL PRESTADOR</td></tr>
                    <tr><td class="bg-gray-simar" style="text-align: left;">RAZÓN SOCIAL</td><td colspan="7" style="font-weight: bold; padding-left: 5px;">SISTEMAS EN MANEJO Y ADMINISTRACION DE RESIDUOS S.A. DE C.V.</td></tr>
                    <tr>
                        <td class="bg-gray-simar" style="text-align: left;">CONSTITUTIVA NÚMERO</td><td style="text-align: center;">556</td>
                        <td class="bg-gray-simar" style="width: 10%;">FECHA</td><td style="text-align: center;">23 de octubre de 2008</td>
                        <td class="bg-gray-simar" style="width: 15%;">CORREDOR PÚBLICO:</td><td style="text-align: center;">Número 08, Plaza Veracruz.</td>
                        <td class="bg-gray-simar" style="width: 10%;">FOLIO MERCANTIL</td><td style="text-align: center;">19779*11</td>
                    </tr>
                    <tr>
                        <td class="bg-gray-simar" style="text-align: left;">APODERADO</td><td colspan="3" style="font-weight: bold; text-align: center;">GUSTAVO CRUZ TORRES</td>
                        <td colspan="2" class="bg-gray-simar">IDENTIFICACIÓN DEL APODERADO LEGAL</td><td colspan="2" style="text-align: center; font-size: 7pt;">Credencial para votar con fotografía expedida por el INE.</td>
                    </tr>
                    <tr>
                        <td class="bg-gray-simar" style="text-align: left;">INSTRUMENTO NÚMERO</td><td style="text-align: center;">556</td>
                        <td class="bg-gray-simar">FECHA</td><td style="text-align: center;">23 de octubre de 2008</td>
                        <td class="bg-gray-simar">CORREDOR PÚBLICO:</td><td style="text-align: center;">Número 08, Plaza Veracruz.</td>
                        <td class="bg-gray-simar">FOLIO MERCANTIL</td><td style="text-align: center;">19779*11</td>
                    </tr>
                    <tr>
                        <td class="bg-gray-simar" style="text-align: left;">OBJETO SOCIAL</td>
                        <td colspan="7" style="padding: 5px; text-align: justify;">Realizar la recolección de residuos peligrosos y no peligrosos, sea al gobierno federal, estatal o municipal, se tratare de sus órganos centrales o descentralizados así como otra persona física o moral de nacionalidad mexicana o extranjera.</td>
                    </tr>
                    <tr>
                        <td class="bg-gray-simar" style="text-align: left;">DOMICILIO</td>
                        <td colspan="5" style="padding: 5px;">Calle Pípila, N.E. 126, José Cardel, Xalapa, Ver. C.P. :91030</td>
                        <td class="bg-gray-simar">R.F.C.</td><td style="font-weight: bold; text-align: center;">SMA0810239L9</td>
                    </tr>
                    <tr>
                        <td class="bg-gray-simar" style="text-align: left;">DECLARACIONES</td>
                        <td colspan="7" style="padding: 5px; text-align: justify; font-size: 7.5pt;">
                            <strong>a.</strong> Es una sociedad anónima de capital variable...<br>
                            <strong>b.</strong> Su apoderado legal, cuenta con las facultades...<br>
                            <strong>c.</strong> Cuenta con los recursos humanos y materiales...<br>
                            <strong>d.</strong> Cuenta con los recursos económicos...<br>
                            <strong>e.</strong> Es su intención celebrar el presente contrato...
                        </td>
                    </tr>

                    <tr><td colspan="8" class="bg-gray-simar">"EL CLIENTE"</td></tr>
                    <tr><td class="bg-gray-simar" style="text-align: left;">RAZÓN SOCIAL</td><td colspan="7" style="font-weight: bold; padding-left: 5px;">@Model.BusinessName</td></tr>
                    <tr><td class="bg-gray-simar" style="text-align: left;">APODERADO LEGAL</td><td colspan="7" style="font-weight: bold; padding-left: 5px;">@Model.Representative</td></tr>
                    <tr>
                        <td class="bg-gray-simar" style="text-align: left;">OBJETO SOCIAL</td>
                        <td colspan="7" style="padding: 5px; text-align: justify; white-space: pre-wrap;" id="viewObjetoSocial">@Model.ClientObjetoSocial</td>
                    </tr>
                    <tr>
                        <td class="bg-gray-simar" style="text-align: left;">DOMICILIO</td>
                        <td colspan="5" style="padding: 5px;">@Model.Address</td>
                        <td class="bg-gray-simar">R.F.C.</td><td style="font-weight: bold; text-align: center;">@Model.RFC</td>
                    </tr>
                    <tr>
                        <td class="bg-gray-simar" style="text-align: left;">DECLARACIONES</td>
                        <td colspan="7" style="padding: 5px; text-align: justify; font-size: 7.5pt; white-space: pre-wrap;" id="viewDeclaraciones">@Model.ClientDeclaraciones</td>
                    </tr>
                </table>

                <div class="section-header">CLÁUSULAS</div>
                <partial name="BodyContract" model="Model" />
            </div>

            <div class="pdf-page" id="pageAnexoExtras" style="display: none;">
                <div class="section-header">ANEXO ÚNICO: CATÁLOGO DE SERVICIOS EXTRAORDINARIOS</div>
                <p class="legal-body text-justify">De conformidad con la Cláusula Quinta, en caso de requerir servicios adicionales a los descritos en las cláusulas operativas, se aplicarán los siguientes costos autorizados:</p>
                
                <div id="preview-anexo-extras"></div>
                
                <table class="sig-table" style="width: 100%; margin-top: 80px;">
                    <tr><td colspan="2" style="text-align:center; font-weight:bold; margin-bottom:10px;">LAS PARTES</td></tr>
                    <tr>
                        <td style="text-align: center; width: 50%;">
                            <span style="font-weight:bold;">EL PRESTADOR</span><div class="sig-line">GUSTAVO CRUZ TORRES</div>
                        </td>
                        <td style="text-align: center; width: 50%;">
                            <span style="font-weight:bold;">EL CLIENTE</span><div class="sig-line">@Model.Representative</div>
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    }

    <div class="modal fade" id="modalConfig" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-bold text-simar-dark"><i class="bi bi-gear-fill me-2"></i> Configuración Integral del Contrato</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    
                    <h6 class="fw-bold mb-3 border-bottom pb-2 text-simar-green">1. Declaraciones del Cliente</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label-simar">Objeto Social</label>
                            <textarea class="form-control" id="modObjetoSocial" rows="3">@Model.ClientObjetoSocial</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-simar">Declaraciones Específicas</label>
                            <textarea class="form-control" id="modDeclaraciones" rows="3">@Model.ClientDeclaraciones</textarea>
                        </div>
                    </div>

                    <h6 class="fw-bold mb-3 border-bottom pb-2 text-simar-green">2. Variables Comerciales</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label-simar">Duración del Contrato</label>
                            <input type="text" class="form-control" id="modDuration" value="@Model.ContractDuration">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-simar">Fecha del Primer Servicio</label>
                            <input type="date" class="form-control" id="modFirstService" value="@Model.FirstServiceDate">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-simar">Precio Total del Contrato ($)</label>
                            <input type="number" step="0.01" class="form-control" id="modTotalPrice" value="@Model.TotalPrice">
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-2">
                        <h6 class="fw-bold mb-0 text-simar-green">3. Tabla Operativa (Servicios y Residuos)</h6>
                        <button type="button" class="btn btn-sm btn-dark" onclick="addServiceRow()"><i class="bi bi-plus"></i> Añadir Servicio</button>
                    </div>
                    <div class="table-responsive mb-4">
                        <table class="table table-bordered table-editable">
                            <thead class="table-light text-center" style="font-size:0.85rem">
                                <tr><th>Tipo de Residuo</th><th>Unidad</th><th>Periodicidad</th><th>Vehículos</th><th>Técnicos</th><th>Dir. Servicio</th><th>Almacén Destino</th><th></th></tr>
                            </thead>
                            <tbody id="modServicesBody"></tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-2">
                        <h6 class="fw-bold mb-0 text-simar-green">4. Desglose de Pagos</h6>
                        <button type="button" class="btn btn-sm btn-dark" onclick="addPaymentRow()"><i class="bi bi-plus"></i> Añadir Pago</button>
                    </div>
                    <div class="table-responsive mb-4">
                        <table class="table table-bordered table-editable" style="max-width: 800px;">
                            <thead class="table-light text-center" style="font-size:0.85rem">
                                <tr><th>Concepto del Pago</th><th>Monto ($)</th><th>Fecha de Pago</th><th style="width: 50px;"></th></tr>
                            </thead>
                            <tbody id="modPaymentsBody"></tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-2">
                        <h6 class="fw-bold mb-0 text-warning">5. Anexo Único: Servicios Extraordinarios</h6>
                        <button type="button" class="btn btn-sm btn-warning" onclick="addExtraRow()"><i class="bi bi-plus"></i> Añadir Servicio Extra</button>
                    </div>
                    <p class="small text-muted mb-2">Si agregas filas aquí, se generará una página adicional al final del PDF con el catálogo de extras.</p>
                    <div class="table-responsive">
                        <table class="table table-bordered table-editable">
                            <thead class="table-light text-center" style="font-size:0.85rem">
                                <tr><th>Descripción del Extra</th><th>Costo Unitario ($)</th><th>Cantidad Autorizada</th><th style="width: 50px;"></th></tr>
                            </thead>
                            <tbody id="modExtrasBody"></tbody>
                        </table>
                    </div>

                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn-simar-primary" onclick="saveConfiguration()"><i class="bi bi-check-circle me-1"></i> Aplicar y Actualizar PDF</button>
                </div>
            </div>
        </div>
    </div>
</form>

<script>
    function filterQuotations() {
        let input = document.getElementById("tableSearchInput").value.toLowerCase();
        document.querySelectorAll("#quotationsTable tbody tr").forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(input) ? "" : "none";
        });
    }

    function selectQuotationAndPreview(id) {
        document.getElementById('selectedQuotationId').value = id;
        let form = document.getElementById('mainForm');
        let actionInput = document.createElement('input'); actionInput.type = 'hidden'; actionInput.name = 'action'; actionInput.value = 'preview';
        form.appendChild(actionInput);
        form.submit();
    }

    let services = @Html.Raw(Model.ServicesJsonHidden ?? "[]");
    let payments = @Html.Raw(Model.PaymentsJsonHidden ?? "[]");
    let extras = @Html.Raw(Model.ExtrasJsonHidden ?? "[]");

    document.addEventListener("DOMContentLoaded", () => {
        if (@(Model.ShowPreview ? "true" : "false")) {
            renderLegalTables();
        }
    });

    function openConfigModal() {
        const sBody = document.getElementById('modServicesBody'); sBody.innerHTML = '';
        services.forEach(s => appendServiceRow(s.WasteType, s.WasteUnit, s.Frequency, s.Vehicles, s.Technicians, s.ServiceAddress, s.WarehouseAddress));
        
        const pBody = document.getElementById('modPaymentsBody'); pBody.innerHTML = '';
        payments.forEach(p => appendPaymentRow(p.Description, p.Amount, p.PaymentDate));

        const eBody = document.getElementById('modExtrasBody'); eBody.innerHTML = '';
        extras.forEach(e => appendExtraRow(e.Description, e.UnitCost, e.Quantity));

        new bootstrap.Modal(document.getElementById('modalConfig')).show();
    }

    function appendServiceRow(w, u, f, v, t, sa, wa) {
        document.getElementById('modServicesBody').insertAdjacentHTML('beforeend', `<tr><td><input type="text" value="${w}"></td><td><input type="text" value="${u}"></td><td><input type="text" value="${f}"></td><td><input type="number" value="${v}"></td><td><input type="number" value="${t}"></td><td><input type="text" value="${sa}"></td><td><input type="text" value="${wa}"></td><td><button type="button" class="btn btn-sm btn-danger" onclick="this.closest('tr').remove()"><i class="bi bi-trash"></i></button></td></tr>`);
    }

    function appendPaymentRow(d, a, pd) {
        document.getElementById('modPaymentsBody').insertAdjacentHTML('beforeend', `<tr><td><input type="text" value="${d}"></td><td><input type="number" step="0.01" value="${a}"></td><td><input type="date" value="${pd}"></td><td><button type="button" class="btn btn-sm btn-danger" onclick="this.closest('tr').remove()"><i class="bi bi-trash"></i></button></td></tr>`);
    }

    function appendExtraRow(d, u, q) {
        document.getElementById('modExtrasBody').insertAdjacentHTML('beforeend', `<tr><td><input type="text" value="${d}"></td><td><input type="number" step="0.01" value="${u}"></td><td><input type="number" value="${q}"></td><td><button type="button" class="btn btn-sm btn-danger" onclick="this.closest('tr').remove()"><i class="bi bi-trash"></i></button></td></tr>`);
    }

    function addServiceRow() { appendServiceRow('','', '', 1, 1, '', ''); }
    function addPaymentRow() { appendPaymentRow('', 0, ''); }
    function addExtraRow() { appendExtraRow('', 0, 1); }

    function saveConfiguration() {
        let objSocial = document.getElementById('modObjetoSocial').value;
        let decs = document.getElementById('modDeclaraciones').value;
        document.getElementById('hidObjetoSocial').value = objSocial;
        document.getElementById('hidDeclaraciones').value = decs;
        document.getElementById('viewObjetoSocial').innerText = objSocial;
        document.getElementById('viewDeclaraciones').innerText = decs;

        document.getElementById('hidDuration').value = document.getElementById('modDuration').value;
        document.getElementById('hidFirstService').value = document.getElementById('modFirstService').value;
        document.getElementById('hidTotalPrice').value = document.getElementById('modTotalPrice').value;
        
        document.getElementById('lblDuration').innerText = document.getElementById('modDuration').value;
        
        let fd = new Date(document.getElementById('modFirstService').value + "T00:00:00");
        document.getElementById('lblFirstService').innerText = isNaN(fd) ? "Pendiente" : fd.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' });
        
        let tp = parseFloat(document.getElementById('modTotalPrice').value);
        document.getElementById('lblTotalPrice').innerText = tp.toLocaleString('es-MX', {style: 'currency', currency: 'MXN'});

        services = []; document.querySelectorAll('#modServicesBody tr').forEach(tr => { let i = tr.querySelectorAll('input'); services.push({ WasteType: i[0].value, WasteUnit: i[1].value, Frequency: i[2].value, Vehicles: parseInt(i[3].value), Technicians: parseInt(i[4].value), ServiceAddress: i[5].value, WarehouseAddress: i[6].value }); });
        document.getElementById('hidServicesJson').value = JSON.stringify(services);

        payments = []; document.querySelectorAll('#modPaymentsBody tr').forEach(tr => { let i = tr.querySelectorAll('input'); payments.push({ Description: i[0].value, Amount: parseFloat(i[1].value), PaymentDate: i[2].value }); });
        document.getElementById('hidPaymentsJson').value = JSON.stringify(payments);

        extras = []; document.querySelectorAll('#modExtrasBody tr').forEach(tr => { let i = tr.querySelectorAll('input'); extras.push({ Description: i[0].value, UnitCost: parseFloat(i[1].value), Quantity: parseInt(i[2].value) }); });
        document.getElementById('hidExtrasJson').value = JSON.stringify(extras);

        renderLegalTables();
        bootstrap.Modal.getInstance(document.getElementById('modalConfig')).hide();
    }

    function renderLegalTables() {
        let sHtml = '';
        services.forEach(s => { sHtml += `<tr><td>${s.WasteType}</td><td>${s.WasteUnit}</td><td>${s.Frequency}</td><td style="text-align:center">${s.Vehicles} / ${s.Technicians}</td><td>${s.ServiceAddress}</td><td>${s.WarehouseAddress}</td></tr>`; });
        document.getElementById('preview-services-body').innerHTML = sHtml;

        let pHtml = '';
        payments.forEach(p => { 
            let dateStr = new Date(p.PaymentDate + "T00:00:00").toLocaleDateString('es-MX');
            pHtml += `<tr><td>${p.Description}</td><td style="text-align:right">$${p.Amount.toLocaleString('en-US', {minimumFractionDigits: 2})}</td><td style="text-align:center">${dateStr}</td></tr>`; 
        });
        document.getElementById('preview-payments-body').innerHTML = pHtml;

        if(extras.length > 0) {
            document.getElementById('pageAnexoExtras').style.display = 'block';
            let eHtml = `<table class="table-legal" style="font-size: 8pt; margin-top: 10px; margin-bottom: 20px;"><tr class="bg-gray-simar" style="text-align:center"><td>Descripción</td><td style="width:20%">Costo Unit.</td><td style="width:15%">Cant.</td><td style="width:20%">Subtotal</td></tr>`;
            let total = 0;
            extras.forEach(x => { let sub = x.UnitCost * x.Quantity; total += sub; eHtml += `<tr><td>${x.Description}</td><td style="text-align:right">$${x.UnitCost.toLocaleString('en-US', {minimumFractionDigits:2})}</td><td style="text-align:center">${x.Quantity}</td><td style="text-align:right">$${sub.toLocaleString('en-US', {minimumFractionDigits:2})}</td></tr>`; });
            eHtml += `<tr><td colspan="3" style="text-align:right; font-weight:bold; background-color:#E6E6E6;">TOTAL SERVICIOS EXTRAORDINARIOS:</td><td style="text-align:right; font-weight:bold;">$${total.toLocaleString('en-US', {minimumFractionDigits:2})}</td></tr></table>`;
            document.getElementById('preview-anexo-extras').innerHTML = eHtml;
        } else {
            document.getElementById('pageAnexoExtras').style.display = 'none';
        }
    }
</script>