@page
@model ClienteWeb.Pages.Contracts.Generate.GenerateModel

<style>
    .container {
        max-width: 800px;
        margin: 0 auto;
        font-family: Arial;
    }

    h2 {
        border-bottom: 2px solid black;
        padding-bottom: 10px;
    }

    .card {
        border: 1px solid #ccc;
        padding: 20px;
        margin-top: 20px;
        background-color: #f9f9f9;
    }

    .form-group {
        margin-bottom: 15px;
    }

    select, button {
        padding: 6px;
    }

    .btn {
        padding: 6px 12px;
        border: 1px solid black;
        background: white;
        cursor: pointer;
        margin-right: 10px;
    }

    .btn:hover {
        background: #eee;
    }

    .document {
        width: 800px;
        margin: 20px auto;
        padding: 30px;
        border: 2px solid black;
        background: white;
    }

    .header {
        text-align: center;
        border-bottom: 2px solid black;
        margin-bottom: 20px;
    }

    .section {
        margin-bottom: 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    td {
        border: 1px solid #000;
        padding: 8px;
    }

    h4 {
        margin-bottom: 5px;
    }

    .signatures {
        display: flex;
        justify-content: space-between;
        margin-top: 40px;
    }
</style>

<div class="container">

<h2>Generar Contrato</h2>

<form method="post">

    <div class="form-group">
        <label>Seleccionar Cotización Aprobada:</label><br />

        <select name="QuotationId" @(Model.ShowPreview ? "disabled" : "")>
            <option value="">-- Selecciona una cotización --</option>

            @foreach (var q in Model.Quotations)
            {
                <option value="@q.Id" selected="@(q.Id == Model.QuotationId)">
                    @q.Name
                </option>
            }
        </select>

        @if (Model.ShowPreview)
        {
            <input type="hidden" name="QuotationId" value="@Model.QuotationId" />
        }
    </div>

    @if (Model.ShowPreview)
    {
        <div class="document">

            <div class="header">
                <h2>SIMAR</h2>
                <p><strong>Contrato de Servicios</strong></p>
            </div>

            <div class="section">
                <table>
                    <tr>
                        <td><strong>Cliente:</strong></td>
                        <td>@Model.BusinessName</td>
                    </tr>
                    <tr>
                        <td><strong>RFC:</strong></td>
                        <td>RFC123456</td>
                    </tr>
                    <tr>
                        <td><strong>Domicilio:</strong></td>
                        <td>Dirección del cliente</td>
                    </tr>
                </table>
            </div>

            <div class="section">
                <h4>Detalle del Servicio</h4>
                <p>@Model.ServiceDetails</p>
            </div>

            <div class="section">
                <table>
                    <tr>
                        <td><strong>Precio:</strong></td>
                        <td>$@Model.Price</td>
                    </tr>
                    <tr>
                        <td><strong>Forma de pago:</strong></td>
                        <td>@Model.PaymentMethod</td>
                    </tr>
                    <tr>
                        <td><strong>Vigencia:</strong></td>
                        <td>@Model.Validity</td>
                    </tr>
                </table>
            </div>

            <div class="section">
                <h4>Cláusulas</h4>
                <p>
                    Este contrato establece los términos y condiciones del servicio...
                </p>
            </div>

            <div class="signatures">
                <div>
                    _______________________<br />
                    Firma Cliente
                </div>

                <div>
                    _______________________<br />
                    Firma Empresa
                </div>
            </div>

            <br />

            <button class="btn" type="submit" name="action" value="confirm">
                Confirmar
            </button>

            <button class="btn" type="submit" name="action" value="cancel">
                Cancelar
            </button>

        </div>
    }
    else
    {
        <button class="btn" type="submit" name="action" value="preview">
            Generar Vista Previa
        </button>
    }

</form>

</div>