    </div>
</div>

<script>
    function filtrarTabla() {
        // 1. Obtener valores de los filtros
        const busqueda = document.getElementById('busquedaInput').value.toLowerCase();
        const rolSeleccionado = document.getElementById('rolFiltro').value.toLowerCase();

        // 2. Obtener las filas de la tabla (excepto el encabezado)
        const filas = document.getElementById('tablaUsuarios').getElementsByTagName('tbody')[0].getElementsByTagName('tr');

        // 3. Recorrer cada fila para decidir si se muestra o se oculta
        for (let i = 0; i < filas.length; i++) {
            const celdas = filas[i].getElementsByTagName('td');
            if (celdas.length > 0) {
                const username = celdas[0].textContent.toLowerCase();
                const nombre = celdas[1].textContent.toLowerCase();
                const rol = celdas[2].textContent.toLowerCase();

                // Lógica de coincidencia
                const coincideBusqueda = username.includes(busqueda) || nombre.includes(busqueda);
                const coincideRol = rolSeleccionado === "" || rol.includes(rolSeleccionado);

                if (coincideBusqueda && coincideRol) {
                    filas[i].style.display = "";
                } else {
                    filas[i].style.display = "none";
                }
            }
        }
    }

    function confirmarBaja(usuario) {
        if (confirm("¿Estás seguro de que deseas dar de baja al usuario: " + usuario + "?")) {
            alert(usuario + " ha sido desactivado del sistema.");
        }
    }
</script>
