<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Usuarios SIMAR</h4>
            <a href="/registro" class="btn btn-sm btn-outline-light"> + Nuevo Registro</a>
        </div>

        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Buscar por Nombre o usuario:</label>
                    <input type="text" id="busquedaInput" class="form-control" placeholder="Buscar..." onkeyup="filtrarTabla()">
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Filtrar por Rol:</label>
                    <select id="rolFiltro" class="form-select" onchange="filtrarTabla()">
                        <option value="">-- Todos los Roles --</option>
                        <option value="Seller">Seller</option>
                        <option value="Technical">Technical</option>
                        <option value="Manager">Manager</option>
                        <option value="Owner">Owner</option>
                        <option value="Accountant">Accountant</option>
                        <option value="Driver">Driver</option>
                    </select>
                </div>
            </div>

            <table class="table table-striped table-hover mt-3" id="tablaUsuarios">
                <thead class="table-dark">
                    <tr>
                        <th>Usuario</th>
                        <th>Nombre</th>
                        <th>Rol</th>
                        <th>CURP</th>
                        <th>RFC</th>
                        <th>Salario</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
