@page
@model ClienteWeb.Pages.Vehiculos.IndexModel
@{
    ViewData["Title"] = "Vehículos - SIMAR";
}

<style>
    /* Unificación de estilos con el layout */
    :root {
        --simar-green: #5aad31;
        --simar-dark: #4a4a4a;
        --simar-gray-light: #f8f9fa;
        --simar-border: #e9ecef;
    }
    
    * {
        font-family: 'Inter', sans-serif;
    }
    
    /* Tarjetas mejoradas */
    .vehiculo-card {
        background: white;
        border-radius: 20px;
        transition: all 0.3s ease;
        cursor: default;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }
    
    .vehiculo-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(90, 173, 49, 0.12);
        border-color: rgba(90, 173, 49, 0.2);
    }
    
    .card-img-top {
        height: 180px;
        object-fit: cover;
        background-color: var(--simar-gray-light);
    }
    
    .badge-vehiculo {
        background: var(--simar-green);
        color: white;
        font-size: 0.7rem;
        padding: 0.3rem 0.6rem;
        border-radius: 30px;
        font-weight: 500;
    }
    
    /* Botones mejorados */
    .btn-simar-outline {
        background: transparent;
        border: 1px solid var(--simar-green);
        color: var(--simar-green);
        border-radius: 10px;
        padding: 0.5rem 1rem;
        transition: all 0.2s;
        font-weight: 500;
    }
    
    .btn-simar-outline:hover {
        background: var(--simar-green);
        color: white;
        transform: translateY(-2px);
    }
    
    .btn-simar-primary {
        background: var(--simar-green);
        border: none;
        color: white;
        border-radius: 10px;
        padding: 0.5rem 1rem;
        transition: all 0.2s;
        font-weight: 500;
    }
    
    .btn-simar-primary:hover {
        background: #3d7a1f;
        transform: translateY(-2px);
    }
    
    .btn-simar-secondary {
        background: var(--simar-dark);
        border: none;
        color: white;
        border-radius: 10px;
        padding: 0.5rem 1rem;
        transition: all 0.2s;
        font-weight: 500;
    }
    
    .btn-simar-secondary:hover {
        background: #3a3a3a;
        transform: translateY(-2px);
    }
    
    /* Barra de búsqueda */
    .search-box {
        border: 1px solid var(--simar-border);
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.2s;
    }
    
    .search-box:focus-within {
        border-color: var(--simar-green);
        box-shadow: 0 0 0 2px rgba(90, 173, 49, 0.2);
    }
    
    .search-box input {
        border: none;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
    }
    
    .search-box input:focus {
        box-shadow: none;
    }
    
    .search-box button {
        background: white;
        border: none;
        color: var(--simar-dark);
        padding: 0.6rem 1.2rem;
    }
    
    .search-box button:hover {
        background: var(--simar-green);
        color: white;
    }
    
    /* Modales mejorados */
    .modal-content {
        border-radius: 20px;
        border: none;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }
    
    .modal-header {
        border-bottom: 2px solid var(--simar-green);
        background: white;
        border-radius: 20px 20px 0 0;
        padding: 1.2rem 1.5rem;
    }
    
    .modal-header .modal-title {
        color: var(--simar-dark);
        font-weight: 600;
    }
    
    .modal-header .modal-title i {
        color: var(--simar-green);
    }
    
    .modal-footer {
        border-top: 1px solid var(--simar-border);
        padding: 1rem 1.5rem;
    }
    
    /* Campos de formulario */
    .form-label {
        font-weight: 500;
        font-size: 0.85rem;
        color: var(--simar-dark);
        margin-bottom: 0.3rem;
    }
    
    .form-control, .form-select {
        border-radius: 10px;
        border: 1px solid var(--simar-border);
        padding: 0.5rem 0.8rem;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    
    .form-control:focus, .form-select:focus {
        border-color: var(--simar-green);
        box-shadow: 0 0 0 2px rgba(90, 173, 49, 0.2);
    }
    
    /* Imagen preview */
    .img-preview {
        max-height: 120px;
        border-radius: 10px;
        border: 2px solid var(--simar-border);
        padding: 5px;
    }
    
    /* Scroll del modal */
    .modal-scrollable {
        max-height: 65vh;
        overflow-y: auto;
        padding-right: 0.5rem;
    }
    
    .modal-scrollable::-webkit-scrollbar {
        width: 4px;
    }
    
    .modal-scrollable::-webkit-scrollbar-track {
        background: var(--simar-border);
        border-radius: 4px;
    }
    
    .modal-scrollable::-webkit-scrollbar-thumb {
        background: var(--simar-green);
        border-radius: 4px;
    }
    
    /* Dropdown personalizado */
    .dropdown-menu {
        border-radius: 12px;
        border: 1px solid var(--simar-border);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    }
    
    .dropdown-item:hover {
        background: rgba(90, 173, 49, 0.1);
        color: var(--simar-green);
    }
    
    .dropdown-item.text-danger:hover {
        background: rgba(220, 53, 69, 0.1);
        color: #dc3545;
    }
    
    /* Estado vacío */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 20px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
    }
    
    .empty-state i {
        font-size: 4rem;
        color: var(--simar-green);
        opacity: 0.5;
        margin-bottom: 1rem;
    }
    
    /* Ajuste para que el contenido no se corte con el sidebar */
    .main-content-simar {
        overflow-x: hidden;
    }
    
    .container-fluid-custom {
        width: 100%;
        padding-right: 1rem;
        padding-left: 1rem;
    }
</style>

<div class="container-fluid-custom">
    <!-- Header de la página -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-semibold" style="color: var(--simar-dark);">
                <i class="bi bi-truck-front me-2" style="color: var(--simar-green);"></i>
                Vehículos
            </h2>
            <p class="text-muted small mb-0">Gestión de la flota vehicular</p>
        </div>
        
        <button class="btn-simar-primary" data-bs-toggle="modal" data-bs-target="#modalCreate">
            <i class="bi bi-plus-lg me-2"></i>Agregar Vehículo
        </button>
    </div>
    
    <!-- Barra de búsqueda -->
    <div class="mb-4">
        <form method="get" class="d-flex flex-column flex-sm-row gap-2">
            <div class="search-box flex-grow-1">
                <div class="d-flex">
                    <input type="text" name="Search" class="form-control" placeholder="Buscar por marca, modelo, placas, tipo de desecho..." value="@Model.Search">
                    <button type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a asp-page="Index" class="btn-simar-outline text-center" style="min-width: 100px;">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </a>
            }
        </form>
    </div>
    
    <!-- Listado de vehículos -->
    @if (!Model.Vehiculos.Any())
    {
        <div class="empty-state">
            <i class="bi bi-truck-front"></i>
            <h4 class="text-secondary">No hay vehículos registrados</h4>
            <p class="text-muted">Comienza agregando tu primer vehículo</p>
            <button class="btn-simar-primary mt-3" data-bs-toggle="modal" data-bs-target="#modalCreate">
                <i class="bi bi-plus-lg"></i> Agregar Vehículo
            </button>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model.Vehiculos)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="vehiculo-card h-100">
                        <div class="position-relative">
                            <!-- Imagen -->
                            <img src="@(item.FotoUrl ?? "/images/vehiculos/default-truck.jpg")"
                                 alt="@item.Marca @item.Modelo"
                                 class="card-img-top"
                                 onerror="this.onerror=null; this.src='https://placehold.co/300x180/e9ecef/5aad31?text=SIN+IMAGEN'; this.style.backgroundColor='#f8f9fa';" 
                                 loading="lazy" />
                            
                            <!-- Número económico -->
                            @if (!string.IsNullOrEmpty(item.NumeroEconomico))
                            {
                                <span class="position-absolute top-0 start-0 m-2 badge-vehiculo">
                                    <i class="bi bi-123 me-1"></i> @item.NumeroEconomico
                                </span>
                            }
                            
                            <!-- Botón de opciones -->
                            <div class="position-absolute top-0 end-0 m-2">
                                <div class="dropdown">
                                    <button class="btn btn-light btn-sm rounded-circle shadow-sm" type="button" data-bs-toggle="dropdown" style="width: 32px; height: 32px;">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <button class="dropdown-item btn-edit" 
                                                    data-id="@item.Id"
                                                    data-marca="@item.Marca"
                                                    data-modelo="@item.Modelo"
                                                    data-peso="@item.PesoToneladas"
                                                    data-licencia="@item.LicenciaRequerida"
                                                    data-tipodesecho="@item.TipoDesecho"
                                                    data-tipogasolina="@item.TipoGasolina"
                                                    data-placas="@item.Placas"
                                                    data-numeroeconomico="@item.NumeroEconomico"
                                                    data-año="@item.Año"
                                                    data-color="@item.Color"
                                                    data-descripcion="@item.Descripcion"
                                                    data-fotourl="@item.FotoUrl">
                                                <i class="bi bi-pencil me-2"></i> Editar
                                            </button>
                                        </li>
                                        <li>
                                            <button class="dropdown-item btn-details"
                                                    data-id="@item.Id"
                                                    data-marca="@item.Marca"
                                                    data-modelo="@item.Modelo"
                                                    data-peso="@item.PesoToneladas"
                                                    data-licencia="@item.LicenciaRequerida"
                                                    data-tipodesecho="@item.TipoDesecho"
                                                    data-tipogasolina="@item.TipoGasolina"
                                                    data-placas="@item.Placas"
                                                    data-numeroeconomico="@item.NumeroEconomico"
                                                    data-año="@item.Año"
                                                    data-color="@item.Color"
                                                    data-descripcion="@item.Descripcion"
                                                    data-fotourl="@item.FotoUrl">
                                                <i class="bi bi-eye me-2"></i> Ver detalles
                                            </button>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <button class="dropdown-item text-danger btn-delete"
                                                    data-id="@item.Id"
                                                    data-numeroeconomico="@item.NumeroEconomico"
                                                    data-marca="@item.Marca"
                                                    data-modelo="@item.Modelo"
                                                    data-placas="@item.Placas">
                                                <i class="bi bi-trash me-2"></i> Eliminar
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                        
                        <div class="p-3">
                            <h5 class="fw-semibold mb-2" style="color: var(--simar-dark);">
                                @item.Marca @item.Modelo
                            </h5>
                            
                            <div class="mb-2">
                                @if (!string.IsNullOrEmpty(item.Año.ToString()))
                                {
                                    <div class="small mb-1">
                                        <i class="bi bi-calendar text-muted me-2"></i>
                                        <strong>Año:</strong> @item.Año
                                    </div>
                                }
                                <div class="small mb-1">
                                    <i class="bi bi-speedometer2 text-muted me-2"></i>
                                    <strong>Peso:</strong> @(item.PesoToneladas?.ToString("N1") ?? "N/A") ton
                                </div>
                                <div class="small mb-1">
                                    <i class="bi bi-file-earmark-text text-muted me-2"></i>
                                    <strong>Desecho:</strong> @(item.TipoDesecho.Length > 25 ? item.TipoDesecho.Substring(0, 25) + "..." : item.TipoDesecho)
                                </div>
                                <div class="small">
                                    <i class="bi bi-upc-scan text-muted me-2"></i>
                                    <strong>Placas:</strong> @item.Placas
                                </div>
                            </div>
                        </div>
                        
                        <div class="px-3 pb-3 pt-0">
                            <button class="btn-simar-outline w-100 btn-sm btn-details"
                                    data-id="@item.Id"
                                    data-marca="@item.Marca"
                                    data-modelo="@item.Modelo"
                                    data-peso="@item.PesoToneladas"
                                    data-licencia="@item.LicenciaRequerida"
                                    data-tipodesecho="@item.TipoDesecho"
                                    data-tipogasolina="@item.TipoGasolina"
                                    data-placas="@item.Placas"
                                    data-numeroeconomico="@item.NumeroEconomico"
                                    data-año="@item.Año"
                                    data-color="@item.Color"
                                    data-descripcion="@item.Descripcion"
                                    data-fotourl="@item.FotoUrl">
                                <i class="bi bi-arrow-right me-1"></i> Ver detalles
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- ==================== MODALES ==================== -->
<!-- (Los modales se mantienen igual, solo se mejora la clase de los botones) -->

<!-- Modal Create -->
<div class="modal fade" id="modalCreate" tabindex="-1" aria-labelledby="modalCreateLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalCreateLabel">
                    <i class="bi bi-plus-circle me-2"></i>Registrar Nuevo Vehículo
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form id="formCreate" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body modal-scrollable">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-123 me-1"></i> Número Económico</label>
                            <input type="text" name="NumeroEconomico" class="form-control" placeholder="Ej: VH-001">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-calendar me-1"></i> Año</label>
                            <input type="number" name="Año" class="form-control" placeholder="Ej: 2020" min="1990" max="2025">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-tag me-1"></i> Marca *</label>
                            <input type="text" name="Marca" class="form-control" placeholder="Ej: Kenworth" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-gear me-1"></i> Modelo *</label>
                            <input type="text" name="Modelo" class="form-control" placeholder="Ej: T680" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><i class="bi bi-palette me-1"></i> Color</label>
                            <input type="text" name="Color" class="form-control" placeholder="Ej: Blanco">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><i class="bi bi-upc-scan me-1"></i> Placas *</label>
                            <input type="text" name="Placas" class="form-control" placeholder="Ej: ABC-1234" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><i class="bi bi-speedometer2 me-1"></i> Peso (toneladas) *</label>
                            <input type="number" step="0.1" name="PesoToneladas" class="form-control" placeholder="Ej: 8.5" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-card-text me-1"></i> Licencia requerida *</label>
                            <select name="LicenciaRequerida" class="form-select" required>
                                <option value="">Seleccionar licencia</option>
                                <option value="A">A - Automóviles</option>
                                <option value="B">B - Camiones ligeros</option>
                                <option value="C">C - Camiones pesados</option>
                                <option value="D">D - Autobuses</option>
                                <option value="E">E - Tractocamiones</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-fuel-pump me-1"></i> Tipo de gasolina *</label>
                            <select name="TipoGasolina" class="form-select" id="createTipoGasolina" required>
                                <option value="">Seleccionar tipo</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-trash me-1"></i> Tipo de desecho que puede transportar *</label>
                            <select name="TipoDesecho" class="form-select" id="createTipoDesecho" required>
                                <option value="">Seleccionar tipo de desecho</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-chat-text me-1"></i> Descripción</label>
                            <textarea name="Descripcion" class="form-control" rows="2" placeholder="Características adicionales del vehículo..."></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-image me-1"></i> Foto del vehículo</label>
                            <input type="file" name="FotoArchivo" accept="image/*" class="form-control" id="createFotoInput">
                            <div class="mt-3 text-center">
                                <img id="createFotoPreview" src="#" alt="Vista previa" class="img-preview d-none">
                            </div>
                            <small class="text-muted">Formatos: JPG, PNG. Tamaño máximo: 5MB</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-simar-outline" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-simar-primary">
                        <i class="bi bi-check-lg"></i> Registrar Vehículo
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Edit -->
<div class="modal fade" id="modalEdit" tabindex="-1" aria-labelledby="modalEditLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalEditLabel">
                    <i class="bi bi-pencil-square me-2"></i>Editar Vehículo
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form id="formEdit" method="post" enctype="multipart/form-data">
                <input type="hidden" name="Id" id="editId">
                @Html.AntiForgeryToken()
                <div class="modal-body modal-scrollable">
                    <div class="text-center mb-3">
                        <p class="mb-1">Foto actual:</p>
                        <img id="editFotoActual" src="#" alt="Foto actual" class="img-preview" style="max-height: 120px;">
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-123 me-1"></i> Número Económico</label>
                            <input type="text" name="NumeroEconomico" class="form-control" id="editNumeroEconomico">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-calendar me-1"></i> Año</label>
                            <input type="number" name="Año" class="form-control" id="editAño" min="1990" max="2025">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-tag me-1"></i> Marca *</label>
                            <input type="text" name="Marca" class="form-control" id="editMarca" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-gear me-1"></i> Modelo *</label>
                            <input type="text" name="Modelo" class="form-control" id="editModelo" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><i class="bi bi-palette me-1"></i> Color</label>
                            <input type="text" name="Color" class="form-control" id="editColor">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><i class="bi bi-upc-scan me-1"></i> Placas *</label>
                            <input type="text" name="Placas" class="form-control" id="editPlacas" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><i class="bi bi-speedometer2 me-1"></i> Peso (toneladas) *</label>
                            <input type="number" step="0.1" name="PesoToneladas" class="form-control" id="editPeso" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-card-text me-1"></i> Licencia requerida *</label>
                            <select name="LicenciaRequerida" class="form-select" id="editLicencia" required>
                                <option value="">Seleccionar licencia</option>
                                <option value="A">A - Automóviles</option>
                                <option value="B">B - Camiones ligeros</option>
                                <option value="C">C - Camiones pesados</option>
                                <option value="D">D - Autobuses</option>
                                <option value="E">E - Tractocamiones</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-fuel-pump me-1"></i> Tipo de gasolina *</label>
                            <select name="TipoGasolina" class="form-select" id="editTipoGasolina" required>
                                <option value="">Seleccionar tipo</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-trash me-1"></i> Tipo de desecho que puede transportar *</label>
                            <select name="TipoDesecho" class="form-select" id="editTipoDesecho" required>
                                <option value="">Seleccionar tipo de desecho</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-chat-text me-1"></i> Descripción</label>
                            <textarea name="Descripcion" class="form-control" id="editDescripcion" rows="2"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-image me-1"></i> Nueva foto (opcional)</label>
                            <input type="file" name="FotoArchivo" accept="image/*" class="form-control" id="editFotoInput">
                            <div class="mt-3 text-center">
                                <img id="editFotoPreview" src="#" alt="Vista previa" class="img-preview d-none">
                            </div>
                            <small class="text-muted">Dejar vacío para mantener la foto actual</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-simar-outline" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-simar-primary">
                        <i class="bi bi-check-lg"></i> Guardar cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Details -->
<div class="modal fade" id="modalDetails" tabindex="-1" aria-labelledby="modalDetailsLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalDetailsLabel">
                    <i class="bi bi-info-circle me-2"></i>Detalles del Vehículo
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-4 text-center mb-3">
                        <img id="detailsFoto" src="#" alt="Foto del vehículo" class="img-fluid rounded border img-preview" style="max-height: 200px;">
                    </div>
                    <div class="col-md-8">
                        <h4 class="mb-3" id="detailsTitulo"></h4>
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-123 me-2"></i>No. Económico:</strong> <span id="detailsNumeroEconomico"></span>
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-calendar me-2"></i>Año:</strong> <span id="detailsAño"></span>
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-tag me-2"></i>Marca:</strong> <span id="detailsMarca"></span>
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-gear me-2"></i>Modelo:</strong> <span id="detailsModelo"></span>
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-palette me-2"></i>Color:</strong> <span id="detailsColor"></span>
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-upc-scan me-2"></i>Placas:</strong> <span id="detailsPlacas"></span>
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-speedometer2 me-2"></i>Peso:</strong> <span id="detailsPeso"></span> toneladas
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-card-text me-2"></i>Licencia:</strong> <span id="detailsLicencia"></span>
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-fuel-pump me-2"></i>Gasolina:</strong> <span id="detailsGasolina"></span>
                            </div>
                            <div class="col-12 mb-2">
                                <strong><i class="bi bi-trash me-2"></i>Tipo de desecho:</strong> <span id="detailsTipoDesecho"></span>
                            </div>
                            <div class="col-12 mb-2">
                                <strong><i class="bi bi-chat-text me-2"></i>Descripción:</strong> 
                                <p id="detailsDescripcion" class="mt-1"></p>
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-hash me-2"></i>ID:</strong> <span id="detailsId"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-simar-outline" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn-simar-primary" id="btnEditFromDetails">
                    <i class="bi bi-pencil"></i> Editar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Delete -->
<div class="modal fade" id="modalDelete" tabindex="-1" aria-labelledby="modalDeleteLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalDeleteLabel">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirmar eliminación
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning mb-3" style="background: rgba(90, 173, 49, 0.1); border: 1px solid var(--simar-green); color: var(--simar-dark);">
                    <i class="bi bi-exclamation-circle me-2"></i> Esta acción no se puede deshacer.
                </div>
                <p>¿Estás seguro de que quieres eliminar este vehículo?</p>
                <div class="card mb-3 bg-light">
                    <div class="card-body">
                        <h6 id="deleteVehiculoNombre"></h6>
                        <p class="mb-1"><strong>No. Económico:</strong> <span id="deleteNumeroEconomico"></span></p>
                        <p class="mb-1"><strong>Placas:</strong> <span id="deletePlacas"></span></p>
                        <p class="mb-0"><strong>ID:</strong> <span id="deleteId"></span></p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-simar-outline" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cancelar
                </button>
                <button type="button" class="btn-simar-primary" id="confirmDelete">
                    <i class="bi bi-trash"></i> Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Variables globales
        let tiposDesecho = [];
        let tiposGasolina = [];
        let vehiculoAEliminar = null;

        // Cargar datos al iniciar
        document.addEventListener('DOMContentLoaded', function() {
            cargarTiposDesecho();
            cargarTiposGasolina();
        });

        // Función para cargar tipos de desecho
        async function cargarTiposDesecho() {
            try {
                const response = await fetch('?handler=ObtenerTiposDesecho');
                if (response.ok) {
                    tiposDesecho = await response.json();
                    llenarSelectsDesecho();
                }
            } catch (error) {
                console.error('Error al cargar tipos de desecho:', error);
            }
        }

        // Función para cargar tipos de gasolina
        async function cargarTiposGasolina() {
            try {
                const response = await fetch('?handler=ObtenerTiposGasolina');
                if (response.ok) {
                    tiposGasolina = await response.json();
                    llenarSelectsGasolina();
                }
            } catch (error) {
                console.error('Error al cargar tipos de gasolina:', error);
            }
        }

        // Llenar selects de tipo de desecho
        function llenarSelectsDesecho() {
            const selects = document.querySelectorAll('select[name="TipoDesecho"]');
            selects.forEach(select => {
                while (select.options.length > 1) {
                    select.remove(1);
                }
                tiposDesecho.forEach(tipo => {
                    const option = document.createElement('option');
                    option.value = tipo;
                    option.textContent = tipo;
                    select.appendChild(option);
                });
            });
        }

        // Llenar selects de tipo de gasolina
        function llenarSelectsGasolina() {
            const selects = document.querySelectorAll('select[name="TipoGasolina"]');
            selects.forEach(select => {
                while (select.options.length > 1) {
                    select.remove(1);
                }
                tiposGasolina.forEach(tipo => {
                    const option = document.createElement('option');
                    option.value = tipo;
                    option.textContent = tipo;
                    select.appendChild(option);
                });
            });
        }

        // Vista previa de foto en create
        document.getElementById('createFotoInput')?.addEventListener('change', function (e) {
            manejarVistaPreviaFoto(e, 'createFotoPreview');
        });

        // Editar
        document.querySelectorAll('.btn-edit').forEach(btn => {
            btn.addEventListener('click', function () {
                document.getElementById('editId').value = this.dataset.id;
                document.getElementById('editMarca').value = this.dataset.marca || '';
                document.getElementById('editModelo').value = this.dataset.modelo || '';
                document.getElementById('editPeso').value = this.dataset.peso || '';
                document.getElementById('editPlacas').value = this.dataset.placas || '';
                document.getElementById('editNumeroEconomico').value = this.dataset.numeroeconomico || '';
                document.getElementById('editAño').value = this.dataset.año || '';
                document.getElementById('editColor').value = this.dataset.color || '';
                document.getElementById('editDescripcion').value = this.dataset.descripcion || '';
                
                setTimeout(() => {
                    document.getElementById('editLicencia').value = this.dataset.licencia || '';
                    document.getElementById('editTipoDesecho').value = this.dataset.tipodesecho || '';
                    document.getElementById('editTipoGasolina').value = this.dataset.tipogasolina || '';
                }, 100);
                
                const fotoActual = document.getElementById('editFotoActual');
                fotoActual.src = this.dataset.fotourl || 'https://placehold.co/300x200/e9ecef/5aad31?text=SIN+IMAGEN';
                
                document.getElementById('editFotoPreview').classList.add('d-none');
                document.getElementById('editFotoInput').value = '';
                
                new bootstrap.Modal(document.getElementById('modalEdit')).show();
            });
        });

        // Vista previa en edit
        document.getElementById('editFotoInput')?.addEventListener('change', function (e) {
            manejarVistaPreviaFoto(e, 'editFotoPreview');
        });

        // Detalles
        document.querySelectorAll('.btn-details').forEach(btn => {
            btn.addEventListener('click', function () {
                document.getElementById('detailsId').textContent = this.dataset.id;
                document.getElementById('detailsMarca').textContent = this.dataset.marca || 'No especificado';
                document.getElementById('detailsModelo').textContent = this.dataset.modelo || 'No especificado';
                document.getElementById('detailsPeso').textContent = this.dataset.peso ? parseFloat(this.dataset.peso).toFixed(1) : 'N/A';
                document.getElementById('detailsPlacas').textContent = this.dataset.placas || 'No especificado';
                document.getElementById('detailsNumeroEconomico').textContent = this.dataset.numeroeconomico || 'No especificado';
                document.getElementById('detailsAño').textContent = this.dataset.año || 'No especificado';
                document.getElementById('detailsColor').textContent = this.dataset.color || 'No especificado';
                document.getElementById('detailsDescripcion').textContent = this.dataset.descripcion || 'No hay descripción';
                
                const licencia = this.dataset.licencia || '';
                let licenciaTexto = licencia;
                if (licencia === 'A') licenciaTexto = 'A - Automóviles';
                else if (licencia === 'B') licenciaTexto = 'B - Camiones ligeros';
                else if (licencia === 'C') licenciaTexto = 'C - Camiones pesados';
                else if (licencia === 'D') licenciaTexto = 'D - Autobuses';
                else if (licencia === 'E') licenciaTexto = 'E - Tractocamiones';
                document.getElementById('detailsLicencia').textContent = licenciaTexto;
                
                document.getElementById('detailsGasolina').textContent = this.dataset.tipogasolina || 'No especificado';
                document.getElementById('detailsTipoDesecho').textContent = this.dataset.tipodesecho || 'No especificado';
                document.getElementById('detailsTitulo').textContent = (this.dataset.marca || '') + ' ' + (this.dataset.modelo || '');
                document.getElementById('detailsFoto').src = this.dataset.fotourl || 'https://placehold.co/300x200/e9ecef/5aad31?text=SIN+IMAGEN';
                
                new bootstrap.Modal(document.getElementById('modalDetails')).show();
            });
        });

        // Editar desde detalles
        document.getElementById('btnEditFromDetails')?.addEventListener('click', function() {
            const id = document.getElementById('detailsId').textContent;
            if (id && id !== 'No especificado') {
                const btnEdit = document.querySelector(`.btn-edit[data-id="${id}"]`);
                if (btnEdit) btnEdit.click();
                bootstrap.Modal.getInstance(document.getElementById('modalDetails')).hide();
            }
        });

        // Eliminar
        document.querySelectorAll('.btn-delete').forEach(btn => {
            btn.addEventListener('click', function () {
                vehiculoAEliminar = {
                    id: this.dataset.id,
                    numeroEconomico: this.dataset.numeroeconomico || 'Sin número',
                    marca: this.dataset.marca || '',
                    modelo: this.dataset.modelo || '',
                    placas: this.dataset.placas || ''
                };
                
                document.getElementById('deleteId').textContent = vehiculoAEliminar.id;
                document.getElementById('deleteNumeroEconomico').textContent = vehiculoAEliminar.numeroEconomico;
                document.getElementById('deletePlacas').textContent = vehiculoAEliminar.placas;
                document.getElementById('deleteVehiculoNombre').textContent = vehiculoAEliminar.marca + ' ' + vehiculoAEliminar.modelo;
                
                new bootstrap.Modal(document.getElementById('modalDelete')).show();
            });
        });

        document.getElementById('confirmDelete')?.addEventListener('click', function() {
            if (vehiculoAEliminar) {
                alert(`Vehículo ${vehiculoAEliminar.marca} ${vehiculoAEliminar.modelo} eliminado (simulado)`);
                bootstrap.Modal.getInstance(document.getElementById('modalDelete')).hide();
            }
        });

        // Función auxiliar para vista previa
        function manejarVistaPreviaFoto(event, previewId) {
            const file = event.target.files[0];
            if (!file) return;
            
            if (file.size > 5 * 1024 * 1024) {
                alert('El archivo es demasiado grande. El tamaño máximo es 5MB.');
                event.target.value = '';
                return;
            }
            
            if (!file.type.startsWith('image/')) {
                alert('Solo se permiten archivos de imagen');
                event.target.value = '';
                return;
            }
            
            const reader = new FileReader();
            reader.onload = () => {
                const preview = document.getElementById(previewId);
                preview.src = reader.result;
                preview.classList.remove('d-none');
            };
            reader.readAsDataURL(file);
        }

        // Limpiar modales al cerrar
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('hidden.bs.modal', function () {
                const forms = this.querySelectorAll('form');
                forms.forEach(form => form.reset());
                this.querySelectorAll('.img-preview').forEach(img => img.classList.add('d-none'));
            });
        });
    </script>
}